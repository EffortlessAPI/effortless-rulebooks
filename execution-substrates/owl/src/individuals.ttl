# === Individuals: VocabularyReconciliations ===

effortless-ntwf:recon-foaf-name a effortless-ntwf:VocabularyReconciliations ;
    effortless-ntwf:reconciliationId "recon-foaf-name" ;
    effortless-ntwf:deprecatedTerm "foaf:name" ;
    effortless-ntwf:replacementTerm "ntwf:name" ;
    effortless-ntwf:reconciliationRelation "owl:sameAs" ;
    effortless-ntwf:sourceStandard "FOAF" ;
    effortless-ntwf:introducedInVersion "v1.1.0" ;
    effortless-ntwf:rationale "Part IV worked example: a deprecated FOAF element is re-prefixed into the NTWF namespace; existing data stays valid (URIs do not disappear), and foaf:name owl:sameAs ntwf:name keeps the two interchangeable for reasoners." .

effortless-ntwf:recon-dcat-v3 a effortless-ntwf:VocabularyReconciliations ;
    effortless-ntwf:reconciliationId "recon-dcat-v3" ;
    effortless-ntwf:deprecatedTerm "dcat:Dataset (v2)" ;
    effortless-ntwf:replacementTerm "dcat:Dataset (v3)" ;
    effortless-ntwf:reconciliationRelation "owl:sameAs" ;
    effortless-ntwf:sourceStandard "DCAT" ;
    effortless-ntwf:introducedInVersion "v1.1.0" ;
    effortless-ntwf:rationale "Part IV external-dependency fact: DCAT went through a major v2 -> v3 revision that introduced new classes and deprecated others. NTWF tracks the alignment so its dcat:Dataset usage stays semantically current; existing data remains valid because URIs do not disappear." .

