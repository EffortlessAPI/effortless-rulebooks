# === Individuals: Roles ===

effortless-ntwf:ntwf-ci-executor-role a effortless-ntwf:Roles ;
    effortless-ntwf:roleId "ntwf-ci-executor-role" ;
    effortless-ntwf:displayName "CI/CD Executor" ;
    effortless-ntwf:label "CI/CD Executor" ;
    effortless-ntwf:comment "Executes the automated build, test, and deployment sequence. Filled by an AutomatedPipeline. Demonstrates CQ3: this step does NOT require human approval." ;
    effortless-ntwf:hasCapability effortless-ntwf:cap-ci-execution ;
    effortless-ntwf:filledByAutomatedPipeline effortless-ntwf:ntwf-ci-pipeline ;
    effortless-ntwf:ownedBy effortless-ntwf:ntwf-engineering .

effortless-ntwf:ntwf-cto-role a effortless-ntwf:Roles ;
    effortless-ntwf:roleId "ntwf-cto-role" ;
    effortless-ntwf:displayName "Chief Technology Officer" ;
    effortless-ntwf:label "Chief Technology Officer" ;
    effortless-ntwf:comment "Top of the delegation chain. Has cap-executive-authorization. When both Release Manager and VP Engineering are unavailable, the CTO is the final escalation target." ;
    effortless-ntwf:hasCapability effortless-ntwf:cap-executive-authorization ;
    effortless-ntwf:filledByHumanAgent effortless-ntwf:ntwf-sarah-kim ;
    effortless-ntwf:ownedBy effortless-ntwf:ntwf-engineering ;
    effortless-ntwf:fromDelegatesTo effortless-ntwf:ntwf-vp-engineering-role .

effortless-ntwf:ntwf-deployment-health-role a effortless-ntwf:Roles ;
    effortless-ntwf:roleId "ntwf-deployment-health-role" ;
    effortless-ntwf:displayName "Deployment Health Agent" ;
    effortless-ntwf:label "Deployment Health Agent" ;
    effortless-ntwf:comment "Generates the post-deployment health report by summarizing telemetry after a release. A role, not an identity — currently filled by the DeploymentHealth-AI agent (health-summarizer-v1.2.0), it could be reassigned to a human or a newer model without changing the workflow structure. Its RoleAssignments history records an earlier human-reviewer period and the agent-type transitions." ;
    effortless-ntwf:hasCapability effortless-ntwf:cap-risk-analysis ;
    effortless-ntwf:filledByAIAgent effortless-ntwf:ntwf-health-ai ;
    effortless-ntwf:ownedBy effortless-ntwf:ntwf-engineering .

effortless-ntwf:ntwf-vp-engineering-role a effortless-ntwf:Roles ;
    effortless-ntwf:roleId "ntwf-vp-engineering-role" ;
    effortless-ntwf:displayName "VP of Engineering" ;
    effortless-ntwf:label "VP of Engineering" ;
    effortless-ntwf:comment "First escalation target when Release Manager is unavailable. Demonstrates ntwf:delegatesTo chain: Release Manager → VP Engineering → CTO." ;
    effortless-ntwf:hasCapability effortless-ntwf:cap-human-judgment ;
    effortless-ntwf:filledByHumanAgent effortless-ntwf:ntwf-david-chen ;
    effortless-ntwf:ownedBy effortless-ntwf:ntwf-engineering ;
    effortless-ntwf:delegatesTo effortless-ntwf:ntwf-cto-role ;
    effortless-ntwf:fromDelegatesTo effortless-ntwf:ntwf-release-manager-role .

