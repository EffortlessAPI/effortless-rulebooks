# === Individuals: WorkflowStatusConcepts ===

effortless-ntwf:status-draft a effortless-ntwf:WorkflowStatusConcepts ;
    effortless-ntwf:conceptId "status-draft" ;
    effortless-ntwf:prefLabel "Draft" ;
    effortless-ntwf:altLabel "In Progress" ;
    effortless-ntwf:definition "Workflow is being authored or reviewed and is not yet in production use." ;
    effortless-ntwf:scopeNote "Set this status when the workflow has not completed its initial review cycle." .

effortless-ntwf:status-active a effortless-ntwf:WorkflowStatusConcepts ;
    effortless-ntwf:conceptId "status-active" ;
    effortless-ntwf:prefLabel "Active" ;
    effortless-ntwf:altLabel "In Use" ;
    effortless-ntwf:definition "Workflow is approved and currently being executed by the organization." ;
    effortless-ntwf:scopeNote "Only active workflows should be assigned to running process instances." .

effortless-ntwf:status-deprecated a effortless-ntwf:WorkflowStatusConcepts ;
    effortless-ntwf:conceptId "status-deprecated" ;
    effortless-ntwf:prefLabel "Deprecated" ;
    effortless-ntwf:altLabel "Superseded" ;
    effortless-ntwf:definition "Workflow has been replaced by a newer version and should not be used for new instances." ;
    effortless-ntwf:scopeNote "Deprecated workflows may still have in-flight instances; do not archive until all instances close." .

effortless-ntwf:status-archived a effortless-ntwf:WorkflowStatusConcepts ;
    effortless-ntwf:conceptId "status-archived" ;
    effortless-ntwf:prefLabel "Archived" ;
    effortless-ntwf:altLabel "Retired" ;
    effortless-ntwf:definition "Workflow is no longer in use and has been moved to historical records." ;
    effortless-ntwf:scopeNote "Archived workflows answer CQ5 stale-workflow queries but generate no new instances." .

