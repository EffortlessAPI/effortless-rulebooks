    effortless-ntwf:roleId "ntwf-legal-compliance-role" ;
    effortless-ntwf:displayName "Legal Compliance Reviewer" ;
    effortless-ntwf:label "Legal Compliance Reviewer" ;
    effortless-ntwf:comment "Certifies that the deployment plan meets regulatory and contractual requirements. Must be a human agent — AI agents may not fill this role (requiresHumanApproval)." ;
