# === Individuals: Workflows ===

erb:Workflows_0 a erb:Workflows ;
    erb:workflowId "onboarding-new-employees" ;
    erb:title "Onboarding New Employees" ;
    erb:description "Automates the process of onboarding new hires, including document collection, account setup, and training assignments." ;
