# Local overrides for the effortless CLI and per-domain apps.
# Copy this file to effortless.env (gitignored) before running effortless build / start.sh.
# Values here are the canonical defaults — override only if you know why.

# Per-domain Postgres database. Convention: erb_<domain_underscored>.
# Used by postgres/init-db.sh and any app server that reads DATABASE_URL.
DATABASE_URL=postgresql://postgres@localhost:5432/erb_product_inventory_demo
