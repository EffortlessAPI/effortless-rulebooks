        "formula": "=INDEX(FlightControlSystems!{{UnitPrice}}, MATCH({{FCSId}}, FlightControlSystems!{{FlightControlSystemsId}}, 0))"
      },
      {
        "name": "FCSArchitecture",
        "datatype": "string",
