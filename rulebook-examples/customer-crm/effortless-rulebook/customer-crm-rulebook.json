        "nullable": true,
        "Description": "Parent order customer FK.",
        "formula": "=INDEX(Orders!{{Customer}}, MATCH({{OrderId}}, Orders!{{OrdersId}}, 0))"
      },
      {
        "name": "LineTotal",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "Description": "Quantity * FCSUnitPrice (in $M).",
        "formula": "={{Quantity}} * {{FCSUnitPrice}}"
      }
    ],
