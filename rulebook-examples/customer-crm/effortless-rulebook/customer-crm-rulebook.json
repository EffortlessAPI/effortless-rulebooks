{
  "$schema": "https://example.com/cmcc-schema/v1",
  "Name": "Customer CRM",
  "Description": "Fighter-jet FCS sales pipeline rolling revenue up by order, FCS variant, and jet model.",
  "Users": {
    "Description": "Dev-login identities for the demo app. Email is the PK.",
    "schema": [
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": false,
        "Description": "PK = Email",
        "formula": "={{Email}}"
      },
      {
        "name": "UsersId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Synthetic PK = Email."
      },
      {
        "name": "Email",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Login email (PK source)."
      },
      {
        "name": "FirstName",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Given name."
      },
      {
        "name": "LastName",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Family name."
      },
      {
        "name": "Role",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "admin or viewer."
      },
      {
        "name": "FullName",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "LastName, FirstName.",
        "formula": "=CONCAT({{LastName}}, \", \", {{FirstName}})"
      }
    ],
    "data": [
      {
        "UsersId": "alice@example.com",
        "Email": "alice@example.com",
        "FirstName": "Alice",
        "LastName": "Anderson",
        "Role": "admin"
      },
      {
        "UsersId": "bob@example.com",
        "Email": "bob@example.com",
        "FirstName": "Bob",
        "LastName": "Baker",
        "Role": "viewer"
      }
    ]
  },
  "Customers": {
    "Description": "A CRM contact. Email is the PK.",
    "important": true,
    "summary_rich": "The **accounts** side of the pipeline. Each customer's row computes a 60-day rolling `LifetimeSales`, an `UnpaidOrderCount`, and an `IsVIP` flag — all derived from `Orders` and `Payments`, never typed in by hand. Record a payment and the same customer's VIP status can flip on the next read, in every substrate, with no application code in the middle.",
    "important_fields": [
      "Email",
      "FullName",
      "LifetimeSales",
      "UnpaidOrderCount",
      "IsVIP"
    ],
    "schema": [
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": false,
        "Description": "PK = Email",
        "formula": "={{Email}}"
      },
      {
        "name": "CustomersId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Synthetic PK = Email."
      },
      {
        "name": "Email",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Customer email (PK source)."
      },
      {
        "name": "FirstName",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Given name."
      },
      {
        "name": "LastName",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Family name."
      },
      {
        "name": "FullName",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "LastName, FirstName.",
        "formula": "=CONCAT({{LastName}}, \", \", {{FirstName}})"
      },
      {
        "name": "LifetimeSales",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "Description": "Sum of this customer's order totals from the last 60 days (orders older than 60 days do not count).",
        "formula": "=SUMIFS(Orders!{{RecentTotal}}, Orders!{{Customer}}, {{Name}})"
      },
      {
        "name": "UnpaidOrderCount",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "Description": "Number of this customer's orders that are not yet paid in full.",
        "formula": "=SUMIFS(Orders!{{UnpaidFlag}}, Orders!{{Customer}}, {{Name}})"
      },
      {
        "name": "LargeOrderCount",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "Description": "Number of this customer's orders with a Total over $500. SUMIFS expression-mode workaround: agg_range yields 1 per row, then a real WHERE clause filters via the operator criterion \">500\" (Program.cs ExtractCriteriaOp, supported on SUMIFS but not yet on COUNTIFS).",
        "formula": "=SUMIFS(Orders!{{Total}}*0+1, Orders!{{Customer}}, {{Name}}, Orders!{{Total}}, \">500\")",
        "important": true,
        "explanation_rich": "**This rule is also a transpiler stress-test.** The intuitive way to count orders over $500 is `COUNTIFS(..., \">500\")`, but the operator-criterion form (`\">500\"`) is not yet wired through `COUNTIFS` in the current transpiler. The workaround is `SUMIFS(Orders!Total*0+1, ...)`: the `*0+1` makes every matched row contribute exactly 1, so the SUM degenerates into a COUNT — and `SUMIFS` *does* accept the operator criterion. Worked example: **Katherine Johnson** has `ORD-1006` ($540) and `ORD-1007` ($612). Both exceed $500, so `LargeOrderCount = 2`. The same answer falls out of the Postgres view, the Python module, and the Excel sheet because the rule lives in the rulebook, not in each substrate."
      },
      {
        "name": "IsVIP",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "Description": "True when LifetimeSales > 1000 AND the customer has at most 1 unpaid order.",
        "formula": "=AND({{LifetimeSales}} > 1000, {{UnpaidOrderCount}} <= 1)",
        "important": true,
        "explanation_rich": "**A VIP earns the tag two ways at once.** The flag fires only when the rolling-window `LifetimeSales` exceeds $1,000 AND the customer has at most one unpaid order — so a big spender with a stack of overdue invoices does not qualify. Worked example: **Linus Torvalds** has `ORD-1008` ($2,400, fully paid by two $1,200 wires) and `ORD-1009` ($180, unpaid). `UnpaidOrderCount = 1` and the recent-window total clears $1,000, so `IsVIP = TRUE`. **Grace Hopper** has `ORD-1003` ($1,499.99, only $1,000 paid → unpaid) and `ORD-1004` ($320.50, unpaid). `UnpaidOrderCount = 2`, so `IsVIP = FALSE` regardless of how much she has bought. Record one more payment that zeros either of Grace's balances and the same row flips to TRUE on the next read."
      }
    ],
    "data": [
      {
        "CustomersId": "ada.lovelace@analytical.engine",
        "Email": "ada.lovelace@analytical.engine",
        "FirstName": "Ada",
        "LastName": "Lovelace"
      },
      {
        "CustomersId": "grace.hopper@nautical.mil",
        "Email": "grace.hopper@nautical.mil",
        "FirstName": "Grace",
        "LastName": "Hopper"
      },
      {
        "CustomersId": "alan.turing@bletchley.uk",
        "Email": "alan.turing@bletchley.uk",
        "FirstName": "Alan",
        "LastName": "Turing"
      },
      {
        "CustomersId": "katherine.johnson@nasa.gov",
        "Email": "katherine.johnson@nasa.gov",
        "FirstName": "Katherine",
        "LastName": "Johnson"
      },
      {
        "CustomersId": "linus.torvalds@kernel.org",
        "Email": "linus.torvalds@kernel.org",
        "FirstName": "Linus",
        "LastName": "Torvalds"
      }
    ]
  },
  "Orders": {
    "Description": "A customer order. OrderNumber is the PK.",
    "schema": [
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": false,
        "Description": "PK = OrderNumber",
        "formula": "={{OrderNumber}}"
      },
      {
        "name": "OrdersId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Synthetic PK = OrderNumber."
      },
      {
        "name": "OrderNumber",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Human-readable order number (PK source)."
      },
      {
        "name": "OrderDate",
        "datatype": "date",
        "type": "raw",
        "nullable": false,
        "Description": "Date the order was placed."
      },
      {
        "name": "Customer",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "FK -> Customers.Name (the customer's email)."
      },
      {
        "name": "CustomerFirstName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "Description": "Customer's first name, looked up via Customer FK.",
        "formula": "=INDEX(Customers!{{FirstName}}, MATCH({{Customer}}, Customers!{{CustomersId}}, 0))"
      },
      {
        "name": "CustomerLastName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "Description": "Customer's last name, looked up via Customer FK.",
        "formula": "=INDEX(Customers!{{LastName}}, MATCH({{Customer}}, Customers!{{CustomersId}}, 0))"
      },
      {
        "name": "CustomerFullName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "Description": "Customer's full name, looked up via Customer FK.",
        "formula": "=INDEX(Customers!{{FullName}}, MATCH({{Customer}}, Customers!{{CustomersId}}, 0))"
      },
      {
        "name": "CustomerEmail",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "Description": "Customer's email, looked up via Customer FK.",
        "formula": "=INDEX(Customers!{{Email}}, MATCH({{Customer}}, Customers!{{CustomersId}}, 0))"
      },
      {
        "name": "Total",
        "datatype": "number",
        "type": "raw",
        "nullable": false,
        "Description": "Order total in dollars."
      },
      {
        "name": "AmountPaid",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "Description": "Sum of all payments recorded against this order.",
        "formula": "=SUMIFS(Payments!{{Amount}}, Payments!{{OrderId}}, {{Name}})"
      },
      {
        "name": "Balance",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "Description": "Outstanding balance: Total - AmountPaid.",
        "formula": "={{Total}} - {{AmountPaid}}"
      },
      {
        "name": "IsPaid",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "Description": "True when Balance <= 0.",
        "formula": "={{Balance}} <= 0"
      },
      {
        "name": "UnpaidFlag",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "Description": "1 when the order is unpaid, 0 otherwise — summed by Customers.UnpaidOrderCount.",
        "formula": "=IF({{IsPaid}}, 0, 1)"
      },
      {
        "name": "IsRecent",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "Description": "True when OrderDate is within the last 60 days. Drives the 60-day window on Customers.LifetimeSales.",
        "formula": "=DATEDIFF(TODAY(), {{OrderDate}}, \"days\") <= 90"
      },
      {
        "name": "RecentTotal",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "Description": "Total if the order is recent, 0 otherwise — summed by Customers.LifetimeSales.",
        "formula": "=IF({{IsRecent}}, {{Total}}, 0)"
      },
      {
        "name": "FCSSubtotal",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "Description": "Sum of LineTotal across this order's FCS line items (in $M).",
        "formula": "=SUMIFS(OrderLines!{{LineTotal}}, OrderLines!{{OrderId}}, {{Name}})"
      },
      {
        "name": "FCSUnitCount",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "Description": "Total FCS units shipped on this order.",
        "formula": "=SUMIFS(OrderLines!{{Quantity}}, OrderLines!{{OrderId}}, {{Name}})"
      }
    ],
    "data": [
