    effortless-ntwf:study effortless-ntwf:kidney-1986 ;
    effortless-ntwf:stratumLabel "large" ;
    effortless-ntwf:description "Patients with large kidney stones — harder to treat, lower baseline success rate regardless of treatment. Preferentially assigned to Treatment A." .

effortless-ntwf:kidney-balanced-small a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "kidney-balanced-small" ;
    effortless-ntwf:study effortless-ntwf:kidney-balanced ;
    effortless-ntwf:stratumLabel "small" ;
    effortless-ntwf:description "Small kidney stones — same baseline rates as kidney-1986 small stratum but now receiving exactly 50% of each treatment's cases. Counterfactual stratum." .

effortless-ntwf:kidney-balanced-large a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "kidney-balanced-large" ;
    effortless-ntwf:study effortless-ntwf:kidney-balanced ;
    effortless-ntwf:stratumLabel "large" ;
    effortless-ntwf:description "Large kidney stones — same baseline rates as kidney-1986 large stratum but now receiving exactly 50% of each treatment's cases. Equal allocation prevents confounding." .

effortless-ntwf:balanced-synthetic-easy a effortless-ntwf:Strata ;
