effortless-ntwf:conc-01-paradox-is-derived a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-01-paradox-is-derived" ;
    effortless-ntwf:category "domain" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:reportTier "supporting" ;
    effortless-ntwf:title "Simpson's Paradox is a derived fact from the DAG, not a modeled entity" ;
    effortless-ntwf:evidence "IsReversal (and later IsSignFlip) falls out as a calculated field on TreatmentRankings, derived from aggregated CaseCell counts. No 'ReversalDetection' entity was ever needed." ;
    effortless-ntwf:witnessedInLoop "loop-04" ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:researcherId "researcher-blyth" .

effortless-ntwf:conc-02-reversal-from-allocation a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-02-reversal-from-allocation" ;
    effortless-ntwf:category "domain" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:reportTier "supporting" ;
    effortless-ntwf:title "The reversal in kidney-1986 is entirely an allocation artifact — same rates with balanced allocation produce no reversal" ;
    effortless-ntwf:evidence "kidney-balanced uses identical stratum success rates to kidney-1986 but with equal allocation (175 cases per cell). IsReversal=FALSE, AllocationDistortion=0. The paradox is algebraically isolated as a property of allocation, not of treatment efficacy." ;
    effortless-ntwf:witnessedInLoop "loop-14" ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:researcherId "researcher-pearson" .

effortless-ntwf:conc-03-binary-excludes-partial a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-03-binary-excludes-partial" ;
    effortless-ntwf:category "instrument" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:reportTier "supporting" ;
    effortless-ntwf:title "The unanimity criterion (IsReversal) incorrectly excludes Berkeley 1973 despite its being a Simpson-type paradox" ;
    effortless-ntwf:evidence "Berkeley: WSGSUM=−0.0642, SignedPooledGap=+0.1292, IsSignFlip=TRUE, AllocationDistortion=0.1934 — greater distortion than kidney-1986. But IsReversal=FALSE because dept-C marginally favors male. The unanimity criterion is a strict subtype, not the primary definition." ;
    effortless-ntwf:witnessedInLoop "loop-17" ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:researcherId "researcher-blyth" ;
    effortless-ntwf:challengesResearcher "researcher-cohen-nagel" .

effortless-ntwf:conc-04-type-c-exists a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-04-type-c-exists" ;
    effortless-ntwf:category "instrument" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:reportTier "supporting" ;
    effortless-ntwf:title "Allocation can compress the pooled signal without flipping it (type-C): a class invisible to IsReversal and IsSignFlip but visible to AllocationDistortion" ;
    effortless-ntwf:evidence "compressed-synthetic: A wins every stratum and wins pooled, but the pooled margin is 6pp rather than the equal-weight 10pp. AllocationDistortion=0.0400, IsSignFlip=FALSE. The pooled winner is correct; the effect size is wrong by 4pp." ;
    effortless-ntwf:witnessedInLoop "loop-19" ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:researcherId "researcher-blyth" .

