effortless-ntwf:loop-47 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-47" ;
    effortless-ntwf:title "Studies enrichment: PublicationYear, Domain, IsSynthetic as first-class stratification fields" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "PublicationYear (integer), Domain (medicine|epidemiology|social-science|education|legal|sports|economics|synthetic), IsSynthetic (boolean) on Studies; RealStudyCount, MedicineStudyCount, EpidemiologyStudyCount, OtherDomainStudyCount, DomainDiversityNote on ModelSummary" ;
    effortless-ntwf:domainQuestion "Does the instrument know enough about each study to stratify SignalPurity and DistortionType by domain? Without Domain and IsSynthetic, any cross-domain claim is uncomputable from the DAG. Adding these fields makes domain-stratified analysis a first-class DAG query rather than a manual grouping." ;
    effortless-ntwf:mockDataNote "90+ studies populated: medicine=3 (kidney-1986, hannan-1994, melanoma-altman-1991), epidemiology=6 (berkeley-1973→social-science actually; reintjes-2000, appleton-1996, phe-covid-2021, birth-weight-paradox, coffee-tverdal-2020), social-science=2 (berkeley-1973, titanic-1912), legal=1 (radelet-1981), sports=1 (jeter-justice-1997), education=1 (sat-wainer-1986), synthetic=3. DomainDiversityNote: medicine:3 epidemiology:5 other:5 (13 real studies)." ;
    effortless-ntwf:nextSuggestion "loop-48: AvgSignalPurityReversal vs AvgSignalPurityNonReversal — witness the SignalPurity theorem quantitatively as a ModelSummary gap field" ;
    effortless-ntwf:commitHash "5a14dcb9e84aaf645e19965933246fdc0cb76e34" ;
    effortless-ntwf:commitDate "2026-06-28" ;
    effortless-ntwf:commitMessage "Add new metrics and definitions for allocation sweep analysis" ;
