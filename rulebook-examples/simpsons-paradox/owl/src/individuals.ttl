    effortless-ntwf:study effortless-ntwf:jeter-justice-1997 ;
    effortless-ntwf:treatmentLabel "B" ;
    effortless-ntwf:description "David Justice (Atlanta Braves 1995-96, Cleveland Indians 1997). Higher batting average in each individual year (1995: .253, 1996: .321, 1997: .329) but lower combined (.298). Bulk at-bats in his weakest year (1995: 411 AB at .253) drag his combined average down." .

effortless-ntwf:appleton-1996-A a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "appleton-1996-A" ;
    effortless-ntwf:study effortless-ntwf:appleton-1996 ;
    effortless-ntwf:treatmentLabel "A" ;
    effortless-ntwf:description "Smoker at baseline (1972-74). Higher mortality within every age stratum. Pooled mortality appears LOWER (23.9%) than non-smokers (31.4%) — the reversal. Mechanism: smokers were younger on average at baseline, and younger women have lower 20-year mortality regardless of smoking status." .

effortless-ntwf:appleton-1996-B a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "appleton-1996-B" ;
    effortless-ntwf:study effortless-ntwf:appleton-1996 ;
    effortless-ntwf:treatmentLabel "B" ;
    effortless-ntwf:description "Non-smoker at baseline. Lower mortality within every age stratum. Pooled mortality appears HIGHER (31.4%) — misleadingly so. Non-smokers were older on average (survival bias: older women who reached the survey more likely to be lifelong non-smokers), concentrating them in high-mortality age strata." .

effortless-ntwf:phe-covid-2021-A a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "phe-covid-2021-A" ;
    effortless-ntwf:study effortless-ntwf:phe-covid-2021 ;
    effortless-ntwf:treatmentLabel "A" ;
    effortless-ntwf:description "Vaccinated (includes partially vaccinated). Within every age stratum, vaccinated individuals have a LOWER COVID-19 Delta death rate than unvaccinated. Pooled death rate appears HIGHER (0.41%) than unvaccinated (0.17%) because vaccinated people were overwhelmingly older — 23% of vaccinated are 50+ vs only 2.3% of unvaccinated, and the 50+ group has ~100× higher CFR." .

effortless-ntwf:phe-covid-2021-B a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "phe-covid-2021-B" ;
    effortless-ntwf:study effortless-ntwf:phe-covid-2021 ;
    effortless-ntwf:treatmentLabel "B" ;
    effortless-ntwf:description "Unvaccinated. Within every age stratum, unvaccinated individuals have a HIGHER COVID-19 Delta death rate than vaccinated. Pooled death rate appears LOWER (0.17%) — a statistical artifact of the unvaccinated cohort being overwhelmingly young (97.7% under 50)." .

# === Individuals: UIComponents ===

effortless-ntwf:comp-01-distortion-badge a effortless-ntwf:UIComponents ;
    effortless-ntwf:componentId "comp-01-distortion-badge" ;
    effortless-ntwf:componentName "DistortionBadge" ;
    effortless-ntwf:usedOnScreens "screen-01-study-list, screen-02-study-detail, screen-05-distortion-plane" ;
    effortless-ntwf:primaryEntity "TreatmentRankings" ;
    effortless-ntwf:description "A colored pill/chip that shows DistortionType (A/B/C/D) and PolicyImplication for one study. Color-coded: A=red (stratify-immediately), B=orange (investigate-confounder), C=yellow (check-allocation-bias), D=green (pooled-analysis-trustworthy)." ;
    effortless-ntwf:requiredFields "DistortionType, PolicyImplication" ;
    effortless-ntwf:visualSpec "Pill shape, 2–3 chars for the type letter, tooltip on hover showing PolicyImplication text. Consistent color across all screens." .

effortless-ntwf:comp-02-rate-comparison-bar a effortless-ntwf:UIComponents ;
    effortless-ntwf:componentId "comp-02-rate-comparison-bar" ;
    effortless-ntwf:componentName "RateComparisonBar" ;
    effortless-ntwf:usedOnScreens "screen-02-study-detail, screen-03-strata-detail" ;
    effortless-ntwf:primaryEntity "TreatmentRankings" ;
    effortless-ntwf:description "A side-by-side horizontal bar chart comparing PooledRateA vs PooledRateB (or StratumRateA vs StratumRateB for strata). The bar for the loser under equal-weight allocation is visually distinguished from the bar for the pooled loser." ;
    effortless-ntwf:requiredFields "PooledRateA, PooledRateB, PooledWinner, WeightedStratumGapSum, SignedPooledGap, IsSignFlip" ;
    effortless-ntwf:visualSpec "Two horizontal bars, labeled A and B. Arrow or bracket showing the gap. IsSignFlip=TRUE triggers a 'reversal' annotation. Width proportional to rate (0–1 scale)." .

effortless-ntwf:comp-03-allocation-heatmap a effortless-ntwf:UIComponents ;
    effortless-ntwf:componentId "comp-03-allocation-heatmap" ;
    effortless-ntwf:componentName "AllocationHeatmap" ;
    effortless-ntwf:usedOnScreens "screen-03-strata-detail" ;
    effortless-ntwf:primaryEntity "StratumSummaries" ;
    effortless-ntwf:description "A grid of (Stratum × Treatment) cells where cell color encodes AllocationBias magnitude and sign. Positive bias (A over-allocated here) in one color; negative (B over-allocated) in another. Cell text shows AllocationFractionA and AllocationFractionB." ;
    effortless-ntwf:requiredFields "StratumLabel, TreatmentLabel, AllocationBias, AllocationFractionA, AllocationFractionB, StratumSuccessRate" ;
    effortless-ntwf:visualSpec "Matrix layout: rows=strata, cols=treatments. Diverging color scale centered at 0. Tooltip shows raw Cases and Successes from CaseCells." .

effortless-ntwf:comp-04-distortion-plane-scatter a effortless-ntwf:UIComponents ;
    effortless-ntwf:componentId "comp-04-distortion-plane-scatter" ;
    effortless-ntwf:componentName "DistortionPlaneScatter" ;
    effortless-ntwf:usedOnScreens "screen-05-distortion-plane" ;
    effortless-ntwf:primaryEntity "TreatmentRankings" ;
    effortless-ntwf:description "A 2D scatter plot with AllocationDistortion on the x-axis and ReversalIntensity on the y-axis. Each point is one study, colored by DistortionType. Quadrant lines at AllocationDistortion=0.01 (threshold) and ReversalIntensity=1.0 (unanimity) divide the plane into the four types." ;
    effortless-ntwf:requiredFields "AllocationDistortion, ReversalIntensity, DistortionType, PolicyImplication, IsSignFlip" ;
    effortless-ntwf:visualSpec "SVG or canvas scatter. Labeled quadrant regions. Clickable points. Legend showing type → color → policy action." .

effortless-ntwf:comp-05-stratum-gap-waterfall a effortless-ntwf:UIComponents ;
    effortless-ntwf:componentId "comp-05-stratum-gap-waterfall" ;
    effortless-ntwf:componentName "StratumGapWaterfall" ;
    effortless-ntwf:usedOnScreens "screen-03-strata-detail" ;
    effortless-ntwf:primaryEntity "StratumSummaries" ;
    effortless-ntwf:description "A waterfall chart showing how each stratum's WeightedStratumGap contributes to WeightedStratumGapSum, then how the allocation re-weights them to produce SignedPooledGap. The visual makes the mechanism equation explicit: pooled = Σ(weight × rate)." ;
    effortless-ntwf:requiredFields "StratumLabel, StratumGap, StratumFraction, WeightedStratumGap, WeightedStratumGapSum, SignedPooledGap" ;
    effortless-ntwf:visualSpec "Waterfall/stacked bar: each stratum's WeightedStratumGap as a segment; running sum shown; final total vs actual SignedPooledGap shown side-by-side. IsSignFlip highlights the sign difference." .

effortless-ntwf:comp-06-model-summary-scorecard a effortless-ntwf:UIComponents ;
    effortless-ntwf:componentId "comp-06-model-summary-scorecard" ;
    effortless-ntwf:componentName "ModelSummaryScorecard" ;
    effortless-ntwf:usedOnScreens "screen-06-model-summary" ;
    effortless-ntwf:primaryEntity "ModelSummary" ;
    effortless-ntwf:description "A summary scorecard showing all ModelSummary fields as labeled metric tiles: StudyCount, ReversalCount, ExplainedCount, TypeA/B/C/D counts, AvgAllocationDistortion, TotalParadoxStrength." ;
    effortless-ntwf:requiredFields "StudyCount, ReversalCount, ExplainedCount, ZeroStrengthCount, TotalParadoxStrength, AvgParadoxStrength" ;
    effortless-ntwf:visualSpec "Grid of metric tiles. Each tile: large number, small label. Color: ReversalCount in orange/red; ExplainedCount in green; TypeD in grey. Single row layout on desktop, 2-column on mobile." .

effortless-ntwf:comp-07-confounder-card a effortless-ntwf:UIComponents ;
    effortless-ntwf:componentId "comp-07-confounder-card" ;
    effortless-ntwf:componentName "ConfounderCard" ;
    effortless-ntwf:usedOnScreens "screen-04-confounder-panel" ;
    effortless-ntwf:primaryEntity "StratumVariables" ;
    effortless-ntwf:description "A card showing one StratumVariable row: VariableName, CausalRole badge, AffectsTreatmentAssignment checkbox, AffectsOutcome checkbox, IsConfounder result, and MechanismNote prose block." ;
    effortless-ntwf:requiredFields "VariableName, CausalRole, AffectsTreatmentAssignment, AffectsOutcome, IsConfounder, MechanismNote" ;
    effortless-ntwf:visualSpec "Card with header=VariableName, CausalRole as a badge (confounder=red, mediator=orange, contested=yellow, unknown=grey), two boolean indicators, and MechanismNote as body text." .

effortless-ntwf:comp-08-loop-timeline a effortless-ntwf:UIComponents ;
    effortless-ntwf:componentId "comp-08-loop-timeline" ;
    effortless-ntwf:componentName "LoopTimeline" ;
    effortless-ntwf:usedOnScreens "screen-07-loop-history" ;
    effortless-ntwf:primaryEntity "Loops" ;
    effortless-ntwf:description "A vertical timeline of all Loops rows, grouped by Status. Each entry shows LoopId, Title, Status indicator, NewConcept chip, and an expandable section with DomainQuestion, MockDataNote, and NextSuggestion." ;
    effortless-ntwf:requiredFields "LoopId, Title, Status, NewConcept, DomainQuestion, MockDataNote, NextSuggestion" ;
    effortless-ntwf:visualSpec "Vertical list. Status=complete: solid circle; in-progress: half-filled; planned: open circle. Expandable accordion per entry. Color: complete=green, in-progress=blue, planned=grey." .

effortless-ntwf:comp-09-policy-action-banner a effortless-ntwf:UIComponents ;
    effortless-ntwf:componentId "comp-09-policy-action-banner" ;
    effortless-ntwf:componentName "PolicyActionBanner" ;
    effortless-ntwf:usedOnScreens "screen-02-study-detail" ;
    effortless-ntwf:primaryEntity "TreatmentRankings" ;
    effortless-ntwf:description "A prominent banner at the top of the Study Detail screen showing PolicyImplication as a clear action statement, color-coded by DistortionType. Includes a one-sentence explanation of why this action follows from the geometry." ;
    effortless-ntwf:requiredFields "PolicyImplication, DistortionType, AllocationDistortion, IsSignFlip" ;
    effortless-ntwf:visualSpec "Full-width colored banner. Large icon (e.g. warning triangle for A, magnifying glass for B, scale for C, checkmark for D). Bold action text. Secondary line explaining the geometric basis." .

effortless-ntwf:comp-10-conclusion-list a effortless-ntwf:UIComponents ;
    effortless-ntwf:componentId "comp-10-conclusion-list" ;
    effortless-ntwf:componentName "ConclusionList" ;
    effortless-ntwf:usedOnScreens "screen-09-conclusions" ;
    effortless-ntwf:primaryEntity "Conclusions" ;
    effortless-ntwf:description "A filterable list of Conclusions rows grouped by Category and Status. Each entry shows the Title, Status badge, Evidence summary, and a link to the WitnessedInLoop or TargetLoop." ;
    effortless-ntwf:requiredFields "Category, Status, Title, Evidence, WitnessedInLoop, TargetLoop" ;
    effortless-ntwf:visualSpec "Grouped list with category headers. Status badge: witnessed=green, planned=blue, open=orange. Evidence shown as collapsed text (expand on click). Loop links navigate to LoopTimeline." .

# === Individuals: UIScreens ===

effortless-ntwf:screen-01-study-list a effortless-ntwf:UIScreens ;
    effortless-ntwf:screenId "screen-01-study-list" ;
    effortless-ntwf:title "Study List" ;
    effortless-ntwf:route "/" ;
    effortless-ntwf:primaryEntity "Studies" ;
    effortless-ntwf:purpose "Show all studies with their DistortionType badge and AllocationDistortion magnitude so a user can immediately see which studies exhibit the paradox and how severely." ;
    effortless-ntwf:keyFields "Title, DistortionType (from TreatmentRankings), AllocationDistortion, PolicyImplication, IsSignFlip, TotalCases" ;
    effortless-ntwf:userAction "Click a study row to navigate to the Study Detail screen." .

effortless-ntwf:screen-02-study-detail a effortless-ntwf:UIScreens ;
    effortless-ntwf:screenId "screen-02-study-detail" ;
    effortless-ntwf:title "Study Detail" ;
    effortless-ntwf:route "/study/:studyId" ;
    effortless-ntwf:primaryEntity "TreatmentRankings" ;
    effortless-ntwf:purpose "Show one study's complete geometry: pooled rates, per-stratum rates, allocation fractions, AllocationDistortion, DistortionType, and PolicyImplication — the full causal picture for this study." ;
    effortless-ntwf:keyFields "PooledRateA, PooledRateB, PooledWinner, PerStratumWinner, IsReversal, IsSignFlip, WeightedStratumGapSum, SignedPooledGap, AllocationDistortion, DistortionType, PolicyImplication, ConfoundersInStudy, IsParadoxExplained" ;
    effortless-ntwf:userAction "Expand strata panel to see per-stratum breakdown; navigate to Strata Detail." .

effortless-ntwf:screen-03-strata-detail a effortless-ntwf:UIScreens ;
    effortless-ntwf:screenId "screen-03-strata-detail" ;
    effortless-ntwf:title "Strata Detail" ;
    effortless-ntwf:route "/study/:studyId/strata" ;
    effortless-ntwf:primaryEntity "StratumSummaries" ;
    effortless-ntwf:purpose "Show every (stratum, treatment) cell for a study: StratumSuccessRate, AllocationBias, StratumGap, WeightedStratumGap — the leaf-level evidence for why the pooled conclusion is or isn't misleading." ;
    effortless-ntwf:keyFields "StratumLabel, TreatmentLabel, StratumSuccessRate, StratumRateA, StratumRateB, StratumWinner, AllocationBias, AllocationFractionA, AllocationFractionB, StratumGap, WeightedStratumGap, StratumFraction" ;
    effortless-ntwf:userAction "Hover a cell for the raw Successes/Cases count from CaseCells." .

effortless-ntwf:screen-04-confounder-panel a effortless-ntwf:UIScreens ;
    effortless-ntwf:screenId "screen-04-confounder-panel" ;
    effortless-ntwf:title "Confounder Panel" ;
    effortless-ntwf:route "/study/:studyId/confounder" ;
    effortless-ntwf:primaryEntity "StratumVariables" ;
    effortless-ntwf:purpose "Show the stratifying variable's causal role for a study: VariableName, CausalRole, AffectsTreatmentAssignment, AffectsOutcome, IsConfounder, MechanismNote." ;
    effortless-ntwf:keyFields "VariableName, CausalRole, AffectsTreatmentAssignment, AffectsOutcome, IsConfounder, MechanismNote" ;
    effortless-ntwf:userAction "Read the mechanism note; understand why IsParadoxExplained is TRUE or FALSE for this study." .

effortless-ntwf:screen-05-distortion-plane a effortless-ntwf:UIScreens ;
    effortless-ntwf:screenId "screen-05-distortion-plane" ;
    effortless-ntwf:title "Distortion Plane" ;
    effortless-ntwf:route "/plane" ;
    effortless-ntwf:primaryEntity "TreatmentRankings" ;
    effortless-ntwf:purpose "Plot all studies on a 2D plane: AllocationDistortion (x-axis) × ReversalIntensity (y-axis), colored by DistortionType. Shows the geometric taxonomy at a glance and reveals how the four types partition the plane." ;
    effortless-ntwf:keyFields "Title (from Studies), AllocationDistortion, ReversalIntensity, IsSignFlip, DistortionType, PolicyImplication, ParadoxStrength" ;
    effortless-ntwf:userAction "Click a data point to navigate to that study's Study Detail screen." .

effortless-ntwf:screen-06-model-summary a effortless-ntwf:UIScreens ;
    effortless-ntwf:screenId "screen-06-model-summary" ;
    effortless-ntwf:title "Model Summary" ;
    effortless-ntwf:route "/summary" ;
    effortless-ntwf:primaryEntity "ModelSummary" ;
    effortless-ntwf:purpose "Show the instrument's self-portrait: how many studies, how many of each DistortionType, average AllocationDistortion, total paradox strength — the epistemic coverage of the full model instance." ;
    effortless-ntwf:keyFields "StudyCount, ReversalCount, ExplainedCount, TypeACount, TypeBCount, TypeCCount, TypeDCount, AvgAllocationDistortion, TotalParadoxStrength" ;
    effortless-ntwf:userAction "Navigate to Study List or Distortion Plane from this summary." .

effortless-ntwf:screen-07-loop-history a effortless-ntwf:UIScreens ;
    effortless-ntwf:screenId "screen-07-loop-history" ;
    effortless-ntwf:title "Loop History" ;
    effortless-ntwf:route "/loops" ;
    effortless-ntwf:primaryEntity "Loops" ;
    effortless-ntwf:purpose "Show the full build history: all 31 loops with their status, new concept, domain question, and mock data note. Lets a developer understand why the model is shaped the way it is — the DAG is the story." ;
    effortless-ntwf:keyFields "LoopId, Title, Status, NewConcept, DomainQuestion, MockDataNote, NextSuggestion" ;
    effortless-ntwf:userAction "Filter by Status (complete/planned); click a loop to expand its full detail." .

effortless-ntwf:screen-08-methodology a effortless-ntwf:UIScreens ;
    effortless-ntwf:screenId "screen-08-methodology" ;
    effortless-ntwf:title "Methodology" ;
    effortless-ntwf:route "/methodology" ;
    effortless-ntwf:primaryEntity "Methodology" ;
    effortless-ntwf:purpose "Show the ten first-principles methodological axioms that shaped this model — from CMCC as the floor, through DAG-first decomposition, to the four-type taxonomy. Enables a developer to apply the same process to a new domain." ;
    effortless-ntwf:keyFields "Phase, Title, Statement, WhyItMatters, IllustratedByLoop" ;
    effortless-ntwf:userAction "Click IllustratedByLoop to jump to that loop in the Loop History screen." .

effortless-ntwf:screen-09-conclusions a effortless-ntwf:UIScreens ;
    effortless-ntwf:screenId "screen-09-conclusions" ;
    effortless-ntwf:title "Conclusions" ;
    effortless-ntwf:route "/conclusions" ;
    effortless-ntwf:primaryEntity "Conclusions" ;
    effortless-ntwf:purpose "Show all witnessed and planned conclusions, grouped by category (domain / instrument / methodology / open-question). The read-out of what this model has actually established." ;
    effortless-ntwf:keyFields "Category, Status, Title, Evidence, WitnessedInLoop, TargetLoop" ;
    effortless-ntwf:userAction "Filter by Status (witnessed/planned/open); click WitnessedInLoop to navigate to Loop History." .
