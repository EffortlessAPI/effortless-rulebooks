# === Individuals: DiscoveryHypotheses ===

effortless-ntwf:H-latent-d a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-latent-d" ;
    effortless-ntwf:statement "More than half of Type-D (SAFE) studies would flip their pooled winner under counterfactual allocation reweighting." ;
    effortless-ntwf:expectedOutcome "LatentTypeDFraction > 0.5" ;
    effortless-ntwf:registeredInLoop "loop-61" ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-purity a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-purity" ;
    effortless-ntwf:statement "Every sign-flip study has SignalPurity strictly below 0.5." ;
    effortless-ntwf:expectedOutcome "SignFlipSignalPurityMax < 0.5" ;
    effortless-ntwf:registeredInLoop "loop-61" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "consistency-check" .

effortless-ntwf:H-small-effect a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-small-effect" ;
    effortless-ntwf:statement "Allocation-stable Type-D studies carry larger observed pooled gaps than latent Type-D studies." ;
    effortless-ntwf:expectedOutcome "AvgPooledGapStableD > AvgPooledGapLatentD" ;
    effortless-ntwf:registeredInLoop "loop-61" ;
    effortless-ntwf:traditionId "tradition-epidemiology" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-causal-manifest a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-causal-manifest" ;
    effortless-ntwf:statement "Confounder-labeled studies produce manifest sign-flips at observed allocation (IsSignFlip=TRUE) far more often than collider/selection studies — reversal mode differs by mechanism class." ;
    effortless-ntwf:expectedOutcome "ConfounderSignFlipCount > ColliderSelectionManifestCount AND ConfounderSignFlipCount >= 10" ;
    effortless-ntwf:registeredInLoop "loop-62" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-causal-latent a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-causal-latent" ;
    effortless-ntwf:statement "Collider/selection studies produce latent-only flips under allocation sweep without manifest sign-flips at observed allocation." ;
    effortless-ntwf:expectedOutcome "ColliderSelectionManifestCount = 0 AND ColliderSelectionLatentOnlyCount >= 5" ;
    effortless-ntwf:registeredInLoop "loop-62" ;
    effortless-ntwf:traditionId "tradition-epidemiology" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-explained-confounder a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-explained-confounder" ;
    effortless-ntwf:statement "IsParadoxExplained is TRUE for all and only confounder sign-flip studies — adjust-resolvable confounding is the unique condition that makes a reversal fully explained." ;
    effortless-ntwf:expectedOutcome "ExplainedConfounderCount = SignFlipCount AND ExplainedNonConfounderCount = 0" ;
    effortless-ntwf:registeredInLoop "loop-63" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-unexplained-nonconfounder a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-unexplained-nonconfounder" ;
    effortless-ntwf:statement "Studies with IsSignFlip=TRUE and CausalRole != confounder (contested or mediator) have IsParadoxExplained=FALSE." ;
    effortless-ntwf:expectedOutcome "ContestedOrMediatorExplainedCount = 0" ;
    effortless-ntwf:registeredInLoop "loop-63" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-catalog-exact-match a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-catalog-exact-match" ;
    effortless-ntwf:statement "Catalog ExpectedDistortionType exact-match rate is below 50% — curator tags behave as mechanism priors, not taxonomy predictors." ;
    effortless-ntwf:expectedOutcome "TypePredictionMatchRate < 0.5" ;
    effortless-ntwf:registeredInLoop "loop-65" ;
    effortless-ntwf:traditionId "tradition-epidemiology" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-collider-no-manifest-v2 a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-collider-no-manifest-v2" ;
    effortless-ntwf:statement "Collider and selection studies produce zero manifest sign-flips (DistortionType A or B) at observed allocation — including hernandez-diaz birth-weight collider tagged Expected A in catalog." ;
    effortless-ntwf:expectedOutcome "ColliderSelectionManifestCount = 0" ;
    effortless-ntwf:registeredInLoop "loop-68" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-cplus-magnitude a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-cplus-magnitude" ;
    effortless-ntwf:statement "C+ studies carry higher mean AllocationDistortion than C- studies and Type-D studies — magnitude inflation is the largest quantitative error class and invisible to is_sign_flip." ;
    effortless-ntwf:expectedOutcome "CPlusAvgDistortion > CMinusAvgDistortion AND CPlusAvgDistortion > TypeDAvgDistortion" ;
    effortless-ntwf:registeredInLoop "loop-68" ;
    effortless-ntwf:traditionId "tradition-epidemiology" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-ultra-fragile a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-ultra-fragile" ;
    effortless-ntwf:statement "At least four Type-D studies are sweep-fragile: signal_purity=1, allocation_distortion=0, sweep_pooled_gap_range>0.3, allocation_fragility>=10 — perfectly safe by pooled metrics yet latent-flip under reweighting." ;
    effortless-ntwf:expectedOutcome "SweepFragileCount >= 4" ;
    effortless-ntwf:registeredInLoop "loop-68" ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-corrected-gap-invariant a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-corrected-gap-invariant" ;
    effortless-ntwf:statement "CorrectedGap is allocation-invariant for every study: MAX(SweepStudySummary.SweepCorrectedGapRange) < 0.0001 and zero failing studies." ;
    effortless-ntwf:expectedOutcome "MaxStudySweepCorrectedGapRange < 0.0001 AND CorrectedGapInvariantFailCount = 0" ;
    effortless-ntwf:registeredInLoop "loop-73" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "consistency-check" .

effortless-ntwf:H-explained-bidirectional a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-explained-bidirectional" ;
    effortless-ntwf:statement "IsParadoxExplained ⟺ confounder manifest sign-flip: ExplainedConfounderCount = ConfounderSignFlipCount, no false-positive explained rows, no unexplained confounder sign-flips." ;
    effortless-ntwf:expectedOutcome "ExplainedConfounderCount = ConfounderSignFlipCount AND FalsePositiveExplainedCount = 0 AND UnexplainedConfounderSignFlipCount = 0" ;
    effortless-ntwf:registeredInLoop "loop-74" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "consistency-check" .

effortless-ntwf:H-collider-no-manifest-theorem a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-collider-no-manifest-theorem" ;
    effortless-ntwf:statement "At scale (≥10 collider/selection studies post expansion), zero manifest sign-flips: ColliderSelectionManifestCount = 0." ;
    effortless-ntwf:expectedOutcome "ColliderSelectionManifestCount = 0 AND ColliderSelectionCount >= 10" ;
    effortless-ntwf:registeredInLoop "loop-75" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "consistency-check" .

effortless-ntwf:H-theorem-portfolio a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-theorem-portfolio" ;
    effortless-ntwf:statement "Four Category=theorem conclusions are witnessed: SignalPurity (conc-12/20) plus three new theorems from loops 73–75." ;
    effortless-ntwf:expectedOutcome "TheoremCount >= 4" ;
    effortless-ntwf:registeredInLoop "loop-76" ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:epistemicTier "consistency-check" .

effortless-ntwf:H-age-identity-flip-rate a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-age-identity-flip-rate" ;
    effortless-ntwf:statement "Age-composition identity (id-age-composition) produces manifest flip rate ≥ 40% among real studies — cross-domain demographic confounding is flip-prone, not latent-only." ;
    effortless-ntwf:expectedOutcome "AgeIdentityManifestFlipRate >= 0.40 AND AgeIdentityStudyCount >= 10" ;
    effortless-ntwf:registeredInLoop "loop-80" ;
    effortless-ntwf:traditionId "tradition-epidemiology" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-severity-vs-age-latent a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-severity-vs-age-latent" ;
    effortless-ntwf:statement "Disease-severity identity shows lower Type-D latent fraction than age-composition identity — severity drives manifest reversals more than hidden sweep sensitivity." ;
    effortless-ntwf:expectedOutcome "SeverityIdentityLatentFractionAmongTypeD < AgeIdentityLatentFractionAmongTypeD" ;
    effortless-ntwf:registeredInLoop "loop-80" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-pattern-superseded" .

effortless-ntwf:H-identity-map-coverage a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-identity-map-coverage" ;
    effortless-ntwf:statement "At least 95% of real-study StratumVariables carry a ConfounderIdentity map — ontology covers the corpus." ;
    effortless-ntwf:expectedOutcome "IdentityMapCoverageRate >= 0.95" ;
    effortless-ntwf:registeredInLoop "loop-80" ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:epistemicTier "consistency-check" .

effortless-ntwf:H-severity-medicine-manifest a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-severity-medicine-manifest" ;
    effortless-ntwf:statement "Disease-severity identity within medicine domain has manifest flip rate ≥45% — severity drives reversals in clinical settings." ;
    effortless-ntwf:expectedOutcome "ManifestFlipRate(cell-id-disease-severity-x-medicine) >= 0.45" ;
    effortless-ntwf:registeredInLoop "loop-82" ;
    effortless-ntwf:traditionId "tradition-epidemiology" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-severity-epi-latent-only a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-severity-epi-latent-only" ;
    effortless-ntwf:statement "Disease-severity identity within epidemiology domain shows zero manifest flips — latent-only geometry in that domain." ;
    effortless-ntwf:expectedOutcome "ManifestFlipCount(cell-id-disease-severity-x-epidemiology) = 0" ;
    effortless-ntwf:registeredInLoop "loop-82" ;
    effortless-ntwf:traditionId "tradition-epidemiology" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-mechanism-other-drain a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-mechanism-other-drain" ;
    effortless-ntwf:statement "After ontology drain, id-mechanism-other contains ≤5 studies — the catch-all is no longer the dominant bucket." ;
    effortless-ntwf:expectedOutcome "StudyCount(cluster-id-mechanism-other) <= 5" ;
    effortless-ntwf:registeredInLoop "loop-83" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-selection-frailty-zero-manifest a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-selection-frailty-zero-manifest" ;
    effortless-ntwf:statement "Selection-frailty identity (id-selection-frailty) produces zero manifest sign-flips — pure latent-D geometry, no allocation-reversal at observed weights." ;
    effortless-ntwf:expectedOutcome "ManifestFlipCount(cluster-id-selection-frailty) = 0 AND StudyCount(cluster-id-selection-frailty) >= 3" ;
    effortless-ntwf:registeredInLoop "loop-84" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-collider-identity-low-manifest a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-collider-identity-low-manifest" ;
    effortless-ntwf:statement "Collider-proxy identity (id-collider-proxy) produces ≤15% manifest flip rate — near-zero manifest, predominantly latent Type-D geometry." ;
    effortless-ntwf:expectedOutcome "ManifestFlipRate(cluster-id-collider-proxy) <= 0.15 AND StudyCount(cluster-id-collider-proxy) >= 5" ;
    effortless-ntwf:registeredInLoop "loop-84" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-geographic-stable-type-d a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-geographic-stable-type-d" ;
    effortless-ntwf:statement "Geographic-composition identity (id-geographic-composition) has ≥25% Type-D fraction — stable latent-D presence distinct from manifest-flip-prone identities." ;
    effortless-ntwf:expectedOutcome "TypeDFraction(cluster-id-geographic-composition) >= 0.25 AND StudyCount(cluster-id-geographic-composition) >= 3" ;
    effortless-ntwf:registeredInLoop "loop-84" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-unexplained-flips-only-nonconfounders a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-unexplained-flips-only-nonconfounders" ;
    effortless-ntwf:statement "All unexplained sign-flips (IsSignFlip=TRUE AND IsParadoxExplained=FALSE) have ConfounderIdentity ∈ {id-contested-org-choice, id-collider-proxy} OR CausalRole=contested — no unexplained flip belongs to an unambiguous confounder identity." ;
    effortless-ntwf:expectedOutcome "UnexplainedConfounderSignFlipCount = 0" ;
    effortless-ntwf:registeredInLoop "loop-85" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "consistency-check" .

effortless-ntwf:H-perfect-balance-sufficient-safety a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-perfect-balance-sufficient-safety" ;
    effortless-ntwf:statement "Perfect allocation balance (ArmSizeRatio=0.5 AND MaxStratumImbalance=0.0) is a domain-agnostic sufficient condition for no manifest Simpson's Paradox — no such study produces IsSignFlip=TRUE regardless of mechanism class, domain, or confounder identity." ;
    effortless-ntwf:expectedOutcome "PerfectBalanceFlipCount=0 AND PerfectBalanceStudyCount>=100" ;
    effortless-ntwf:registeredInLoop "loop-86" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "consistency-check" .

effortless-ntwf:H-safety-corridor-lower-bound a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-safety-corridor-lower-bound" ;
    effortless-ntwf:statement "The minimum observed MaxStratumImbalance among all manifest sign-flip studies is 0.033 (flu-vaccine-elderly-mortality). No sign-flip occurs below this threshold — the gap [0.0, 0.033) is a corpus-level safety corridor." ;
    effortless-ntwf:expectedOutcome "MinSignFlipStratumImbalance >= 0.033 AND SafeCorridorFlipCount=0" ;
    effortless-ntwf:registeredInLoop "loop-86" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-purity-inversion a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-purity-inversion" ;
    effortless-ntwf:statement "Mechanism classes with PolicyDefault='do-not-condition' or 'do-not-naively-adjust' (collider-selection, selection-frailty) have strictly higher mean SignalPurity than all stratify-* mechanism classes. High SignalPurity anti-predicts safe stratification — it is a trap for researchers who use data cleanliness as a quality heuristic." ;
    effortless-ntwf:expectedOutcome "MeanPurityColliderSelection > MeanPurityAllStratifyClasses AND MeanPuritySelectionFrailty >= 0.95" ;
    effortless-ntwf:registeredInLoop "loop-87" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "consistency-check" .

effortless-ntwf:H-purity-trap-flag-coverage a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-purity-trap-flag-coverage" ;
    effortless-ntwf:statement "PurityTrapFlag=TRUE covers ≥80% of collider/selection studies and ≤5% of demographic-composition confounder studies — the flag correctly discriminates the trap from the safe-stratification zone." ;
    effortless-ntwf:expectedOutcome "PurityTrapCoverage(collider-selection) >= 0.80 AND PurityTrapFalsePositiveRate(demographic-composition) <= 0.05" ;
    effortless-ntwf:registeredInLoop "loop-87" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-control-type-d-predominance a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-control-type-d-predominance" ;
    effortless-ntwf:statement "At least 70% of control studies encode as Type-D (neutral allocation, no sign flip) — Type-D is the expected basin for studies selected for absence of paradox." ;
    effortless-ntwf:expectedOutcome "COUNTIF(TreatmentRankings[IsSignFlip],TRUE,Studies[IsControlStudy],TRUE) / COUNTIF(Studies[IsControlStudy],TRUE) < 0.3" ;
    effortless-ntwf:registeredInLoop "loop-88" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-control-no-manifest-flip a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-control-no-manifest-flip" ;
    effortless-ntwf:statement "Zero manifest sign flips among control studies. These studies were selected for absence of paradox, so no pooled-vs-stratified reversal should be present." ;
    effortless-ntwf:expectedOutcome "COUNTIF(TreatmentRankings[IsSignFlip],TRUE,Studies[IsControlStudy],TRUE) = 0" ;
    effortless-ntwf:registeredInLoop "loop-88" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-control-safety-corridor a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-control-safety-corridor" ;
    effortless-ntwf:statement "No control study with MaxStratumImbalance < 0.033 (the safe-corridor threshold) has IsSignFlip=TRUE. The safety corridor hypothesis predicts zero flips below this boundary." ;
    effortless-ntwf:expectedOutcome "COUNTIF(TreatmentRankings[IsSignFlip],TRUE,TreatmentRankings[MaxStratumImbalance],\"<0.033\",Studies[IsControlStudy],TRUE) = 0" ;
    effortless-ntwf:registeredInLoop "loop-88" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-synthetic-edge-coverage a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-synthetic-edge-coverage" ;
    effortless-ntwf:statement "All four corpus theorem boundary regions (near-zero-distortion, equal-weight sign-flip, zero-corrected-gap, collider-purity) are covered by at least one synthetic study." ;
    effortless-ntwf:expectedOutcome "COUNTIF(Studies[IsSynthetic],TRUE) >= 4 AND all four boundary regions represented" ;
    effortless-ntwf:registeredInLoop "loop-89" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

effortless-ntwf:H-confounder-drift-type-d a effortless-ntwf:DiscoveryHypotheses ;
    effortless-ntwf:hypothesisId "H-confounder-drift-type-d" ;
    effortless-ntwf:statement "When studies are bucketed by real-world valid-time (cohort midpoint, not publication year), case-mix / geographic / situational confounder archetypes (MechanismClass in severity-case-mix, geography, sports-situation) show DriftDirection=rising toward clean Type-D outcomes in ConfounderDistortionTimeline, while age / institutional / SES archetypes (demographic-composition, organizational-unit, ses-income) show DriftDirection in (flat, single-decade) -- i.e. the drift is confounder-specific, not corpus-wide." ;
    effortless-ntwf:expectedOutcome "COUNTIFS(ConfounderDistortionTimeline[MechanismClass],\"severity-case-mix|geography|sports-situation\",ConfounderDistortionTimeline[DriftDirection],\"rising\") = COUNTIFS(ConfounderDistortionTimeline[MechanismClass],\"severity-case-mix|geography|sports-situation\") AND COUNTIFS(ConfounderDistortionTimeline[MechanismClass],\"demographic-composition|organizational-unit|ses-income\",ConfounderDistortionTimeline[DriftDirection],\"rising\") = 0" ;
    effortless-ntwf:registeredInLoop "loop-92" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:epistemicTier "corpus-hypothesis" .

