# === Individuals: Treatments ===

effortless-ntwf:kidney-1986-A a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "kidney-1986-A" ;
    effortless-ntwf:study effortless-ntwf:kidney-1986 ;
    effortless-ntwf:treatmentLabel "A" ;
    effortless-ntwf:description "Open surgery / percutaneous nephrolithotomy (PCNL) — the more invasive procedure, used preferentially for large stones." .

effortless-ntwf:kidney-1986-B a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "kidney-1986-B" ;
    effortless-ntwf:study effortless-ntwf:kidney-1986 ;
    effortless-ntwf:treatmentLabel "B" ;
    effortless-ntwf:description "Extracorporeal shock wave lithotripsy (ESWL) — the less invasive procedure, used more for small stones." .

effortless-ntwf:kidney-balanced-A a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "kidney-balanced-A" ;
    effortless-ntwf:study effortless-ntwf:kidney-balanced ;
    effortless-ntwf:treatmentLabel "A" ;
    effortless-ntwf:description "Open surgery / PCNL — same per-stratum rates as kidney-1986 (small:93.1%, large:73.0%) but now allocated equally (50%) to each stratum. Counterfactual treatment A." .

effortless-ntwf:kidney-balanced-B a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "kidney-balanced-B" ;
    effortless-ntwf:study effortless-ntwf:kidney-balanced ;
    effortless-ntwf:treatmentLabel "B" ;
    effortless-ntwf:description "ESWL — same per-stratum rates as kidney-1986 (small:86.7%, large:68.8%) but allocated equally (50%) to each stratum. Counterfactual treatment B." .

effortless-ntwf:balanced-synthetic-A a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "balanced-synthetic-A" ;
    effortless-ntwf:study effortless-ntwf:balanced-synthetic ;
    effortless-ntwf:treatmentLabel "A" ;
    effortless-ntwf:description "Synthetic treatment A — 60% success rate in both strata. Allocated equally (50%) to each stratum." .

effortless-ntwf:balanced-synthetic-B a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "balanced-synthetic-B" ;
    effortless-ntwf:study effortless-ntwf:balanced-synthetic ;
    effortless-ntwf:treatmentLabel "B" ;
    effortless-ntwf:description "Synthetic treatment B — 50% success rate in both strata. Allocated equally (50%) to each stratum." .

effortless-ntwf:berkeley-1973-male a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "berkeley-1973-male" ;
    effortless-ntwf:study effortless-ntwf:berkeley-1973 ;
    effortless-ntwf:treatmentLabel "A" ;
    effortless-ntwf:description "Male applicants (labeled A). Pooled admission rate appears higher than female." .

effortless-ntwf:berkeley-1973-female a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "berkeley-1973-female" ;
    effortless-ntwf:study effortless-ntwf:berkeley-1973 ;
    effortless-ntwf:treatmentLabel "B" ;
    effortless-ntwf:description "Female applicants (labeled B). Pooled admission rate appears lower, but per-department rates are equal or higher in most departments." .

effortless-ntwf:compressed-synthetic-A a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "compressed-synthetic-A" ;
    effortless-ntwf:study effortless-ntwf:compressed-synthetic ;
    effortless-ntwf:treatmentLabel "A" ;
    effortless-ntwf:description "Treatment A — 70% success rate in hard stratum, 90% in easy stratum. Over-allocated to the hard stratum (60% of A cases go to hard). A wins in both strata and also wins pooled, but pooled margin is compressed by the allocation imbalance." .

effortless-ntwf:compressed-synthetic-B a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "compressed-synthetic-B" ;
    effortless-ntwf:study effortless-ntwf:compressed-synthetic ;
    effortless-ntwf:treatmentLabel "B" ;
    effortless-ntwf:description "Treatment B — 60% success rate in hard stratum, 80% in easy stratum. Over-allocated to the easy stratum (60% of B cases go to easy). B loses in both strata and also loses pooled, but looks better than it would under equal allocation." .

effortless-ntwf:reintjes-2000-A a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "reintjes-2000-A" ;
    effortless-ntwf:study effortless-ntwf:reintjes-2000 ;
    effortless-ntwf:treatmentLabel "A" ;
    effortless-ntwf:description "Antibiotic prophylaxis given. Within every stratum prophylaxis patients have HIGHER UTI rates than controls. Aggregate inverts due to confounding by hospital incidence level." .

effortless-ntwf:reintjes-2000-B a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "reintjes-2000-B" ;
    effortless-ntwf:study effortless-ntwf:reintjes-2000 ;
    effortless-ntwf:treatmentLabel "B" ;
    effortless-ntwf:description "No antibiotic prophylaxis (control). Within every stratum controls have LOWER UTI rates. Aggregate inverts: controls appear to have higher rates pooled." .

effortless-ntwf:radelet-1981-A a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "radelet-1981-A" ;
    effortless-ntwf:study effortless-ntwf:radelet-1981 ;
    effortless-ntwf:treatmentLabel "A" ;
    effortless-ntwf:description "White defendant. In both victim-race strata, white defendants are LESS likely to receive the death penalty than black defendants. Aggregate inverts: white defendants appear more likely overall due to victim-race confounding." .

effortless-ntwf:radelet-1981-B a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "radelet-1981-B" ;
    effortless-ntwf:study effortless-ntwf:radelet-1981 ;
    effortless-ntwf:treatmentLabel "B" ;
    effortless-ntwf:description "Black defendant. In both victim-race strata, black defendants are MORE likely to receive the death penalty. Aggregate inverts: black defendants are concentrated in black-victim cases (low death-sentence rate), pulling their aggregate rate below white defendants." .

effortless-ntwf:jeter-justice-1997-A a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "jeter-justice-1997-A" ;
    effortless-ntwf:study effortless-ntwf:jeter-justice-1997 ;
    effortless-ntwf:treatmentLabel "A" ;
    effortless-ntwf:description "Derek Jeter (New York Yankees). Higher combined batting average (.300) despite losing to Justice in every individual season. Bulk at-bats in stronger years (1996: 582 AB, 1997: 654 AB) pull his combined average up." .

effortless-ntwf:jeter-justice-1997-B a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "jeter-justice-1997-B" ;
    effortless-ntwf:study effortless-ntwf:jeter-justice-1997 ;
    effortless-ntwf:treatmentLabel "B" ;
    effortless-ntwf:description "David Justice (Atlanta Braves 1995-96, Cleveland Indians 1997). Higher batting average in each individual year (1995: .253, 1996: .321, 1997: .329) but lower combined (.298). Bulk at-bats in his weakest year (1995: 411 AB at .253) drag his combined average down." .

effortless-ntwf:appleton-1996-A a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "appleton-1996-A" ;
    effortless-ntwf:study effortless-ntwf:appleton-1996 ;
    effortless-ntwf:treatmentLabel "A" ;
    effortless-ntwf:description "Smoker at baseline (1972-74). Higher mortality within every age stratum. Pooled mortality appears LOWER (23.9%) than non-smokers (31.4%) — the reversal. Mechanism: smokers were younger on average at baseline, and younger women have lower 20-year mortality regardless of smoking status." .

effortless-ntwf:appleton-1996-B a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "appleton-1996-B" ;
    effortless-ntwf:study effortless-ntwf:appleton-1996 ;
    effortless-ntwf:treatmentLabel "B" ;
    effortless-ntwf:description "Non-smoker at baseline. Lower mortality within every age stratum. Pooled mortality appears HIGHER (31.4%) — misleadingly so. Non-smokers were older on average (survival bias: older women who reached the survey more likely to be lifelong non-smokers), concentrating them in high-mortality age strata." .

effortless-ntwf:phe-covid-2021-A a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "phe-covid-2021-A" ;
    effortless-ntwf:study effortless-ntwf:phe-covid-2021 ;
    effortless-ntwf:treatmentLabel "A" ;
    effortless-ntwf:description "Vaccinated (includes partially vaccinated). Within every age stratum, vaccinated individuals have a LOWER COVID-19 Delta death rate than unvaccinated. Pooled death rate appears HIGHER (0.41%) than unvaccinated (0.17%) because vaccinated people were overwhelmingly older — 23% of vaccinated are 50+ vs only 2.3% of unvaccinated, and the 50+ group has ~100× higher CFR." .

effortless-ntwf:phe-covid-2021-B a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "phe-covid-2021-B" ;
    effortless-ntwf:study effortless-ntwf:phe-covid-2021 ;
    effortless-ntwf:treatmentLabel "B" ;
    effortless-ntwf:description "Unvaccinated. Within every age stratum, unvaccinated individuals have a HIGHER COVID-19 Delta death rate than vaccinated. Pooled death rate appears LOWER (0.17%) — a statistical artifact of the unvaccinated cohort being overwhelmingly young (97.7% under 50)." .

