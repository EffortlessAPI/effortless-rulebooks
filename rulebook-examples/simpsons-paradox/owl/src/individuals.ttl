# === Individuals: IngestionProtocol ===

effortless-ntwf:ingest-input-study a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-input-study" ;
    effortless-ntwf:ruleType "required-input" ;
    effortless-ntwf:targetTable "CaseCells" ;
    effortless-ntwf:fieldName "Study" ;
    effortless-ntwf:requirementStatement "Every cell row must name its parent study with a stable unique slug." ;
    effortless-ntwf:mechanicalCheck "Non-empty string; identical across all cells in the study; matches Studies.StudyId." ;
    effortless-ntwf:sortOrder 1 .

effortless-ntwf:ingest-input-stratum a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-input-stratum" ;
    effortless-ntwf:ruleType "required-input" ;
    effortless-ntwf:targetTable "CaseCells" ;
    effortless-ntwf:fieldName "StratumLabel" ;
    effortless-ntwf:requirementStatement "Every cell must name its stratum — the subgroup being stratified on." ;
    effortless-ntwf:mechanicalCheck "Non-empty string; consistent label for both A and B cells within the same stratum." ;
    effortless-ntwf:sortOrder 2 .

effortless-ntwf:ingest-input-treatment a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-input-treatment" ;
    effortless-ntwf:ruleType "required-input" ;
    effortless-ntwf:targetTable "CaseCells" ;
    effortless-ntwf:fieldName "TreatmentLabel" ;
    effortless-ntwf:requirementStatement "Every cell must be labeled A or B — exactly two treatments per study." ;
    effortless-ntwf:mechanicalCheck "Value in {A, B}; both labels appear." ;
    effortless-ntwf:sortOrder 3 .

effortless-ntwf:ingest-input-cases a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-input-cases" ;
    effortless-ntwf:ruleType "required-input" ;
    effortless-ntwf:targetTable "CaseCells" ;
    effortless-ntwf:fieldName "Cases" ;
    effortless-ntwf:requirementStatement "Total observations in the cell — the denominator for the success rate." ;
    effortless-ntwf:mechanicalCheck "Positive integer > 0." ;
    effortless-ntwf:sortOrder 4 .

effortless-ntwf:ingest-input-successes a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-input-successes" ;
    effortless-ntwf:ruleType "required-input" ;
    effortless-ntwf:targetTable "CaseCells" ;
    effortless-ntwf:fieldName "Successes" ;
    effortless-ntwf:requirementStatement "Count of successful outcomes in the cell — the numerator." ;
    effortless-ntwf:mechanicalCheck "Non-negative integer; Successes <= Cases." ;
    effortless-ntwf:sortOrder 5 .

effortless-ntwf:ingest-struct-min-two-strata a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-struct-min-two-strata" ;
    effortless-ntwf:ruleType "structural" ;
    effortless-ntwf:targetTable "Studies" ;
    effortless-ntwf:fieldName "" ;
    effortless-ntwf:requirementStatement "At least two strata required." ;
    effortless-ntwf:mechanicalCheck "TreatmentRankings.StratumCount >= 2." ;
    effortless-ntwf:sortOrder 6 .

effortless-ntwf:ingest-struct-binary-treatment a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-struct-binary-treatment" ;
    effortless-ntwf:ruleType "structural" ;
    effortless-ntwf:targetTable "Studies" ;
    effortless-ntwf:fieldName "" ;
    effortless-ntwf:requirementStatement "Exactly two treatment arms (A and B) per study." ;
    effortless-ntwf:mechanicalCheck "Exactly two distinct TreatmentLabel values in CaseCells." ;
    effortless-ntwf:sortOrder 7 .

effortless-ntwf:ingest-struct-paired-cells a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-struct-paired-cells" ;
    effortless-ntwf:ruleType "structural" ;
    effortless-ntwf:targetTable "Studies" ;
    effortless-ntwf:fieldName "" ;
    effortless-ntwf:requirementStatement "Every stratum must have exactly one A-cell and one B-cell." ;
    effortless-ntwf:mechanicalCheck "Studies.CellCount = 2 x StratumCount." ;
    effortless-ntwf:sortOrder 8 .

effortless-ntwf:ingest-struct-valid-counts a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-struct-valid-counts" ;
    effortless-ntwf:ruleType "structural" ;
    effortless-ntwf:targetTable "CaseCells" ;
    effortless-ntwf:fieldName "" ;
    effortless-ntwf:requirementStatement "Every cell must pass IsValidIngestionCell." ;
    effortless-ntwf:mechanicalCheck "Cases > 0 AND 0 <= Successes <= Cases." ;
    effortless-ntwf:sortOrder 9 .

effortless-ntwf:ingest-incl-2xk-table a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-incl-2xk-table" ;
    effortless-ntwf:ruleType "inclusion" ;
    effortless-ntwf:targetTable "Studies" ;
    effortless-ntwf:fieldName "" ;
    effortless-ntwf:requirementStatement "Published or citable 2xK contingency table with aggregate counts." ;
    effortless-ntwf:mechanicalCheck "Source citation present; counts are integers." ;
    effortless-ntwf:sortOrder 10 .

effortless-ntwf:ingest-incl-named-confounder a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-incl-named-confounder" ;
    effortless-ntwf:ruleType "inclusion" ;
    effortless-ntwf:targetTable "StratumVariables" ;
    effortless-ntwf:fieldName "VariableName" ;
    effortless-ntwf:requirementStatement "Stratifying variable named before classification." ;
    effortless-ntwf:mechanicalCheck "StratumVariables.VariableName non-empty." ;
    effortless-ntwf:sortOrder 11 .

effortless-ntwf:ingest-incl-binary-outcome a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-incl-binary-outcome" ;
    effortless-ntwf:ruleType "inclusion" ;
    effortless-ntwf:targetTable "CaseCells" ;
    effortless-ntwf:fieldName "Successes" ;
    effortless-ntwf:requirementStatement "Binary outcome encodable as Successes out of Cases." ;
    effortless-ntwf:mechanicalCheck "Successes/Cases in [0,1]." ;
    effortless-ntwf:sortOrder 12 .

effortless-ntwf:ingest-excl-continuous-outcome a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-excl-continuous-outcome" ;
    effortless-ntwf:ruleType "exclusion" ;
    effortless-ntwf:targetTable "Studies" ;
    effortless-ntwf:fieldName "" ;
    effortless-ntwf:requirementStatement "Exclude continuous outcomes without stated dichotomisation." ;
    effortless-ntwf:mechanicalCheck "Reject if only mean/SD reported." ;
    effortless-ntwf:sortOrder 13 .

effortless-ntwf:ingest-excl-posthoc-strata a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-excl-posthoc-strata" ;
    effortless-ntwf:ruleType "exclusion" ;
    effortless-ntwf:targetTable "Studies" ;
    effortless-ntwf:fieldName "" ;
    effortless-ntwf:requirementStatement "Exclude post-hoc stratum splitting to force a reversal." ;
    effortless-ntwf:mechanicalCheck "Stratum variable named in original publication." ;
    effortless-ntwf:sortOrder 14 .

effortless-ntwf:ingest-adapter-strata a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-adapter-strata" ;
    effortless-ntwf:ruleType "adapter-metadata" ;
    effortless-ntwf:targetTable "Strata" ;
    effortless-ntwf:fieldName "" ;
    effortless-ntwf:requirementStatement "One Strata row per (study, stratum) with Description." ;
    effortless-ntwf:mechanicalCheck "COUNT(Strata) = StratumCount." ;
    effortless-ntwf:sortOrder 15 .

effortless-ntwf:ingest-adapter-treatments a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-adapter-treatments" ;
    effortless-ntwf:ruleType "adapter-metadata" ;
    effortless-ntwf:targetTable "Treatments" ;
    effortless-ntwf:fieldName "" ;
    effortless-ntwf:requirementStatement "Two Treatments rows with Description." ;
    effortless-ntwf:mechanicalCheck "Exactly two Treatments rows per study." ;
    effortless-ntwf:sortOrder 16 .

effortless-ntwf:ingest-adapter-stratum-variable a effortless-ntwf:IngestionProtocol ;
    effortless-ntwf:protocolId "ingest-adapter-stratum-variable" ;
    effortless-ntwf:ruleType "adapter-metadata" ;
    effortless-ntwf:targetTable "StratumVariables" ;
    effortless-ntwf:fieldName "" ;
    effortless-ntwf:requirementStatement "One StratumVariables row with CausalRole and MechanismNote." ;
    effortless-ntwf:mechanicalCheck "CausalRole in {confounder, mediator, contested, unknown}." ;
    effortless-ntwf:sortOrder 17 .

# === Individuals: IngestionSummary ===

effortless-ntwf:ingestion-v1 a effortless-ntwf:IngestionSummary ;
    effortless-ntwf:ingestionSummaryId "ingestion-v1" .

# === Individuals: InstrumentSpec ===

effortless-ntwf:input-study a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "input-study" ;
    effortless-ntwf:componentType "input" ;
    effortless-ntwf:fieldName "Study" ;
    effortless-ntwf:dataType "string" ;
    effortless-ntwf:sourceTable "CaseCells" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "A unique identifier for the study being classified (e.g. 'kidney-1986')." ;
    effortless-ntwf:adapterNote "Assign a slug that is stable and unique. All rows for a study share this value." .

effortless-ntwf:input-stratum a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "input-stratum" ;
    effortless-ntwf:componentType "input" ;
    effortless-ntwf:fieldName "StratumLabel" ;
    effortless-ntwf:dataType "string" ;
    effortless-ntwf:sourceTable "CaseCells" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "The label of the subgroup (stratum) for this cell — the variable being stratified on (e.g. 'large', 'high-risk', 'male')." ;
    effortless-ntwf:adapterNote "Must be consistent across the A and B cells within the same stratum. At least 2 strata required." .

effortless-ntwf:input-treatment a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "input-treatment" ;
    effortless-ntwf:componentType "input" ;
    effortless-ntwf:fieldName "TreatmentLabel" ;
    effortless-ntwf:dataType "string" ;
    effortless-ntwf:sourceTable "CaseCells" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "Which treatment (exposure, group, class) this cell belongs to — 'A' or 'B'." ;
    effortless-ntwf:adapterNote "Exactly two treatment labels per study. Encode the group you want to investigate as 'A'; comparator as 'B'." .

effortless-ntwf:input-successes a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "input-successes" ;
    effortless-ntwf:componentType "input" ;
    effortless-ntwf:fieldName "Successes" ;
    effortless-ntwf:dataType "integer" ;
    effortless-ntwf:sourceTable "CaseCells" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "Count of successful outcomes (survived, passed, admitted, etc.) in this cell." ;
    effortless-ntwf:adapterNote "Must be a non-negative integer ≤ Cases. Define 'success' consistently across all cells in the study." .

effortless-ntwf:input-cases a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "input-cases" ;
    effortless-ntwf:componentType "input" ;
    effortless-ntwf:fieldName "Cases" ;
    effortless-ntwf:dataType "integer" ;
    effortless-ntwf:sourceTable "CaseCells" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "Total number of observations (trials, patients, applicants, etc.) in this cell." ;
    effortless-ntwf:adapterNote "Must be a positive integer. Every (Study, Stratum, Treatment) combination must have exactly one CaseCell row." .

effortless-ntwf:derived-stratum-rate a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-stratum-rate" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "CellSuccessRate" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "CaseCells" ;
    effortless-ntwf:formula "=Successes/Cases" ;
    effortless-ntwf:naturalLanguage "The success rate for this specific treatment within this specific stratum." ;
    effortless-ntwf:adapterNote "Computed automatically. Range [0,1]." .

effortless-ntwf:derived-pooled-rate-a a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-pooled-rate-a" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "PooledRateA" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=TotalSuccessesA/TotalCasesA" ;
    effortless-ntwf:naturalLanguage "The overall (pooled, unstratified) success rate for treatment A across all strata." ;
    effortless-ntwf:adapterNote "Computed from SUMIFS across CaseCells. This is the rate a naive observer would report." .

effortless-ntwf:derived-pooled-rate-b a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-pooled-rate-b" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "PooledRateB" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=TotalSuccessesB/TotalCasesB" ;
    effortless-ntwf:naturalLanguage "The overall (pooled, unstratified) success rate for treatment B across all strata." ;
    effortless-ntwf:adapterNote "Computed from SUMIFS across CaseCells." .

effortless-ntwf:derived-signed-pooled-gap a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-signed-pooled-gap" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "SignedPooledGap" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=PooledRateA - PooledRateB" ;
    effortless-ntwf:naturalLanguage "The signed difference in pooled rates (A minus B). Positive means A appears better pooled; negative means B appears better." ;
    effortless-ntwf:adapterNote "The naive result — what the unadjusted analysis reports." .

effortless-ntwf:derived-alloc-fraction-a a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-alloc-fraction-a" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "AllocationFractionA" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "StratumSummaries" ;
    effortless-ntwf:formula "=TreatmentACasesHere/TreatmentATotalCases" ;
    effortless-ntwf:naturalLanguage "The fraction of all treatment-A cases that fall in this stratum — treatment A's allocation weight." ;
    effortless-ntwf:adapterNote "Sums to 1.0 across strata within a study." .

effortless-ntwf:derived-stratum-gap a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-stratum-gap" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "StratumGap" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "StratumSummaries" ;
    effortless-ntwf:formula "=StratumRateA - StratumRateB" ;
    effortless-ntwf:naturalLanguage "The signed per-stratum rate difference (A minus B). The true causal signal for this stratum, free of allocation effects." ;
    effortless-ntwf:adapterNote "Computed from within-stratum aggregation of CaseCells." .

effortless-ntwf:derived-weighted-stratum-gap a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-weighted-stratum-gap" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "WeightedStratumGap" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "StratumSummaries" ;
    effortless-ntwf:formula "=((AllocationFractionA + AllocationFractionB) / 2) * StratumGap" ;
    effortless-ntwf:naturalLanguage "The stratum gap weighted by the average of A's and B's allocation fractions — the equal-weight contribution of this stratum." ;
    effortless-ntwf:adapterNote "Summing across strata yields WeightedStratumGapSum." .

effortless-ntwf:derived-wgs a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-wgs" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "WeightedStratumGapSum" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=SUMIFS(StratumSummaries!WeightedStratumGap, StratumSummaries!Study, Study, StratumSummaries!TreatmentLabel, TreatmentA)" ;
    effortless-ntwf:naturalLanguage "The equal-allocation benchmark: what SignedPooledGap would be if each treatment received the same case-mix. This is the allocation-free signal." ;
    effortless-ntwf:adapterNote "Compare to SignedPooledGap to detect distortion." .

effortless-ntwf:derived-is-sign-flip a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-is-sign-flip" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "IsSignFlip" ;
    effortless-ntwf:dataType "boolean" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=IF(WeightedStratumGapSum > 0, SignedPooledGap < 0, SignedPooledGap > 0)" ;
    effortless-ntwf:naturalLanguage "TRUE when the pooled winner (SignedPooledGap) points in the opposite direction from the equal-weight per-stratum winner (WeightedStratumGapSum). This is the sign of a reversal." ;
    effortless-ntwf:adapterNote "The primary reversal detector." .

effortless-ntwf:derived-allocation-distortion a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-allocation-distortion" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "AllocationDistortion" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=ABS(WeightedStratumGapSum - SignedPooledGap)" ;
    effortless-ntwf:naturalLanguage "The absolute magnitude of the allocation distortion — how much the observed pooled gap differs from the equal-weight benchmark." ;
    effortless-ntwf:adapterNote "Zero means no allocation confounding. > 0.01 is the classification threshold for types C and D." .

effortless-ntwf:class-distortion-type a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "class-distortion-type" ;
    effortless-ntwf:componentType "classification" ;
    effortless-ntwf:fieldName "DistortionType" ;
    effortless-ntwf:dataType "categorical" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=IF(AND(IsSignFlip, ReversalIntensity=1), 'A', IF(AND(IsSignFlip, ReversalIntensity<1), 'B', IF(AND(NOT(IsSignFlip), AllocationDistortion>0.01), 'C', 'D')))" ;
    effortless-ntwf:naturalLanguage "The four-type classification: A=full reversal (A wins all strata, B wins pooled); B=partial reversal (split strata, pooled contradicts weighted); C=distortion without reversal (same winner, but margin compressed or inflated by ≥1pp); D=trustworthy pooled (allocation-free or near-free)." ;
    effortless-ntwf:adapterNote "Output. Read-only for the researcher." .

effortless-ntwf:class-policy-implication a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "class-policy-implication" ;
    effortless-ntwf:componentType "classification" ;
    effortless-ntwf:fieldName "PolicyImplication" ;
    effortless-ntwf:dataType "string" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=IF(DistortionType='A','stratify-immediately', IF(DistortionType='B','investigate-confounder', IF(DistortionType='C','check-allocation-bias','pooled-analysis-trustworthy')))" ;
    effortless-ntwf:naturalLanguage "The recommended analytic action given the distortion type: A→stratify immediately (pooled is misleading); B→investigate the confounder structure; C→report allocation bias alongside pooled result; D→pooled analysis is trustworthy." ;
    effortless-ntwf:adapterNote "Output. This is the instrument's primary policy-facing deliverable." .

effortless-ntwf:adapter-stratum-seed a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "adapter-stratum-seed" ;
    effortless-ntwf:componentType "adapter-requirement" ;
    effortless-ntwf:fieldName "Strata" ;
    effortless-ntwf:dataType "string" ;
    effortless-ntwf:sourceTable "Strata" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "One Strata row per (study, stratum) combination, with a plain-English Description of what this subgroup represents and why it matters." ;
    effortless-ntwf:adapterNote "Required for interpretability. The DAG computes rates without it, but the explanation of the paradox requires this context." .

effortless-ntwf:adapter-stratum-variable a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "adapter-stratum-variable" ;
    effortless-ntwf:componentType "adapter-requirement" ;
    effortless-ntwf:fieldName "StratumVariables" ;
    effortless-ntwf:dataType "string" ;
    effortless-ntwf:sourceTable "StratumVariables" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "One StratumVariables row per study naming the confounding variable, its CausalRole (confounder/mediator/contested), and a MechanismNote explaining how the allocation imbalance arises." ;
    effortless-ntwf:adapterNote "CausalRole must be one of: confounder, mediator, contested, unknown. IsConfounder is derived (confounder AND both affect-flags true)." .

effortless-ntwf:adapter-stratum-summaries a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "adapter-stratum-summaries" ;
    effortless-ntwf:componentType "adapter-requirement" ;
    effortless-ntwf:fieldName "StratumSummaries" ;
    effortless-ntwf:dataType "string" ;
    effortless-ntwf:sourceTable "StratumSummaries" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "Four StratumSummaries seed rows per study (one per stratum × treatment combination) — only StratumSummaryId, Study, StratumLabel, TreatmentLabel required; all computed fields are populated by the DAG." ;
    effortless-ntwf:adapterNote "Minimum hydration contract: provide the four raw-key fields. The re-hydrate step fills in all derived values from the views." .

effortless-ntwf:theorem-signal-purity a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "theorem-signal-purity" ;
    effortless-ntwf:componentType "theorem" ;
    effortless-ntwf:fieldName "SignalPurity" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=ABS(CorrectedGap)/(ABS(CorrectedGap)+AllocationDistortion)" ;
    effortless-ntwf:naturalLanguage "Theorem (loop-44): manifest sign-flip requires SignalPurity < 0.5 — allocation noise exceeds true signal." ;
    effortless-ntwf:adapterNote "Build-breaking invariant inv-sign-flip-signal-purity-max. Category=theorem in conc-12/20." .

effortless-ntwf:theorem-corrected-gap-invariant a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "theorem-corrected-gap-invariant" ;
    effortless-ntwf:componentType "theorem" ;
    effortless-ntwf:fieldName "CorrectedGap" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=WeightedStratumGapSum" ;
    effortless-ntwf:naturalLanguage "Theorem (loop-73): CorrectedGap is invariant under allocation reweighting — conserved quantity across AllocationSweep." ;
    effortless-ntwf:adapterNote "Build-breaking invariant inv-corrected-gap-invariant. Promoted conc-28." .

effortless-ntwf:theorem-explained-confounder a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "theorem-explained-confounder" ;
    effortless-ntwf:componentType "theorem" ;
    effortless-ntwf:fieldName "IsParadoxExplained" ;
    effortless-ntwf:dataType "boolean" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=IsSignFlip AND StratumCausalRole='confounder'" ;
    effortless-ntwf:naturalLanguage "Theorem (loop-74): IsParadoxExplained ⟺ confounder manifest sign-flip — adjust-resolvable confounding is the unique explanation." ;
    effortless-ntwf:adapterNote "Biconditional: inv-explained-sign-flip-confounder + inv-confounder-signflip-explained. Promoted conc-29." .

effortless-ntwf:theorem-collider-no-manifest a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "theorem-collider-no-manifest" ;
    effortless-ntwf:componentType "theorem" ;
    effortless-ntwf:fieldName "IsSignFlip" ;
    effortless-ntwf:dataType "boolean" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=FALSE when StratumCausalRole IN (collider, selection)" ;
    effortless-ntwf:naturalLanguage "Theorem (loop-75, conditional): given correct causal-role annotation, collider/selection studies produce no manifest sign-flips at observed allocation." ;
    effortless-ntwf:adapterNote "Build-breaking invariant inv-collider-no-manifest. Promoted conc-30." .

# === Individuals: InvariantChecks ===

effortless-ntwf:inv-taxonomy-complete a effortless-ntwf:InvariantChecks ;
    effortless-ntwf:invariantCheckId "inv-taxonomy-complete" ;
    effortless-ntwf:algebraicStatement "DistortionType ∈ {A,B,C+,C-,D} for all rows" ;
    effortless-ntwf:naturalLanguage "Every TreatmentRanking row in the 40-study corpus must have a non-null five-type DistortionType. A blank classification means the DAG has a gap." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "" ;
    effortless-ntwf:assertionExpression "DistortionType IS NOT NULL AND DistortionType <> ''" ;
    effortless-ntwf:sqlFilter "" ;
    effortless-ntwf:sqlAssertion "distortion_type IS NOT NULL AND distortion_type <> ''" ;
    effortless-ntwf:passCount 40 ;
    effortless-ntwf:failCount 0 ;
    effortless-ntwf:severity "critical" ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:protectsConclusion "conc-01-paradox-is-derived" .

effortless-ntwf:inv-type-ab-sign-flip a effortless-ntwf:InvariantChecks ;
    effortless-ntwf:invariantCheckId "inv-type-ab-sign-flip" ;
    effortless-ntwf:algebraicStatement "DistortionType ∈ {A,B} → IsSignFlip=TRUE" ;
    effortless-ntwf:naturalLanguage "Types A and B are sign-flip reversals. A study classified A or B where IsSignFlip is FALSE violates the type definition." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "DistortionType IN ('A','B')" ;
