# === Individuals: Conclusions ===

effortless-ntwf:conc-01-paradox-is-derived a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-01-paradox-is-derived" ;
    effortless-ntwf:category "domain" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:title "Simpson's Paradox is a derived fact from the DAG, not a modeled entity" ;
    effortless-ntwf:evidence "IsReversal (and later IsSignFlip) falls out as a calculated field on TreatmentRankings, derived from aggregated CaseCell counts. No 'ReversalDetection' entity was ever needed." ;
    effortless-ntwf:witnessedInLoop "loop-04" .

effortless-ntwf:conc-02-reversal-from-allocation a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-02-reversal-from-allocation" ;
    effortless-ntwf:category "domain" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:title "The reversal in kidney-1986 is entirely an allocation artifact — same rates with balanced allocation produce no reversal" ;
    effortless-ntwf:evidence "kidney-balanced uses identical stratum success rates to kidney-1986 but with equal allocation (175 cases per cell). IsReversal=FALSE, AllocationDistortion=0. The paradox is algebraically isolated as a property of allocation, not of treatment efficacy." ;
    effortless-ntwf:witnessedInLoop "loop-14" .

effortless-ntwf:conc-03-binary-excludes-partial a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-03-binary-excludes-partial" ;
    effortless-ntwf:category "instrument" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:title "The unanimity criterion (IsReversal) incorrectly excludes Berkeley 1973 despite its being a Simpson-type paradox" ;
    effortless-ntwf:evidence "Berkeley: WSGSUM=−0.0642, SignedPooledGap=+0.1292, IsSignFlip=TRUE, AllocationDistortion=0.1934 — greater distortion than kidney-1986. But IsReversal=FALSE because dept-C marginally favors male. The unanimity criterion is a strict subtype, not the primary definition." ;
    effortless-ntwf:witnessedInLoop "loop-17" .

effortless-ntwf:conc-04-type-c-exists a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-04-type-c-exists" ;
    effortless-ntwf:category "instrument" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:title "Allocation can compress the pooled signal without flipping it (type-C): a class invisible to IsReversal and IsSignFlip but visible to AllocationDistortion" ;
    effortless-ntwf:evidence "compressed-synthetic: A wins every stratum and wins pooled, but the pooled margin is 6pp rather than the equal-weight 10pp. AllocationDistortion=0.0400, IsSignFlip=FALSE. The pooled winner is correct; the effect size is wrong by 4pp." ;
    effortless-ntwf:witnessedInLoop "loop-19" .

effortless-ntwf:conc-05-real-data-generalizes a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-05-real-data-generalizes" ;
    effortless-ntwf:category "instrument" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:title "Two real published studies (reintjes-2000, radelet-1981) hydrate as type-A full reversals without schema changes" ;
    effortless-ntwf:evidence "Both studies entered via 05b-customize-data.sql. Witnessed: reintjes AllocationDistortion=0.0516, DistortionType=A; radelet AllocationDistortion=0.0684, DistortionType=A. No DAG or schema change was needed — the hydration contract generalizes." ;
    effortless-ntwf:witnessedInLoop "loop-20b" .

effortless-ntwf:conc-06-policy-derivable a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-06-policy-derivable" ;
    effortless-ntwf:category "instrument" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:title "PolicyImplication is domain-neutral: the same formula produces researcher actions across medicine, law, and education" ;
    effortless-ntwf:evidence "All five current studies (kidney-1986, berkeley-1973, compressed-synthetic, kidney-balanced, balanced-synthetic) plus two real studies produce unambiguous PolicyImplication values from DistortionType alone. No domain-specific knowledge is encoded in the formula." ;
    effortless-ntwf:witnessedInLoop "loop-21" .

effortless-ntwf:conc-07-model-self-portrait a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-07-model-self-portrait" ;
    effortless-ntwf:category "instrument" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:title "ModelSummary witnesses the instrument's own epistemic coverage as a first-class derived fact" ;
    effortless-ntwf:evidence "ModelSummary aggregates ReversalCount, ExplainedCount, TypeA/B/C/D counts, and AvgAllocationDistortion across all studies. The model describes its own completeness in a single row." ;
    effortless-ntwf:witnessedInLoop "loop-10" .

effortless-ntwf:conc-08-type-c-real a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-08-type-c-real" ;
    effortless-ntwf:category "open-question" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:title "Does the published literature contain real type-C studies (compression without sign flip)?" ;
    effortless-ntwf:evidence "Witnessed in loop-24: hannan-1994 (CABG surgery), titanic-1912, melanoma-altman-1991, and coffee-tverdal-2020 all hydrate as DistortionType=C. AllocationDistortion>0.01, IsSignFlip=FALSE — the correct pooled direction but compressed magnitude. The type-C cell is not a synthetic pathology." ;
    effortless-ntwf:witnessedInLoop "loop-24" ;
    effortless-ntwf:targetLoop "loop-25" .

effortless-ntwf:conc-09-causal-vs-geometric a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-09-causal-vs-geometric" ;
    effortless-ntwf:category "open-question" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:title "AllocationDistortion is a geometric measure; causal interpretation requires external domain knowledge, gated by AdjustmentAppropriate" ;
    effortless-ntwf:evidence "Berkeley has the highest AllocationDistortion (0.1934) but CausalRole=contested (mediator vs confounder), proving that geometric severity and causal confounding are not the same thing. The instrument is deliberately geometric: it classifies distortion type and flags the corrected winner from allocation arithmetic alone. Whether it is safe to act on that correction as a causal claim is answered by AdjustmentAppropriate — which gates on ConditioningRisk and CausalClaimStatus. The two layers are complementary, not competing. The instrument computes the geometry; the researcher supplies the causal account. This is a scope boundary, not a limitation." ;
    effortless-ntwf:witnessedInLoop "loop-30" ;
    effortless-ntwf:targetLoop "loop-23" .

effortless-ntwf:conc-10-instrument-specifiable a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-10-instrument-specifiable" ;
    effortless-ntwf:category "methodology" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:title "The full instrument can be specified precisely enough for any researcher to apply it to a new study" ;
    effortless-ntwf:evidence "Witnessed in loop-26: InstrumentSpec table enumerates 5 input fields, 10 derived coordinates, 2 classification rules, and 3 adapter-requirement rows. Machine-verifiable against all 16 studies in the validation set." ;
    effortless-ntwf:witnessedInLoop "loop-26" ;
    effortless-ntwf:targetLoop "loop-30" .

effortless-ntwf:conc-11-reversal-recovery a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-11-reversal-recovery" ;
    effortless-ntwf:category "instrument" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:title "The model can produce the allocation-corrected winner directly from existing DAG fields — no new data required" ;
    effortless-ntwf:evidence "CorrectedGap = WeightedStratumGapSum (already derived in loop-12/17). CorrectedWinner is a sign-read on CorrectedGap. CorrectedVsPooledAgreement is TRUE for Type-D studies and FALSE for Type-A/B studies. For kidney-1986: CorrectedGap=+0.0537, CorrectedWinner=A, CorrectedVsPooledAgreement=FALSE (pooled said B; corrected says A). The reversal recovery is free — it costs zero new data." ;
    effortless-ntwf:witnessedInLoop "loop-27" .

# === Individuals: InstrumentSpec ===

effortless-ntwf:input-study a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "input-study" ;
    effortless-ntwf:componentType "input" ;
    effortless-ntwf:fieldName "Study" ;
    effortless-ntwf:dataType "string" ;
    effortless-ntwf:sourceTable "CaseCells" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "A unique identifier for the study being classified (e.g. 'kidney-1986')." ;
    effortless-ntwf:adapterNote "Assign a slug that is stable and unique. All rows for a study share this value." .

effortless-ntwf:input-stratum a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "input-stratum" ;
    effortless-ntwf:componentType "input" ;
    effortless-ntwf:fieldName "StratumLabel" ;
    effortless-ntwf:dataType "string" ;
    effortless-ntwf:sourceTable "CaseCells" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "The label of the subgroup (stratum) for this cell — the variable being stratified on (e.g. 'large', 'high-risk', 'male')." ;
    effortless-ntwf:adapterNote "Must be consistent across the A and B cells within the same stratum. At least 2 strata required." .

effortless-ntwf:input-treatment a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "input-treatment" ;
    effortless-ntwf:componentType "input" ;
    effortless-ntwf:fieldName "TreatmentLabel" ;
    effortless-ntwf:dataType "string" ;
    effortless-ntwf:sourceTable "CaseCells" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "Which treatment (exposure, group, class) this cell belongs to — 'A' or 'B'." ;
    effortless-ntwf:adapterNote "Exactly two treatment labels per study. Encode the group you want to investigate as 'A'; comparator as 'B'." .

effortless-ntwf:input-successes a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "input-successes" ;
    effortless-ntwf:componentType "input" ;
    effortless-ntwf:fieldName "Successes" ;
    effortless-ntwf:dataType "integer" ;
    effortless-ntwf:sourceTable "CaseCells" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "Count of successful outcomes (survived, passed, admitted, etc.) in this cell." ;
    effortless-ntwf:adapterNote "Must be a non-negative integer ≤ Cases. Define 'success' consistently across all cells in the study." .

effortless-ntwf:input-cases a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "input-cases" ;
    effortless-ntwf:componentType "input" ;
    effortless-ntwf:fieldName "Cases" ;
    effortless-ntwf:dataType "integer" ;
    effortless-ntwf:sourceTable "CaseCells" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "Total number of observations (trials, patients, applicants, etc.) in this cell." ;
    effortless-ntwf:adapterNote "Must be a positive integer. Every (Study, Stratum, Treatment) combination must have exactly one CaseCell row." .

effortless-ntwf:derived-stratum-rate a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-stratum-rate" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "CellSuccessRate" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "CaseCells" ;
    effortless-ntwf:formula "=Successes/Cases" ;
    effortless-ntwf:naturalLanguage "The success rate for this specific treatment within this specific stratum." ;
    effortless-ntwf:adapterNote "Computed automatically. Range [0,1]." .

effortless-ntwf:derived-pooled-rate-a a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-pooled-rate-a" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "PooledRateA" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=TotalSuccessesA/TotalCasesA" ;
    effortless-ntwf:naturalLanguage "The overall (pooled, unstratified) success rate for treatment A across all strata." ;
    effortless-ntwf:adapterNote "Computed from SUMIFS across CaseCells. This is the rate a naive observer would report." .

effortless-ntwf:derived-pooled-rate-b a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-pooled-rate-b" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "PooledRateB" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=TotalSuccessesB/TotalCasesB" ;
    effortless-ntwf:naturalLanguage "The overall (pooled, unstratified) success rate for treatment B across all strata." ;
    effortless-ntwf:adapterNote "Computed from SUMIFS across CaseCells." .

effortless-ntwf:derived-signed-pooled-gap a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-signed-pooled-gap" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "SignedPooledGap" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=PooledRateA - PooledRateB" ;
    effortless-ntwf:naturalLanguage "The signed difference in pooled rates (A minus B). Positive means A appears better pooled; negative means B appears better." ;
    effortless-ntwf:adapterNote "The naive result — what the unadjusted analysis reports." .

effortless-ntwf:derived-alloc-fraction-a a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-alloc-fraction-a" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "AllocationFractionA" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "StratumSummaries" ;
    effortless-ntwf:formula "=TreatmentACasesHere/TreatmentATotalCases" ;
    effortless-ntwf:naturalLanguage "The fraction of all treatment-A cases that fall in this stratum — treatment A's allocation weight." ;
    effortless-ntwf:adapterNote "Sums to 1.0 across strata within a study." .

effortless-ntwf:derived-stratum-gap a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-stratum-gap" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "StratumGap" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "StratumSummaries" ;
    effortless-ntwf:formula "=StratumRateA - StratumRateB" ;
    effortless-ntwf:naturalLanguage "The signed per-stratum rate difference (A minus B). The true causal signal for this stratum, free of allocation effects." ;
    effortless-ntwf:adapterNote "Computed from within-stratum aggregation of CaseCells." .

effortless-ntwf:derived-weighted-stratum-gap a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-weighted-stratum-gap" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "WeightedStratumGap" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "StratumSummaries" ;
    effortless-ntwf:formula "=((AllocationFractionA + AllocationFractionB) / 2) * StratumGap" ;
    effortless-ntwf:naturalLanguage "The stratum gap weighted by the average of A's and B's allocation fractions — the equal-weight contribution of this stratum." ;
    effortless-ntwf:adapterNote "Summing across strata yields WeightedStratumGapSum." .

effortless-ntwf:derived-wgs a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-wgs" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "WeightedStratumGapSum" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=SUMIFS(StratumSummaries!WeightedStratumGap, StratumSummaries!Study, Study, StratumSummaries!TreatmentLabel, TreatmentA)" ;
    effortless-ntwf:naturalLanguage "The equal-allocation benchmark: what SignedPooledGap would be if each treatment received the same case-mix. This is the allocation-free signal." ;
    effortless-ntwf:adapterNote "Compare to SignedPooledGap to detect distortion." .

effortless-ntwf:derived-is-sign-flip a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-is-sign-flip" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "IsSignFlip" ;
    effortless-ntwf:dataType "boolean" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=IF(WeightedStratumGapSum > 0, SignedPooledGap < 0, SignedPooledGap > 0)" ;
    effortless-ntwf:naturalLanguage "TRUE when the pooled winner (SignedPooledGap) points in the opposite direction from the equal-weight per-stratum winner (WeightedStratumGapSum). This is the sign of a reversal." ;
    effortless-ntwf:adapterNote "The primary reversal detector." .

effortless-ntwf:derived-allocation-distortion a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "derived-allocation-distortion" ;
    effortless-ntwf:componentType "derived" ;
    effortless-ntwf:fieldName "AllocationDistortion" ;
    effortless-ntwf:dataType "decimal" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=ABS(WeightedStratumGapSum - SignedPooledGap)" ;
    effortless-ntwf:naturalLanguage "The absolute magnitude of the allocation distortion — how much the observed pooled gap differs from the equal-weight benchmark." ;
    effortless-ntwf:adapterNote "Zero means no allocation confounding. > 0.01 is the classification threshold for types C and D." .

effortless-ntwf:class-distortion-type a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "class-distortion-type" ;
    effortless-ntwf:componentType "classification" ;
    effortless-ntwf:fieldName "DistortionType" ;
    effortless-ntwf:dataType "categorical" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=IF(AND(IsSignFlip, ReversalIntensity=1), 'A', IF(AND(IsSignFlip, ReversalIntensity<1), 'B', IF(AND(NOT(IsSignFlip), AllocationDistortion>0.01), 'C', 'D')))" ;
    effortless-ntwf:naturalLanguage "The four-type classification: A=full reversal (A wins all strata, B wins pooled); B=partial reversal (split strata, pooled contradicts weighted); C=distortion without reversal (same winner, but margin compressed or inflated by ≥1pp); D=trustworthy pooled (allocation-free or near-free)." ;
    effortless-ntwf:adapterNote "Output. Read-only for the researcher." .

effortless-ntwf:class-policy-implication a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "class-policy-implication" ;
    effortless-ntwf:componentType "classification" ;
    effortless-ntwf:fieldName "PolicyImplication" ;
    effortless-ntwf:dataType "string" ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:formula "=IF(DistortionType='A','stratify-immediately', IF(DistortionType='B','investigate-confounder', IF(DistortionType='C','check-allocation-bias','pooled-analysis-trustworthy')))" ;
    effortless-ntwf:naturalLanguage "The recommended analytic action given the distortion type: A→stratify immediately (pooled is misleading); B→investigate the confounder structure; C→report allocation bias alongside pooled result; D→pooled analysis is trustworthy." ;
    effortless-ntwf:adapterNote "Output. This is the instrument's primary policy-facing deliverable." .

effortless-ntwf:adapter-stratum-seed a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "adapter-stratum-seed" ;
    effortless-ntwf:componentType "adapter-requirement" ;
    effortless-ntwf:fieldName "Strata" ;
    effortless-ntwf:dataType "string" ;
    effortless-ntwf:sourceTable "Strata" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "One Strata row per (study, stratum) combination, with a plain-English Description of what this subgroup represents and why it matters." ;
    effortless-ntwf:adapterNote "Required for interpretability. The DAG computes rates without it, but the explanation of the paradox requires this context." .

effortless-ntwf:adapter-stratum-variable a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "adapter-stratum-variable" ;
    effortless-ntwf:componentType "adapter-requirement" ;
    effortless-ntwf:fieldName "StratumVariables" ;
    effortless-ntwf:dataType "string" ;
    effortless-ntwf:sourceTable "StratumVariables" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "One StratumVariables row per study naming the confounding variable, its CausalRole (confounder/mediator/contested), and a MechanismNote explaining how the allocation imbalance arises." ;
    effortless-ntwf:adapterNote "CausalRole must be one of: confounder, mediator, contested, unknown. IsConfounder is derived (confounder AND both affect-flags true)." .

effortless-ntwf:adapter-stratum-summaries a effortless-ntwf:InstrumentSpec ;
    effortless-ntwf:specId "adapter-stratum-summaries" ;
    effortless-ntwf:componentType "adapter-requirement" ;
    effortless-ntwf:fieldName "StratumSummaries" ;
    effortless-ntwf:dataType "string" ;
    effortless-ntwf:sourceTable "StratumSummaries" ;
    effortless-ntwf:formula "" ;
    effortless-ntwf:naturalLanguage "Four StratumSummaries seed rows per study (one per stratum × treatment combination) — only StratumSummaryId, Study, StratumLabel, TreatmentLabel required; all computed fields are populated by the DAG." ;
    effortless-ntwf:adapterNote "Minimum hydration contract: provide the four raw-key fields. The re-hydrate step fills in all derived values from the views." .

# === Individuals: InvariantChecks ===

effortless-ntwf:inv-taxonomy-complete a effortless-ntwf:InvariantChecks ;
    effortless-ntwf:invariantCheckId "inv-taxonomy-complete" ;
    effortless-ntwf:algebraicStatement "DistortionType ∈ {A,B,C,D} for all rows" ;
    effortless-ntwf:naturalLanguage "Every TreatmentRanking row must have a non-null DistortionType. A blank classification means the DAG has a gap." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "" ;
    effortless-ntwf:assertionExpression "DistortionType IS NOT NULL AND DistortionType <> ''" ;
    effortless-ntwf:sqlFilter "" ;
    effortless-ntwf:sqlAssertion "distortion_type IS NOT NULL AND distortion_type <> ''" ;
    effortless-ntwf:passCount 16 ;
    effortless-ntwf:failCount 0 ;
    effortless-ntwf:severity "critical" .

effortless-ntwf:inv-type-ab-sign-flip a effortless-ntwf:InvariantChecks ;
    effortless-ntwf:invariantCheckId "inv-type-ab-sign-flip" ;
    effortless-ntwf:algebraicStatement "DistortionType ∈ {A,B} → IsSignFlip=TRUE" ;
    effortless-ntwf:naturalLanguage "Types A and B are defined as sign-flip reversals. A study classified A or B where IsSignFlip is FALSE violates the type definition." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "DistortionType IN ('A','B')" ;
    effortless-ntwf:assertionExpression "IsSignFlip = TRUE" ;
    effortless-ntwf:sqlFilter "distortion_type IN ('A','B')" ;
    effortless-ntwf:sqlAssertion "is_sign_flip = TRUE" ;
    effortless-ntwf:passCount 9 ;
    effortless-ntwf:failCount 0 ;
    effortless-ntwf:severity "critical" .

effortless-ntwf:inv-type-cd-no-sign-flip a effortless-ntwf:InvariantChecks ;
    effortless-ntwf:invariantCheckId "inv-type-cd-no-sign-flip" ;
    effortless-ntwf:algebraicStatement "DistortionType ∈ {C,D} → IsSignFlip=FALSE" ;
    effortless-ntwf:naturalLanguage "Types C and D are non-reversal types. A C or D study where IsSignFlip is TRUE is a classification contradiction." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "DistortionType IN ('C','D')" ;
    effortless-ntwf:assertionExpression "IsSignFlip = FALSE" ;
    effortless-ntwf:sqlFilter "distortion_type IN ('C','D')" ;
    effortless-ntwf:sqlAssertion "(is_sign_flip = FALSE OR is_sign_flip IS NULL)" ;
    effortless-ntwf:passCount 7 ;
    effortless-ntwf:failCount 0 ;
    effortless-ntwf:severity "critical" .

effortless-ntwf:inv-sign-flip-winner a effortless-ntwf:InvariantChecks ;
    effortless-ntwf:invariantCheckId "inv-sign-flip-winner" ;
    effortless-ntwf:algebraicStatement "IsSignFlip=TRUE → CorrectedVsPooledAgreement=FALSE" ;
    effortless-ntwf:naturalLanguage "When pooled and equal-weight signals point in opposite directions (IsSignFlip), the corrected winner must differ from the pooled winner. This is the definition of a sign flip." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "IsSignFlip = TRUE" ;
    effortless-ntwf:assertionExpression "CorrectedVsPooledAgreement = FALSE" ;
    effortless-ntwf:sqlFilter "is_sign_flip = TRUE" ;
    effortless-ntwf:sqlAssertion "corrected_vs_pooled_agreement = FALSE" ;
    effortless-ntwf:passCount 9 ;
    effortless-ntwf:failCount 0 ;
    effortless-ntwf:severity "critical" .

effortless-ntwf:inv-type-d-agreement a effortless-ntwf:InvariantChecks ;
    effortless-ntwf:invariantCheckId "inv-type-d-agreement" ;
    effortless-ntwf:algebraicStatement "DistortionType=D → CorrectedVsPooledAgreement=TRUE" ;
    effortless-ntwf:naturalLanguage "Type-D studies have negligible allocation distortion so corrected and pooled winners must agree. Disagreement means the type classification is wrong." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "DistortionType = 'D'" ;
    effortless-ntwf:assertionExpression "CorrectedVsPooledAgreement = TRUE" ;
    effortless-ntwf:sqlFilter "distortion_type = 'D'" ;
    effortless-ntwf:sqlAssertion "corrected_vs_pooled_agreement = TRUE" ;
    effortless-ntwf:passCount 3 ;
    effortless-ntwf:failCount 0 ;
    effortless-ntwf:severity "critical" .

effortless-ntwf:inv-type-d-low-distortion a effortless-ntwf:InvariantChecks ;
    effortless-ntwf:invariantCheckId "inv-type-d-low-distortion" ;
    effortless-ntwf:algebraicStatement "DistortionType=D → AllocationDistortion < 0.01" ;
    effortless-ntwf:naturalLanguage "Type D is defined as allocation-free (distortion below the 1pp threshold). Any Type-D row with AllocationDistortion ≥ 0.01 violates the classification invariant." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "DistortionType = 'D'" ;
    effortless-ntwf:assertionExpression "AllocationDistortion < 0.01" ;
    effortless-ntwf:sqlFilter "distortion_type = 'D'" ;
    effortless-ntwf:sqlAssertion "allocation_distortion < 0.01" ;
    effortless-ntwf:passCount 3 ;
    effortless-ntwf:failCount 0 ;
    effortless-ntwf:severity "critical" .

effortless-ntwf:inv-corrected-gap-sign a effortless-ntwf:InvariantChecks ;
    effortless-ntwf:invariantCheckId "inv-corrected-gap-sign" ;
    effortless-ntwf:algebraicStatement "SIGN(CorrectedGap) = SIGN(WeightedStratumGapSum)" ;
    effortless-ntwf:naturalLanguage "CorrectedGap is defined as WeightedStratumGapSum. Their signs must always agree — a mismatch would mean the corrected winner formula reads the wrong field." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "WeightedStratumGapSum IS NOT NULL" ;
    effortless-ntwf:assertionExpression "SIGN(corrected_gap) = SIGN(weighted_stratum_gap_sum)" ;
    effortless-ntwf:sqlFilter "weighted_stratum_gap_sum IS NOT NULL" ;
    effortless-ntwf:sqlAssertion "SIGN(corrected_gap) = SIGN(weighted_stratum_gap_sum)" ;
    effortless-ntwf:passCount 16 ;
    effortless-ntwf:failCount 0 ;
    effortless-ntwf:severity "critical" .

# === Individuals: Loops ===

effortless-ntwf:loop-01 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-01" ;
    effortless-ntwf:title "Core domain: Study, Treatment, Stratum, CaseCell → SuccessRate falls out" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "Studies, Treatments, Strata, CaseCells" ;
    effortless-ntwf:domainQuestion "For each (stratum, treatment) cell in a study, what is the success rate?" ;
    effortless-ntwf:mockDataNote "Kidney stone study (Charig 1986): 2 strata (small/large), 2 treatments (A/B), 4 cells. CellSuccessRate is the first derived fact." ;
    effortless-ntwf:nextSuggestion "Ask: for each treatment, what is its pooled (across all strata) success rate? That requires TreatmentSummary — aggregating CaseCells by treatment, ignoring stratum." .

effortless-ntwf:loop-02 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-02" ;
    effortless-ntwf:title "TreatmentSummary: pooled rate per treatment across all strata" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "TreatmentSummaries" ;
    effortless-ntwf:domainQuestion "If you ignore stratum entirely, what is each treatment's overall success rate?" ;
    effortless-ntwf:mockDataNote "Pooled: A=273/350=78%, B=289/350=83%. B looks better — this is the misleading aggregate view." ;
    effortless-ntwf:nextSuggestion "Ask: for each (stratum, treatment) pair, what is the success rate WITHIN that stratum? That requires StratumSummary — the view that contradicts the pooled view." .

effortless-ntwf:loop-03 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-03" ;
    effortless-ntwf:title "StratumSummary: per-stratum rate per treatment — the true picture" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "StratumSummaries" ;
    effortless-ntwf:domainQuestion "Within each stratum, which treatment has the higher success rate?" ;
    effortless-ntwf:mockDataNote "Small: A=93.1% > B=86.7%. Large: A=73.0% > B=68.8%. A wins in BOTH strata. Contradiction with pooled view is now visible." ;
    effortless-ntwf:nextSuggestion "Ask: for each treatment pair in a study, does the pooled winner match the per-stratum winner? That requires TreatmentRanking — the node where the paradox either exists or doesn't." .

effortless-ntwf:loop-04 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-04" ;
    effortless-ntwf:title "TreatmentRanking: does the pooled winner = the per-stratum winner?" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "TreatmentRankings" ;
    effortless-ntwf:domainQuestion "When pooled and stratified conclusions disagree — which treatment should actually be preferred?" ;
    effortless-ntwf:mockDataNote "Pooled winner = B. Per-stratum winner = A in every stratum. Simpson's Paradox: IsReversal = true. This is the paradox as a derived fact, not a modeled entity." ;
    effortless-ntwf:nextSuggestion "Ask: WHY does the paradox occur? The stratifying variable (stone size) affects both treatment assignment AND outcome. Name it as a StratumVariable with a CausalRole field." .

effortless-ntwf:loop-05 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-05" ;
    effortless-ntwf:title "StratumVariable: name the confounding factor, its causal role, and derive IsConfounder + IsParadoxExplained" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "StratumVariables (one per study); CausalRole field; IsConfounder boolean; IsParadoxExplained on TreatmentRankings" ;
    effortless-ntwf:domainQuestion "What IS the stratum variable, why does it confound, and does the model witness its own explanation?" ;
    effortless-ntwf:mockDataNote "kidney-1986: VariableName=stone_size, CausalRole=confounder, AffectsTreatmentAssignment=true, AffectsOutcome=true → IsConfounder=true → IsParadoxExplained=true on TreatmentRankings." ;
    effortless-ntwf:nextSuggestion "Ask: how large is the allocation imbalance? Derive TreatmentExposureFraction on CaseCells — the fraction of each treatment's cases that land in each stratum. High imbalance = confounding mechanism as a witnessed number." .

effortless-ntwf:loop-06 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-06" ;
    effortless-ntwf:title "TreatmentExposureFraction: the allocation imbalance as a witnessed number" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "TreatmentExposureFraction field on CaseCells (Cases / TotalCasesForTreatment in this study)" ;
    effortless-ntwf:domainQuestion "What fraction of each treatment's total cases fall in each stratum? High imbalance across strata is the mechanism of confounding." ;
    effortless-ntwf:mockDataNote "A: 263/350=75% in large-stone stratum. B: 80/350=23% in large-stone stratum. The 52-point gap IS the mechanism — now a first-class derived number." ;
    effortless-ntwf:nextSuggestion "Add a degenerate study where treatment allocation is perfectly balanced across strata. IsReversal must be FALSE — not because the data says so, but because the algebra guarantees it. The model witnesses its own structural impossibility." .

effortless-ntwf:loop-07 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-07" ;
    effortless-ntwf:title "Degenerate study: balanced allocation → IsReversal structurally impossible" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "Second Studies row (balanced-synthetic); equal TreatmentExposureFraction across strata; IsReversal = FALSE by construction" ;
    effortless-ntwf:domainQuestion "If every stratum gets the same treatment-allocation fraction, can a reversal occur? The DAG should witness that it cannot." ;
    effortless-ntwf:mockDataNote "Synthetic: A and B each assigned 50/50 to small/large strata. A=60% success both strata, B=50% both. Pooled: A=60%, B=50%. No reversal. IsParadoxExplained vacuously true (IsConfounder=false, no confounding, no reversal)." ;
    effortless-ntwf:nextSuggestion "Add Berkeley 1973 — same DAG, contested domain. Aggregate: women admitted at lower rate. Per-department: women admitted at equal or higher rate in most. IsReversal=true. But IsConfounder is ambiguous — department choice may be downstream of gender (mediator, not confounder). The model witnesses its own explanatory limits." .

effortless-ntwf:loop-08 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-08" ;
    effortless-ntwf:title "Berkeley 1973: contested confounder — model reveals a PARTIAL paradox, not a clean reversal" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "Third Studies row (berkeley-1973); StratumVariable=department; CausalRole=contested; IsConfounder=false; IsParadoxExplained=false; PerStratumWinner=none (mixed, not unanimous)" ;
    effortless-ntwf:domainQuestion "Does Berkeley show a clean reversal? No — PerStratumWinner='none' because the per-stratum winner is mixed (female wins 3/4 depts, male wins 1). The model surfaces a structural limit of the reversal definition: partial paradoxes are real but don't satisfy the strict IsReversal criterion." ;
    effortless-ntwf:mockDataNote "Witnessed: male pooled 52.8% vs female 39.9% (large gap). Per dept: female wins A (82%>62%), B (68%>63%), D (35%>33%); male wins C (37%>34%). No unanimous per-stratum winner → IsReversal=FALSE by strict definition. The intuitive paradox is real; the formal paradox is partial." ;
    effortless-ntwf:nextSuggestion "Add ParadoxStrength (scalar severity) to capture partial reversals — pooled gap and average per-stratum gap regardless of unanimity. Then StudySummary for epistemic coverage across all 3 studies." .

effortless-ntwf:loop-09 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-09" ;
    effortless-ntwf:title "ParadoxStrength: scalar severity derived from pooled gap and per-stratum gap" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "ParadoxStrength on TreatmentRankings; PooledGap and AvgStratumGap on StratumSummaries" ;
    effortless-ntwf:domainQuestion "How large is the reversal? Can we rank studies by paradox severity, and does strength correlate with allocation imbalance?" ;
    effortless-ntwf:mockDataNote "Kidney: pooled gap ~4.6pp favoring B, avg stratum gap ~5pp favoring A. Berkeley: larger pooled gap, varies by department. Balanced: strength=0 (no reversal)." ;
    effortless-ntwf:nextSuggestion "StudySummary: roll up ReversalCount, ExplainedCount, AvgParadoxStrength across all studies. The model now describes its own epistemic coverage in a single view." .

effortless-ntwf:loop-10 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-10" ;
    effortless-ntwf:title "StudySummary: the model witnesses its own epistemic coverage" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "StudySummary table (one row per model instance): StudyCount, ReversalCount, ExplainedCount, UnexplainedCount, ImpossibleCount, AvgParadoxStrength" ;
    effortless-ntwf:domainQuestion "Across all studies in this model, what is the epistemic state? How many reversals, how many explained, how many witnessed-but-unexplained?" ;
    effortless-ntwf:mockDataNote "3 studies: ReversalCount=2 (kidney+berkeley), ExplainedCount=1 (kidney), UnexplainedCount=1 (berkeley), ImpossibleCount=1 (balanced). The model now holds a mirror to itself." ;
    effortless-ntwf:nextSuggestion "Ask: how heavy is each stratum? Add StratumFraction to StratumSummaries — the fraction of the study's total cases that land in each stratum. The weight each stratum carries IS the lever the confounder pulls." .

effortless-ntwf:loop-11 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-11" ;
    effortless-ntwf:title "StratumFraction: the weight each stratum carries in the pooled average" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "StratumFraction (and StudyTotalCases, StratumTotalCases) on StratumSummaries" ;
    effortless-ntwf:domainQuestion "What fraction of the study's total cases land in each stratum? High StratumFraction on a low-success stratum pulls the pooled rate down — and when that stratum is also over-allocated to one treatment, the reversal follows." ;
    effortless-ntwf:mockDataNote "kidney-1986: large-stratum = (263+80)/700 = 49%; small-stratum = (87+270)/700 = 51%. Nearly equal stratum weights — but unequal per-treatment allocation (75% of A is in large; 23% of B is in large). The weight alone is not the mechanism; the differential allocation into heavy strata is." ;
    effortless-ntwf:nextSuggestion "Add WeightedStratumRate: StratumFraction × StratumSuccessRate per treatment row. Sum these across strata to reconstruct PooledRate from first principles. The DAG now witnesses the mechanism equation: pooled rate = weighted average of stratum rates." .

effortless-ntwf:loop-12 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-12" ;
    effortless-ntwf:title "WeightedPull: mechanism equation witnessed — pooled rate = weighted sum of stratum rates" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "WeightedStratumRate on StratumSummaries; PooledRateFromWeightsA and PooledRateFromWeightsB on TreatmentRankings" ;
    effortless-ntwf:domainQuestion "Can the DAG reconstruct each treatment's pooled rate purely from stratum weights × stratum rates? If PooledRateFromWeights = PooledRate, the mechanism equation is verified: Simpson's Paradox is algebraically explained." ;
    effortless-ntwf:mockDataNote "kidney-1986: PooledRateFromWeightsA=0.833, PooledRateFromWeightsB=0.779 (A looks better under equal study-level weights). But actual pooled rates are A=0.780, B=0.826 (B looks better). The divergence IS the mechanism: real pooled uses treatment-level allocation weights; the reconstruction uses study-level weights. The swap between the two orderings shows exactly how differential allocation flips the conclusion. balanced-synthetic: weights match exactly (equal allocation = no flip possible)." ;
    effortless-ntwf:nextSuggestion "Add AllocationBias to StratumSummaries: the difference between TreatmentExposureFraction for A and B in each stratum. High bias toward the losing treatment in a low-success stratum IS the confounder's fingerprint as a witnessed number." .

effortless-ntwf:loop-13 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-13" ;
    effortless-ntwf:title "AllocationBias: the confounder's fingerprint as a signed witnessed number" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "AllocationBias on StratumSummaries (AllocationFractionA - AllocationFractionB); also AllocationFractionA, AllocationFractionB, TreatmentACasesHere, TreatmentBCasesHere, TreatmentATotalCases, TreatmentBTotalCases" ;
    effortless-ntwf:domainQuestion "In each stratum, is one treatment disproportionately concentrated here? AllocationBias = AllocationFractionA - AllocationFractionB: positive means A is over-represented here, negative means B is. A strong negative bias in a low-success stratum is the confounder's fingerprint." ;
    effortless-ntwf:mockDataNote "kidney-1986 large-stratum: AllocationFractionA=263/350=0.751, AllocationFractionB=80/350=0.229, AllocationBias=+0.523. A is massively over-allocated to the hard (large-stone) stratum. This single number summarizes why the pooled rate misleads: A carries 52pp more exposure to the hard case, dragging its pooled average down below B's despite beating B in both strata." ;
    effortless-ntwf:nextSuggestion "Add a 4th study: kidney-balanced — same stratum rates as kidney-1986 but with equal allocation (50/50 split). AllocationBias=0 everywhere, IsReversal=FALSE. The counterfactual shows the reversal is purely an allocation artifact, not a property of the treatment rates themselves." .

effortless-ntwf:loop-14 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-14" ;
    effortless-ntwf:title "Counterfactual: kidney-balanced isolates allocation as the sole cause of the reversal" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "Fourth study (kidney-balanced): same stratum rates as kidney-1986, equal allocation (175 cases per cell). IsReversal=FALSE, AllocationBias=0, ParadoxStrength=0." ;
    effortless-ntwf:domainQuestion "If the same doctors, same disease, same treatments, same stratum difficulty — but patients were allocated equally — would the paradox still exist? The DAG answers: no. The reversal lives in the allocation, not in the treatment rates." ;
    effortless-ntwf:mockDataNote "kidney-balanced: PooledRateA = (163+128)/350 = 0.831, PooledRateB = (152+120)/350 = 0.777. A wins pooled AND per-stratum. IsReversal=FALSE, ParadoxStrength=0. AllocationBias=0 in both strata. The counterfactual witnesses that the reversal in kidney-1986 is entirely an artifact of differential allocation, not of treatment efficacy." ;
    effortless-ntwf:nextSuggestion "Add ReversalThreshold to TreatmentRankings: the minimum AllocationBias magnitude needed to flip the pooled winner. How far is kidney-1986 from the threshold? How close is berkeley-1973? This quantifies paradox fragility vs robustness." .

effortless-ntwf:loop-15 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-15" ;
    effortless-ntwf:title "ReversalThreshold: how robust or fragile is each study's paradox?" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "MaxAllocationBias, WeightedStratumGapSum, ThresholdMargin on TreatmentRankings" ;
    effortless-ntwf:domainQuestion "How much allocation bias is needed to produce a reversal? Is the observed bias well above threshold (robust paradox) or barely over it (fragile paradox)? ThresholdMargin = observed bias minus minimum needed." ;
    effortless-ntwf:mockDataNote "kidney-1986: ReversalIntensity=1.0, ThresholdMargin=+0.5 — maximally robust, every stratum opposes pooled. berkeley-1973: ReversalIntensity=0.75, ThresholdMargin=+0.25 — past threshold but not unanimous (3/4 departments oppose). balanced-synthetic and kidney-balanced: intensity=0, margin=-0.5 — structurally impossible. ThresholdMargin > 0 means the paradox is robust; < 0 means absent or impossible." ;
    effortless-ntwf:nextSuggestion "Pour a real-world dataset with a known mediator (not confounder) through the same DAG and witness where it lands on the reversal_intensity × paradox_strength plane. The geometry of the plane is the next frontier." .

effortless-ntwf:loop-16 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-16" ;
    effortless-ntwf:title "StratumGap: per-stratum rate difference as a signed witnessed number" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "StratumGap field on StratumSummaries (StratumRateA - StratumRateB, signed)" ;
    effortless-ntwf:domainQuestion "In each stratum, how large is the treatment advantage, and in which direction? StratumGap > 0 means A wins here; < 0 means B wins. Summing StratumGap × StratumFraction gives the equal-weight pooled gap — a new derived node." ;
    effortless-ntwf:mockDataNote "kidney-1986: small-stratum gap = +0.064 (A wins by 6.4pp), large-stratum gap = +0.043 (A wins by 4.3pp). Both positive — A wins everywhere. The pooled gap is negative (B appears to win by 4.6pp) purely due to allocation. The signed gap makes this contradiction arithmetically visible in one column. kidney-balanced: small=+0.064, large=+0.042 (same signs, same magnitudes — the rates are identical to kidney-1986 but now A also wins pooled because allocation is balanced). balanced-synthetic: small=+0.10, large=+0.10 (constant, equal allocation). berkeley-1973: dept-A=−0.200 (female wins), dept-B=+0.011 (male wins barely), dept-C=−0.002 (female wins barely), dept-D=−0.016 (female wins). Mixed signs confirm the partial paradox: no unanimous StratumGap direction, hence no clean reversal." ;
    effortless-ntwf:nextSuggestion "Derive WeightedStratumGapSum on TreatmentRankings: SUM(StratumGap × StratumFraction) aggregated across all TreatmentA rows for this study. This is the equal-weight pooled gap — the gap allocation-free weighting would produce. When WeightedStratumGapSum and PooledGap have opposite signs, the allocation has not just compressed the signal but flipped it. That sign flip is a more precise characterisation of Simpson's Paradox than IsReversal: it handles partial flips and gives a magnitude to the distortion." .

effortless-ntwf:loop-17 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-17" ;
    effortless-ntwf:title "WeightedStratumGapSum: the equal-weight signal — and the Berkeley category error witnessed" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "WeightedStratumGap on StratumSummaries (StratumGap × StratumFraction, the per-stratum contribution to the equal-weight pooled gap); WeightedStratumGapSum on TreatmentRankings (SUMIFS of WeightedStratumGap across TreatmentA rows); SignedPooledGap (PooledRateA − PooledRateB, signed); IsSignFlip boolean (WeightedStratumGapSum and SignedPooledGap have opposite signs)" ;
    effortless-ntwf:domainQuestion "If allocation were equal across strata, what would the pooled gap be? WeightedStratumGapSum answers this. When it has the opposite sign to SignedPooledGap, the allocation has not just compressed the signal — it has flipped it. That sign flip IS Simpson's Paradox under a continuous definition. Does Berkeley sign-flip?" ;
    effortless-ntwf:mockDataNote "Witnessed from DB: balanced-synthetic: WSGSUM=+0.1000, SignedPooledGap=+0.1000 → IsSignFlip=FALSE (equal allocation, no distortion). kidney-1986: WSGSUM=+0.0537, SignedPooledGap=−0.0457 → IsSignFlip=TRUE (A wins in every stratum by 5.4pp on average, but actual pooled shows B winning by 4.6pp). kidney-balanced: WSGSUM=+0.0543, SignedPooledGap=+0.0543 → IsSignFlip=FALSE (equal allocation, WSGSUM = actual pooled gap). berkeley-1973: WSGSUM=−0.0642, SignedPooledGap=+0.1292 → IsSignFlip=TRUE. Per-stratum breakdown: dept-A gap=−0.2035 (female wins by 20.4pp, fraction=0.289); dept-B=−0.0496 (female wins, fraction=0.181); dept-C=+0.0286 (male wins barely, fraction=0.284); dept-D=−0.0184 (female wins, fraction=0.245). Under equal allocation female would win pooled by 6.4pp — but the actual pooled shows male winning by 12.9pp. Berkeley IS a Simpson's Paradox under the sign-flip definition despite IsReversal=FALSE. The binary unanimity criterion excluded Berkeley because dept-C goes to male; the sign-flip criterion correctly includes it." ;
    effortless-ntwf:nextSuggestion "The sign flip is witnessed. Now measure the magnitude: how far has the allocation bent the pooled signal? AllocationDistortion = |WeightedStratumGapSum − SignedPooledGap|. Berkeley: |−0.0642 − (+0.1292)| = 0.1934. Kidney: |+0.0537 − (−0.0457)| = 0.0994. Berkeley's distortion is nearly twice kidney's — despite IsReversal=FALSE. This is the single-number measure that ranks studies by how badly confounding has distorted their pooled result." .

effortless-ntwf:loop-18 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-18" ;
    effortless-ntwf:title "AllocationDistortion: the magnitude of the signal the allocation erased or fabricated" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "AllocationDistortion on TreatmentRankings (|WeightedStratumGapSum − SignedPooledGap|) — the scalar distance between the equal-weight signal and the actual pooled signal" ;
    effortless-ntwf:domainQuestion "How much has the allocation distorted the pooled signal relative to what equal-weight strata would show? AllocationDistortion=0 means the allocation is neutral. A large AllocationDistortion means the pooled number is mostly noise from case assignment, not signal about treatment efficacy." ;
    effortless-ntwf:mockDataNote "Witnessed from DB (ordered by AllocationDistortion desc): berkeley-1973: WSGSUM=−0.0642, SignedPooledGap=+0.1292, AllocationDistortion=0.1934. kidney-1986: WSGSUM=+0.0537, SignedPooledGap=−0.0457, AllocationDistortion=0.0994. kidney-balanced: AllocationDistortion=0.0000 (balanced allocation, no distortion). balanced-synthetic: AllocationDistortion=0.0000 (equal allocation, no distortion). The allocation is injecting a 19.3pp distortion into Berkeley's pooled result — reversing a real female advantage of 6.4pp into an apparent male advantage of 12.9pp. This is nearly twice the 9.9pp distortion in kidney-1986. ParadoxStrength (old measure) gives berkeley=0.0969, kidney=0.0457 — same ordinal ranking but ParadoxStrength is penalized by the unanimity criterion: Berkeley's 0.75 ReversalIntensity reduces its score. AllocationDistortion is not so penalized: it measures what the allocation DID to the signal, not whether the outcome passes an arbitrary threshold." ;
    effortless-ntwf:nextSuggestion "Two severity measures are now live: ParadoxStrength and AllocationDistortion. They agree on ordinal ranking across our four studies but diverge in magnitude (Berkeley is 2× kidney under AllocationDistortion but only 2.1× under ParadoxStrength). The more important question: is a study with AllocationDistortion > 0 but IsSignFlip=FALSE possible? That would be a type-C study — allocation has compressed but not reversed the signal. None of the current studies are type-C. Design a synthetic type-C study: same-sign WSGSUM and SignedPooledGap, but WSGSUM closer to zero than SignedPooledGap. Add it to the data and witness AllocationDistortion > 0, IsSignFlip=FALSE." .

effortless-ntwf:loop-19 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-19" ;
    effortless-ntwf:title "Type-C witness: compressed-synthetic — allocation distortion without sign flip" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "compressed-synthetic study (fifth study): type-C case — A wins every stratum and wins pooled, but allocation compresses A's pooled advantage. Witnesses AllocationDistortion > 0, IsSignFlip=FALSE, IsReversal=FALSE, PerStratumWinner=A. Completes the four-type taxonomy." ;
    effortless-ntwf:domainQuestion "Does a study with real allocation distortion (AllocationDistortion > 0) but no sign flip (IsSignFlip=FALSE) exist? If yes, the type-C cell in the DistortionType taxonomy is nonempty — there is a class of misleading aggregates that compress but do not reverse the pooled signal. This class is invisible to both IsReversal and IsSignFlip but is visible to AllocationDistortion." ;
    effortless-ntwf:mockDataNote "Witnessed from DB (ordered by AllocationDistortion desc): berkeley-1973: WSGSUM=−0.0642, SignedPooledGap=+0.1292, IsSignFlip=TRUE, AllocationDistortion=0.1934, ReversalIntensity=0.75 → type B. kidney-1986: WSGSUM=+0.0537, SignedPooledGap=−0.0457, IsSignFlip=TRUE, AllocationDistortion=0.0994, ReversalIntensity=1.0 → type A. compressed-synthetic: WSGSUM=+0.1000, SignedPooledGap=+0.0600, IsSignFlip=FALSE, AllocationDistortion=0.0400, ReversalIntensity=0.0 → type C (A wins pooled by 6pp but would win by 10pp under equal allocation). kidney-balanced: AllocationDistortion=0.0000 → type D. balanced-synthetic: AllocationDistortion=0.0000 → type D. All four types are now empirically populated. Type-C is important: a researcher seeing pooled A=78%, B=72% and concluding 'A wins by 6pp' is correct — but the equal-weight truth is 'A wins by 10pp.' The allocation has consumed 4pp of signal without a single stratum switching winner." ;
    effortless-ntwf:nextSuggestion "All four DistortionType cells are now populated. Add DistortionType as a derived field on TreatmentRankings: A = IsSignFlip AND ReversalIntensity=1.0; B = IsSignFlip AND ReversalIntensity<1.0; C = NOT IsSignFlip AND AllocationDistortion>0.01; D = AllocationDistortion≤0.01. This makes the geometric taxonomy a first-class derived fact in the DAG. Then add PolicyImplication per type: type A = stratify-immediately; type B = investigate-confounder; type C = check-allocation-bias; type D = pooled-analysis-trustworthy." .

effortless-ntwf:loop-20 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-20" ;
    effortless-ntwf:title "Hydration contract: real study data enters through 05b-customize-data.sql, not the rulebook JSON" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "Real study data lives directly in the rulebook JSON — the SSoT is unified. Provenance files in data/raw/. The view chain computes everything from there." ;
    effortless-ntwf:domainQuestion "Can real published study data enter the instrument through a SQL hydration file (not the rulebook JSON) and produce DistortionType / AllocationDistortion / PolicyImplication results from the existing view chain without any schema changes?" ;
    effortless-ntwf:mockDataNote "Two real studies hydrated: reintjes-2000 (Epidemiology 2000, N=3519, antibiotic prophylaxis UTI study) and radelet-1981 (Am Soc Rev 1981, N=326, Florida death penalty). Both are type-A full reversals. Witnessed: reintjes AllocationDistortion=0.0516, radelet AllocationDistortion=0.0684. No schema changes were needed. 05b-customize-data.sql is the durable hydration path." ;
    effortless-ntwf:nextSuggestion "ModelSummary currently counts only synthetic studies in its ReversalCount/NonReversalCount. Add DistortionType aggregations (TypeACount, TypeBCount, TypeCCount, TypeDCount, SignFlipCount, AvgAllocationDistortion) so the model's self-portrait reflects all seven studies including the two real ones." .

effortless-ntwf:loop-20b a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-20b" ;
    effortless-ntwf:title "Two real studies witnessed: reintjes-2000 and radelet-1981 — both type-A full reversals from real data in the rulebook" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "Two non-canonical published datasets poured through the hydration contract. Provenance files in data/raw/. Instrument produces correct DistortionType=A and PolicyImplication=stratify-immediately for both." ;
    effortless-ntwf:domainQuestion "Do two real published studies with well-known outcomes (antibiotic prophylaxis UTI reversal; racial death-penalty reversal) produce the expected DistortionType=A when hydrated through the instrument? Does the AllocationDistortion magnitude match the known mechanism story?" ;
    effortless-ntwf:mockDataNote "Witnessed from DB (full table ordered by AllocationDistortion desc): berkeley-1973: type B, distortion=0.1934. kidney-1986: type A, distortion=0.0994. radelet-1981: type A, distortion=0.0684 (REAL). reintjes-2000: type A, distortion=0.0516 (REAL). compressed-synthetic: type C, distortion=0.0400. kidney-balanced: type D, distortion=0.0000. balanced-synthetic: type D, distortion=0.0000. Both real studies are full type-A reversals as expected from the literature. radelet has higher AllocationDistortion (0.0684) than reintjes (0.0516), consistent with the victim-race confound being stronger — black defendants are 62% in the low-sentence black-victim stratum, a more extreme allocation imbalance than reintjes where 87% of prophylaxis patients are in low-incidence hospitals." ;
    effortless-ntwf:nextSuggestion "ModelSummary currently counts only the synthetic study set. Add DistortionType aggregations (TypeACount, TypeBCount, TypeCCount, TypeDCount, SignFlipCount, AvgAllocationDistortion) so the model describes its real empirical coverage, not just the synthetic controls." .

effortless-ntwf:loop-21 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-21" ;
    effortless-ntwf:title "DistortionType + PolicyImplication: the four-type taxonomy as a first-class DAG fact" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "DistortionType (derived field on TreatmentRankings): A = full sign-flip unanimous reversal; B = sign-flip non-unanimous; C = distortion without sign flip; D = neutral. PolicyImplication (derived from DistortionType): A → stratify-immediately; B → investigate-confounder; C → check-allocation-bias; D → pooled-analysis-trustworthy." ;
    effortless-ntwf:domainQuestion "Can the geometric taxonomy (four cells defined by IsSignFlip × ReversalIntensity × AllocationDistortion magnitude) be collapsed into a single derived field that a researcher or policy layer can read without knowing the internal coordinates?" ;
    effortless-ntwf:mockDataNote "All five current studies resolve cleanly: kidney-1986 → type A (stratify-immediately); berkeley-1973 → type B (investigate-confounder); compressed-synthetic → type C (check-allocation-bias); kidney-balanced → type D (pooled-analysis-trustworthy); balanced-synthetic → type D (pooled-analysis-trustworthy). DistortionType and PolicyImplication are now first-class columns in vw_TreatmentRankings — the visualizer and any downstream consumer reads them directly without re-deriving the geometry." ;
    effortless-ntwf:nextSuggestion "ModelSummary currently counts ReversalCount and NonReversalCount using the old IsReversal (unanimity) criterion. Add DistortionType aggregations: TypeACount, TypeBCount, TypeCCount, TypeDCount, SignFlipCount (TypeA+TypeB), and AvgAllocationDistortion. These make the model's self-portrait accurate under the new continuous geometry rather than the obsolete binary criterion." .

effortless-ntwf:loop-22 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-22" ;
    effortless-ntwf:title "ModelSummary DistortionType aggregations: the model's self-portrait updated to the new geometry" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "TypeACount, TypeBCount, TypeCCount, TypeDCount, SignFlipCount, AvgAllocationDistortion on ModelSummary. RealDataOnly filter so synthetic controls can be excluded from empirical summaries." ;
    effortless-ntwf:domainQuestion "Across all studies in this model, what is the DistortionType breakdown? How many sign-flips, what is the average AllocationDistortion? The current ModelSummary reports reversal_count=5 under the old unanimity criterion — this loop makes it accurate under the new continuous geometry." ;
    effortless-ntwf:nextSuggestion "With the model's self-portrait corrected, formally name IsReversal_v2 = IsSignFlip as a first-class field and document that the unanimity IsReversal is now a strict subtype (DistortionType=A only)." .

effortless-ntwf:loop-23 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-23" ;
    effortless-ntwf:title "IsReversal_v2: formally retire the unanimity criterion as the primary definition" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "IsReversal_v2 = IsSignFlip as a named first-class field on TreatmentRankings. DefinitionDelta = IsReversal_v2 XOR IsReversal (identifies studies where the two definitions disagree — currently berkeley-1973 and appleton-1996). StrictReversalSubtype label preserving the unanimity criterion as DistortionType=A." ;
    effortless-ntwf:domainQuestion "Does the sign-flip definition strictly generalize the old unanimity definition across all 10 hydrated studies? Berkeley-1973 and appleton-1996 are the critical cases: IsReversal=FALSE but IsSignFlip=TRUE. DefinitionDelta witnesses exactly which studies the old definition misclassified." ;
    effortless-ntwf:nextSuggestion "Find one real published study that hydrates as DistortionType=C (AllocationDistortion>0, IsSignFlip=FALSE) to prove the type-C cell is not merely a synthetic pathology." .

effortless-ntwf:loop-23b a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-23b" ;
    effortless-ntwf:title "Cleanup: resolve internal tensions introduced by the v2 definition" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "IsParadoxExplained_v2 on TreatmentRankings. ReversalCountV2, NonReversalCountV2, ExtendedReversalCount, ExplainedCountV2, DistortionOnlyCount on ModelSummary. Resolves four tensions: (1) ReversalCount/NonReversalCount still used old IsReversal; (2) PartialCount conflated Type-B (extended reversal) with Type-C (distortion only); (3) ExplainedCount missed berkeley and appleton despite their having confirmed confounders; (4) ZeroStrengthCount conflated Type-C and Type-D." ;
    effortless-ntwf:domainQuestion "With IsReversal_v2 as the primary definition, does the model's self-portrait (ModelSummary) accurately reflect the v2 geometry? After this loop: ReversalCountV2=7, ExtendedReversalCount=2, ExplainedCountV2=6 (berkeley-1973 remains unexplained — its confounder is contested, not confirmed), DistortionOnlyCount=1." ;
    effortless-ntwf:nextSuggestion "Find one real published study that hydrates as DistortionType=C to prove the type-C cell is not merely a synthetic pathology." .

effortless-ntwf:loop-24 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-24" ;
    effortless-ntwf:title "Type-C real-data witness: allocation distortion without sign flip in published data" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "One real published study hydrating as DistortionType=C: pooled winner directionally correct but margin materially compressed or inflated by differential allocation. Entered through the same 05b-customize-data.sql hydration contract as reintjes-2000 and radelet-1981." ;
    effortless-ntwf:domainQuestion "Does the published literature contain studies where AllocationDistortion>0 but IsSignFlip=FALSE? Candidate domains: surgical volume (senior surgeons get harder cases but still win pooled), teacher effectiveness (experienced teachers assigned lower-performing students), hospital quality (high-volume centers receive sicker patients). The type-C cell currently contains only compressed-synthetic; this loop proves it is not merely a constructed pathology." ;
    effortless-ntwf:nextSuggestion "Build a validation set of 5 additional real studies across diverse domains to confirm multi-domain generalization of the four-type taxonomy." .

effortless-ntwf:loop-25 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-25" ;
    effortless-ntwf:title "Validation set: 5 additional real studies confirm multi-domain generalization" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "5 additional real published studies hydrated through 05b-customize-data.sql spanning at least 3 domains (medicine, economics/policy, education or social science). Each produces a witnessed DistortionType and AllocationDistortion. ModelSummary updated to reflect the full empirical set." ;
    effortless-ntwf:domainQuestion "Does the four-type taxonomy classify real studies consistently across domains? Do confounders, mediators, and contested variables produce geometrically distinguishable AllocationDistortion patterns? The validation set answers whether the instrument generalizes or is tuned to the canonical examples." ;
    effortless-ntwf:nextSuggestion "Formalize the instrument specification as a first-class InstrumentSpec table so another researcher can hydrate a new study and classify it without knowledge of the internal DAG." .

effortless-ntwf:loop-26 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-26" ;
    effortless-ntwf:title "Instrument specification: adapter contract, five input fields, four output types" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "InstrumentSpec table: one row per required input field, derived coordinate, classification rule, and adapter contract requirement. Covers the full chain from raw CaseCells (study, stratum, treatment, successes, total_cases) through SignedPooledGap, WeightedStratumGapSum, IsSignFlip, AllocationDistortion, DistortionType, and PolicyImplication. Every row machine-verifiable against the hydrated studies." ;
    effortless-ntwf:domainQuestion "Can the full instrument be stated precisely enough that another researcher or script can hydrate a new study and classify it without access to the internal DAG? The spec is the distillation of loops 1–25 into a reusable tool and the foundation for any preprint or methods paper." ;
    effortless-ntwf:nextSuggestion "The instrument specification is the terminal deliverable. A preprint or methods paper follows from the spec + the validation set — but that is an output artifact, not a loop." .

effortless-ntwf:loop-27 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-27" ;
    effortless-ntwf:title "Reversal Recovery: the corrected treatment signal as a first-class derived fact" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "CorrectedGap (= WeightedStratumGapSum, named with intent), CorrectedWinner, CorrectedVsPooledAgreement on TreatmentRankings. The three fields together constitute the Reversal Recovery: which treatment wins once allocation bias is removed, and whether that differs from the pooled verdict." ;
    effortless-ntwf:domainQuestion "Given the observed allocation distortion, which treatment would a researcher conclude is better if the allocation artifact were corrected? Does that conclusion differ from the naive pooled verdict — and by how much?" ;
    effortless-ntwf:nextSuggestion "Loop 28 could introduce a CorrectedPolicyImplication field that derives the appropriate research action from CorrectedWinner + DistortionType together, superseding the allocation-unaware PolicyImplication for Types A and B studies." .

effortless-ntwf:loop-28 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-28" ;
    effortless-ntwf:title "CorrectedPolicyImplication: allocation-aware action replaces the naive verdict for Types A and B" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "CorrectedPolicyImplication on TreatmentRankings: derives the researcher action from CorrectedWinner + DistortionType together. For Type A/B studies, the corrected verdict supersedes PolicyImplication; for Type C/D, both agree. Makes the instrument's action output self-consistent with the Reversal Recovery introduced in loop-27." ;
    effortless-ntwf:domainQuestion "When the corrected winner differs from the pooled winner, what should a researcher do — and does the instrument tell them clearly, or does it give two contradictory action fields?" ;
    effortless-ntwf:nextSuggestion "Loop 29 must audit every derived formula for internal consistency: balanced allocation ⇒ AllocationDistortion=0; Type D ⇒ CorrectedVsPooledAgreement=TRUE; Type A ⇒ CorrectedVsPooledAgreement=FALSE. These are not empirical claims — they are algebraic invariants. Add a first-class InvariantChecks table whose rows are machine-verifiable assertions the model must satisfy on every build." .

effortless-ntwf:loop-29 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-29" ;
    effortless-ntwf:title "InvariantChecks: algebraic self-consistency as first-class witnessed assertions" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "InvariantChecks table: one row per algebraic invariant (balanced allocation → AllocationDistortion=0; Type D → CorrectedVsPooledAgreement=TRUE; IsSignFlip → CorrectedWinner≠PooledWinner; WeightedStratumGapSum = Σ(StratumFraction×StratumGap); etc.). Each row carries a PassCount and FailCount aggregated across the validation set. Any FailCount>0 is a build-breaking bug, not a data anomaly." ;
    effortless-ntwf:domainQuestion "Is the model algebraically self-consistent across all 16 studies? Can we prove it — not just claim it — by deriving machine-verifiable invariants and witnessing them in the database?" ;
    effortless-ntwf:nextSuggestion "Loop 33 must lock the hydration and provenance story to a single canonical account. Real data enters via one path (rulebook JSON as SSoT; 05b-customize-data.sql is a build artifact). Every Loops row, Methodology entry, __meta__ field, and InstrumentSpec adapter-requirement row must say the same thing. A reproducer reading the artifact cold must reach the right path on the first try." .

effortless-ntwf:loop-30 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-30" ;
    effortless-ntwf:title "Causality Boundary Layer: separate geometric distortion from causal interpretation" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "CausalClaimStatus (established | contested | geometric-only) and AdjustmentAppropriate (boolean with rationale) on TreatmentRankings. ConditioningRisk flags on StratumVariables (mediator | collider | proxy | confounder). Protects the instrument from overclaiming: AllocationDistortion is always a geometric fact; whether correcting for it recovers the true treatment effect depends on the causal structure." ;
    effortless-ntwf:domainQuestion "When is CorrectedGap the right estimate to report, and when is it still wrong? Does adjusting for a mediator or collider make things worse? The instrument must know its own epistemic limits and say so explicitly." ;
    effortless-ntwf:nextSuggestion "After loop-33 the instrument is publishable as a methods paper: allocation-aware action guidance (loop-28), algebraic self-consistency (loop-29), clean provenance (loop-30), structural integrity + honest weighting (loop-31), cherry-picking defense (loop-32), and causality honesty (loop-33). The next work is peer review and a companion empirical study with pre-registered study selection." .

effortless-ntwf:loop-31 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-31" ;
    effortless-ntwf:title "Provenance Contract: one canonical source-of-truth story, zero contradictory docstrings" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "ProvenanceAudit: a sweep of every Loops row, Methodology entry, __meta__ field, InstrumentSpec adapter-requirement, and 05b header comment for contradictions about where real data lives and how a reproducer seeds a new study. All resolved to a single canonical account. No loop row may claim a different hydration path than another." ;
    effortless-ntwf:domainQuestion "If a researcher reads only the artifact — no prior context, no conversation — do they arrive at the correct seeding procedure? Or do some docstrings point to SQL, some to JSON, and some to neither?" ;
    effortless-ntwf:nextSuggestion "Loop 33 must complete structural integrity: every study has exactly 2 treatment rows, every stratum has exactly one A-cell and one B-cell, every TreatmentRanking FK resolves to a valid Study. Missing rows flagged and added; orphaned rows identified and removed. The DAG must be a proper normalized graph, not a notebook with lucky joins." .

effortless-ntwf:loop-32 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-32" ;
    effortless-ntwf:title "Structural Integrity + Sample-Size Weighting: a proper normalized DAG and epistemically honest ModelSummary" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "RelationshipIntegrityValidator: assertions that every study has ≥2 strata, exactly 2 treatment labels, paired A/B cells per stratum, and every FK resolves. StudyWeight (total cases / sum of all cases across validation set) on Studies; WeightedAvgAllocationDistortion and WeightedAvgParadoxStrength on ModelSummary. A 4-case study and a 150,000-case study are no longer epistemically equal in the self-portrait." ;
    effortless-ntwf:domainQuestion "Is the model a proper normalized DAG with no missing links? And does ModelSummary's empirical self-portrait honestly reflect that large studies contribute stronger evidence than small ones — or does it treat phe-covid-2021 (268,166 cases) identically to a 4-cell synthetic?" ;
    effortless-ntwf:nextSuggestion "Loop 33 must define the validation protocol — inclusion/exclusion criteria and minimum cell counts — so the empirical generalization claim is not vulnerable to a cherry-picking objection. Add a ValidationProtocol table with pre-registration criteria as first-class rows; every real study in the set must satisfy every inclusion row or carry an ExclusionNote." .

effortless-ntwf:loop-33 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-33" ;
    effortless-ntwf:title "Validation Protocol: inclusion/exclusion criteria and cherry-picking defense" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "ValidationProtocol table: one row per inclusion/exclusion criterion (minimum cell count ≥ 10 per cell; binary treatment; outcome direction pre-registered; stratum variable named before classification; no post-hoc stratum splitting). Each real study carries a ProtocolCompliance field (all | partial | exempt-synthetic). Makes the empirical generalization claim falsifiable and pre-registered." ;
    effortless-ntwf:domainQuestion "Could a reviewer accuse the validation set of being hand-picked to make the instrument look good? What protocol discipline removes that objection and makes the 16-study classification reproducible by an independent researcher?" ;
    effortless-ntwf:nextSuggestion "Loop 30 must add the causality boundary layer — explicitly separate what the geometry says (AllocationDistortion, CorrectedGap) from what the causal interpretation claims (IsConfounder, CausalRole). Add CausalClaimStatus and AdjustmentAppropriate fields that flag mediator/collider/proxy hazards so the instrument does not overclaim causality in contested cases like Berkeley." .

# === Individuals: Methodology ===

effortless-ntwf:method-01-cmcc a effortless-ntwf:Methodology ;
    effortless-ntwf:methodologyId "method-01-cmcc" ;
    effortless-ntwf:phase "axiom" ;
    effortless-ntwf:title "CMCC: any sufficiently crisp conceptual world decomposes into a DAG of S/D/L/A/F primitives" ;
    effortless-ntwf:statement "The Conceptual Model Conjecture (CMCC) holds that every domain can be decomposed into Schema, Data, Lookups, Aggregations, and Functions arranged as a directed acyclic graph. Each node is locally simple; complexity emerges from composition, not from any single node. This is the working assumption for the entire model, not a hypothesis to relitigate each turn." ;
    effortless-ntwf:whyItMatters "If CMCC holds, the paradox can be derived rather than modeled. The model does not need a 'ReversalDetection' entity — it just needs the right leaf data and the right DAG edges. The paradox falls out as a consequence." ;
    effortless-ntwf:illustratedByLoop "loop-01" .

effortless-ntwf:method-02-dag-first a effortless-ntwf:Methodology ;
    effortless-ntwf:methodologyId "method-02-dag-first" ;
    effortless-ntwf:phase "decomposition" ;
    effortless-ntwf:title "Model the domain entities first; derived facts emerge from the DAG" ;
    effortless-ntwf:statement "Start with the empirical leaf data: Cases and Successes in each (Study, Stratum, Treatment) cell. Never model the phenomenon of interest (the paradox) directly. The paradox is a derived fact — it emerges when you ask the right questions of a correctly-shaped DAG." ;
    effortless-ntwf:whyItMatters "Modeling the paradox directly (e.g. a 'ReversalDetection' table) would conflate the phenomenon with the domain. The domain is Studies, Treatments, Strata, and CaseCells. The paradox is a read on that domain." ;
    effortless-ntwf:illustratedByLoop "loop-01, loop-04" .

effortless-ntwf:method-03-leopold-loops a effortless-ntwf:Methodology ;
    effortless-ntwf:methodologyId "method-03-leopold-loops" ;
    effortless-ntwf:phase "decomposition" ;
    effortless-ntwf:title "Build the model incrementally via Leopold Loops — one new concept per loop" ;
    effortless-ntwf:statement "Each loop introduces exactly one new first-class concept and asks the natural-language question that concept answers. The loop ends when the new derived fact is witnessed in the database. Loop N's NextSuggestion seeds Loop N+1." ;
    effortless-ntwf:whyItMatters "Introducing multiple concepts per loop makes it hard to witness whether each concept earns its place. One concept per loop forces the question: 'what new thing can I now ask that I couldn't before?'" ;
    effortless-ntwf:illustratedByLoop "loop-01, loop-02, loop-03, loop-04, loop-05" .

effortless-ntwf:method-04-witness-not-claim a effortless-ntwf:Methodology ;
    effortless-ntwf:methodologyId "method-04-witness-not-claim" ;
    effortless-ntwf:phase "derivation" ;
    effortless-ntwf:title "Every derived fact must be witnessed from the database, not claimed from the rulebook" ;
    effortless-ntwf:statement "A field is not 'done' when it is added to the rulebook. It is done when a Postgres query returns the expected value for the seeded data. MockDataNote in each Loop row states what value is expected and from which study. If the DB returns a different value, the formula or the seed data is wrong." ;
    effortless-ntwf:whyItMatters "Without witnessing, silent fallbacks and mistranslations accumulate invisibly. The rulebook says CellSuccessRate = Successes/Cases; the DB must actually return 0.931 for kidney small-A." ;
    effortless-ntwf:illustratedByLoop "loop-01, loop-06, loop-12, loop-17" .

effortless-ntwf:method-05-synthetic-controls a effortless-ntwf:Methodology ;
    effortless-ntwf:methodologyId "method-05-synthetic-controls" ;
    effortless-ntwf:phase "validation" ;
    effortless-ntwf:title "Introduce synthetic control studies to test structural impossibility" ;
    effortless-ntwf:statement "For every interesting derived boolean (IsReversal, IsSignFlip), add at least one synthetic study where the boolean MUST be false by construction. Witnessing the false case in the DB proves the derivation is not vacuously true." ;
    effortless-ntwf:whyItMatters "Without a structural-impossibility witness, a bug in the formula that always returns TRUE would pass all the positive tests. The balanced-synthetic and kidney-balanced studies exist solely to witness IsReversal=FALSE and AllocationDistortion=0." ;
    effortless-ntwf:illustratedByLoop "loop-07, loop-14" .

effortless-ntwf:method-06-real-data-hydration a effortless-ntwf:Methodology ;
    effortless-ntwf:methodologyId "method-06-real-data-hydration" ;
    effortless-ntwf:phase "hydration" ;
    effortless-ntwf:title "Real study data lives in the rulebook JSON — the SSoT is unified" ;
    effortless-ntwf:statement "The rulebook JSON is the single source of truth for both schema and instance data. Real published study counts (Successes, Cases per cell) live directly in each table's data array alongside the synthetic studies. Provenance for each real study is recorded in data/raw/<study-id>/provenance.md. The view chain computes every derived field from the rulebook without any separate hydration step." ;
    effortless-ntwf:whyItMatters "Keeping schema and instance data together in one document makes the instrument self-contained and auditable. The rulebook JSON can be shared, forked, or loaded without a separate SQL hydration step. The schema still defines derivations; the data rows supply the raw inputs." ;
    effortless-ntwf:illustratedByLoop "loop-01, loop-20, loop-20b" .

effortless-ntwf:method-07-continuous-geometry a effortless-ntwf:Methodology ;
    effortless-ntwf:methodologyId "method-07-continuous-geometry" ;
    effortless-ntwf:phase "taxonomy" ;
    effortless-ntwf:title "Replace binary reversal criterion with continuous geometry: IsSignFlip + AllocationDistortion" ;
    effortless-ntwf:statement "The original IsReversal (unanimous per-stratum winner disagrees with pooled winner) is a binary that excludes partial reversals. The sign-flip definition (WeightedStratumGapSum and SignedPooledGap have opposite signs) captures the full continuum. AllocationDistortion = |WSGSUM − SignedPooledGap| is the scalar severity regardless of direction." ;
    effortless-ntwf:whyItMatters "Berkeley 1973 fails the unanimity criterion (dept-C gives male a marginal win) but IS a Simpson-type paradox under the continuous definition. Excluding Berkeley from the analysis would be a category error." ;
    effortless-ntwf:illustratedByLoop "loop-17, loop-18" .

effortless-ntwf:method-08-four-type-taxonomy a effortless-ntwf:Methodology ;
    effortless-ntwf:methodologyId "method-08-four-type-taxonomy" ;
    effortless-ntwf:phase "taxonomy" ;
    effortless-ntwf:title "Classify studies into four types (A/B/C/D) by distortion geometry, independent of causal label" ;
    effortless-ntwf:statement "Type A = IsSignFlip AND ReversalIntensity=1.0 (full unanimous reversal). Type B = IsSignFlip AND ReversalIntensity<1.0 (partial sign-flip). Type C = NOT IsSignFlip AND AllocationDistortion>threshold (compression without flip). Type D = AllocationDistortion≈0 (neutral). The geometry is computed from allocation and rates alone — no causal story is required." ;
    effortless-ntwf:whyItMatters "The taxonomy makes PolicyImplication derivable. A researcher reading DistortionType=A knows to stratify immediately without needing to know what caused the allocation imbalance." ;
    effortless-ntwf:illustratedByLoop "loop-19, loop-21" .

effortless-ntwf:method-09-model-self-portrait a effortless-ntwf:Methodology ;
    effortless-ntwf:methodologyId "method-09-model-self-portrait" ;
    effortless-ntwf:phase "conclusion" ;
    effortless-ntwf:title "The model witnesses its own epistemic coverage via ModelSummary" ;
    effortless-ntwf:statement "ModelSummary is a single-row table that aggregates ReversalCount, ExplainedCount, TypeACount, TypeBCount, TypeCCount, TypeDCount, and AvgAllocationDistortion across all studies. It is the model's self-portrait — a derived fact about the model's own completeness." ;
    effortless-ntwf:whyItMatters "Without ModelSummary, you can query any individual study but cannot ask 'how many studies does this instrument explain?' The self-portrait is the epistemic coverage claim." ;
    effortless-ntwf:illustratedByLoop "loop-10" .

effortless-ntwf:method-10-policy-from-geometry a effortless-ntwf:Methodology ;
    effortless-ntwf:methodologyId "method-10-policy-from-geometry" ;
    effortless-ntwf:phase "conclusion" ;
    effortless-ntwf:title "Policy implication is derived from geometry, not asserted from domain knowledge" ;
    effortless-ntwf:statement "PolicyImplication is a calculated field derived from DistortionType. No domain-specific knowledge about medicine, law, or education is encoded. The instrument tells a researcher what to do next with the pooled conclusion (stratify, investigate, check bias, or trust) purely from the allocation geometry." ;
    effortless-ntwf:whyItMatters "Domain-neutral policy derivation means the instrument generalizes across clinical, judicial, educational, and other settings without re-tuning. The same formula works for kidney stones, Berkeley admissions, and antibiotic prophylaxis." ;
    effortless-ntwf:illustratedByLoop "loop-21, loop-26" .

# === Individuals: ModelSummary ===

effortless-ntwf:simpsons-paradox-v1 a effortless-ntwf:ModelSummary ;
    effortless-ntwf:modelSummaryId "simpsons-paradox-v1" .

