    effortless-ntwf:algebraicStatement "IsSignFlip=TRUE → CorrectedVsPooledAgreement=FALSE" ;
    effortless-ntwf:naturalLanguage "When pooled and equal-weight signals point in opposite directions (IsSignFlip), the corrected winner must differ from the pooled winner." ;
