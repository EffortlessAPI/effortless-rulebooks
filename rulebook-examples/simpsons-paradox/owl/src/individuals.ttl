    effortless-ntwf:treatmentRankingId "coffee-tverdal-2020-A-vs-B" ;
    effortless-ntwf:study effortless-ntwf:coffee-tverdal-2020 ;
    effortless-ntwf:treatmentA "A" ;
    effortless-ntwf:treatmentB "B" ;
    effortless-ntwf:adjustmentRationale "Smoking is a confirmed confounder (affects both coffee consumption patterns and cardiovascular outcomes). Adjustment appropriate." .

effortless-ntwf:sat-wainer-1986-A-vs-B a effortless-ntwf:TreatmentRankings ;
    effortless-ntwf:treatmentRankingId "sat-wainer-1986-A-vs-B" ;
    effortless-ntwf:study effortless-ntwf:sat-wainer-1986 ;
    effortless-ntwf:treatmentA "A" ;
    effortless-ntwf:treatmentB "B" ;
    effortless-ntwf:adjustmentRationale "School spending is a proxy for underlying socioeconomic status (SES), which is the true confounder. Conditioning on a noisy proxy only partially removes confounding. Adjustment is directionally appropriate but should be interpreted cautiously — residual confounding by unmeasured SES components is likely." .

