# === Individuals: TreatmentRankings ===

effortless-ntwf:kidney-1986-A-vs-B a effortless-ntwf:TreatmentRankings ;
    effortless-ntwf:treatmentRankingId "kidney-1986-A-vs-B" ;
    effortless-ntwf:study effortless-ntwf:kidney-1986 ;
    effortless-ntwf:treatmentA "A" ;
    effortless-ntwf:treatmentB "B" ;
    effortless-ntwf:adjustmentRationale "Stone size is a confirmed confounder (affects both assignment and outcome via baseline severity). Conditioning recovers the true per-stratum treatment effect." .

effortless-ntwf:kidney-balanced-A-vs-B a effortless-ntwf:TreatmentRankings ;
    effortless-ntwf:treatmentRankingId "kidney-balanced-A-vs-B" ;
    effortless-ntwf:study effortless-ntwf:kidney-balanced ;
    effortless-ntwf:treatmentA "A" ;
    effortless-ntwf:treatmentB "B" ;
    effortless-ntwf:adjustmentRationale "Balanced allocation; stone size is a confounder but allocation distortion is negligible (Type D). CorrectedGap = SignedPooledGap. Adjustment appropriate but immaterial." .

effortless-ntwf:balanced-synthetic-A-vs-B a effortless-ntwf:TreatmentRankings ;
    effortless-ntwf:treatmentRankingId "balanced-synthetic-A-vs-B" ;
    effortless-ntwf:study effortless-ntwf:balanced-synthetic ;
    effortless-ntwf:treatmentA "A" ;
    effortless-ntwf:treatmentB "B" ;
    effortless-ntwf:adjustmentRationale "Synthetic study with balanced allocation and unknown causal role. No causal warrant for adjustment — CorrectedGap is a geometric identity here." .

effortless-ntwf:berkeley-1973-A-vs-B a effortless-ntwf:TreatmentRankings ;
    effortless-ntwf:treatmentRankingId "berkeley-1973-A-vs-B" ;
    effortless-ntwf:study effortless-ntwf:berkeley-1973 ;
    effortless-ntwf:treatmentA "A" ;
    effortless-ntwf:treatmentB "B" ;
    effortless-ntwf:adjustmentRationale "Department is a contested stratum variable: applicants self-select departments (endogenous), so department may be a mediator of gender bias rather than a confounder of it. Conditioning on department could block the very discrimination pathway under investigation. Adjustment should not be applied without resolving the causal model." .

effortless-ntwf:compressed-synthetic-A-vs-B a effortless-ntwf:TreatmentRankings ;
    effortless-ntwf:treatmentRankingId "compressed-synthetic-A-vs-B" ;
    effortless-ntwf:study effortless-ntwf:compressed-synthetic ;
    effortless-ntwf:treatmentA "A" ;
    effortless-ntwf:treatmentB "B" ;
    effortless-ntwf:adjustmentRationale "Synthetic study with confirmed confounder structure. CorrectedGap is an appropriate estimate of the equal-weight treatment effect." .

effortless-ntwf:reintjes-2000-A-vs-B a effortless-ntwf:TreatmentRankings ;
    effortless-ntwf:treatmentRankingId "reintjes-2000-A-vs-B" ;
    effortless-ntwf:study effortless-ntwf:reintjes-2000 ;
    effortless-ntwf:treatmentA "A" ;
    effortless-ntwf:treatmentB "B" ;
    effortless-ntwf:adjustmentRationale "Hospital incidence rate is a confirmed confounder (affects both vaccination coverage and cholera outcome via baseline risk). Adjustment appropriate." .

effortless-ntwf:radelet-1981-A-vs-B a effortless-ntwf:TreatmentRankings ;
    effortless-ntwf:treatmentRankingId "radelet-1981-A-vs-B" ;
    effortless-ntwf:study effortless-ntwf:radelet-1981 ;
    effortless-ntwf:treatmentA "A" ;
    effortless-ntwf:treatmentB "B" ;
    effortless-ntwf:adjustmentRationale "Victim race is a confirmed confounder (affects both treatment assignment — prosecutor decisions — and outcome). Adjustment recovers the allocation-free signal." .

effortless-ntwf:jeter-justice-1997-A-vs-B a effortless-ntwf:TreatmentRankings ;
    effortless-ntwf:treatmentRankingId "jeter-justice-1997-A-vs-B" ;
    effortless-ntwf:study effortless-ntwf:jeter-justice-1997 ;
    effortless-ntwf:treatmentA "A" ;
    effortless-ntwf:treatmentB "B" ;
