# === Individuals: ResearchTraditions ===

effortless-ntwf:tradition-historical a effortless-ntwf:ResearchTraditions ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:name "Historical Statistical Origins" ;
    effortless-ntwf:era "1899–1972" ;
    effortless-ntwf:coreConcern "Documenting that aggregate and partial associations can differ or reverse" ;
    effortless-ntwf:primaryVenue "Biometrika; Journal of the Royal Statistical Society" ;
    effortless-ntwf:keyClaim "The reversal is a well-defined mathematical property of weighted averages, not a logical paradox — formalised by Blyth (1972)" ;
    effortless-ntwf:openQuestion "Whether \"disappearing association\" (Pearson/Yule) and \"sign reversal\" (Cohen/Nagel) are the same phenomenon or two distinct effects" ;
    effortless-ntwf:verifiedByDeepResearch true ;
    effortless-ntwf:illustratedByStudy "kidney-1986" ;
    effortless-ntwf:supportingConclusion "conc-01-paradox-is-derived" .

effortless-ntwf:tradition-philosophy a effortless-ntwf:ResearchTraditions ;
    effortless-ntwf:traditionId "tradition-philosophy" ;
    effortless-ntwf:name "Philosophy of Science / Probabilistic Causality" ;
    effortless-ntwf:era "1956–present" ;
    effortless-ntwf:coreConcern "Whether probabilistic associations alone can ground causal claims — the paradox is the stress test" ;
    effortless-ntwf:primaryVenue "Philosophy of Science; Nous; Cambridge studies in probability/induction" ;
    effortless-ntwf:keyClaim "Cartwright (1979): causes must raise probabilities relative to ALL background contexts, not just the aggregate. Statistical accounts of causation fail without this constraint." ;
    effortless-ntwf:openQuestion "Whether the probabilistic causality framework is ultimately reducible to a causal graph account (Pearl) or remains genuinely distinct" ;
    effortless-ntwf:verifiedByDeepResearch true ;
    effortless-ntwf:illustratedByStudy "berkeley-1973" ;
    effortless-ntwf:supportingConclusion "conc-09-causal-vs-geometric" .

effortless-ntwf:tradition-dag a effortless-ntwf:ResearchTraditions ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:name "Causal Graphical / DAG Tradition" ;
    effortless-ntwf:era "1988–present" ;
    effortless-ntwf:coreConcern "Identifying the structural (graph) conditions under which stratification resolves or worsens the paradox" ;
    effortless-ntwf:primaryVenue "JMLR; UAI; Artificial Intelligence; MIT Press books" ;
    effortless-ntwf:keyClaim "The paradox is a confounding problem solvable via the back-door criterion; a DAG over observed variables determines which table (pooled or stratified) is the correct one" ;
    effortless-ntwf:openQuestion "Dong, Cai & Zhao (2024): confounding is not the universal source — inter-unit causation and accidental associations also produce the paradox, so DAG adjustment alone is insufficient" ;
    effortless-ntwf:verifiedByDeepResearch true ;
    effortless-ntwf:illustratedByStudy "birth-weight-paradox" ;
    effortless-ntwf:supportingConclusion "conc-09-causal-vs-geometric" .

effortless-ntwf:tradition-epidemiology a effortless-ntwf:ResearchTraditions ;
    effortless-ntwf:traditionId "tradition-epidemiology" ;
    effortless-ntwf:name "Epidemiology / Observational Studies" ;
    effortless-ntwf:era "1980–present" ;
    effortless-ntwf:coreConcern "Noncollapsibility: when does controlling for a confounder change the measure of association, and when is that change meaningful?" ;
    effortless-ntwf:primaryVenue "Epidemiology; American Journal of Epidemiology; Statistical Science" ;
    effortless-ntwf:keyClaim "Noncollapsibility is not identical to confounding — some measures (OR, HR) are noncollapsible even without confounding. Greenland (2021): distinguishing the two prevents spurious \"paradox\" diagnoses." ;
    effortless-ntwf:openQuestion "Which effect measures (RR, OR, RD) are collapsible under what conditions — an active debate in biostatistics" ;
    effortless-ntwf:verifiedByDeepResearch true ;
    effortless-ntwf:illustratedByStudy "reintjes-2000" ;
    effortless-ntwf:supportingConclusion "conc-05-real-data-generalizes" .

effortless-ntwf:tradition-bayesian a effortless-ntwf:ResearchTraditions ;
    effortless-ntwf:traditionId "tradition-bayesian" ;
    effortless-ntwf:name "Bayesian / Decision-Theoretic" ;
    effortless-ntwf:era "1981–present" ;
    effortless-ntwf:coreConcern "Whether Bayesian model-selection criteria (Bayes factors, posterior predictive) are themselves susceptible to Simpson-type reversals" ;
    effortless-ntwf:primaryVenue "Journal of the Royal Statistical Society Series B; Bayesian Analysis" ;
    effortless-ntwf:keyClaim "Lindley (1997): Bayes factor proponents can simultaneously conclude tall men > tall women AND short men > short women AND women > men overall — a Simpson reversal in posterior odds. The paradox lives inside Bayesian inference, not just frequentist aggregation." ;
    effortless-ntwf:openQuestion "Whether prior specification can fully neutralise the reversal or whether the paradox is structurally unavoidable in hierarchical Bayesian models" ;
    effortless-ntwf:verifiedByDeepResearch true ;
    effortless-ntwf:illustratedByStudy "sat-wainer-1986" ;
    effortless-ntwf:supportingConclusion "conc-01-paradox-is-derived" .

effortless-ntwf:tradition-ai-fairness a effortless-ntwf:ResearchTraditions ;
    effortless-ntwf:traditionId "tradition-ai-fairness" ;
    effortless-ntwf:name "AI Fairness / Machine Learning" ;
    effortless-ntwf:era "2016–present" ;
    effortless-ntwf:coreConcern "Whether group-level fairness metrics are reliable when base rates differ across subgroups — Simpson's Paradox as a structural threat to audit validity" ;
    effortless-ntwf:primaryVenue "FAccT; NeurIPS; Big Data journal; VLDB" ;
    effortless-ntwf:keyClaim "Chouldechova (2017) impossibility theorem: calibration and equal error rates are simultaneously unachievable when prevalence differs across groups. Differing base rates ARE the paradox mechanism in disguise." ;
    effortless-ntwf:openQuestion "Whether the FAccT community explicitly frames its impossibility results as Simpson's Paradox instances or treats base-rate divergence as a distinct phenomenon" ;
    effortless-ntwf:verifiedByDeepResearch true ;
    effortless-ntwf:illustratedByStudy "phe-covid-2021" ;
    effortless-ntwf:supportingConclusion "conc-06-policy-derivable" .

# === Individuals: Researchers ===

effortless-ntwf:researcher-pearson a effortless-ntwf:Researchers ;
    effortless-ntwf:researcherId "researcher-pearson" ;
    effortless-ntwf:name "Karl Pearson" ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:activePeriod "1899" ;
    effortless-ntwf:affiliation "University College London" ;
    effortless-ntwf:keyContribution "First (1899) observed that marginal and partial associations between continuous variables can differ, producing spurious correlations — the pre-Simpson precursor." ;
    effortless-ntwf:signatureWork "Pearson et al. (1899) — early work on genetic inheritance and spurious correlation" ;
    effortless-ntwf:relationToHannanPearl "Predates both; Pearl's DAG tradition explicitly cites Pearson as the origin point of the confusion his framework resolves" ;
    effortless-ntwf:verifiedByDeepResearch true ;
    effortless-ntwf:confidenceLevel "high" ;
    effortless-ntwf:canonicalStudyId "kidney-1986" .

effortless-ntwf:researcher-yule a effortless-ntwf:Researchers ;
    effortless-ntwf:researcherId "researcher-yule" ;
    effortless-ntwf:name "G. Udny Yule" ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:activePeriod "1903" ;
    effortless-ntwf:affiliation "University of Cambridge" ;
    effortless-ntwf:keyContribution "Extended Pearson's observation (1903) to categorical data; the phenomenon is sometimes called the Yule–Simpson effect." ;
    effortless-ntwf:signatureWork "Yule (1903) — Notes on the theory of association of attributes in statistics" ;
    effortless-ntwf:relationToHannanPearl "Provides the categorical-data framing that Hannan's aggregation bias literature builds on; Pearl's back-door criterion addresses exactly what Yule's correlations could not distinguish" ;
    effortless-ntwf:verifiedByDeepResearch true ;
    effortless-ntwf:confidenceLevel "high" ;
    effortless-ntwf:canonicalStudyId "kidney-1986" .

