effortless-ntwf:researcher-blyth a effortless-ntwf:Researchers ;
    effortless-ntwf:researcherId "researcher-blyth" ;
    effortless-ntwf:name "C. R. Blyth" ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:activePeriod "1972" ;
    effortless-ntwf:affiliation "University of Idaho" ;
    effortless-ntwf:keyContribution "Coined the term \"Simpson's Paradox\" (1972), provided the first formal definition, and framed the reversal as a genuine logical paradox rather than a statistical curiosity." ;
    effortless-ntwf:signatureWork "Blyth (1972) — On Simpson's Paradox and the Sure-Thing Principle, JASA" ;
    effortless-ntwf:relationToHannanPearl "Blyth's formal definition is one of three non-equivalent definitions in the literature (Blyth 1972, Mittal 1991, Bandyopadhyay et al. 2011); Pearl's framework dissolves the definitional ambiguity via causal structure" ;
    effortless-ntwf:verifiedByDeepResearch true ;
    effortless-ntwf:confidenceLevel "high" ;
    effortless-ntwf:canonicalStudyId "kidney-1986" ;
    effortless-ntwf:illustratesConclusion "conc-01-paradox-is-derived" .

effortless-ntwf:researcher-reichenbach a effortless-ntwf:Researchers ;
    effortless-ntwf:researcherId "researcher-reichenbach" ;
    effortless-ntwf:name "Hans Reichenbach" ;
    effortless-ntwf:traditionId "tradition-philosophy" ;
    effortless-ntwf:activePeriod "1956" ;
    effortless-ntwf:affiliation "UCLA" ;
    effortless-ntwf:keyContribution "Developed the Common Cause Principle (1956): every statistical correlation has a causal explanation, either direct causation or a common cause. This principle frames the paradox as a symptom of an uncontrolled common cause." ;
    effortless-ntwf:signatureWork "Reichenbach (1956) — The Direction of Time" ;
    effortless-ntwf:relationToHannanPearl "Pearl's backdoor criterion is a formalisation of Reichenbach's common-cause screening-off idea in DAG language" ;
    effortless-ntwf:verifiedByDeepResearch true ;
    effortless-ntwf:confidenceLevel "high" ;
    effortless-ntwf:canonicalStudyId "kidney-1986" ;
    effortless-ntwf:illustratesConclusion "conc-09-causal-vs-geometric" .

effortless-ntwf:researcher-suppes a effortless-ntwf:Researchers ;
    effortless-ntwf:researcherId "researcher-suppes" ;
    effortless-ntwf:name "Patrick Suppes" ;
    effortless-ntwf:traditionId "tradition-philosophy" ;
    effortless-ntwf:activePeriod "1970" ;
    effortless-ntwf:affiliation "Stanford University" ;
    effortless-ntwf:keyContribution "Developed probabilistic causality theory (1970): causes raise the probability of their effects. The paradox shows this is necessary but insufficient — background context must be held fixed." ;
    effortless-ntwf:signatureWork "Suppes (1970) — A Probabilistic Theory of Causality" ;
    effortless-ntwf:relationToHannanPearl "Suppes's framework is the direct predecessor Cartwright critiques and extends; Pearl's do-calculus supersedes probabilistic causality by making interventions explicit" ;
    effortless-ntwf:verifiedByDeepResearch true ;
    effortless-ntwf:confidenceLevel "high" ;
    effortless-ntwf:canonicalStudyId "kidney-1986" ;
    effortless-ntwf:illustratesConclusion "conc-09-causal-vs-geometric" .

effortless-ntwf:researcher-cartwright a effortless-ntwf:Researchers ;
    effortless-ntwf:researcherId "researcher-cartwright" ;
    effortless-ntwf:name "Nancy Cartwright" ;
    effortless-ntwf:traditionId "tradition-philosophy" ;
    effortless-ntwf:activePeriod "1979" ;
    effortless-ntwf:affiliation "Stanford / LSE / UCSD" ;
    effortless-ntwf:keyContribution "Proposed the influential resolution (1979): a cause must raise the probability of its effect in every homogeneous background context, not just in the aggregate. Argued purely statistical accounts of causation fail." ;
    effortless-ntwf:signatureWork "Cartwright (1979) — Causal Laws and Effective Strategies, Nous" ;
    effortless-ntwf:relationToHannanPearl "Cartwright's \"background contexts\" anticipate stratification in Pearl's sense; Pearl acknowledges Cartwright but argues DAGs make the notion precise and computable" ;
    effortless-ntwf:verifiedByDeepResearch true ;
    effortless-ntwf:confidenceLevel "high" ;
    effortless-ntwf:canonicalStudyId "berkeley-1973" ;
    effortless-ntwf:illustratesConclusion "conc-09-causal-vs-geometric" .

