effortless-ntwf:balanced-synthetic-hard a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "balanced-synthetic-hard" ;
    effortless-ntwf:study effortless-ntwf:balanced-synthetic ;
    effortless-ntwf:stratumLabel "hard" ;
    effortless-ntwf:description "Hard stratum — lower baseline success rate. Receives exactly 50% of each treatment's cases. Equal allocation prevents confounding." .

effortless-ntwf:berkeley-1973-dept-A a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "berkeley-1973-dept-A" ;
    effortless-ntwf:study effortless-ntwf:berkeley-1973 ;
    effortless-ntwf:stratumLabel "dept-A" ;
