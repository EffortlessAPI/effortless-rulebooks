effortless-ntwf:near-zero-distortion-boundary-A-vs-B a effortless-ntwf:TreatmentRankings ;
    effortless-ntwf:treatmentRankingId "near-zero-distortion-boundary-A-vs-B" ;
    effortless-ntwf:study effortless-ntwf:near-zero-distortion-boundary ;
    effortless-ntwf:treatmentA "A" ;
    effortless-ntwf:treatmentB "B" ;
    effortless-ntwf:adjustmentRationale "Boundary-probe synthetic: confirms nonzero-but-tiny AllocationDistortion remains far from the sign-flip threshold. CorrectedGap is a valid equal-weight estimate." .

effortless-ntwf:equal-weight-signflip-boundary-A-vs-B a effortless-ntwf:TreatmentRankings ;
    effortless-ntwf:treatmentRankingId "equal-weight-signflip-boundary-A-vs-B" ;
    effortless-ntwf:study effortless-ntwf:equal-weight-signflip-boundary ;
    effortless-ntwf:treatmentA "A" ;
    effortless-ntwf:treatmentB "B" ;
    effortless-ntwf:adjustmentRationale "Boundary-probe synthetic: confirmed confounder with within-stratum allocation skew produces a manifest flip despite stratum sizes being perfectly balanced (0.5/0.5). CorrectedGap is the appropriate equal-weight estimate; use with caution per Type-B." .

effortless-ntwf:zero-corrected-gap-boundary-A-vs-B a effortless-ntwf:TreatmentRankings ;
    effortless-ntwf:treatmentRankingId "zero-corrected-gap-boundary-A-vs-B" ;
    effortless-ntwf:study effortless-ntwf:zero-corrected-gap-boundary ;
    effortless-ntwf:treatmentA "A" ;
    effortless-ntwf:treatmentB "B" ;
    effortless-ntwf:adjustmentRationale "Boundary-probe synthetic: CorrectedGap is exactly 0.0 (a true tie) — the entire observed pooled gap is an allocation artifact. Check allocation bias before trusting the pooled estimate." .

effortless-ntwf:collider-purity-boundary-flip-A-vs-B a effortless-ntwf:TreatmentRankings ;
    effortless-ntwf:treatmentRankingId "collider-purity-boundary-flip-A-vs-B" ;
    effortless-ntwf:study effortless-ntwf:collider-purity-boundary-flip ;
    effortless-ntwf:treatmentA "A" ;
    effortless-ntwf:treatmentB "B" ;
    effortless-ntwf:adjustmentRationale "Adversarial boundary-probe synthetic: highest-purity (0.49994) manifest sign-flip discoverable via 1.2M-trial search, tagged collider to stress conc-30. CorrectedGap should be used with caution — but note the collider causal-role tag means naive stratification adjustment is NOT causally appropriate despite the geometric flip (see AdjustmentAppropriate gating)." .

# === Individuals: Treatments ===

effortless-ntwf:kidney-1986-A a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "kidney-1986-A" ;
    effortless-ntwf:study effortless-ntwf:kidney-1986 ;
    effortless-ntwf:treatmentLabel "A" ;
    effortless-ntwf:description "Open surgery / percutaneous nephrolithotomy (PCNL) — the more invasive procedure, used preferentially for large stones." .

effortless-ntwf:kidney-1986-B a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "kidney-1986-B" ;
    effortless-ntwf:study effortless-ntwf:kidney-1986 ;
    effortless-ntwf:treatmentLabel "B" ;
    effortless-ntwf:description "Extracorporeal shock wave lithotripsy (ESWL) — the less invasive procedure, used more for small stones." .

effortless-ntwf:kidney-balanced-A a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "kidney-balanced-A" ;
    effortless-ntwf:study effortless-ntwf:kidney-balanced ;
    effortless-ntwf:treatmentLabel "A" ;
    effortless-ntwf:description "Open surgery / PCNL — same per-stratum rates as kidney-1986 (small:93.1%, large:73.0%) but now allocated equally (50%) to each stratum. Counterfactual treatment A." .

effortless-ntwf:kidney-balanced-B a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "kidney-balanced-B" ;
    effortless-ntwf:study effortless-ntwf:kidney-balanced ;
    effortless-ntwf:treatmentLabel "B" ;
    effortless-ntwf:description "ESWL — same per-stratum rates as kidney-1986 (small:86.7%, large:68.8%) but allocated equally (50%) to each stratum. Counterfactual treatment B." .

effortless-ntwf:balanced-synthetic-A a effortless-ntwf:Treatments ;
    effortless-ntwf:treatmentId "balanced-synthetic-A" ;
    effortless-ntwf:study effortless-ntwf:balanced-synthetic ;
    effortless-ntwf:treatmentLabel "A" ;
