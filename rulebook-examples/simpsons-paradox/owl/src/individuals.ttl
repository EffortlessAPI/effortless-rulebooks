    effortless-ntwf:loopId "loop-35" ;
    effortless-ntwf:title "Multi-Study AllocationSweep + UI Slider" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:domainQuestion "Does the invariant hold for every distortion type? Can we show the pooled gap wandering and CorrectedGap flat in real time?" ;
