# === Individuals: ConfounderIdentities ===

effortless-ntwf:id-age-composition a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-age-composition" ;
    effortless-ntwf:displayName "Age Composition" ;
    effortless-ntwf:mechanismClass "demographic-composition" ;
    effortless-ntwf:description "Age or cohort stratification shifts treatment exposure and baseline outcome rates independently — classic demographic confounding (CFR by age, trial subgroups, school entry age)." ;
    effortless-ntwf:policyDefault "stratify-by-age" .

effortless-ntwf:id-disease-severity a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-disease-severity" ;
    effortless-ntwf:displayName "Disease Severity / Case Mix" ;
    effortless-ntwf:mechanismClass "severity-case-mix" ;
    effortless-ntwf:description "Illness severity, stage, or case-mix drives both treatment selection and prognosis — dominant in medicine and epidemiology reversals." ;
    effortless-ntwf:policyDefault "stratify-by-severity" .

effortless-ntwf:id-institutional-unit a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-institutional-unit" ;
    effortless-ntwf:displayName "Institutional Unit" ;
    effortless-ntwf:mechanismClass "organizational-unit" ;
    effortless-ntwf:description "School, department, hospital, or center choice correlates with both treatment exposure and outcomes — admissions and quality comparisons." ;
    effortless-ntwf:policyDefault "investigate-unit-choice" .

effortless-ntwf:id-socioeconomic-status a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-socioeconomic-status" ;
    effortless-ntwf:displayName "Socioeconomic Status" ;
    effortless-ntwf:mechanismClass "ses-income" ;
    effortless-ntwf:description "Income, SES, or neighborhood tier confounds pooled comparisons in economics, education, and lending encodes." ;
    effortless-ntwf:policyDefault "stratify-by-ses" .

effortless-ntwf:id-geographic-composition a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-geographic-composition" ;
    effortless-ntwf:displayName "Geographic Composition" ;
    effortless-ntwf:mechanismClass "geography" ;
    effortless-ntwf:description "Country, region, state, or city composition drives aggregate rate differences without per-unit reversal." ;
    effortless-ntwf:policyDefault "stratify-by-geography" .

effortless-ntwf:id-legal-case-context a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-legal-case-context" ;
    effortless-ntwf:displayName "Legal Case Context" ;
    effortless-ntwf:mechanismClass "legal-offense-victim" ;
    effortless-ntwf:description "Offense type, charge severity, victim characteristics, or stage in criminal process — legal/sentencing paradox encodes." ;
    effortless-ntwf:policyDefault "stratify-by-offense-context" .

effortless-ntwf:id-credit-risk-tier a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-credit-risk-tier" ;
    effortless-ntwf:displayName "Credit / Risk Tier" ;
    effortless-ntwf:mechanismClass "lending-risk" ;
    effortless-ntwf:description "Credit score, FICO band, or loan-risk tier — financial lending allocation confounds." ;
    effortless-ntwf:policyDefault "stratify-by-risk-tier" .

effortless-ntwf:id-situational-context a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-situational-context" ;
    effortless-ntwf:displayName "Situational Context" ;
    effortless-ntwf:mechanismClass "sports-situation" ;
    effortless-ntwf:description "Game situation, score state, home/away, surface, or down-and-distance — sports analytics allocation confounds." ;
    effortless-ntwf:policyDefault "stratify-by-situation" .

effortless-ntwf:id-user-platform-segment a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-user-platform-segment" ;
    effortless-ntwf:displayName "User / Platform Segment" ;
    effortless-ntwf:mechanismClass "ab-test-segment" ;
    effortless-ntwf:description "User tenure, device, platform, or experiment segment — online A/B and recsys allocation confounds." ;
    effortless-ntwf:policyDefault "stratify-by-segment" .

effortless-ntwf:id-demographic-group a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-demographic-group" ;
    effortless-ntwf:displayName "Demographic Group" ;
    effortless-ntwf:mechanismClass "race-sex-group" ;
    effortless-ntwf:description "Race, sex, or demographic group base rates — distinct from age composition when not age-stratified." ;
    effortless-ntwf:policyDefault "stratify-by-demographic" .

effortless-ntwf:id-contested-org-choice a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-contested-org-choice" ;
    effortless-ntwf:displayName "Contested Organizational Choice" ;
    effortless-ntwf:mechanismClass "contested-mediator" ;
    effortless-ntwf:description "Department or institution where causal role is disputed (Berkeley) — geometry without adjust-resolvable explanation." ;
    effortless-ntwf:policyDefault "do-not-naively-adjust" .

effortless-ntwf:id-collider-proxy a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-collider-proxy" ;
    effortless-ntwf:displayName "Collider / Conditioning Proxy" ;
    effortless-ntwf:mechanismClass "collider-selection" ;
    effortless-ntwf:description "BMI, birth-weight category, or other collider/selection variables — latent sweep sensitivity without manifest flip." ;
    effortless-ntwf:policyDefault "do-not-condition" .

effortless-ntwf:id-selection-frailty a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-selection-frailty" ;
    effortless-ntwf:displayName "Selection / Frailty" ;
    effortless-ntwf:mechanismClass "healthy-vaccinee" ;
    effortless-ntwf:description "Frailty, employment, abstainer composition, or healthy-vaccinee selection — epidemiology selection bias." ;
    effortless-ntwf:policyDefault "model-selection-explicitly" .

effortless-ntwf:id-treatment-indication a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-treatment-indication" ;
    effortless-ntwf:displayName "Treatment Indication" ;
    effortless-ntwf:mechanismClass "clinical-indication" ;
    effortless-ntwf:description "Baseline risk tier, HbA1c, PD-L1, or indication-for-treatment stratification in trials." ;
    effortless-ntwf:policyDefault "stratify-by-indication" .

effortless-ntwf:id-mechanism-other a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-mechanism-other" ;
    effortless-ntwf:displayName "Other Mechanism" ;
    effortless-ntwf:mechanismClass "other" ;
    effortless-ntwf:description "Catch-all for stratum variables not yet assigned a canonical archetype — pending ontology refinement." ;
    effortless-ntwf:policyDefault "investigate-confounder" .

effortless-ntwf:id-smoking-behavior a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-smoking-behavior" ;
    effortless-ntwf:displayName "Smoking / Substance Behavior" ;
    effortless-ntwf:mechanismClass "behavioral-exposure" ;
    effortless-ntwf:description "Smoking status, drinking pattern, or substance-use history drives outcome differences independent of treatment — behavioral confounder that inverts pooled comparisons." ;
    effortless-ntwf:policyDefault "stratify-by-behavior" .

effortless-ntwf:id-trial-timing-design a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-trial-timing-design" ;
    effortless-ntwf:displayName "Trial Timing / Design Profile" ;
    effortless-ntwf:mechanismClass "design-artifact" ;
    effortless-ntwf:description "Trial allocation profile, treatment timing from symptom onset, study design type, or protocol subgroup definition — design-level strata, not substantive confounders." ;
    effortless-ntwf:policyDefault "stratify-by-protocol-design" .

effortless-ntwf:id-method-specification a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-method-specification" ;
    effortless-ntwf:displayName "Methodological Specification" ;
    effortless-ntwf:mechanismClass "analytic-method" ;
    effortless-ntwf:description "Model specification choice, source study, group base rate, field subarea, or noncollapsible measure — reversals arise from analytic decisions rather than substantive confounding." ;
    effortless-ntwf:policyDefault "investigate-specification" .

effortless-ntwf:id-exposure-mix a effortless-ntwf:ConfounderIdentities ;
    effortless-ntwf:confounderIdentityId "id-exposure-mix" ;
    effortless-ntwf:displayName "Exposure Mix / Context Heterogeneity" ;
    effortless-ntwf:mechanismClass "exposure-heterogeneity" ;
    effortless-ntwf:description "Vaccination base rate, exposure popularity, local labor market, or interaction type — aggregate exposure pool is heterogeneous across strata, driving allocation distortion." ;
    effortless-ntwf:policyDefault "stratify-by-exposure-context" .

# === Individuals: CorpusBalance ===

effortless-ntwf:corpus-balance a effortless-ntwf:CorpusBalance ;
    effortless-ntwf:balanceId "corpus-balance" .

# === Individuals: CorpusCatalogSummary ===

effortless-ntwf:catalog-v1 a effortless-ntwf:CorpusCatalogSummary ;
