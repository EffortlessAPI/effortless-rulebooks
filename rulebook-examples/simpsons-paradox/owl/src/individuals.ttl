# === Individuals: StudyImportTemplate ===

effortless-ntwf:import-step-studies a effortless-ntwf:StudyImportTemplate ;
    effortless-ntwf:templateStepId "import-step-studies" ;
    effortless-ntwf:sortOrder 1 ;
    effortless-ntwf:targetTable "Studies" ;
    effortless-ntwf:rowDescription "One Studies row with StudyId, Title, Source, SourceUrl, Domain, PublicationYear, IsSynthetic=FALSE." ;
    effortless-ntwf:requiredFields "StudyId, Title, Source, SourceUrl" ;
    effortless-ntwf:mechanicalCheck "StudyId unique; Source is citation string." .

effortless-ntwf:import-step-stratum-var a effortless-ntwf:StudyImportTemplate ;
    effortless-ntwf:templateStepId "import-step-stratum-var" ;
    effortless-ntwf:sortOrder 2 ;
    effortless-ntwf:targetTable "StratumVariables" ;
    effortless-ntwf:rowDescription "One StratumVariables row naming the confounder before classification." ;
    effortless-ntwf:requiredFields "VariableName, CausalRole, MechanismNote" ;
    effortless-ntwf:mechanicalCheck "CausalRole in {confounder, mediator, contested, unknown}." .

effortless-ntwf:import-step-treatments a effortless-ntwf:StudyImportTemplate ;
    effortless-ntwf:templateStepId "import-step-treatments" ;
    effortless-ntwf:sortOrder 3 ;
    effortless-ntwf:targetTable "Treatments" ;
    effortless-ntwf:rowDescription "Two Treatments rows (A and B) with human-readable descriptions." ;
    effortless-ntwf:requiredFields "TreatmentId, Study, TreatmentLabel, Description" ;
    effortless-ntwf:mechanicalCheck "Exactly two rows per study." .

effortless-ntwf:import-step-strata a effortless-ntwf:StudyImportTemplate ;
    effortless-ntwf:templateStepId "import-step-strata" ;
    effortless-ntwf:sortOrder 4 ;
    effortless-ntwf:targetTable "Strata" ;
    effortless-ntwf:rowDescription "One Strata row per stratum with StratumLabel and Description." ;
    effortless-ntwf:requiredFields "StratumId, Study, StratumLabel, Description" ;
    effortless-ntwf:mechanicalCheck "COUNT(Strata) >= 2." .

effortless-ntwf:import-step-casecells a effortless-ntwf:StudyImportTemplate ;
    effortless-ntwf:templateStepId "import-step-casecells" ;
    effortless-ntwf:sortOrder 5 ;
    effortless-ntwf:targetTable "CaseCells" ;
    effortless-ntwf:rowDescription "2×K CaseCells: every (stratum × treatment) with Cases and Successes." ;
    effortless-ntwf:requiredFields "CaseCellId, Study, StratumLabel, TreatmentLabel, Cases, Successes" ;
    effortless-ntwf:mechanicalCheck "CellCount = 2 × StratumCount; all IsValidIngestionCell." .

effortless-ntwf:import-step-catalog a effortless-ntwf:StudyImportTemplate ;
    effortless-ntwf:templateStepId "import-step-catalog" ;
    effortless-ntwf:sortOrder 6 ;
    effortless-ntwf:targetTable "CandidateStudyCatalog" ;
    effortless-ntwf:rowDescription "Mark catalog row imported: IngestionStatus=imported, LinkedStudyId set." ;
    effortless-ntwf:requiredFields "CandidateId, IngestionStatus, LinkedStudyId" ;
    effortless-ntwf:mechanicalCheck "LinkedStudyId matches new Studies.StudyId." .

effortless-ntwf:import-step-summaries a effortless-ntwf:StudyImportTemplate ;
    effortless-ntwf:templateStepId "import-step-summaries" ;
    effortless-ntwf:sortOrder 7 ;
    effortless-ntwf:targetTable "StratumSummaries" ;
    effortless-ntwf:rowDescription "One StratumSummaries row per (stratum × treatment) — keys for derived rates." ;
    effortless-ntwf:requiredFields "StratumSummaryId, Study, StratumLabel, TreatmentLabel" ;
    effortless-ntwf:mechanicalCheck "COUNT = 2 × StratumCount." .

effortless-ntwf:import-step-rankings a effortless-ntwf:StudyImportTemplate ;
    effortless-ntwf:templateStepId "import-step-rankings" ;
    effortless-ntwf:sortOrder 8 ;
    effortless-ntwf:targetTable "TreatmentRankings" ;
    effortless-ntwf:rowDescription "One TreatmentRankings row (A vs B) with AdjustmentRationale." ;
    effortless-ntwf:requiredFields "TreatmentRankingId, Study, TreatmentA, TreatmentB, AdjustmentRationale" ;
    effortless-ntwf:mechanicalCheck "Exactly one ranking row per study." .

