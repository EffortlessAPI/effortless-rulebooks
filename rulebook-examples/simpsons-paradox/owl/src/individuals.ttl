    effortless-ntwf:mechanismNote "First-half vs second-half season affects both at-bat volume and batting average. Player A front-loads ABs into weaker half, flipping combined ranking." ;
    effortless-ntwf:conditioningRisk "confounder" .

effortless-ntwf:wilson-batting-2000-inning_half a effortless-ntwf:StratumVariables ;
