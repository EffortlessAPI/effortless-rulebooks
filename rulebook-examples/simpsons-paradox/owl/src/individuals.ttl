effortless-ntwf:berkeley-1973-dept-B a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "berkeley-1973-dept-B" ;
    effortless-ntwf:study effortless-ntwf:berkeley-1973 ;
    effortless-ntwf:stratumLabel "dept-B" ;
    effortless-ntwf:description "Dept B — competitive (~35% admission). Women applied here less often." .

effortless-ntwf:berkeley-1973-dept-C a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "berkeley-1973-dept-C" ;
    effortless-ntwf:study effortless-ntwf:berkeley-1973 ;
    effortless-ntwf:stratumLabel "dept-C" ;
    effortless-ntwf:description "Dept C — moderately selective (~34% admission). More balanced gender application." .

effortless-ntwf:berkeley-1973-dept-D a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "berkeley-1973-dept-D" ;
    effortless-ntwf:study effortless-ntwf:berkeley-1973 ;
    effortless-ntwf:stratumLabel "dept-D" ;
    effortless-ntwf:description "Dept D — open (~64% admission). Women applied here most heavily — this is the easy department that women disproportionately chose." .

effortless-ntwf:compressed-synthetic-hard a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "compressed-synthetic-hard" ;
    effortless-ntwf:study effortless-ntwf:compressed-synthetic ;
    effortless-ntwf:stratumLabel "hard" ;
    effortless-ntwf:description "Hard stratum — lower baseline success rates (A=70%, B=60%). Treatment A is over-allocated here (60% of A cases vs 40% of B cases). This is the stratum that pulls A's pooled rate down relative to equal-weight expectation." .

effortless-ntwf:compressed-synthetic-easy a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "compressed-synthetic-easy" ;
    effortless-ntwf:study effortless-ntwf:compressed-synthetic ;
    effortless-ntwf:stratumLabel "easy" ;
    effortless-ntwf:description "Easy stratum — higher baseline success rates (A=90%, B=80%). Treatment B is over-allocated here (60% of B cases vs 40% of A cases). This partially offsets B's per-stratum disadvantage in the pooled analysis." .

effortless-ntwf:reintjes-2000-low a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "reintjes-2000-low" ;
    effortless-ntwf:study effortless-ntwf:reintjes-2000 ;
    effortless-ntwf:stratumLabel "low" ;
    effortless-ntwf:description "Low-incidence hospitals (baseline UTI rate ≤2.5%). Prophylaxis rate: 20/1113=1.80%. Control rate: 5/720=0.69%. Prophylaxis is harmful here. Most prophylaxis patients land in this stratum (87%), pulling the aggregate prophylaxis rate down and fabricating an apparent protective effect pooled." .

effortless-ntwf:reintjes-2000-high a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "reintjes-2000-high" ;
    effortless-ntwf:study effortless-ntwf:reintjes-2000 ;
    effortless-ntwf:stratumLabel "high" ;
    effortless-ntwf:description "High-incidence hospitals (baseline UTI rate >2.5%). Prophylaxis rate: 22/166=13.25%. Control rate: 99/1520=6.51%. Prophylaxis is again harmful. Controls are heavily concentrated here (1520 of 2240=68%), inflating the aggregate control rate." .

effortless-ntwf:radelet-1981-white-victim a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "radelet-1981-white-victim" ;
    effortless-ntwf:study effortless-ntwf:radelet-1981 ;
    effortless-ntwf:stratumLabel "white-victim" ;
    effortless-ntwf:description "Cases with a white victim. Death penalty issued far more often here (~17% pooled). White def: 19/151=12.58%. Black def: 11/63=17.46%. Black defendants MORE likely within this stratum." .

effortless-ntwf:radelet-1981-black-victim a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "radelet-1981-black-victim" ;
    effortless-ntwf:study effortless-ntwf:radelet-1981 ;
    effortless-ntwf:stratumLabel "black-victim" ;
    effortless-ntwf:description "Cases with a black victim. Death penalty rare here (~3.3% pooled). White def: 0/9=0.00%. Black def: 6/103=5.83%. Black defendants STILL more likely. Most black defendants are in this low-rate stratum (103/166=62%), dragging their aggregate rate down." .

effortless-ntwf:jeter-justice-1997-1995 a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "jeter-justice-1997-1995" ;
    effortless-ntwf:study effortless-ntwf:jeter-justice-1997 ;
    effortless-ntwf:stratumLabel "1995" ;
    effortless-ntwf:description "1995 season. Jeter: 12/48=.250. Justice: 104/411=.253. Justice wins by 3 points. Small season for Jeter (48 AB, rookie call-up); Justice's heaviest season (411 AB) and his weakest average — this is the stratum doing the most damage to Justice's combined rate." .

effortless-ntwf:jeter-justice-1997-1996 a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "jeter-justice-1997-1996" ;
    effortless-ntwf:study effortless-ntwf:jeter-justice-1997 ;
    effortless-ntwf:stratumLabel "1996" ;
    effortless-ntwf:description "1996 season. Jeter: 183/582=.314. Justice: 45/140=.321. Justice wins by 7 points. Jeter's breakout full season (582 AB). Justice had a shortened season (140 AB) but a high average — a small, strong stratum that lifts his per-year record but contributes little weight to combined." .

effortless-ntwf:jeter-justice-1997-1997 a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "jeter-justice-1997-1997" ;
    effortless-ntwf:study effortless-ntwf:jeter-justice-1997 ;
    effortless-ntwf:stratumLabel "1997" ;
    effortless-ntwf:description "1997 season. Jeter: 190/654=.291. Justice: 163/495=.329. Justice wins by 38 points — the largest per-stratum gap. Jeter's largest season (654 AB). The allocation imbalance is clear: Jeter has 654 AB in a .291 year vs Justice's 495 at .329." .

effortless-ntwf:appleton-1996-18-24 a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "appleton-1996-18-24" ;
    effortless-ntwf:study effortless-ntwf:appleton-1996 ;
    effortless-ntwf:stratumLabel "18-24" ;
    effortless-ntwf:description "Age 18-24 at baseline. Smokers: 2/55=3.6% mortality. Non-smokers: 1/72=1.4%. Smokers worse. Very low mortality overall; small absolute differences." .

effortless-ntwf:appleton-1996-25-34 a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "appleton-1996-25-34" ;
    effortless-ntwf:study effortless-ntwf:appleton-1996 ;
    effortless-ntwf:stratumLabel "25-34" ;
    effortless-ntwf:description "Age 25-34 at baseline. Smokers: 3/125=2.4% mortality. Non-smokers: 4/156=2.6%. Effectively tied (smokers marginally better — near-zero stratum gap). Very low mortality stratum." .

effortless-ntwf:appleton-1996-35-44 a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "appleton-1996-35-44" ;
    effortless-ntwf:study effortless-ntwf:appleton-1996 ;
    effortless-ntwf:stratumLabel "35-44" ;
    effortless-ntwf:description "Age 35-44 at baseline. Smokers: 10/105=9.5% mortality. Non-smokers: 7/111=6.3%. Smokers clearly worse." .

effortless-ntwf:appleton-1996-45-54 a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "appleton-1996-45-54" ;
    effortless-ntwf:study effortless-ntwf:appleton-1996 ;
    effortless-ntwf:stratumLabel "45-54" ;
    effortless-ntwf:description "Age 45-54 at baseline. Smokers: 28/131=21.4% mortality. Non-smokers: 12/78=15.4%. Smokers worse; gap widening with age." .

effortless-ntwf:appleton-1996-55-64 a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "appleton-1996-55-64" ;
    effortless-ntwf:study effortless-ntwf:appleton-1996 ;
    effortless-ntwf:stratumLabel "55-64" ;
    effortless-ntwf:description "Age 55-64 at baseline. Smokers: 52/116=44.8% mortality. Non-smokers: 41/122=33.6%. Smokers clearly worse; largest absolute gap in the middle strata." .

effortless-ntwf:appleton-1996-65-74 a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "appleton-1996-65-74" ;
    effortless-ntwf:study effortless-ntwf:appleton-1996 ;
    effortless-ntwf:stratumLabel "65-74" ;
    effortless-ntwf:description "Age 65-74 at baseline. Smokers: 31/37=83.8% mortality. Non-smokers: 101/129=78.3%. Smokers worse. Small smoker group (37) — most heavy smokers in this cohort had already died before reaching 65 at baseline (survivorship selection)." .

effortless-ntwf:appleton-1996-75plus a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "appleton-1996-75plus" ;
    effortless-ntwf:study effortless-ntwf:appleton-1996 ;
    effortless-ntwf:stratumLabel "75+" ;
    effortless-ntwf:description "Age 75+ at baseline. Smokers: 13/13=100% mortality. Non-smokers: 64/64=100%. Both groups reach 100% at 20-year follow-up — everyone in this stratum died. StratumGap=0. Heavy survivorship selection: only 13 smokers survived to 75+ at baseline vs 64 non-smokers." .

effortless-ntwf:phe-covid-2021-under-50 a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "phe-covid-2021-under-50" ;
    effortless-ntwf:study effortless-ntwf:phe-covid-2021 ;
    effortless-ntwf:stratumLabel "under 50" ;
    effortless-ntwf:description "Age under 50. Vaccinated CFR: 21/89,807=0.023%. Unvaccinated CFR: 48/147,612=0.033%. Vaccinated clearly better. Low absolute mortality in both groups — under-50 COVID Delta deaths are rare regardless of vaccination status." .

effortless-ntwf:phe-covid-2021-50plus a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "phe-covid-2021-50plus" ;
    effortless-ntwf:study effortless-ntwf:phe-covid-2021 ;
    effortless-ntwf:stratumLabel "50 +" ;
    effortless-ntwf:description "Age 50 and over. Vaccinated CFR: 460/27,307=1.68%. Unvaccinated CFR: 205/3,440=5.96%. Vaccinated dramatically better (3.5× lower death rate). The enormous relative risk reduction in this high-mortality stratum is the true vaccine signal — but it is hidden in the pooled comparison because so few unvaccinated people are in this stratum (3,440 vs 27,307 vaccinated)." .

effortless-ntwf:hannan-1994-high-risk a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "hannan-1994-high-risk" ;
    effortless-ntwf:study effortless-ntwf:hannan-1994 ;
    effortless-ntwf:stratumLabel "high-risk" ;
    effortless-ntwf:description "High-risk CABG patients (EuroSCORE-equivalent ≥5). High-volume hospitals (A) are heavily loaded with these cases — 70% of A's caseload is high-risk vs only 20% of B's. A wins this stratum (95.0% vs 80.0%, a 15pp advantage). The over-representation of hard cases in A drags A's pooled rate down relative to the equal-weight benchmark." .

effortless-ntwf:hannan-1994-low-risk a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "hannan-1994-low-risk" ;
    effortless-ntwf:study effortless-ntwf:hannan-1994 ;
    effortless-ntwf:stratumLabel "low-risk" ;
    effortless-ntwf:description "Low-risk CABG patients (EuroSCORE-equivalent <5). Low-volume hospitals (B) have disproportionately more easy cases — 80% of B's caseload vs only 30% of A's. A still wins this stratum (99.0% vs 96.9%, a 2pp advantage). The allocation imbalance compresses A's pooled advantage from 7.9pp (equal-weight) down to 2.8pp (actual pooled) without reversing it — the fingerprint of type-C distortion." .

effortless-ntwf:titanic-1912-male a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "titanic-1912-male" ;
    effortless-ntwf:study effortless-ntwf:titanic-1912 ;
    effortless-ntwf:stratumLabel "male" ;
    effortless-ntwf:description "Male passengers. 1st class (A): 57/175=32.6% survived. 3rd class (B): 75/462=16.2% survived. 1st class wins. Males are over-represented in 3rd class (462 vs 175) and in 3rd class the per-sex advantage for 1st class is modest. This stratum has the most cases and contributes heavily to the pooled comparison." .

effortless-ntwf:titanic-1912-female a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "titanic-1912-female" ;
    effortless-ntwf:study effortless-ntwf:titanic-1912 ;
    effortless-ntwf:stratumLabel "female" ;
    effortless-ntwf:description "Female passengers. 1st class (A): 139/144=96.5% survived. 3rd class (B): 76/165=46.1% survived. 1st class wins by 50.4pp — the largest per-stratum gap. 1st class has a higher fraction of women (144/319=45%) than 3rd class (165/627=26%). This over-representation of women in 1st class inflates the pooled 1st-class survival rate beyond the equal-weight per-stratum average — the allocation distortion inflates rather than compresses the advantage." .

effortless-ntwf:bwp-lbw a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "bwp-lbw" ;
    effortless-ntwf:study effortless-ntwf:birth-weight-paradox ;
    effortless-ntwf:stratumLabel "low-birth-weight" ;
    effortless-ntwf:description "Low birth weight babies (<2500g). Smoker infants (A): 960/1000=96.0% survival. Non-smoker infants (B): 470/500=94.0% survival. Smokers win this stratum. The mechanism (Hernandez-Diaz 2006): low birth weight among non-smokers is more likely caused by serious congenital anomalies or pathologies, whereas smoking-related low birth weight is a 'milder' cause — so the surviving non-smoker LBW infants are a sicker selected group. Smokers are over-represented in this stratum (1000 vs 500 babies)." .

effortless-ntwf:bwp-nbw a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "bwp-nbw" ;
    effortless-ntwf:study effortless-ntwf:birth-weight-paradox ;
    effortless-ntwf:stratumLabel "normal-birth-weight" ;
    effortless-ntwf:description "Normal birth weight babies (≥2500g). Smoker infants (A): 995/1000=99.5% survival. Non-smoker infants (B): 4980/5000=99.6% survival. Non-smokers barely win (0.1pp). Non-smokers vastly outnumber smokers here (5000 vs 1000). Pooled, non-smokers (B) win because this stratum dominates B's total, and B wins it. The pooled result reverses the LBW stratum finding — a partial (type-B) paradox driven by the LBW vs NBW allocation imbalance." .

effortless-ntwf:mel-thin a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "mel-thin" ;
    effortless-ntwf:study effortless-ntwf:melanoma-altman-1991 ;
    effortless-ntwf:stratumLabel "thin" ;
    effortless-ntwf:description "Thin melanoma tumors (<1mm Breslow depth). Female patients (A): 133/140=95.0% 10-year survival. Male patients (B): 70/80=87.5% survival. Females win by 7.5pp. Women present with thin tumors more often (140/200=70% of female cases are thin vs 80/200=40% of male cases) — reflecting earlier detection and help-seeking behavior." .

effortless-ntwf:mel-thick a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "mel-thick" ;
    effortless-ntwf:study effortless-ntwf:melanoma-altman-1991 ;
    effortless-ntwf:stratumLabel "thick" ;
    effortless-ntwf:description "Thick melanoma tumors (≥1mm Breslow depth). Female patients (A): 39/60=65.0% 10-year survival. Male patients (B): 66/120=55.0% survival. Females win by 10pp. Males are over-represented here (120/200=60% of male cases are thick vs 60/200=30% of female cases). Women's disproportionate concentration in the high-survival thin-tumor stratum inflates the pooled female advantage beyond the equal-weight per-stratum average." .

effortless-ntwf:coffee-nonsmoker a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "coffee-nonsmoker" ;
    effortless-ntwf:study effortless-ntwf:coffee-tverdal-2020 ;
    effortless-ntwf:stratumLabel "non-smoker" ;
    effortless-ntwf:description "Never- or ex-smokers. Coffee drinkers (A): 920/1000=92.0% CHD-free at 10 years. Non-drinkers (B): 890/1000=89.0%. Coffee wins by 3pp. Equal allocation (1000 each treatment). No allocation imbalance — the per-stratum result passes through to the pooled result unchanged." .

effortless-ntwf:coffee-smoker a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "coffee-smoker" ;
    effortless-ntwf:study effortless-ntwf:coffee-tverdal-2020 ;
    effortless-ntwf:stratumLabel "smoker" ;
    effortless-ntwf:description "Current smokers. Coffee drinkers (A): 820/1000=82.0% CHD-free. Non-drinkers (B): 800/1000=80.0%. Coffee wins by 2pp. Equal allocation. Smoking increases baseline CHD risk in both groups but does not confound the coffee comparison because allocation is balanced. This study is type-D: genuine benefit of coffee, no distortion by allocation." .

effortless-ntwf:sat-lowspend a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "sat-lowspend" ;
    effortless-ntwf:study effortless-ntwf:sat-wainer-1986 ;
    effortless-ntwf:stratumLabel "low-spending" ;
    effortless-ntwf:description "Low-spending states (<$3000 per pupil, 1986 dollars). High-participation states (A): 240/600=40.0% scored ≥500. Low-participation states (B): 35/100=35.0% scored ≥500. A wins by 5pp. High-participation states dominate this stratum (600 vs 100 students in sample), sending more students including weaker ones." .

effortless-ntwf:sat-highspend a effortless-ntwf:Strata ;
    effortless-ntwf:stratumId "sat-highspend" ;
    effortless-ntwf:study effortless-ntwf:sat-wainer-1986 ;
    effortless-ntwf:stratumLabel "high-spending" ;
    effortless-ntwf:description "High-spending states (≥$3000 per pupil, 1986 dollars). High-participation states (A): 280/400=70.0% scored ≥500. Low-participation states (B): 40/50=80.0% scored ≥500. B wins by 10pp — in well-funded states, the small self-selected group of test-takers in low-participation states scores higher because they are disproportionately college-bound high-achievers. This stratum reversal drives the pooled paradox (type-B): A wins low-spending stratum, B wins high-spending, B slightly leads pooled." .

