effortless-ntwf:open-university-1975-age_band a effortless-ntwf:StratumVariables ;
    effortless-ntwf:stratumVariableId "open-university-1975-age_band" ;
    effortless-ntwf:study effortless-ntwf:open-university-1975 ;
