    effortless-ntwf:conclusionId "conc-05-real-data-generalizes" ;
    effortless-ntwf:category "instrument" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:reportTier "supporting" ;
    effortless-ntwf:title "Two real published studies (reintjes-2000, radelet-1981) hydrate as type-A full reversals without schema changes" ;
    effortless-ntwf:evidence "Both studies entered via 05b-customize-data.sql. Witnessed: reintjes AllocationDistortion=0.0516, DistortionType=A; radelet AllocationDistortion=0.0684, DistortionType=A. No DAG or schema change was needed — the hydration contract generalizes." ;
    effortless-ntwf:witnessedInLoop "loop-20b" ;
    effortless-ntwf:traditionId "tradition-epidemiology" ;
    effortless-ntwf:researcherId "researcher-greenland" .

effortless-ntwf:conc-06-policy-derivable a effortless-ntwf:Conclusions ;
    effortless-ntwf:conclusionId "conc-06-policy-derivable" ;
    effortless-ntwf:category "instrument" ;
    effortless-ntwf:status "witnessed" ;
    effortless-ntwf:reportTier "supporting" ;
    effortless-ntwf:title "PolicyImplication is domain-neutral: the same formula produces researcher actions across medicine, law, and education" ;
    effortless-ntwf:evidence "All five current studies (kidney-1986, berkeley-1973, compressed-synthetic, kidney-balanced, balanced-synthetic) plus two real studies produce unambiguous PolicyImplication values from DistortionType alone. No domain-specific knowledge is encoded in the formula." ;
