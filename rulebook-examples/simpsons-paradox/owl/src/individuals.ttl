    effortless-ntwf:naturalLanguage "Every sign-flip study must have SignalPurity strictly below 0.5. A value >= 0.5 would mean the allocation noise equals or exceeds the true signal — algebraically impossible for a genuine reversal. melanoma-altman-1991 (purity=0.479, no flip) is the known boundary non-counterexample." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "IsSignFlip = TRUE" ;
    effortless-ntwf:assertionExpression "SignalPurity < 0.5" ;
    effortless-ntwf:sqlFilter "is_sign_flip = true" ;
    effortless-ntwf:sqlAssertion "signal_purity < 0.5" ;
    effortless-ntwf:passCount 18 ;
    effortless-ntwf:failCount 0 ;
    effortless-ntwf:severity "critical" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:protectsConclusion "conc-12-signal-purity-theorem" .

effortless-ntwf:inv-type-a-unanimous a effortless-ntwf:InvariantChecks ;
    effortless-ntwf:invariantCheckId "inv-type-a-unanimous" ;
    effortless-ntwf:algebraicStatement "DistortionType = A → IsStratumUnanimous = TRUE" ;
    effortless-ntwf:naturalLanguage "Type-A sign-flip studies require unanimous stratum direction. rosiglitazone-mi-pool-2007 reclassified to Type B (1–1 split strata)." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "DistortionType = A" ;
    effortless-ntwf:assertionExpression "IsStratumUnanimous = TRUE" ;
    effortless-ntwf:sqlFilter "distortion_type = 'A'" ;
    effortless-ntwf:sqlAssertion "is_stratum_unanimous = TRUE" ;
    effortless-ntwf:passCount 0 ;
    effortless-ntwf:failCount 0 ;
    effortless-ntwf:severity "critical" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:protectsConclusion "conc-03-binary-excludes-partial" .

effortless-ntwf:inv-confounder-signflip-explained a effortless-ntwf:InvariantChecks ;
    effortless-ntwf:invariantCheckId "inv-confounder-signflip-explained" ;
    effortless-ntwf:algebraicStatement "IsSignFlip=TRUE AND StratumCausalRole='confounder' → IsParadoxExplained=TRUE" ;
    effortless-ntwf:naturalLanguage "Every confounder manifest sign-flip must be marked explained. Other half of the explained↔confounder biconditional (loop-74)." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "IsSignFlip = TRUE AND StratumCausalRole = 'confounder'" ;
    effortless-ntwf:assertionExpression "IsParadoxExplained = TRUE" ;
    effortless-ntwf:sqlFilter "is_sign_flip = true AND stratum_causal_role = 'confounder'" ;
    effortless-ntwf:sqlAssertion "is_paradox_explained = true" ;
    effortless-ntwf:passCount 0 ;
    effortless-ntwf:failCount 0 ;
    effortless-ntwf:severity "critical" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:protectsConclusion "conc-29-explained-confounder-theorem" .

effortless-ntwf:inv-collider-no-manifest a effortless-ntwf:InvariantChecks ;
    effortless-ntwf:invariantCheckId "inv-collider-no-manifest" ;
    effortless-ntwf:algebraicStatement "StratumCausalRole ∈ {collider, selection} AND NOT IsSynthetic → IsSignFlip = FALSE" ;
    effortless-ntwf:naturalLanguage "Real-data collider and selection studies never produce manifest sign-flips at observed allocation — conditional theorem requiring correct causal-role annotation (loop-75). Scoped to real-data studies: loop-89's collider-purity-boundary-flip is a deliberately-constructed synthetic adversarial stress test (1.2M-trial search for the highest-purity manifest flip a collider geometry can produce, purity=0.49994) built specifically to probe this theorem's boundary from the outside — it is evidence the boundary is real and tight, not a counterexample to the real-data claim (loop-92)." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "StratumCausalRole IN ('collider','selection') AND NOT IsSynthetic" ;
    effortless-ntwf:assertionExpression "IsSignFlip = FALSE" ;
    effortless-ntwf:sqlFilter "stratum_causal_role IN ('collider', 'selection') AND study NOT IN (SELECT study_id FROM studies WHERE is_synthetic = TRUE)" ;
    effortless-ntwf:sqlAssertion "(is_sign_flip = false OR is_sign_flip IS NULL)" ;
    effortless-ntwf:passCount 0 ;
    effortless-ntwf:failCount 0 ;
    effortless-ntwf:severity "critical" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:protectsConclusion "conc-30-collider-no-manifest-theorem" .

effortless-ntwf:inv-unexplained-identity-sink a effortless-ntwf:InvariantChecks ;
    effortless-ntwf:invariantCheckId "inv-unexplained-identity-sink" ;
    effortless-ntwf:algebraicStatement "IsSignFlip=TRUE AND IsParadoxExplained=FALSE AND NOT IsSynthetic → ConfounderIdentity ∈ {id-contested-org-choice, id-collider-proxy}" ;
    effortless-ntwf:naturalLanguage "Every real-data unexplained sign-flip must be linked to contested-org-choice or collider-proxy identity — no unexplained flip belongs to an unambiguous confounder archetype. Identity-conditioned extension of conc-29 (loop-74 biconditional). Scoped to real-data studies (loop-92): loop-89's collider-purity-boundary-flip is a deliberately-constructed synthetic study with no StratumVariableIdentityMaps row at all (synthetic studies are never identity-mapped), so it is not a counterexample to this real-corpus claim." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "IsSignFlip = TRUE AND IsParadoxExplained = FALSE AND NOT IsSynthetic" ;
    effortless-ntwf:assertionExpression "StratumCausalRole IN ('contested') OR ConfounderIdentity IN ('id-contested-org-choice','id-collider-proxy')" ;
    effortless-ntwf:sqlFilter "is_sign_flip = true AND is_paradox_explained = false AND study NOT IN (SELECT study_id FROM studies WHERE is_synthetic = TRUE)" ;
    effortless-ntwf:sqlAssertion """stratum_causal_role = 'contested' OR study IN (
 SELECT s.study_id FROM stratum_variable_identity_maps m
 JOIN stratum_variables sv ON sv.stratum_variable_id = m.stratum_variable
 JOIN studies s ON s.study_id = sv.study
 WHERE m.confounder_identity IN ('id-contested-org-choice','id-collider-proxy')
 )""" ;
    effortless-ntwf:passCount 3 ;
    effortless-ntwf:failCount 0 ;
    effortless-ntwf:severity "critical" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:protectsConclusion "conc-35-unexplained-identity-sink-theorem" .

effortless-ntwf:inv-perfect-balance-no-flip a effortless-ntwf:InvariantChecks ;
    effortless-ntwf:invariantCheckId "inv-perfect-balance-no-flip" ;
    effortless-ntwf:algebraicStatement "ArmSizeRatio=0.5 AND MaxStratumImbalance=0.0 → IsSignFlip=FALSE" ;
    effortless-ntwf:naturalLanguage "Perfect allocation balance (equal arm sizes AND zero stratum imbalance) is a sufficient condition for no manifest Simpson's Paradox. Zero exceptions allowed." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "ArmSizeRatio=0.5 AND MaxStratumImbalance=0.0" ;
    effortless-ntwf:assertionExpression "IsSignFlip=FALSE" ;
    effortless-ntwf:sqlFilter "arm_size_ratio = 0.5 AND max_stratum_imbalance = 0.0" ;
    effortless-ntwf:sqlAssertion "is_sign_flip = FALSE" ;
    effortless-ntwf:passCount 118 ;
    effortless-ntwf:failCount 0 ;
    effortless-ntwf:severity "critical" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:protectsConclusion "conc-36-perfect-balance-theorem" .

effortless-ntwf:inv-collider-purity-dominance a effortless-ntwf:InvariantChecks ;
    effortless-ntwf:invariantCheckId "inv-collider-purity-dominance" ;
    effortless-ntwf:algebraicStatement "MeanSignalPurity(collider-selection) > MeanSignalPurity(demographic-composition)" ;
    effortless-ntwf:naturalLanguage "Collider and selection-bias studies have higher mean SignalPurity than demographic-composition confounder studies — the purity trap: mechanistic classes that must not be stratified have cleaner-looking data than those that should be stratified." ;
    effortless-ntwf:sourceTable "TreatmentRankings" ;
    effortless-ntwf:filterExpression "ColliderSelectionCount>=10 AND DemographicCompositionCount>=10" ;
    effortless-ntwf:assertionExpression "AvgPurityColliderSelection > AvgPurityDemographicComposition" ;
    effortless-ntwf:sqlFilter "TRUE" ;
    effortless-ntwf:sqlAssertion "(SELECT AVG(calc_treatment_rankings_signal_purity(tr2.treatment_ranking_id)) FROM treatment_rankings tr2 WHERE calc_treatment_rankings_stratum_causal_role(tr2.treatment_ranking_id) IN ('collider','selection')) > (SELECT AVG(calc_treatment_rankings_signal_purity(tr3.treatment_ranking_id)) FROM treatment_rankings tr3 WHERE tr3.study IN (SELECT s.study_id FROM stratum_variable_identity_maps m JOIN stratum_variables sv ON sv.stratum_variable_id = m.stratum_variable JOIN studies s ON s.study_id = sv.study JOIN confounder_identities ci ON ci.confounder_identity_id = m.confounder_identity WHERE ci.mechanism_class = 'demographic-composition'))" ;
    effortless-ntwf:passCount 1 ;
    effortless-ntwf:failCount 0 ;
    effortless-ntwf:severity "warning" ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:protectsConclusion "conc-37-purity-inversion-theorem" .

# === Individuals: Loops ===

effortless-ntwf:loop-01 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-01" ;
    effortless-ntwf:title "Core domain: Study, Treatment, Stratum, CaseCell → SuccessRate falls out" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "Studies, Treatments, Strata, CaseCells" ;
    effortless-ntwf:domainQuestion "For each (stratum, treatment) cell in a study, what is the success rate?" ;
    effortless-ntwf:mockDataNote "Kidney stone study (Charig 1986): 2 strata (small/large), 2 treatments (A/B), 4 cells. CellSuccessRate is the first derived fact." ;
    effortless-ntwf:nextSuggestion "Ask: for each treatment, what is its pooled (across all strata) success rate? That requires TreatmentSummary — aggregating CaseCells by treatment, ignoring stratum." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "b96e0fe6e3402d85b16e9772518d9241c64c1b1e" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-05: StratumVariables + IsParadoxExplained — the DAG witnesses its own explanation" ;
    effortless-ntwf:gitTag "sp-loop-milestone-01-loops-01-10" .

effortless-ntwf:loop-02 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-02" ;
    effortless-ntwf:title "TreatmentSummary: pooled rate per treatment across all strata" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "TreatmentSummaries" ;
    effortless-ntwf:domainQuestion "If you ignore stratum entirely, what is each treatment's overall success rate?" ;
    effortless-ntwf:mockDataNote "Pooled: A=273/350=78%, B=289/350=83%. B looks better — this is the misleading aggregate view." ;
    effortless-ntwf:nextSuggestion "Ask: for each (stratum, treatment) pair, what is the success rate WITHIN that stratum? That requires StratumSummary — the view that contradicts the pooled view." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "b96e0fe6e3402d85b16e9772518d9241c64c1b1e" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-05: StratumVariables + IsParadoxExplained — the DAG witnesses its own explanation" ;
    effortless-ntwf:gitTag "sp-loop-milestone-01-loops-01-10" .

effortless-ntwf:loop-03 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-03" ;
    effortless-ntwf:title "StratumSummary: per-stratum rate per treatment — the true picture" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "StratumSummaries" ;
    effortless-ntwf:domainQuestion "Within each stratum, which treatment has the higher success rate?" ;
    effortless-ntwf:mockDataNote "Small: A=93.1% > B=86.7%. Large: A=73.0% > B=68.8%. A wins in BOTH strata. Contradiction with pooled view is now visible." ;
    effortless-ntwf:nextSuggestion "Ask: for each treatment pair in a study, does the pooled winner match the per-stratum winner? That requires TreatmentRanking — the node where the paradox either exists or doesn't." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "b96e0fe6e3402d85b16e9772518d9241c64c1b1e" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-05: StratumVariables + IsParadoxExplained — the DAG witnesses its own explanation" ;
    effortless-ntwf:gitTag "sp-loop-milestone-01-loops-01-10" .

effortless-ntwf:loop-04 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-04" ;
    effortless-ntwf:title "TreatmentRanking: does the pooled winner = the per-stratum winner?" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "TreatmentRankings" ;
    effortless-ntwf:domainQuestion "When pooled and stratified conclusions disagree — which treatment should actually be preferred?" ;
    effortless-ntwf:mockDataNote "Pooled winner = B. Per-stratum winner = A in every stratum. Simpson's Paradox: IsReversal = true. This is the paradox as a derived fact, not a modeled entity." ;
    effortless-ntwf:nextSuggestion "Ask: WHY does the paradox occur? The stratifying variable (stone size) affects both treatment assignment AND outcome. Name it as a StratumVariable with a CausalRole field." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "b96e0fe6e3402d85b16e9772518d9241c64c1b1e" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-05: StratumVariables + IsParadoxExplained — the DAG witnesses its own explanation" ;
    effortless-ntwf:gitTag "sp-loop-milestone-01-loops-01-10" .

effortless-ntwf:loop-05 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-05" ;
    effortless-ntwf:title "StratumVariable: name the confounding factor, its causal role, and derive IsConfounder + IsParadoxExplained" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "StratumVariables (one per study); CausalRole field; IsConfounder boolean; IsParadoxExplained on TreatmentRankings" ;
    effortless-ntwf:domainQuestion "What IS the stratum variable, why does it confound, and does the model witness its own explanation?" ;
    effortless-ntwf:mockDataNote "kidney-1986: VariableName=stone_size, CausalRole=confounder, AffectsTreatmentAssignment=true, AffectsOutcome=true → IsConfounder=true → IsParadoxExplained=true on TreatmentRankings." ;
    effortless-ntwf:nextSuggestion "Ask: how large is the allocation imbalance? Derive TreatmentExposureFraction on CaseCells — the fraction of each treatment's cases that land in each stratum. High imbalance = confounding mechanism as a witnessed number." ;
    effortless-ntwf:traditionId "tradition-dag" ;
    effortless-ntwf:commitHash "b96e0fe6e3402d85b16e9772518d9241c64c1b1e" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-05: StratumVariables + IsParadoxExplained — the DAG witnesses its own explanation" ;
    effortless-ntwf:gitTag "sp-loop-milestone-01-loops-01-10" .

effortless-ntwf:loop-06 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-06" ;
    effortless-ntwf:title "TreatmentExposureFraction: the allocation imbalance as a witnessed number" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "TreatmentExposureFraction field on CaseCells (Cases / TotalCasesForTreatment in this study)" ;
    effortless-ntwf:domainQuestion "What fraction of each treatment's total cases fall in each stratum? High imbalance across strata is the mechanism of confounding." ;
    effortless-ntwf:mockDataNote "A: 263/350=75% in large-stone stratum. B: 80/350=23% in large-stone stratum. The 52-point gap IS the mechanism — now a first-class derived number." ;
    effortless-ntwf:nextSuggestion "Add a degenerate study where treatment allocation is perfectly balanced across strata. IsReversal must be FALSE — not because the data says so, but because the algebra guarantees it. The model witnesses its own structural impossibility." ;
    effortless-ntwf:traditionId "tradition-epidemiology" ;
    effortless-ntwf:commitHash "b96e0fe6e3402d85b16e9772518d9241c64c1b1e" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-05: StratumVariables + IsParadoxExplained — the DAG witnesses its own explanation" ;
    effortless-ntwf:gitTag "sp-loop-milestone-01-loops-01-10" .

effortless-ntwf:loop-07 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-07" ;
    effortless-ntwf:title "Degenerate study: balanced allocation → IsReversal structurally impossible" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "Second Studies row (balanced-synthetic); equal TreatmentExposureFraction across strata; IsReversal = FALSE by construction" ;
    effortless-ntwf:domainQuestion "If every stratum gets the same treatment-allocation fraction, can a reversal occur? The DAG should witness that it cannot." ;
    effortless-ntwf:mockDataNote "Synthetic: A and B each assigned 50/50 to small/large strata. A=60% success both strata, B=50% both. Pooled: A=60%, B=50%. No reversal. IsParadoxExplained vacuously true (IsConfounder=false, no confounding, no reversal)." ;
    effortless-ntwf:nextSuggestion "Add Berkeley 1973 — same DAG, contested domain. Aggregate: women admitted at lower rate. Per-department: women admitted at equal or higher rate in most. IsReversal=true. But IsConfounder is ambiguous — department choice may be downstream of gender (mediator, not confounder). The model witnesses its own explanatory limits." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "b96e0fe6e3402d85b16e9772518d9241c64c1b1e" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-05: StratumVariables + IsParadoxExplained — the DAG witnesses its own explanation" ;
    effortless-ntwf:gitTag "sp-loop-milestone-01-loops-01-10" .

effortless-ntwf:loop-08 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-08" ;
    effortless-ntwf:title "Berkeley 1973: contested confounder — model reveals a PARTIAL paradox, not a clean reversal" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "Third Studies row (berkeley-1973); StratumVariable=department; CausalRole=contested; IsConfounder=false; IsParadoxExplained=false; PerStratumWinner=none (mixed, not unanimous)" ;
    effortless-ntwf:domainQuestion "Does Berkeley show a clean reversal? No — PerStratumWinner='none' because the per-stratum winner is mixed (female wins 3/4 depts, male wins 1). The model surfaces a structural limit of the reversal definition: partial paradoxes are real but don't satisfy the strict IsReversal criterion." ;
    effortless-ntwf:mockDataNote "Witnessed: male pooled 52.8% vs female 39.9% (large gap). Per dept: female wins A (82%>62%), B (68%>63%), D (35%>33%); male wins C (37%>34%). No unanimous per-stratum winner → IsReversal=FALSE by strict definition. The intuitive paradox is real; the formal paradox is partial." ;
    effortless-ntwf:nextSuggestion "Add ParadoxStrength (scalar severity) to capture partial reversals — pooled gap and average per-stratum gap regardless of unanimity. Then StudySummary for epistemic coverage across all 3 studies." ;
    effortless-ntwf:traditionId "tradition-epidemiology" ;
    effortless-ntwf:commitHash "b96e0fe6e3402d85b16e9772518d9241c64c1b1e" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-05: StratumVariables + IsParadoxExplained — the DAG witnesses its own explanation" ;
    effortless-ntwf:gitTag "sp-loop-milestone-01-loops-01-10" .

effortless-ntwf:loop-09 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-09" ;
    effortless-ntwf:title "ParadoxStrength: scalar severity derived from pooled gap and per-stratum gap" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "ParadoxStrength on TreatmentRankings; PooledGap and AvgStratumGap on StratumSummaries" ;
    effortless-ntwf:domainQuestion "How large is the reversal? Can we rank studies by paradox severity, and does strength correlate with allocation imbalance?" ;
    effortless-ntwf:mockDataNote "Kidney: pooled gap ~4.6pp favoring B, avg stratum gap ~5pp favoring A. Berkeley: larger pooled gap, varies by department. Balanced: strength=0 (no reversal)." ;
    effortless-ntwf:nextSuggestion "StudySummary: roll up ReversalCount, ExplainedCount, AvgParadoxStrength across all studies. The model now describes its own epistemic coverage in a single view." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "b96e0fe6e3402d85b16e9772518d9241c64c1b1e" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-05: StratumVariables + IsParadoxExplained — the DAG witnesses its own explanation" ;
    effortless-ntwf:gitTag "sp-loop-milestone-01-loops-01-10" .

effortless-ntwf:loop-10 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-10" ;
    effortless-ntwf:title "StudySummary: the model witnesses its own epistemic coverage" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "StudySummary table (one row per model instance): StudyCount, ReversalCount, ExplainedCount, UnexplainedCount, ImpossibleCount, AvgParadoxStrength" ;
    effortless-ntwf:domainQuestion "Across all studies in this model, what is the epistemic state? How many reversals, how many explained, how many witnessed-but-unexplained?" ;
    effortless-ntwf:mockDataNote "3 studies: ReversalCount=2 (kidney+berkeley), ExplainedCount=1 (kidney), UnexplainedCount=1 (berkeley), ImpossibleCount=1 (balanced). The model now holds a mirror to itself." ;
    effortless-ntwf:nextSuggestion "Ask: how heavy is each stratum? Add StratumFraction to StratumSummaries — the fraction of the study's total cases that land in each stratum. The weight each stratum carries IS the lever the confounder pulls." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "b96e0fe6e3402d85b16e9772518d9241c64c1b1e" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-05: StratumVariables + IsParadoxExplained — the DAG witnesses its own explanation" ;
    effortless-ntwf:gitTag "sp-loop-milestone-01-loops-01-10" .

effortless-ntwf:loop-11 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-11" ;
    effortless-ntwf:title "StratumFraction: the weight each stratum carries in the pooled average" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "StratumFraction (and StudyTotalCases, StratumTotalCases) on StratumSummaries" ;
    effortless-ntwf:domainQuestion "What fraction of the study's total cases land in each stratum? High StratumFraction on a low-success stratum pulls the pooled rate down — and when that stratum is also over-allocated to one treatment, the reversal follows." ;
    effortless-ntwf:mockDataNote "kidney-1986: large-stratum = (263+80)/700 = 49%; small-stratum = (87+270)/700 = 51%. Nearly equal stratum weights — but unequal per-treatment allocation (75% of A is in large; 23% of B is in large). The weight alone is not the mechanism; the differential allocation into heavy strata is." ;
    effortless-ntwf:nextSuggestion "Add WeightedStratumRate: StratumFraction × StratumSuccessRate per treatment row. Sum these across strata to reconstruct PooledRate from first principles. The DAG now witnesses the mechanism equation: pooled rate = weighted average of stratum rates." ;
    effortless-ntwf:traditionId "tradition-epidemiology" ;
    effortless-ntwf:commitHash "49f01e7cafcdb6b529db5743081ee7b32d708b01" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-15: ReversalThreshold — intensity and margin witness paradox robustness vs fragility" ;
    effortless-ntwf:gitTag "sp-loop-milestone-03-loops-11-15" .

effortless-ntwf:loop-12 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-12" ;
    effortless-ntwf:title "WeightedPull: mechanism equation witnessed — pooled rate = weighted sum of stratum rates" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "WeightedStratumRate on StratumSummaries; PooledRateFromWeightsA and PooledRateFromWeightsB on TreatmentRankings" ;
    effortless-ntwf:domainQuestion "Can the DAG reconstruct each treatment's pooled rate purely from stratum weights × stratum rates? If PooledRateFromWeights = PooledRate, the mechanism equation is verified: Simpson's Paradox is algebraically explained." ;
    effortless-ntwf:mockDataNote "kidney-1986: PooledRateFromWeightsA=0.833, PooledRateFromWeightsB=0.779 (A looks better under equal study-level weights). But actual pooled rates are A=0.780, B=0.826 (B looks better). The divergence IS the mechanism: real pooled uses treatment-level allocation weights; the reconstruction uses study-level weights. The swap between the two orderings shows exactly how differential allocation flips the conclusion. balanced-synthetic: weights match exactly (equal allocation = no flip possible)." ;
    effortless-ntwf:nextSuggestion "Add AllocationBias to StratumSummaries: the difference between TreatmentExposureFraction for A and B in each stratum. High bias toward the losing treatment in a low-success stratum IS the confounder's fingerprint as a witnessed number." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "49f01e7cafcdb6b529db5743081ee7b32d708b01" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-15: ReversalThreshold — intensity and margin witness paradox robustness vs fragility" ;
    effortless-ntwf:gitTag "sp-loop-milestone-03-loops-11-15" .

effortless-ntwf:loop-13 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-13" ;
    effortless-ntwf:title "AllocationBias: the confounder's fingerprint as a signed witnessed number" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "AllocationBias on StratumSummaries (AllocationFractionA - AllocationFractionB); also AllocationFractionA, AllocationFractionB, TreatmentACasesHere, TreatmentBCasesHere, TreatmentATotalCases, TreatmentBTotalCases" ;
    effortless-ntwf:domainQuestion "In each stratum, is one treatment disproportionately concentrated here? AllocationBias = AllocationFractionA - AllocationFractionB: positive means A is over-represented here, negative means B is. A strong negative bias in a low-success stratum is the confounder's fingerprint." ;
    effortless-ntwf:mockDataNote "kidney-1986 large-stratum: AllocationFractionA=263/350=0.751, AllocationFractionB=80/350=0.229, AllocationBias=+0.523. A is massively over-allocated to the hard (large-stone) stratum. This single number summarizes why the pooled rate misleads: A carries 52pp more exposure to the hard case, dragging its pooled average down below B's despite beating B in both strata." ;
    effortless-ntwf:nextSuggestion "Add a 4th study: kidney-balanced — same stratum rates as kidney-1986 but with equal allocation (50/50 split). AllocationBias=0 everywhere, IsReversal=FALSE. The counterfactual shows the reversal is purely an allocation artifact, not a property of the treatment rates themselves." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "49f01e7cafcdb6b529db5743081ee7b32d708b01" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-15: ReversalThreshold — intensity and margin witness paradox robustness vs fragility" ;
    effortless-ntwf:gitTag "sp-loop-milestone-03-loops-11-15" .

effortless-ntwf:loop-14 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-14" ;
    effortless-ntwf:title "Counterfactual: kidney-balanced isolates allocation as the sole cause of the reversal" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "Fourth study (kidney-balanced): same stratum rates as kidney-1986, equal allocation (175 cases per cell). IsReversal=FALSE, AllocationBias=0, ParadoxStrength=0." ;
    effortless-ntwf:domainQuestion "If the same doctors, same disease, same treatments, same stratum difficulty — but patients were allocated equally — would the paradox still exist? The DAG answers: no. The reversal lives in the allocation, not in the treatment rates." ;
    effortless-ntwf:mockDataNote "kidney-balanced: PooledRateA = (163+128)/350 = 0.831, PooledRateB = (152+120)/350 = 0.777. A wins pooled AND per-stratum. IsReversal=FALSE, ParadoxStrength=0. AllocationBias=0 in both strata. The counterfactual witnesses that the reversal in kidney-1986 is entirely an artifact of differential allocation, not of treatment efficacy." ;
    effortless-ntwf:nextSuggestion "Add ReversalThreshold to TreatmentRankings: the minimum AllocationBias magnitude needed to flip the pooled winner. How far is kidney-1986 from the threshold? How close is berkeley-1973? This quantifies paradox fragility vs robustness." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "49f01e7cafcdb6b529db5743081ee7b32d708b01" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-15: ReversalThreshold — intensity and margin witness paradox robustness vs fragility" ;
    effortless-ntwf:gitTag "sp-loop-milestone-03-loops-11-15" .

effortless-ntwf:loop-15 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-15" ;
    effortless-ntwf:title "ReversalThreshold: how robust or fragile is each study's paradox?" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "MaxAllocationBias, WeightedStratumGapSum, ThresholdMargin on TreatmentRankings" ;
    effortless-ntwf:domainQuestion "How much allocation bias is needed to produce a reversal? Is the observed bias well above threshold (robust paradox) or barely over it (fragile paradox)? ThresholdMargin = observed bias minus minimum needed." ;
    effortless-ntwf:mockDataNote "kidney-1986: ReversalIntensity=1.0, ThresholdMargin=+0.5 — maximally robust, every stratum opposes pooled. berkeley-1973: ReversalIntensity=0.75, ThresholdMargin=+0.25 — past threshold but not unanimous (3/4 departments oppose). balanced-synthetic and kidney-balanced: intensity=0, margin=-0.5 — structurally impossible. ThresholdMargin > 0 means the paradox is robust; < 0 means absent or impossible." ;
    effortless-ntwf:nextSuggestion "Pour a real-world dataset with a known mediator (not confounder) through the same DAG and witness where it lands on the reversal_intensity × paradox_strength plane. The geometry of the plane is the next frontier." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "49f01e7cafcdb6b529db5743081ee7b32d708b01" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-15: ReversalThreshold — intensity and margin witness paradox robustness vs fragility" ;
    effortless-ntwf:gitTag "sp-loop-milestone-03-loops-11-15" .

effortless-ntwf:loop-16 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-16" ;
    effortless-ntwf:title "StratumGap: per-stratum rate difference as a signed witnessed number" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "StratumGap field on StratumSummaries (StratumRateA - StratumRateB, signed)" ;
    effortless-ntwf:domainQuestion "In each stratum, how large is the treatment advantage, and in which direction? StratumGap > 0 means A wins here; < 0 means B wins. Summing StratumGap × StratumFraction gives the equal-weight pooled gap — a new derived node." ;
    effortless-ntwf:mockDataNote "kidney-1986: small-stratum gap = +0.064 (A wins by 6.4pp), large-stratum gap = +0.043 (A wins by 4.3pp). Both positive — A wins everywhere. The pooled gap is negative (B appears to win by 4.6pp) purely due to allocation. The signed gap makes this contradiction arithmetically visible in one column. kidney-balanced: small=+0.064, large=+0.042 (same signs, same magnitudes — the rates are identical to kidney-1986 but now A also wins pooled because allocation is balanced). balanced-synthetic: small=+0.10, large=+0.10 (constant, equal allocation). berkeley-1973: dept-A=−0.200 (female wins), dept-B=+0.011 (male wins barely), dept-C=−0.002 (female wins barely), dept-D=−0.016 (female wins). Mixed signs confirm the partial paradox: no unanimous StratumGap direction, hence no clean reversal." ;
    effortless-ntwf:nextSuggestion "Derive WeightedStratumGapSum on TreatmentRankings: SUM(StratumGap × StratumFraction) aggregated across all TreatmentA rows for this study. This is the equal-weight pooled gap — the gap allocation-free weighting would produce. When WeightedStratumGapSum and PooledGap have opposite signs, the allocation has not just compressed the signal but flipped it. That sign flip is a more precise characterisation of Simpson's Paradox than IsReversal: it handles partial flips and gives a magnitude to the distortion." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "ca3109557acb34bb159bed0ac1c39e5a81cce5dc" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-20+20b: real study hydration via 05b-customize-data.sql — two type-A reversals witnessed" ;
    effortless-ntwf:gitTag "sp-loop-milestone-04-loops-16-31" .

effortless-ntwf:loop-17 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-17" ;
    effortless-ntwf:title "WeightedStratumGapSum: the equal-weight signal — and the Berkeley category error witnessed" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "WeightedStratumGap on StratumSummaries (StratumGap × StratumFraction, the per-stratum contribution to the equal-weight pooled gap); WeightedStratumGapSum on TreatmentRankings (SUMIFS of WeightedStratumGap across TreatmentA rows); SignedPooledGap (PooledRateA − PooledRateB, signed); IsSignFlip boolean (WeightedStratumGapSum and SignedPooledGap have opposite signs)" ;
    effortless-ntwf:domainQuestion "If allocation were equal across strata, what would the pooled gap be? WeightedStratumGapSum answers this. When it has the opposite sign to SignedPooledGap, the allocation has not just compressed the signal — it has flipped it. That sign flip IS Simpson's Paradox under a continuous definition. Does Berkeley sign-flip?" ;
    effortless-ntwf:mockDataNote "Witnessed from DB: balanced-synthetic: WSGSUM=+0.1000, SignedPooledGap=+0.1000 → IsSignFlip=FALSE (equal allocation, no distortion). kidney-1986: WSGSUM=+0.0537, SignedPooledGap=−0.0457 → IsSignFlip=TRUE (A wins in every stratum by 5.4pp on average, but actual pooled shows B winning by 4.6pp). kidney-balanced: WSGSUM=+0.0543, SignedPooledGap=+0.0543 → IsSignFlip=FALSE (equal allocation, WSGSUM = actual pooled gap). berkeley-1973: WSGSUM=−0.0642, SignedPooledGap=+0.1292 → IsSignFlip=TRUE. Per-stratum breakdown: dept-A gap=−0.2035 (female wins by 20.4pp, fraction=0.289); dept-B=−0.0496 (female wins, fraction=0.181); dept-C=+0.0286 (male wins barely, fraction=0.284); dept-D=−0.0184 (female wins, fraction=0.245). Under equal allocation female would win pooled by 6.4pp — but the actual pooled shows male winning by 12.9pp. Berkeley IS a Simpson's Paradox under the sign-flip definition despite IsReversal=FALSE. The binary unanimity criterion excluded Berkeley because dept-C goes to male; the sign-flip criterion correctly includes it." ;
    effortless-ntwf:nextSuggestion "The sign flip is witnessed. Now measure the magnitude: how far has the allocation bent the pooled signal? AllocationDistortion = |WeightedStratumGapSum − SignedPooledGap|. Berkeley: |−0.0642 − (+0.1292)| = 0.1934. Kidney: |+0.0537 − (−0.0457)| = 0.0994. Berkeley's distortion is nearly twice kidney's — despite IsReversal=FALSE. This is the single-number measure that ranks studies by how badly confounding has distorted their pooled result." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "ca3109557acb34bb159bed0ac1c39e5a81cce5dc" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-20+20b: real study hydration via 05b-customize-data.sql — two type-A reversals witnessed" ;
    effortless-ntwf:gitTag "sp-loop-milestone-04-loops-16-31" .

effortless-ntwf:loop-18 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-18" ;
    effortless-ntwf:title "AllocationDistortion: the magnitude of the signal the allocation erased or fabricated" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "AllocationDistortion on TreatmentRankings (|WeightedStratumGapSum − SignedPooledGap|) — the scalar distance between the equal-weight signal and the actual pooled signal" ;
    effortless-ntwf:domainQuestion "How much has the allocation distorted the pooled signal relative to what equal-weight strata would show? AllocationDistortion=0 means the allocation is neutral. A large AllocationDistortion means the pooled number is mostly noise from case assignment, not signal about treatment efficacy." ;
    effortless-ntwf:mockDataNote "Witnessed from DB (ordered by AllocationDistortion desc): berkeley-1973: WSGSUM=−0.0642, SignedPooledGap=+0.1292, AllocationDistortion=0.1934. kidney-1986: WSGSUM=+0.0537, SignedPooledGap=−0.0457, AllocationDistortion=0.0994. kidney-balanced: AllocationDistortion=0.0000 (balanced allocation, no distortion). balanced-synthetic: AllocationDistortion=0.0000 (equal allocation, no distortion). The allocation is injecting a 19.3pp distortion into Berkeley's pooled result — reversing a real female advantage of 6.4pp into an apparent male advantage of 12.9pp. This is nearly twice the 9.9pp distortion in kidney-1986. ParadoxStrength (old measure) gives berkeley=0.0969, kidney=0.0457 — same ordinal ranking but ParadoxStrength is penalized by the unanimity criterion: Berkeley's 0.75 ReversalIntensity reduces its score. AllocationDistortion is not so penalized: it measures what the allocation DID to the signal, not whether the outcome passes an arbitrary threshold." ;
    effortless-ntwf:nextSuggestion "Two severity measures are now live: ParadoxStrength and AllocationDistortion. They agree on ordinal ranking across our four studies but diverge in magnitude (Berkeley is 2× kidney under AllocationDistortion but only 2.1× under ParadoxStrength). The more important question: is a study with AllocationDistortion > 0 but IsSignFlip=FALSE possible? That would be a type-C study — allocation has compressed but not reversed the signal. None of the current studies are type-C. Design a synthetic type-C study: same-sign WSGSUM and SignedPooledGap, but WSGSUM closer to zero than SignedPooledGap. Add it to the data and witness AllocationDistortion > 0, IsSignFlip=FALSE." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "ca3109557acb34bb159bed0ac1c39e5a81cce5dc" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-20+20b: real study hydration via 05b-customize-data.sql — two type-A reversals witnessed" ;
    effortless-ntwf:gitTag "sp-loop-milestone-04-loops-16-31" .

effortless-ntwf:loop-19 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-19" ;
    effortless-ntwf:title "Type-C witness: compressed-synthetic — allocation distortion without sign flip" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "compressed-synthetic study (fifth study): type-C case — A wins every stratum and wins pooled, but allocation compresses A's pooled advantage. Witnesses AllocationDistortion > 0, IsSignFlip=FALSE, IsReversal=FALSE, PerStratumWinner=A. Completes the four-type taxonomy." ;
    effortless-ntwf:domainQuestion "Does a study with real allocation distortion (AllocationDistortion > 0) but no sign flip (IsSignFlip=FALSE) exist? If yes, the type-C cell in the DistortionType taxonomy is nonempty — there is a class of misleading aggregates that compress but do not reverse the pooled signal. This class is invisible to both IsReversal and IsSignFlip but is visible to AllocationDistortion." ;
    effortless-ntwf:mockDataNote "Witnessed from DB (ordered by AllocationDistortion desc): berkeley-1973: WSGSUM=−0.0642, SignedPooledGap=+0.1292, IsSignFlip=TRUE, AllocationDistortion=0.1934, ReversalIntensity=0.75 → type B. kidney-1986: WSGSUM=+0.0537, SignedPooledGap=−0.0457, IsSignFlip=TRUE, AllocationDistortion=0.0994, ReversalIntensity=1.0 → type A. compressed-synthetic: WSGSUM=+0.1000, SignedPooledGap=+0.0600, IsSignFlip=FALSE, AllocationDistortion=0.0400, ReversalIntensity=0.0 → type C (A wins pooled by 6pp but would win by 10pp under equal allocation). kidney-balanced: AllocationDistortion=0.0000 → type D. balanced-synthetic: AllocationDistortion=0.0000 → type D. All four types are now empirically populated. Type-C is important: a researcher seeing pooled A=78%, B=72% and concluding 'A wins by 6pp' is correct — but the equal-weight truth is 'A wins by 10pp.' The allocation has consumed 4pp of signal without a single stratum switching winner." ;
    effortless-ntwf:nextSuggestion "All four DistortionType cells are now populated. Add DistortionType as a derived field on TreatmentRankings: A = IsSignFlip AND ReversalIntensity=1.0; B = IsSignFlip AND ReversalIntensity<1.0; C = NOT IsSignFlip AND AllocationDistortion>0.01; D = AllocationDistortion≤0.01. This makes the geometric taxonomy a first-class derived fact in the DAG. Then add PolicyImplication per type: type A = stratify-immediately; type B = investigate-confounder; type C = check-allocation-bias; type D = pooled-analysis-trustworthy." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "ca3109557acb34bb159bed0ac1c39e5a81cce5dc" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-20+20b: real study hydration via 05b-customize-data.sql — two type-A reversals witnessed" ;
    effortless-ntwf:gitTag "sp-loop-milestone-04-loops-16-31" .

effortless-ntwf:loop-20 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-20" ;
    effortless-ntwf:title "Hydration contract: real study data enters through 05b-customize-data.sql, not the rulebook JSON" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "Real study data lives directly in the rulebook JSON — the SSoT is unified. Provenance files in data/raw/. The view chain computes everything from there." ;
    effortless-ntwf:domainQuestion "Can real published study data enter the instrument through a SQL hydration file (not the rulebook JSON) and produce DistortionType / AllocationDistortion / PolicyImplication results from the existing view chain without any schema changes?" ;
    effortless-ntwf:mockDataNote "Two real studies hydrated: reintjes-2000 (Epidemiology 2000, N=3519, antibiotic prophylaxis UTI study) and radelet-1981 (Am Soc Rev 1981, N=326, Florida death penalty). Both are type-A full reversals. Witnessed: reintjes AllocationDistortion=0.0516, radelet AllocationDistortion=0.0684. No schema changes were needed. 05b-customize-data.sql is the durable hydration path." ;
    effortless-ntwf:nextSuggestion "ModelSummary currently counts only synthetic studies in its ReversalCount/NonReversalCount. Add DistortionType aggregations (TypeACount, TypeBCount, TypeCCount, TypeDCount, SignFlipCount, AvgAllocationDistortion) so the model's self-portrait reflects all seven studies including the two real ones." ;
    effortless-ntwf:traditionId "tradition-epidemiology" ;
    effortless-ntwf:commitHash "ca3109557acb34bb159bed0ac1c39e5a81cce5dc" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-20+20b: real study hydration via 05b-customize-data.sql — two type-A reversals witnessed" ;
    effortless-ntwf:gitTag "sp-loop-milestone-04-loops-16-31" .

effortless-ntwf:loop-20b a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-20b" ;
    effortless-ntwf:title "Two real studies witnessed: reintjes-2000 and radelet-1981 — both type-A full reversals from real data in the rulebook" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "Two non-canonical published datasets poured through the hydration contract. Provenance files in data/raw/. Instrument produces correct DistortionType=A and PolicyImplication=stratify-immediately for both." ;
    effortless-ntwf:domainQuestion "Do two real published studies with well-known outcomes (antibiotic prophylaxis UTI reversal; racial death-penalty reversal) produce the expected DistortionType=A when hydrated through the instrument? Does the AllocationDistortion magnitude match the known mechanism story?" ;
    effortless-ntwf:mockDataNote "Witnessed from DB (full table ordered by AllocationDistortion desc): berkeley-1973: type B, distortion=0.1934. kidney-1986: type A, distortion=0.0994. radelet-1981: type A, distortion=0.0684 (REAL). reintjes-2000: type A, distortion=0.0516 (REAL). compressed-synthetic: type C, distortion=0.0400. kidney-balanced: type D, distortion=0.0000. balanced-synthetic: type D, distortion=0.0000. Both real studies are full type-A reversals as expected from the literature. radelet has higher AllocationDistortion (0.0684) than reintjes (0.0516), consistent with the victim-race confound being stronger — black defendants are 62% in the low-sentence black-victim stratum, a more extreme allocation imbalance than reintjes where 87% of prophylaxis patients are in low-incidence hospitals." ;
    effortless-ntwf:nextSuggestion "ModelSummary currently counts only the synthetic study set. Add DistortionType aggregations (TypeACount, TypeBCount, TypeCCount, TypeDCount, SignFlipCount, AvgAllocationDistortion) so the model describes its real empirical coverage, not just the synthetic controls." ;
    effortless-ntwf:traditionId "tradition-epidemiology" ;
    effortless-ntwf:commitHash "ca3109557acb34bb159bed0ac1c39e5a81cce5dc" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-20+20b: real study hydration via 05b-customize-data.sql — two type-A reversals witnessed" ;
    effortless-ntwf:gitTag "sp-loop-milestone-04-loops-16-31" .

effortless-ntwf:loop-21 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-21" ;
    effortless-ntwf:title "DistortionType + PolicyImplication: the four-type taxonomy as a first-class DAG fact" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "DistortionType (derived field on TreatmentRankings): A = full sign-flip unanimous reversal; B = sign-flip non-unanimous; C = distortion without sign flip; D = neutral. PolicyImplication (derived from DistortionType): A → stratify-immediately; B → investigate-confounder; C → check-allocation-bias; D → pooled-analysis-trustworthy." ;
    effortless-ntwf:domainQuestion "Can the geometric taxonomy (four cells defined by IsSignFlip × ReversalIntensity × AllocationDistortion magnitude) be collapsed into a single derived field that a researcher or policy layer can read without knowing the internal coordinates?" ;
    effortless-ntwf:mockDataNote "All five current studies resolve cleanly: kidney-1986 → type A (stratify-immediately); berkeley-1973 → type B (investigate-confounder); compressed-synthetic → type C (check-allocation-bias); kidney-balanced → type D (pooled-analysis-trustworthy); balanced-synthetic → type D (pooled-analysis-trustworthy). DistortionType and PolicyImplication are now first-class columns in vw_TreatmentRankings — the visualizer and any downstream consumer reads them directly without re-deriving the geometry." ;
    effortless-ntwf:nextSuggestion "ModelSummary currently counts ReversalCount and NonReversalCount using the old IsReversal (unanimity) criterion. Add DistortionType aggregations: TypeACount, TypeBCount, TypeCCount, TypeDCount, SignFlipCount (TypeA+TypeB), and AvgAllocationDistortion. These make the model's self-portrait accurate under the new continuous geometry rather than the obsolete binary criterion." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "ca3109557acb34bb159bed0ac1c39e5a81cce5dc" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-20+20b: real study hydration via 05b-customize-data.sql — two type-A reversals witnessed" ;
    effortless-ntwf:gitTag "sp-loop-milestone-04-loops-16-31" .

effortless-ntwf:loop-22 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-22" ;
    effortless-ntwf:title "ModelSummary DistortionType aggregations: the model's self-portrait updated to the new geometry" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "TypeACount, TypeBCount, TypeCCount, TypeDCount, SignFlipCount, AvgAllocationDistortion on ModelSummary. RealDataOnly filter so synthetic controls can be excluded from empirical summaries." ;
    effortless-ntwf:domainQuestion "Across all studies in this model, what is the DistortionType breakdown? How many sign-flips, what is the average AllocationDistortion? The current ModelSummary reports reversal_count=5 under the old unanimity criterion — this loop makes it accurate under the new continuous geometry." ;
    effortless-ntwf:nextSuggestion "With the model's self-portrait corrected, formally name IsReversal_v2 = IsSignFlip as a first-class field and document that the unanimity IsReversal is now a strict subtype (DistortionType=A only)." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "ca3109557acb34bb159bed0ac1c39e5a81cce5dc" ;
    effortless-ntwf:commitDate "2026-06-27" ;
    effortless-ntwf:commitMessage "loop-20+20b: real study hydration via 05b-customize-data.sql — two type-A reversals witnessed" ;
    effortless-ntwf:gitTag "sp-loop-milestone-04-loops-16-31" .

effortless-ntwf:loop-23 a effortless-ntwf:Loops ;
    effortless-ntwf:loopId "loop-23" ;
    effortless-ntwf:title "IsReversal_v2: formally retire the unanimity criterion as the primary definition" ;
    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "IsReversal_v2 = IsSignFlip as a named first-class field on TreatmentRankings. DefinitionDelta = IsReversal_v2 XOR IsReversal (identifies studies where the two definitions disagree — currently berkeley-1973 and appleton-1996). StrictReversalSubtype label preserving the unanimity criterion as DistortionType=A." ;
    effortless-ntwf:domainQuestion "Does the sign-flip definition strictly generalize the old unanimity definition across all 10 hydrated studies? Berkeley-1973 and appleton-1996 are the critical cases: IsReversal=FALSE but IsSignFlip=TRUE. DefinitionDelta witnesses exactly which studies the old definition misclassified." ;
    effortless-ntwf:nextSuggestion "Find one real published study that hydrates as DistortionType=C (AllocationDistortion>0, IsSignFlip=FALSE) to prove the type-C cell is not merely a synthetic pathology." ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:commitHash "ca3109557acb34bb159bed0ac1c39e5a81cce5dc" ;
