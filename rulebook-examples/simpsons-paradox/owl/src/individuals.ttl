# === Individuals: Studies ===

effortless-ntwf:kidney-1986 a effortless-ntwf:Studies ;
    effortless-ntwf:studyId "kidney-1986" ;
    effortless-ntwf:title "Kidney Stone Treatment Study (Charig et al. 1986)" ;
    effortless-ntwf:source "Charig CR et al. Comparison of treatment of renal calculi by open surgery, percutaneous nephrolithotomy, and extracorporeal shockwave lithotripsy. Br Med J. 1986;292:879." ;
    effortless-ntwf:sourceUrl "https://www.bmj.com/content/292/6524/879" ;
    effortless-ntwf:publicationYear 1986 ;
    effortless-ntwf:domain "medicine" ;
    effortless-ntwf:isSynthetic false ;
    effortless-ntwf:traditionId "tradition-historical" ;
    effortless-ntwf:primaryResearcherId "researcher-blyth" .

effortless-ntwf:balanced-synthetic a effortless-ntwf:Studies ;
    effortless-ntwf:studyId "balanced-synthetic" ;
    effortless-ntwf:title "Balanced Synthetic Study (degenerate case — reversal structurally impossible)" ;
    effortless-ntwf:source "Synthetic dataset constructed to demonstrate that perfectly balanced treatment allocation across strata algebraically prevents Simpson's Paradox. Not based on real data." ;
    effortless-ntwf:sourceUrl "" ;
    effortless-ntwf:domain "synthetic" ;
    effortless-ntwf:isSynthetic true ;
    effortless-ntwf:traditionId "tradition-historical" .

effortless-ntwf:kidney-balanced a effortless-ntwf:Studies ;
    effortless-ntwf:studyId "kidney-balanced" ;
    effortless-ntwf:title "Kidney Stone Counterfactual (balanced allocation — reversal algebraically impossible)" ;
    effortless-ntwf:source "Synthetic dataset derived from Charig 1986 kidney stone rates but with equal treatment allocation across strata (175 cases per cell). Demonstrates that the reversal in the original study is purely an allocation artifact." ;
    effortless-ntwf:sourceUrl "" ;
    effortless-ntwf:domain "synthetic" ;
    effortless-ntwf:isSynthetic true ;
    effortless-ntwf:traditionId "tradition-historical" .

effortless-ntwf:berkeley-1973 a effortless-ntwf:Studies ;
