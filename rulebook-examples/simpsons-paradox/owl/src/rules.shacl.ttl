                BIND(((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "D") && (?signal_purity = 1) && (?allocation_distortion = 0) && (?sweep_pooled_gap_range > 0.3) && (?allocation_fragility >= 10)) AS ?_result)
