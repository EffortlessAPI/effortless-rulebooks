    OPTIONAL { $this effortless-ntwf:confoundersInStudy ?confounders_in_study . }
    OPTIONAL { $this effortless-ntwf:isReversal ?is_reversal . }
                BIND((?is_reversal && (?confounders_in_study > 0)) AS ?_result)
            }
