            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DiscoveryFindings_Evidence" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:evidence ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DiscoveryFindings .
    OPTIONAL { $this effortless-ntwf:isConfirmed ?is_confirmed . }
    OPTIONAL { $this effortless-ntwf:observedMetric ?observed_metric . }
                BIND(IF((?is_confirmed = true), CONCAT("PASS: ", IF(isIRI(?observed_metric), REPLACE(STR(?observed_metric), "^.*[#/]", ""), STR(?observed_metric))), IF((?is_confirmed = false), CONCAT("FAIL: ", IF(isIRI(?observed_metric), REPLACE(STR(?observed_metric), "^.*[#/]", ""), STR(?observed_metric))), "")) AS ?_result)
            }
        """ ;
    ] .
# Rule for ObservedMetric - parse error: unsupported lookup sub-expression: FuncCall

# === Shape with rules for DiscoveryHypotheses ===
effortless-ntwf:DiscoveryHypothesesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:DiscoveryHypotheses ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DiscoveryHypotheses_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DiscoveryHypotheses .
    OPTIONAL { $this effortless-ntwf:hypothesisId ?hypothesis_id . }
                BIND(?hypothesis_id AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for DomainExpansionTargets ===
effortless-ntwf:DomainExpansionTargetsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:DomainExpansionTargets ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DomainExpansionTargets_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DomainExpansionTargets .
    OPTIONAL { $this effortless-ntwf:domainTargetId ?domain_target_id . }
                BIND(?domain_target_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DomainExpansionTargets_CandidateQueuedCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:candidateQueuedCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DomainExpansionTargets .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    ?child effortless-ntwf:domain ?backfk .
                    $this effortless-ntwf:domain ?backpv .
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c2 . }
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER((STR(?c2) = "candidate"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DomainExpansionTargets_ProjectedCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:projectedCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DomainExpansionTargets .
    OPTIONAL { $this effortless-ntwf:candidateQueuedCount ?candidate_queued_count . }
    OPTIONAL { $this effortless-ntwf:currentImportedCount ?current_imported_count . }
                BIND((?current_imported_count + ?candidate_queued_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DomainExpansionTargets_GapCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:gapCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DomainExpansionTargets .
    OPTIONAL { $this effortless-ntwf:projectedCount ?projected_count . }
    OPTIONAL { $this effortless-ntwf:targetMinCount ?target_min_count . }
                BIND(IF((0) > ((?target_min_count - ?projected_count)), (0), ((?target_min_count - ?projected_count))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DomainExpansionTargets_IsUnderRepresented" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isUnderRepresented ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DomainExpansionTargets .
    OPTIONAL { $this effortless-ntwf:projectedCount ?projected_count . }
    OPTIONAL { $this effortless-ntwf:targetMinCount ?target_min_count . }
                BIND((?projected_count < ?target_min_count) AS ?_result)
            }
        """ ;
    ] .
# Rule for CurrentImportedCount - parse error: unsupported COUNTIFS criteria: FuncCall

# === Shape with rules for IngestionProtocol ===
effortless-ntwf:IngestionProtocolShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:IngestionProtocol ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IngestionProtocol_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IngestionProtocol .
    OPTIONAL { $this effortless-ntwf:protocolId ?protocol_id . }
                BIND(?protocol_id AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for IngestionSummary ===
effortless-ntwf:IngestionSummaryShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:IngestionSummary ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IngestionSummary_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IngestionSummary .
    OPTIONAL { $this effortless-ntwf:ingestionSummaryId ?ingestion_summary_id . }
                BIND(?ingestion_summary_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IngestionSummary_ProtocolItemCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:protocolItemCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IngestionSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:IngestionProtocol .
                    OPTIONAL { ?child effortless-ntwf:protocolId ?c0 . }
                    FILTER((STR(?c0) != ""))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IngestionSummary_CorpusCellCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:corpusCellCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IngestionSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CaseCells .
                    OPTIONAL { ?child effortless-ntwf:caseCellId ?c0 . }
                    FILTER((STR(?c0) != ""))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IngestionSummary_ValidCellCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:validCellCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IngestionSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CaseCells .
                    OPTIONAL { ?child effortless-ntwf:isValidIngestionCell ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IngestionSummary_AllCellsValid" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:allCellsValid ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IngestionSummary .
    OPTIONAL { $this effortless-ntwf:corpusCellCount ?corpus_cell_count . }
    OPTIONAL { $this effortless-ntwf:validCellCount ?valid_cell_count . }
                BIND((?valid_cell_count = ?corpus_cell_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IngestionSummary_StudyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:studyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IngestionSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:Studies .
                    OPTIONAL { ?child effortless-ntwf:studyId ?c0 . }
                    FILTER((STR(?c0) != ""))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IngestionSummary_StructuralCompliantCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:structuralCompliantCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IngestionSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:Studies .
                    OPTIONAL { ?child effortless-ntwf:ingestionCellParity ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IngestionSummary_AllStudiesStructural" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:allStudiesStructural ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IngestionSummary .
    OPTIONAL { $this effortless-ntwf:structuralCompliantCount ?structural_compliant_count . }
    OPTIONAL { $this effortless-ntwf:studyCount ?study_count . }
                BIND((?structural_compliant_count = ?study_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IngestionSummary_RealStudyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:realStudyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IngestionSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:Studies .
                    OPTIONAL { ?child effortless-ntwf:isSynthetic ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = false)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IngestionSummary_RealFullyCompliantCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:realFullyCompliantCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IngestionSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:Studies .
                    OPTIONAL { ?child effortless-ntwf:ingestionCompliance ?c0 . }
                    FILTER((STR(?c0) = "all"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IngestionSummary_AllRealStudiesCompliant" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:allRealStudiesCompliant ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IngestionSummary .
    OPTIONAL { $this effortless-ntwf:realFullyCompliantCount ?real_fully_compliant_count . }
    OPTIONAL { $this effortless-ntwf:realStudyCount ?real_study_count . }
                BIND((?real_fully_compliant_count = ?real_study_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IngestionSummary_IngestionContractPasses" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:ingestionContractPasses ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IngestionSummary .
    OPTIONAL { $this effortless-ntwf:allCellsValid ?all_cells_valid . }
    OPTIONAL { $this effortless-ntwf:allRealStudiesCompliant ?all_real_studies_compliant . }
    OPTIONAL { $this effortless-ntwf:allStudiesStructural ?all_studies_structural . }
                BIND((?all_cells_valid && ?all_studies_structural && ?all_real_studies_compliant) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IngestionSummary_IngestionWitnessNote" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:ingestionWitnessNote ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IngestionSummary .
    OPTIONAL { $this effortless-ntwf:corpusCellCount ?corpus_cell_count . }
    OPTIONAL { $this effortless-ntwf:ingestionContractPasses ?ingestion_contract_passes . }
    OPTIONAL { $this effortless-ntwf:protocolItemCount ?protocol_item_count . }
    OPTIONAL { $this effortless-ntwf:realFullyCompliantCount ?real_fully_compliant_count . }
    OPTIONAL { $this effortless-ntwf:realStudyCount ?real_study_count . }
                BIND(IF(?ingestion_contract_passes, CONCAT("PASS: ", IF(isIRI(?protocol_item_count), REPLACE(STR(?protocol_item_count), "^.*[#/]", ""), STR(?protocol_item_count)), " contract items; ", IF(isIRI(?corpus_cell_count), REPLACE(STR(?corpus_cell_count), "^.*[#/]", ""), STR(?corpus_cell_count)), " cells valid; ", IF(isIRI(?real_fully_compliant_count), REPLACE(STR(?real_fully_compliant_count), "^.*[#/]", ""), STR(?real_fully_compliant_count)), "/", IF(isIRI(?real_study_count), REPLACE(STR(?real_study_count), "^.*[#/]", ""), STR(?real_study_count)), " real studies fully compliant"), "FAIL: ingestion contract violated") AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for InstrumentSpec ===
effortless-ntwf:InstrumentSpecShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:InstrumentSpec ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InstrumentSpec_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InstrumentSpec .
    OPTIONAL { $this effortless-ntwf:specId ?spec_id . }
                BIND(?spec_id AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for InvariantChecks ===
effortless-ntwf:InvariantChecksShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:InvariantChecks ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InvariantChecks_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InvariantChecks .
    OPTIONAL { $this effortless-ntwf:invariantCheckId ?invariant_check_id . }
                BIND(?invariant_check_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InvariantChecks_UniverseCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:universeCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InvariantChecks .
    OPTIONAL { $this effortless-ntwf:failCount ?fail_count . }
    OPTIONAL { $this effortless-ntwf:passCount ?pass_count . }
                BIND((?pass_count + ?fail_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InvariantChecks_IsGreen" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isGreen ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InvariantChecks .
    OPTIONAL { $this effortless-ntwf:failCount ?fail_count . }
                BIND((?fail_count = 0) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InvariantChecks_StatusLabel" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:statusLabel ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InvariantChecks .
    OPTIONAL { $this effortless-ntwf:failCount ?fail_count . }
    OPTIONAL { $this effortless-ntwf:isGreen ?is_green . }
                BIND(IF(?is_green, "PASS", CONCAT("FAIL(", IF(isIRI(?fail_count), REPLACE(STR(?fail_count), "^.*[#/]", ""), STR(?fail_count)), ")")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InvariantChecks_TraditionName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:traditionName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InvariantChecks .
                OPTIONAL { $this effortless-ntwf:traditionId ?tradition_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:name ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InvariantChecks_TraditionKeyClaimSummary" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:traditionKeyClaimSummary ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InvariantChecks .
                OPTIONAL { $this effortless-ntwf:traditionId ?tradition_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:keyClaim ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InvariantChecks_ProtectsConclusionTitle" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:protectsConclusionTitle ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InvariantChecks .
                OPTIONAL { $this effortless-ntwf:protectsConclusion ?protects_conclusion . }
                OPTIONAL { ?j0 a effortless-ntwf:Conclusions ; effortless-ntwf:conclusionId ?j1 ; effortless-ntwf:title ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?protects_conclusion), "^.*[#/]", "")) || (?j0 = ?protects_conclusion)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_InvariantChecks_ProtectsConclusionCategory" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:protectsConclusionCategory ?_result .
            }
            WHERE {
    $this a effortless-ntwf:InvariantChecks .
                OPTIONAL { $this effortless-ntwf:protectsConclusion ?protects_conclusion . }
                OPTIONAL { ?j0 a effortless-ntwf:Conclusions ; effortless-ntwf:conclusionId ?j1 ; effortless-ntwf:category ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?protects_conclusion), "^.*[#/]", "")) || (?j0 = ?protects_conclusion)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for Loops ===
effortless-ntwf:LoopsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Loops ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Loops_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Loops .
    OPTIONAL { $this effortless-ntwf:loopId ?loop_id . }
                BIND(?loop_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Loops_TraditionName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:traditionName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Loops .
                OPTIONAL { $this effortless-ntwf:traditionId ?tradition_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:name ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Loops_TraditionCoreConern" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:traditionCoreConern ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Loops .
                OPTIONAL { $this effortless-ntwf:traditionId ?tradition_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:coreConcern ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Loops_CommitShort" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:commitShort ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Loops .
    OPTIONAL { $this effortless-ntwf:commitHash ?commit_hash . }
                BIND(SUBSTR(STR(?commit_hash), 1, 7) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for Methodology ===
effortless-ntwf:MethodologyShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Methodology ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Methodology_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Methodology .
    OPTIONAL { $this effortless-ntwf:methodologyId ?methodology_id . }
                BIND(?methodology_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Methodology_TraditionName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:traditionName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Methodology .
                OPTIONAL { $this effortless-ntwf:traditionId ?tradition_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:name ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Methodology_TraditionPrimaryVenue" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:traditionPrimaryVenue ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Methodology .
                OPTIONAL { $this effortless-ntwf:traditionId ?tradition_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:primaryVenue ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Methodology_PioneeringResearcherName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:pioneeringResearcherName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Methodology .
                OPTIONAL { $this effortless-ntwf:pioneeringResearcher ?pioneering_researcher . }
                OPTIONAL { ?j0 a effortless-ntwf:Researchers ; effortless-ntwf:researcherId ?j1 ; effortless-ntwf:name ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?pioneering_researcher), "^.*[#/]", "")) || (?j0 = ?pioneering_researcher)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Methodology_PioneeringResearcherAffiliation" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:pioneeringResearcherAffiliation ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Methodology .
                OPTIONAL { $this effortless-ntwf:pioneeringResearcher ?pioneering_researcher . }
                OPTIONAL { ?j0 a effortless-ntwf:Researchers ; effortless-ntwf:researcherId ?j1 ; effortless-ntwf:affiliation ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?pioneering_researcher), "^.*[#/]", "")) || (?j0 = ?pioneering_researcher)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Methodology_LoopCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:loopCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Methodology .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:Loops .
                    ?child effortless-ntwf:traditionId ?backfk .
                    $this effortless-ntwf:traditionId ?backpv .
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    }
                }
            }
        """ ;
    ] .

# === Shape with rules for ModelSummary ===
effortless-ntwf:ModelSummaryShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:ModelSummary ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:modelSummaryId ?model_summary_id . }
                BIND(?model_summary_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_ReversalCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:reversalCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:isReversal ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_NonReversalCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:nonReversalCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:isReversal ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = false)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_StudyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:studyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:nonReversalCount ?non_reversal_count . }
    OPTIONAL { $this effortless-ntwf:reversalCount ?reversal_count . }
                BIND((?reversal_count + ?non_reversal_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_ExplainedCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:explainedCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:isParadoxExplained ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_TotalParadoxStrength" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:totalParadoxStrength ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (SUM(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:treatmentA ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:paradoxStrength ?sumraw . }
                    BIND(IF(BOUND(?sumraw), xsd:double(STR(?sumraw)), 0.0) AS ?sumval)
                    FILTER((STR(?c0) = "A"))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_AvgParadoxStrength" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:avgParadoxStrength ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:studyCount ?study_count . }
    OPTIONAL { $this effortless-ntwf:totalParadoxStrength ?total_paradox_strength . }
                BIND(IF((?study_count = 0), "", (?total_paradox_strength / ?study_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_TypeACount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typeACount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:distortionType ?c0 . }
                    FILTER((STR(?c0) = "A"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_TypeBCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typeBCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:distortionType ?c0 . }
                    FILTER((STR(?c0) = "B"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_TypeDCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typeDCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:distortionType ?c0 . }
                    FILTER((STR(?c0) = "D"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_TypeAFraction" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typeAFraction ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:studyCount ?study_count . }
    OPTIONAL { $this effortless-ntwf:typeACount ?type_a_count . }
                BIND(IF((?study_count = 0), "", (?type_a_count / ?study_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_DistortionTaxonomyCoverage" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:distortionTaxonomyCoverage ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:cAmplificationCount ?c_amplification_count . }
    OPTIONAL { $this effortless-ntwf:cCompressionCount ?c_compression_count . }
    OPTIONAL { $this effortless-ntwf:typeACount ?type_a_count . }
    OPTIONAL { $this effortless-ntwf:typeBCount ?type_b_count . }
    OPTIONAL { $this effortless-ntwf:typeDCount ?type_d_count . }
                BIND(CONCAT("A:", IF(isIRI(?type_a_count), REPLACE(STR(?type_a_count), "^.*[#/]", ""), STR(?type_a_count)), " B:", IF(isIRI(?type_b_count), REPLACE(STR(?type_b_count), "^.*[#/]", ""), STR(?type_b_count)), " C+:", IF(isIRI(?c_amplification_count), REPLACE(STR(?c_amplification_count), "^.*[#/]", ""), STR(?c_amplification_count)), " C-:", IF(isIRI(?c_compression_count), REPLACE(STR(?c_compression_count), "^.*[#/]", ""), STR(?c_compression_count)), " D:", IF(isIRI(?type_d_count), REPLACE(STR(?type_d_count), "^.*[#/]", ""), STR(?type_d_count))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_DistortionOnlyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:distortionOnlyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:cAmplificationCount ?c_amplification_count . }
    OPTIONAL { $this effortless-ntwf:cCompressionCount ?c_compression_count . }
                BIND((?c_amplification_count + ?c_compression_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_CAmplificationCount" ;
