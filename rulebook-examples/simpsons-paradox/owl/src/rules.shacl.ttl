# Rule for StudyCount - parse error: Expected TokenType.LPAREN, got TokenType.COMMA at position 63

# === Shape with rules for CorpusBalance ===
effortless-ntwf:CorpusBalanceShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:CorpusBalance ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusBalance_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusBalance .
    OPTIONAL { $this effortless-ntwf:balanceId ?balance_id . }
                BIND(?balance_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusBalance_TotalStudyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:totalStudyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusBalance .
    OPTIONAL { $this effortless-ntwf:controlStudyCount ?control_study_count . }
    OPTIONAL { $this effortless-ntwf:simpsonStudyCount ?simpson_study_count . }
                BIND((?simpson_study_count + ?control_study_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusBalance_SimpsonStudyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:simpsonStudyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusBalance .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:Studies .
                    OPTIONAL { ?child effortless-ntwf:isControlStudy ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = false)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusBalance_ControlStudyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:controlStudyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusBalance .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:Studies .
                    OPTIONAL { ?child effortless-ntwf:isControlStudy ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusBalance_ControlFraction" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:controlFraction ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusBalance .
    OPTIONAL { $this effortless-ntwf:controlStudyCount ?control_study_count . }
    OPTIONAL { $this effortless-ntwf:totalStudyCount ?total_study_count . }
                BIND(IF((?total_study_count = 0), 0, (?control_study_count / ?total_study_count)) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for CorpusCatalogSummary ===
effortless-ntwf:CorpusCatalogSummaryShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:CorpusCatalogSummary ;
