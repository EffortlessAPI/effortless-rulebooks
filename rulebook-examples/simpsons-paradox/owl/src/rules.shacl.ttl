                OPTIONAL { ?j66 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j67 ; effortless-ntwf:cMinusAvgDistortion ?j68 . FILTER((REPLACE(STR(?j67), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j66 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j69 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j70 ; effortless-ntwf:cPlusAvgDistortion ?j71 . FILTER((REPLACE(STR(?j70), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j69 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j72 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j73 ; effortless-ntwf:typeDAvgDistortion ?j74 . FILTER((REPLACE(STR(?j73), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j72 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j75 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j76 ; effortless-ntwf:economicsExpectedAMismatchRate ?j77 . FILTER((REPLACE(STR(?j76), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j75 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j78 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j79 ; effortless-ntwf:educationLatentFraction ?j80 . FILTER((REPLACE(STR(?j79), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j78 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j81 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j82 ; effortless-ntwf:sportsLatentFraction ?j83 . FILTER((REPLACE(STR(?j82), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j81 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j84 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j85 ; effortless-ntwf:economicsSignFlipRate ?j86 . FILTER((REPLACE(STR(?j85), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j84 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j87 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j88 ; effortless-ntwf:maxStudySweepCorrectedGapRange ?j89 . FILTER((REPLACE(STR(?j88), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j87 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j90 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j91 ; effortless-ntwf:correctedGapInvariantFailCount ?j92 . FILTER((REPLACE(STR(?j91), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j90 = "simpsons-paradox-v1")) }
