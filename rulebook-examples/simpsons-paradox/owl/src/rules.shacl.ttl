# === Shape with rules for PhaseDiagramSummary ===
effortless-ntwf:PhaseDiagramSummaryShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:PhaseDiagramSummary ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_PhaseDiagramSummary_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:PhaseDiagramSummary .
    OPTIONAL { $this effortless-ntwf:phaseDiagramId ?phase_diagram_id . }
                BIND(?phase_diagram_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_PhaseDiagramSummary_PhasePointCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phasePointCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:PhaseDiagramSummary .
    OPTIONAL { $this effortless-ntwf:phaseTypeACount ?phase_type_a_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeBCount ?phase_type_b_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCMinusCount ?phase_type_c_minus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCPlusCount ?phase_type_c_plus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeDCount ?phase_type_d_count . }
                BIND(((((?phase_type_a_count + ?phase_type_b_count) + ?phase_type_c_plus_count) + ?phase_type_c_minus_count) + ?phase_type_d_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_PhaseDiagramSummary_AllFiveTypesPresent" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:allFiveTypesPresent ?_result .
            }
            WHERE {
    $this a effortless-ntwf:PhaseDiagramSummary .
    OPTIONAL { $this effortless-ntwf:phaseTypeACount ?phase_type_a_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeBCount ?phase_type_b_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCMinusCount ?phase_type_c_minus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCPlusCount ?phase_type_c_plus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeDCount ?phase_type_d_count . }
                BIND(((?phase_type_a_count > 0) && (?phase_type_b_count > 0) && (?phase_type_c_plus_count > 0) && (?phase_type_c_minus_count > 0) && (?phase_type_d_count > 0)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_PhaseDiagramSummary_PhaseTaxonomyWitness" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseTaxonomyWitness ?_result .
            }
            WHERE {
    $this a effortless-ntwf:PhaseDiagramSummary .
    OPTIONAL { $this effortless-ntwf:phaseTypeACount ?phase_type_a_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeBCount ?phase_type_b_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCMinusCount ?phase_type_c_minus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCPlusCount ?phase_type_c_plus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeDCount ?phase_type_d_count . }
                BIND(CONCAT("A:", IF(isIRI(?phase_type_a_count), REPLACE(STR(?phase_type_a_count), "^.*[#/]", ""), STR(?phase_type_a_count)), " B:", IF(isIRI(?phase_type_b_count), REPLACE(STR(?phase_type_b_count), "^.*[#/]", ""), STR(?phase_type_b_count)), " C+:", IF(isIRI(?phase_type_c_plus_count), REPLACE(STR(?phase_type_c_plus_count), "^.*[#/]", ""), STR(?phase_type_c_plus_count)), " C-:", IF(isIRI(?phase_type_c_minus_count), REPLACE(STR(?phase_type_c_minus_count), "^.*[#/]", ""), STR(?phase_type_c_minus_count)), " D:", IF(isIRI(?phase_type_d_count), REPLACE(STR(?phase_type_d_count), "^.*[#/]", ""), STR(?phase_type_d_count))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_PhaseDiagramSummary_PhaseWitnessNote" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseWitnessNote ?_result .
            }
            WHERE {
    $this a effortless-ntwf:PhaseDiagramSummary .
    OPTIONAL { $this effortless-ntwf:allFiveTypesPresent ?all_five_types_present . }
                BIND(IF(?all_five_types_present, "PASS: all five distortion types populated in parameter space", "FAIL: missing distortion type in grid") AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for ResearchTraditions ===
effortless-ntwf:ResearchTraditionsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:ResearchTraditions ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ResearchTraditions_IllustratedByStudyTitle" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:illustratedByStudyTitle ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ResearchTraditions .
                OPTIONAL { $this effortless-ntwf:illustratedByStudy ?illustrated_by_study . }
                OPTIONAL { ?j0 a effortless-ntwf:Studies ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:title ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?illustrated_by_study), "^.*[#/]", "")) || (?j0 = ?illustrated_by_study)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ResearchTraditions_IllustratedByStudySource" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:illustratedByStudySource ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ResearchTraditions .
                OPTIONAL { $this effortless-ntwf:illustratedByStudy ?illustrated_by_study . }
                OPTIONAL { ?j0 a effortless-ntwf:Studies ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:source ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?illustrated_by_study), "^.*[#/]", "")) || (?j0 = ?illustrated_by_study)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ResearchTraditions_IllustratedByStudyDistortionType" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:illustratedByStudyDistortionType ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ResearchTraditions .
                OPTIONAL { $this effortless-ntwf:illustratedByStudy ?illustrated_by_study . }
                OPTIONAL { ?j0 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j1 ; effortless-ntwf:distortionType ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?illustrated_by_study), "^.*[#/]", "")) || (?j0 = ?illustrated_by_study)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ResearchTraditions_SupportingConclusionTitle" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:supportingConclusionTitle ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ResearchTraditions .
                OPTIONAL { $this effortless-ntwf:supportingConclusion ?supporting_conclusion . }
                OPTIONAL { ?j0 a effortless-ntwf:Conclusions ; effortless-ntwf:conclusionId ?j1 ; effortless-ntwf:title ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?supporting_conclusion), "^.*[#/]", "")) || (?j0 = ?supporting_conclusion)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ResearchTraditions_SupportingConclusionCategory" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:supportingConclusionCategory ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ResearchTraditions .
                OPTIONAL { $this effortless-ntwf:supportingConclusion ?supporting_conclusion . }
                OPTIONAL { ?j0 a effortless-ntwf:Conclusions ; effortless-ntwf:conclusionId ?j1 ; effortless-ntwf:category ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?supporting_conclusion), "^.*[#/]", "")) || (?j0 = ?supporting_conclusion)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ResearchTraditions_ResearcherCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:researcherCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ResearchTraditions .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:Researchers .
                    ?child effortless-ntwf:traditionId ?backfk .
                    $this effortless-ntwf:traditionId ?backpv .
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ResearchTraditions_StudyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
