@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix effortless-ntwf: <https://w3id.org/effortless-ntwf#> .

# === Shape with rules for AllocationSweep ===
effortless-ntwf:AllocationSweepShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:AllocationSweep ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:sweepId ?sweep_id . }
                BIND(?sweep_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_NSweepA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:nSweepA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:allocFractionA ?alloc_fraction_a . }
    OPTIONAL { $this effortless-ntwf:nSweepStratumTotal ?n_sweep_stratum_total . }
                BIND(ROUND((?n_sweep_stratum_total * ?alloc_fraction_a)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_NSweepB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:nSweepB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:nSweepA ?n_sweep_a . }
    OPTIONAL { $this effortless-ntwf:nSweepStratumTotal ?n_sweep_stratum_total . }
                BIND((?n_sweep_stratum_total - ?n_sweep_a) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_SweepPooledRateA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:sweepPooledRateA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:fixedRateA ?fixed_rate_a . }
    OPTIONAL { $this effortless-ntwf:nFixedA ?n_fixed_a . }
    OPTIONAL { $this effortless-ntwf:nSweepA ?n_sweep_a . }
    OPTIONAL { $this effortless-ntwf:sweepRateA ?sweep_rate_a . }
                BIND(IF(((?n_sweep_a + ?n_fixed_a) = 0), "", (((?n_sweep_a * ?sweep_rate_a) + (?n_fixed_a * ?fixed_rate_a)) / (?n_sweep_a + ?n_fixed_a))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_SweepPooledRateB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:sweepPooledRateB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:fixedRateB ?fixed_rate_b . }
    OPTIONAL { $this effortless-ntwf:nFixedB ?n_fixed_b . }
    OPTIONAL { $this effortless-ntwf:nSweepB ?n_sweep_b . }
    OPTIONAL { $this effortless-ntwf:sweepRateB ?sweep_rate_b . }
                BIND(IF(((?n_sweep_b + ?n_fixed_b) = 0), "", (((?n_sweep_b * ?sweep_rate_b) + (?n_fixed_b * ?fixed_rate_b)) / (?n_sweep_b + ?n_fixed_b))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_SweepPooledGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:sweepPooledGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:sweepPooledRateA ?sweep_pooled_rate_a . }
    OPTIONAL { $this effortless-ntwf:sweepPooledRateB ?sweep_pooled_rate_b . }
                BIND(IF((REPLACE(COALESCE(STR(?sweep_pooled_rate_a), ""), "^.*#", "") = ""), "", (?sweep_pooled_rate_a - ?sweep_pooled_rate_b)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_AllocationDistortionWitness" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:allocationDistortionWitness ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:sweepCorrectedGap ?sweep_corrected_gap . }
    OPTIONAL { $this effortless-ntwf:sweepPooledGap ?sweep_pooled_gap . }
                BIND(IF((REPLACE(COALESCE(STR(?sweep_pooled_gap), ""), "^.*#", "") = ""), "", (?sweep_pooled_gap - ?sweep_corrected_gap)) AS ?_result)
            }
        """ ;
    ] .
# Rule for IsOriginal - parse error: Unexpected character '[' at position 61
# Rule for NSweepStratumTotal - parse error: Unexpected character '[' at position 36
# Rule for NFixedA - parse error: Unexpected character '[' at position 36
# Rule for NFixedB - parse error: Unexpected character '[' at position 36
# Rule for SweepRateA - parse error: Unexpected character '[' at position 36
# Rule for SweepRateB - parse error: Unexpected character '[' at position 36
# Rule for FixedRateA - parse error: Unexpected character '[' at position 36
# Rule for FixedRateB - parse error: Unexpected character '[' at position 36
# Rule for SweepCorrectedGap - parse error: Unexpected character '[' at position 36

# === Shape with rules for CandidateStudyCatalog ===
effortless-ntwf:CandidateStudyCatalogShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:CandidateStudyCatalog ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:candidateId ?candidate_id . }
                BIND(?candidate_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_IsReadyToEncode" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isReadyToEncode ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:citation ?citation . }
    OPTIONAL { $this effortless-ntwf:ingestionStatus ?ingestion_status . }
    OPTIONAL { $this effortless-ntwf:proposedStudyId ?proposed_study_id . }
    OPTIONAL { $this effortless-ntwf:stratumVariableName ?stratum_variable_name . }
                BIND(((REPLACE(COALESCE(STR(?ingestion_status), ""), "^.*#", "") = "candidate") && (REPLACE(COALESCE(STR(?proposed_study_id), ""), "^.*#", "") != "") && (REPLACE(COALESCE(STR(?citation), ""), "^.*#", "") != "") && (REPLACE(COALESCE(STR(?stratum_variable_name), ""), "^.*#", "") != "")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_IsImported" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isImported ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:ingestionStatus ?ingestion_status . }
                BIND((REPLACE(COALESCE(STR(?ingestion_status), ""), "^.*#", "") = "imported") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_TypePredictionMatch" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:typePredictionMatch ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:expectedDistortionType ?expected_distortion_type . }
    OPTIONAL { $this effortless-ntwf:isImported ?is_imported . }
    OPTIONAL { $this effortless-ntwf:observedDistortionType ?observed_distortion_type . }
                BIND(IF(?is_imported, (?observed_distortion_type = ?expected_distortion_type), "") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_ExpectedSignFlip" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:expectedSignFlip ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:expectedDistortionType ?expected_distortion_type . }
                BIND(((REPLACE(COALESCE(STR(?expected_distortion_type), ""), "^.*#", "") = "A") || (REPLACE(COALESCE(STR(?expected_distortion_type), ""), "^.*#", "") = "B")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_ObservedSignFlipType" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:observedSignFlipType ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:isImported ?is_imported . }
    OPTIONAL { $this effortless-ntwf:observedDistortionType ?observed_distortion_type . }
                BIND(IF(?is_imported, ((REPLACE(COALESCE(STR(?observed_distortion_type), ""), "^.*#", "") = "A") || (REPLACE(COALESCE(STR(?observed_distortion_type), ""), "^.*#", "") = "B")), "") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_SignFlipPredictionMatch" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:signFlipPredictionMatch ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:expectedSignFlip ?expected_sign_flip . }
    OPTIONAL { $this effortless-ntwf:isImported ?is_imported . }
    OPTIONAL { $this effortless-ntwf:observedSignFlipType ?observed_sign_flip_type . }
                BIND(IF((?is_imported && ?expected_sign_flip), ?observed_sign_flip_type, "") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_IsDataReady" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isDataReady ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:dataAcquisitionStatus ?data_acquisition_status . }
                BIND(((REPLACE(COALESCE(STR(?data_acquisition_status), ""), "^.*#", "") = "downloaded") || (REPLACE(COALESCE(STR(?data_acquisition_status), ""), "^.*#", "") = "manual_only")) AS ?_result)
            }
        """ ;
    ] .
# Rule for ObservedDistortionType - parse error: Unexpected character '[' at position 43

# === Shape with rules for CaseCells ===
effortless-ntwf:CaseCellsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:CaseCells ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CaseCells_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CaseCells .
    OPTIONAL { $this effortless-ntwf:caseCellId ?case_cell_id . }
                BIND(?case_cell_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CaseCells_CellSuccessRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:cellSuccessRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CaseCells .
    OPTIONAL { $this effortless-ntwf:cases ?cases . }
    OPTIONAL { $this effortless-ntwf:successes ?successes . }
                BIND(IF((?cases = 0), "", (?successes / ?cases)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CaseCells_TreatmentExposureFraction" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:treatmentExposureFraction ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CaseCells .
    OPTIONAL { $this effortless-ntwf:cases ?cases . }
    OPTIONAL { $this effortless-ntwf:totalCasesForTreatment ?total_cases_for_treatment . }
                BIND(IF((?total_cases_for_treatment = 0), "", (?cases / ?total_cases_for_treatment)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CaseCells_IsValidIngestionCell" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isValidIngestionCell ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CaseCells .
    OPTIONAL { $this effortless-ntwf:cases ?cases . }
    OPTIONAL { $this effortless-ntwf:successes ?successes . }
                BIND(((?cases > 0) && (?successes >= 0) && (?successes <= ?cases)) AS ?_result)
            }
        """ ;
    ] .
# Rule for TotalCasesForTreatment - parse error: unsupported COUNTIFS criteria: FieldRef

# === Shape with rules for Conclusions ===
effortless-ntwf:ConclusionsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Conclusions ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
    OPTIONAL { $this effortless-ntwf:conclusionId ?conclusion_id . }
                BIND(?conclusion_id AS ?_result)
            }
        """ ;
    ] .
# Rule for TraditionName - parse error: Unexpected character '[' at position 42
# Rule for TraditionKeyClaimSummary - parse error: Unexpected character '[' at position 42
# Rule for ResearcherName - parse error: Unexpected character '[' at position 36
# Rule for ResearcherAffiliation - parse error: Unexpected character '[' at position 36
# Rule for ChallengesResearcherName - parse error: Unexpected character '[' at position 44
# Rule for WitnessedInLoopTitle - parse error: Unexpected character '[' at position 33
# Rule for WitnessedInLoopCommitHash - parse error: Unexpected character '[' at position 33
# Rule for WitnessedInLoopCommitShort - parse error: Unexpected character '[' at position 33
# Rule for WitnessedInLoopCommitDate - parse error: Unexpected character '[' at position 33
# Rule for WitnessedInLoopGitTag - parse error: Unexpected character '[' at position 33
# Rule for InvariantProtectingCount - parse error: unsupported COUNTIFS criteria: FieldRef

# === Shape with rules for CorpusCatalogSummary ===
effortless-ntwf:CorpusCatalogSummaryShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:CorpusCatalogSummary ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
    OPTIONAL { $this effortless-ntwf:catalogSummaryId ?catalog_summary_id . }
                BIND(?catalog_summary_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_TotalCatalogEntries" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:totalCatalogEntries ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:candidateId ?c0 . }
                    FILTER(STR(?c0) = "<>")
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_ImportedCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:importedCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c0 . }
                    FILTER(STR(?c0) = "imported")
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_CandidateCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:candidateCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c0 . }
                    FILTER(STR(?c0) = "candidate")
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_BlockedCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:blockedCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c0 . }
                    FILTER(STR(?c0) = "blocked")
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_ReadyToEncodeCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:readyToEncodeCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:isReadyToEncode ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_ImportSessionReady" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:importSessionReady ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
    OPTIONAL { $this effortless-ntwf:candidateCount ?candidate_count . }
    OPTIONAL { $this effortless-ntwf:readyToEncodeCount ?ready_to_encode_count . }
                BIND(((?candidate_count >= 20) && (?ready_to_encode_count >= 15)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_TypePredictionMatchCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:typePredictionMatchCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:typePredictionMatch ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_TypePredictionMismatchCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:typePredictionMismatchCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:isImported ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:typePredictionMatch ?c2 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER(BOUND(?c2) && ?c2 = false)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_SignFlipPredictionEligibleCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:signFlipPredictionEligibleCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:isImported ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:expectedSignFlip ?c2 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_SignFlipPredictionMatchCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:signFlipPredictionMatchCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:signFlipPredictionMatch ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_TypePredictionMatchRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:typePredictionMatchRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
    OPTIONAL { $this effortless-ntwf:importedCount ?imported_count . }
    OPTIONAL { $this effortless-ntwf:typePredictionMatchCount ?type_prediction_match_count . }
                BIND(IF((?imported_count = 0), "", (?type_prediction_match_count / ?imported_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_SignFlipPredictionMatchRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:signFlipPredictionMatchRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
    OPTIONAL { $this effortless-ntwf:signFlipPredictionEligibleCount ?sign_flip_prediction_eligible_count . }
    OPTIONAL { $this effortless-ntwf:signFlipPredictionMatchCount ?sign_flip_prediction_match_count . }
                BIND(IF((?sign_flip_prediction_eligible_count = 0), "", (?sign_flip_prediction_match_count / ?sign_flip_prediction_eligible_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_DataReadyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:dataReadyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:isDataReady ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c2 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER(STR(?c2) = "candidate")
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_EncodePipelineReadyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:encodePipelineReadyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:isReadyToEncode ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:isDataReady ?c2 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_ExpansionCandidateCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:expansionCandidateCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:expansionWave ?c0 . }
                    FILTER(STR(?c0) = "expansion-wave-1")
                    }
                }
            }
        """ ;
    ] .
# Rule for HighPriorityCount - parse error: aggregation formula must be COUNTIFS(...) or SUMIFS(...)
