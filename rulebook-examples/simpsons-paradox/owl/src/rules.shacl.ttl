# === Shape with rules for SyntheticPhase ===
effortless-ntwf:SyntheticPhaseShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:SyntheticPhase ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseId ?phase_id . }
                BIND(?phase_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseS1Total" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseS1Total ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramStratumFraction ?param_stratum_fraction . }
                BIND(ROUND((200 * ?param_stratum_fraction)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseNA1" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseNA1 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramAllocationBias ?param_allocation_bias . }
    OPTIONAL { $this effortless-ntwf:phaseS1Total ?phase_s1_total . }
                BIND(ROUND((?phase_s1_total * (0.5 + (?param_allocation_bias / 2)))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseNB1" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseNB1 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseNA1 ?phase_na1 . }
    OPTIONAL { $this effortless-ntwf:phaseS1Total ?phase_s1_total . }
                BIND((?phase_s1_total - ?phase_na1) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseNA2" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseNA2 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseNA1 ?phase_na1 . }
                BIND((100 - ?phase_na1) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseNB2" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseNB2 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseNB1 ?phase_nb1 . }
                BIND((100 - ?phase_nb1) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseRateA1" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseRateA1 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramStratumGap1 ?param_stratum_gap1 . }
                BIND((0.45 + (?param_stratum_gap1 / 2)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseRateB1" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseRateB1 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramStratumGap1 ?param_stratum_gap1 . }
                BIND((0.45 - (?param_stratum_gap1 / 2)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseRateA2" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseRateA2 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramStratumGap2 ?param_stratum_gap2 . }
                BIND((0.75 + (?param_stratum_gap2 / 2)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseRateB2" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseRateB2 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramStratumGap2 ?param_stratum_gap2 . }
                BIND((0.75 - (?param_stratum_gap2 / 2)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhasePooledRateA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phasePooledRateA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseNA1 ?phase_na1 . }
    OPTIONAL { $this effortless-ntwf:phaseNA2 ?phase_na2 . }
    OPTIONAL { $this effortless-ntwf:phaseRateA1 ?phase_rate_a1 . }
    OPTIONAL { $this effortless-ntwf:phaseRateA2 ?phase_rate_a2 . }
                BIND((((?phase_na1 * ?phase_rate_a1) + (?phase_na2 * ?phase_rate_a2)) / 100) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhasePooledRateB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phasePooledRateB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseNB1 ?phase_nb1 . }
    OPTIONAL { $this effortless-ntwf:phaseNB2 ?phase_nb2 . }
    OPTIONAL { $this effortless-ntwf:phaseRateB1 ?phase_rate_b1 . }
    OPTIONAL { $this effortless-ntwf:phaseRateB2 ?phase_rate_b2 . }
                BIND((((?phase_nb1 * ?phase_rate_b1) + (?phase_nb2 * ?phase_rate_b2)) / 100) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseSignedPooledGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseSignedPooledGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phasePooledRateA ?phase_pooled_rate_a . }
    OPTIONAL { $this effortless-ntwf:phasePooledRateB ?phase_pooled_rate_b . }
                BIND((?phase_pooled_rate_a - ?phase_pooled_rate_b) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseCorrectedGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseCorrectedGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramStratumFraction ?param_stratum_fraction . }
    OPTIONAL { $this effortless-ntwf:paramStratumGap1 ?param_stratum_gap1 . }
    OPTIONAL { $this effortless-ntwf:paramStratumGap2 ?param_stratum_gap2 . }
                BIND(((?param_stratum_fraction * ?param_stratum_gap1) + ((1 - ?param_stratum_fraction) * ?param_stratum_gap2)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseStrataWonByLoser" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseStrataWonByLoser ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramStratumGap1 ?param_stratum_gap1 . }
    OPTIONAL { $this effortless-ntwf:paramStratumGap2 ?param_stratum_gap2 . }
    OPTIONAL { $this effortless-ntwf:phaseSignedPooledGap ?phase_signed_pooled_gap . }
                BIND(IF((?phase_signed_pooled_gap > 0), (IF((?param_stratum_gap1 < 0), 1, 0) + IF((?param_stratum_gap2 < 0), 1, 0)), (IF((?param_stratum_gap1 > 0), 1, 0) + IF((?param_stratum_gap2 > 0), 1, 0))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseReversalIntensity" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseReversalIntensity ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseStrataWonByLoser ?phase_strata_won_by_loser . }
                BIND((?phase_strata_won_by_loser / 2) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseIsSignFlip" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseIsSignFlip ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseCorrectedGap ?phase_corrected_gap . }
    OPTIONAL { $this effortless-ntwf:phaseSignedPooledGap ?phase_signed_pooled_gap . }
                BIND(IF((?phase_corrected_gap > 0), (?phase_signed_pooled_gap < 0), (?phase_signed_pooled_gap > 0)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseAllocationDistortion" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseAllocationDistortion ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseCorrectedGap ?phase_corrected_gap . }
    OPTIONAL { $this effortless-ntwf:phaseSignedPooledGap ?phase_signed_pooled_gap . }
                BIND(ABS((?phase_corrected_gap - ?phase_signed_pooled_gap)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseDistortionType" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseDistortionType ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseAllocationDistortion ?phase_allocation_distortion . }
    OPTIONAL { $this effortless-ntwf:phaseCorrectedGap ?phase_corrected_gap . }
    OPTIONAL { $this effortless-ntwf:phaseIsSignFlip ?phase_is_sign_flip . }
    OPTIONAL { $this effortless-ntwf:phaseReversalIntensity ?phase_reversal_intensity . }
    OPTIONAL { $this effortless-ntwf:phaseSignedPooledGap ?phase_signed_pooled_gap . }
                BIND(IF((?phase_is_sign_flip && (?phase_reversal_intensity = 1)), "A", IF((?phase_is_sign_flip && (?phase_reversal_intensity < 1)), "B", IF(((!(?phase_is_sign_flip)) && (?phase_allocation_distortion > 0.01) && (ABS(?phase_signed_pooled_gap) > (ABS(?phase_corrected_gap) + 0.001))), "C+", IF(((!(?phase_is_sign_flip)) && (?phase_allocation_distortion > 0.01) && (ABS(?phase_signed_pooled_gap) < (ABS(?phase_corrected_gap) - 0.001))), "C-", "D")))) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for TreatmentRankings ===
effortless-ntwf:TreatmentRankingsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:TreatmentRankings ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:treatmentRankingId ?treatment_ranking_id . }
                BIND(?treatment_ranking_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_TotalCasesA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:totalCasesA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                {
                    SELECT (SUM(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:CaseCells .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:treatmentLabel ?c2 . }
                    OPTIONAL { $this effortless-ntwf:treatmentA ?p2 . }
                    OPTIONAL { ?child effortless-ntwf:cases ?sumraw . }
                    BIND(IF(BOUND(?sumraw), xsd:double(STR(?sumraw)), 0.0) AS ?sumval)
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c2), "^.*[#/]", "") = REPLACE(STR(?p2), "^.*[#/]", ""))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_TotalSuccessesA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:totalSuccessesA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                {
                    SELECT (SUM(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:CaseCells .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:treatmentLabel ?c2 . }
                    OPTIONAL { $this effortless-ntwf:treatmentA ?p2 . }
                    OPTIONAL { ?child effortless-ntwf:successes ?sumraw . }
                    BIND(IF(BOUND(?sumraw), xsd:double(STR(?sumraw)), 0.0) AS ?sumval)
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c2), "^.*[#/]", "") = REPLACE(STR(?p2), "^.*[#/]", ""))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_PooledRateA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:pooledRateA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:totalCasesA ?total_cases_a . }
    OPTIONAL { $this effortless-ntwf:totalSuccessesA ?total_successes_a . }
                BIND(IF((?total_cases_a = 0), "", (?total_successes_a / ?total_cases_a)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_TotalCasesB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:totalCasesB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                {
                    SELECT (SUM(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:CaseCells .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:treatmentLabel ?c2 . }
                    OPTIONAL { $this effortless-ntwf:treatmentB ?p2 . }
                    OPTIONAL { ?child effortless-ntwf:cases ?sumraw . }
                    BIND(IF(BOUND(?sumraw), xsd:double(STR(?sumraw)), 0.0) AS ?sumval)
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c2), "^.*[#/]", "") = REPLACE(STR(?p2), "^.*[#/]", ""))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_TotalSuccessesB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:totalSuccessesB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                {
                    SELECT (SUM(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:CaseCells .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:treatmentLabel ?c2 . }
                    OPTIONAL { $this effortless-ntwf:treatmentB ?p2 . }
                    OPTIONAL { ?child effortless-ntwf:successes ?sumraw . }
                    BIND(IF(BOUND(?sumraw), xsd:double(STR(?sumraw)), 0.0) AS ?sumval)
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c2), "^.*[#/]", "") = REPLACE(STR(?p2), "^.*[#/]", ""))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_PooledRateB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:pooledRateB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:totalCasesB ?total_cases_b . }
    OPTIONAL { $this effortless-ntwf:totalSuccessesB ?total_successes_b . }
                BIND(IF((?total_cases_b = 0), "", (?total_successes_b / ?total_cases_b)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_PooledWinner" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:pooledWinner ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:pooledRateA ?pooled_rate_a . }
    OPTIONAL { $this effortless-ntwf:pooledRateB ?pooled_rate_b . }
    OPTIONAL { $this effortless-ntwf:treatmentA ?treatment_a . }
    OPTIONAL { $this effortless-ntwf:treatmentB ?treatment_b . }
                BIND(IF(((REPLACE(COALESCE(STR(?pooled_rate_a), ""), "^.*#", "") = "") || (REPLACE(COALESCE(STR(?pooled_rate_b), ""), "^.*#", "") = "")), "", IF((ABS((?pooled_rate_a - ?pooled_rate_b)) < 1e-07), "tie", IF((?pooled_rate_a > ?pooled_rate_b), ?treatment_a, ?treatment_b))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_StratumCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:stratumCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:StratumSummaries .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:treatmentLabel ?c2 . }
                    OPTIONAL { $this effortless-ntwf:treatmentA ?p2 . }
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c2), "^.*[#/]", "") = REPLACE(STR(?p2), "^.*[#/]", ""))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_StrataWonByA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:strataWonByA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:StratumSummaries .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:treatmentLabel ?c2 . }
                    OPTIONAL { $this effortless-ntwf:treatmentA ?p2 . }
                    OPTIONAL { ?child effortless-ntwf:stratumWinner ?c4 . }
                    OPTIONAL { $this effortless-ntwf:treatmentA ?p4 . }
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c2), "^.*[#/]", "") = REPLACE(STR(?p2), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c4), "^.*[#/]", "") = REPLACE(STR(?p4), "^.*[#/]", ""))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_StrataWonByB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:strataWonByB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:StratumSummaries .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:treatmentLabel ?c2 . }
                    OPTIONAL { $this effortless-ntwf:treatmentA ?p2 . }
                    OPTIONAL { ?child effortless-ntwf:stratumWinner ?c4 . }
                    OPTIONAL { $this effortless-ntwf:treatmentB ?p4 . }
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c2), "^.*[#/]", "") = REPLACE(STR(?p2), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c4), "^.*[#/]", "") = REPLACE(STR(?p4), "^.*[#/]", ""))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_PerStratumWinner" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:perStratumWinner ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:strataWonByA ?strata_won_by_a . }
    OPTIONAL { $this effortless-ntwf:strataWonByB ?strata_won_by_b . }
    OPTIONAL { $this effortless-ntwf:stratumCount ?stratum_count . }
    OPTIONAL { $this effortless-ntwf:treatmentA ?treatment_a . }
    OPTIONAL { $this effortless-ntwf:treatmentB ?treatment_b . }
                BIND(IF((?strata_won_by_a = ?stratum_count), ?treatment_a, IF((?strata_won_by_b = ?stratum_count), ?treatment_b, "none")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_IsStratumUnanimous" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isStratumUnanimous ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:strataWonByA ?strata_won_by_a . }
    OPTIONAL { $this effortless-ntwf:strataWonByB ?strata_won_by_b . }
    OPTIONAL { $this effortless-ntwf:stratumCount ?stratum_count . }
                BIND(((?strata_won_by_a = ?stratum_count) || (?strata_won_by_b = ?stratum_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_IsReversal" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isReversal ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:isSignFlip ?is_sign_flip . }
                BIND(IF((!BOUND(?is_sign_flip)), "", ?is_sign_flip) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_ConfoundersInStudy" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:confoundersInStudy ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:StratumVariables .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:isConfounder ?c2 . }
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_IsParadoxExplained" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isParadoxExplained ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:confoundersInStudy ?confounders_in_study . }
    OPTIONAL { $this effortless-ntwf:isReversal ?is_reversal . }
                BIND((?is_reversal && (?confounders_in_study > 0)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_PooledGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:pooledGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:pooledRateA ?pooled_rate_a . }
    OPTIONAL { $this effortless-ntwf:pooledRateB ?pooled_rate_b . }
                BIND(IF((REPLACE(COALESCE(STR(?pooled_rate_a), ""), "^.*#", "") = ""), "", ABS((?pooled_rate_a - ?pooled_rate_b))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_StrataWonByLoser" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:strataWonByLoser ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:pooledWinner ?pooled_winner . }
    OPTIONAL { $this effortless-ntwf:strataWonByA ?strata_won_by_a . }
    OPTIONAL { $this effortless-ntwf:strataWonByB ?strata_won_by_b . }
    OPTIONAL { $this effortless-ntwf:treatmentA ?treatment_a . }
                BIND(IF((?pooled_winner = ?treatment_a), ?strata_won_by_b, ?strata_won_by_a) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_ParadoxStrength" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:paradoxStrength ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:pooledGap ?pooled_gap . }
    OPTIONAL { $this effortless-ntwf:strataWonByLoser ?strata_won_by_loser . }
    OPTIONAL { $this effortless-ntwf:stratumCount ?stratum_count . }
                BIND(IF((?stratum_count = 0), "", (?pooled_gap * (?strata_won_by_loser / ?stratum_count))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_PooledRateFromWeightsA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:pooledRateFromWeightsA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                {
                    SELECT (SUM(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:StratumSummaries .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:treatmentLabel ?c2 . }
                    OPTIONAL { $this effortless-ntwf:treatmentA ?p2 . }
                    OPTIONAL { ?child effortless-ntwf:weightedStratumRate ?sumraw . }
                    BIND(IF(BOUND(?sumraw), xsd:double(STR(?sumraw)), 0.0) AS ?sumval)
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c2), "^.*[#/]", "") = REPLACE(STR(?p2), "^.*[#/]", ""))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_PooledRateFromWeightsB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:pooledRateFromWeightsB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                {
                    SELECT (SUM(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:StratumSummaries .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:treatmentLabel ?c2 . }
                    OPTIONAL { $this effortless-ntwf:treatmentB ?p2 . }
                    OPTIONAL { ?child effortless-ntwf:weightedStratumRate ?sumraw . }
                    BIND(IF(BOUND(?sumraw), xsd:double(STR(?sumraw)), 0.0) AS ?sumval)
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c2), "^.*[#/]", "") = REPLACE(STR(?p2), "^.*[#/]", ""))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_ReversalIntensity" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:reversalIntensity ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:strataWonByLoser ?strata_won_by_loser . }
    OPTIONAL { $this effortless-ntwf:stratumCount ?stratum_count . }
                BIND(IF((?stratum_count = 0), "", (?strata_won_by_loser / ?stratum_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_ThresholdMargin" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:thresholdMargin ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:reversalIntensity ?reversal_intensity . }
    OPTIONAL { $this effortless-ntwf:stratumCount ?stratum_count . }
                BIND(IF((?stratum_count = 0), "", (?reversal_intensity - 0.5)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_SignedPooledGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:signedPooledGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:pooledRateA ?pooled_rate_a . }
    OPTIONAL { $this effortless-ntwf:pooledRateB ?pooled_rate_b . }
                BIND(IF((REPLACE(COALESCE(STR(?pooled_rate_a), ""), "^.*#", "") = ""), "", (?pooled_rate_a - ?pooled_rate_b)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_WeightedStratumGapSum" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:weightedStratumGapSum ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                {
                    SELECT (SUM(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:StratumSummaries .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:treatmentLabel ?c2 . }
                    OPTIONAL { $this effortless-ntwf:treatmentA ?p2 . }
                    OPTIONAL { ?child effortless-ntwf:weightedStratumGap ?sumraw . }
                    BIND(IF(BOUND(?sumraw), xsd:double(STR(?sumraw)), 0.0) AS ?sumval)
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c2), "^.*[#/]", "") = REPLACE(STR(?p2), "^.*[#/]", ""))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_IsSignFlip" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isSignFlip ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:signedPooledGap ?signed_pooled_gap . }
    OPTIONAL { $this effortless-ntwf:weightedStratumGapSum ?weighted_stratum_gap_sum . }
                BIND(IF((REPLACE(COALESCE(STR(?weighted_stratum_gap_sum), ""), "^.*#", "") = ""), "", IF((?weighted_stratum_gap_sum > 0), (?signed_pooled_gap < 0), (?signed_pooled_gap > 0))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_AllocationDistortion" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:allocationDistortion ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:signedPooledGap ?signed_pooled_gap . }
    OPTIONAL { $this effortless-ntwf:weightedStratumGapSum ?weighted_stratum_gap_sum . }
                BIND(IF((REPLACE(COALESCE(STR(?weighted_stratum_gap_sum), ""), "^.*#", "") = ""), "", ABS((?weighted_stratum_gap_sum - ?signed_pooled_gap))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_DistortionType" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:distortionType ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:allocationDistortion ?allocation_distortion . }
    OPTIONAL { $this effortless-ntwf:correctedGap ?corrected_gap . }
    OPTIONAL { $this effortless-ntwf:isSignFlip ?is_sign_flip . }
    OPTIONAL { $this effortless-ntwf:isStratumUnanimous ?is_stratum_unanimous . }
    OPTIONAL { $this effortless-ntwf:signedPooledGap ?signed_pooled_gap . }
                BIND(IF((REPLACE(COALESCE(STR(?allocation_distortion), ""), "^.*#", "") = ""), "", IF(?is_sign_flip, IF(?is_stratum_unanimous, "A", "B"), IF(((!(?is_sign_flip)) && (?allocation_distortion > 0.01) && (ABS(?signed_pooled_gap) > (ABS(?corrected_gap) + 0.001))), "C+", IF(((!(?is_sign_flip)) && (?allocation_distortion > 0.01) && (ABS(?signed_pooled_gap) < (ABS(?corrected_gap) - 0.001))), "C-", "D")))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_PolicyImplication" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:policyImplication ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:distortionType ?distortion_type . }
                BIND(IF((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = ""), "", IF((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "A"), "stratify-immediately", IF((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "B"), "investigate-confounder", IF(((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "C+") || (REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "C-")), "check-allocation-bias", "pooled-analysis-trustworthy")))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_CorrectedGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:correctedGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:weightedStratumGapSum ?weighted_stratum_gap_sum . }
                BIND(?weighted_stratum_gap_sum AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_CorrectedWinner" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:correctedWinner ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:correctedGap ?corrected_gap . }
    OPTIONAL { $this effortless-ntwf:treatmentA ?treatment_a . }
    OPTIONAL { $this effortless-ntwf:treatmentB ?treatment_b . }
                BIND(IF((REPLACE(COALESCE(STR(?corrected_gap), ""), "^.*#", "") = ""), "", IF((ABS(?corrected_gap) < 0.0001), "tie", IF((?corrected_gap > 0), ?treatment_a, IF((?corrected_gap < 0), ?treatment_b, "tie")))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_CorrectedVsPooledAgreement" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:correctedVsPooledAgreement ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:correctedWinner ?corrected_winner . }
    OPTIONAL { $this effortless-ntwf:pooledWinner ?pooled_winner . }
                BIND(IF((REPLACE(COALESCE(STR(?corrected_winner), ""), "^.*#", "") = ""), "", (?corrected_winner = ?pooled_winner)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_CorrectedPolicyImplication" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:correctedPolicyImplication ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:distortionType ?distortion_type . }
                BIND(IF((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = ""), "", IF((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "A"), "use-corrected-winner", IF((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "B"), "use-corrected-winner-with-caution", IF(((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "C+") || (REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "C-")), "check-allocation-bias", "pooled-analysis-trustworthy")))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_AllocationDirection" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:allocationDirection ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:correctedGap ?corrected_gap . }
    OPTIONAL { $this effortless-ntwf:isSignFlip ?is_sign_flip . }
    OPTIONAL { $this effortless-ntwf:signedPooledGap ?signed_pooled_gap . }
                BIND(IF((REPLACE(COALESCE(STR(?corrected_gap), ""), "^.*#", "") = ""), "", IF(?is_sign_flip, "reversal", IF((ABS(?signed_pooled_gap) > (ABS(?corrected_gap) + 0.001)), "amplification", IF((ABS(?signed_pooled_gap) < (ABS(?corrected_gap) - 0.001)), "compression", "neutral")))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_SignalPurity" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:signalPurity ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:allocationDistortion ?allocation_distortion . }
    OPTIONAL { $this effortless-ntwf:correctedGap ?corrected_gap . }
                BIND(IF((REPLACE(COALESCE(STR(?corrected_gap), ""), "^.*#", "") = ""), "", IF(((ABS(?corrected_gap) + ?allocation_distortion) = 0), 1, (ABS(?corrected_gap) / (ABS(?corrected_gap) + ?allocation_distortion)))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_PooledGapCrossesZero" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:pooledGapCrossesZero ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                OPTIONAL { $this effortless-ntwf:study ?study . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudySummary ; effortless-ntwf:sweepStudyId ?j1 ; effortless-ntwf:pooledGapCrossesZero ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study), "^.*[#/]", "")) || (?j0 = ?study)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_SweepPooledGapRange" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepPooledGapRange ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                OPTIONAL { $this effortless-ntwf:study ?study . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudySummary ; effortless-ntwf:sweepStudyId ?j1 ; effortless-ntwf:sweepPooledGapRange ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study), "^.*[#/]", "")) || (?j0 = ?study)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_LatentFlipPotential" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:latentFlipPotential ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:distortionType ?distortion_type . }
    OPTIONAL { $this effortless-ntwf:pooledGapCrossesZero ?pooled_gap_crosses_zero . }
                BIND(IF((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = ""), "", ((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "D") && (?pooled_gap_crosses_zero = true))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_AllocationFragility" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:allocationFragility ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:pooledGap ?pooled_gap . }
    OPTIONAL { $this effortless-ntwf:sweepPooledGapRange ?sweep_pooled_gap_range . }
                BIND(IF(((REPLACE(COALESCE(STR(?sweep_pooled_gap_range), ""), "^.*#", "") = "") || (REPLACE(COALESCE(STR(?pooled_gap), ""), "^.*#", "") = "") || (?pooled_gap = 0)), "", (?sweep_pooled_gap_range / ABS(?pooled_gap))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_IsSweepFragile" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isSweepFragile ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:allocationDistortion ?allocation_distortion . }
    OPTIONAL { $this effortless-ntwf:allocationFragility ?allocation_fragility . }
    OPTIONAL { $this effortless-ntwf:distortionType ?distortion_type . }
    OPTIONAL { $this effortless-ntwf:signalPurity ?signal_purity . }
    OPTIONAL { $this effortless-ntwf:sweepPooledGapRange ?sweep_pooled_gap_range . }
                BIND(((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "D") && (?signal_purity = 1) && (?allocation_distortion = 0) && (?sweep_pooled_gap_range > 0.3) && (?allocation_fragility >= 10)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_StudyDomain" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:studyDomain ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                OPTIONAL { $this effortless-ntwf:study ?study . }
                OPTIONAL { ?j0 a effortless-ntwf:Studies ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:domain ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study), "^.*[#/]", "")) || (?j0 = ?study)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_StratumCausalRole" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:stratumCausalRole ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                OPTIONAL { $this effortless-ntwf:study ?study . }
                OPTIONAL { ?j0 a effortless-ntwf:StratumVariables ; effortless-ntwf:study ?j1 ; effortless-ntwf:causalRole ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study), "^.*[#/]", "")) || (?j0 = ?study)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_IsLatentOnlyFlip" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isLatentOnlyFlip ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:isSignFlip ?is_sign_flip . }
    OPTIONAL { $this effortless-ntwf:pooledGapCrossesZero ?pooled_gap_crosses_zero . }
                BIND(IF((!BOUND(?pooled_gap_crosses_zero)), "", ((?pooled_gap_crosses_zero = true) && (?is_sign_flip = false))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_ConfirmedCausalRoleCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:confirmedCausalRoleCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:StratumVariables .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:causalRole ?c2 . }
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER((STR(?c2) = "confounder"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_ContestedStratumCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:contestedStratumCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:StratumVariables .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:causalRole ?c2 . }
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER((STR(?c2) = "contested"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_UnknownCausalRoleCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:unknownCausalRoleCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:StratumVariables .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:causalRole ?c2 . }
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER((STR(?c2) = "unknown"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_CausalClaimStatus" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:causalClaimStatus ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:confirmedCausalRoleCount ?confirmed_causal_role_count . }
    OPTIONAL { $this effortless-ntwf:contestedStratumCount ?contested_stratum_count . }
    OPTIONAL { $this effortless-ntwf:unknownCausalRoleCount ?unknown_causal_role_count . }
                BIND(IF((?contested_stratum_count > 0), "contested", IF((?unknown_causal_role_count > 0), "geometric-only", IF((?confirmed_causal_role_count > 0), "established", "geometric-only"))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_AdjustmentAppropriate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:adjustmentAppropriate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:causalClaimStatus ?causal_claim_status . }
    OPTIONAL { $this effortless-ntwf:mediatorRiskCount ?mediator_risk_count . }
                BIND(((?mediator_risk_count = 0) && (REPLACE(COALESCE(STR(?causal_claim_status), ""), "^.*#", "") = "established")) AS ?_result)
            }
        """ ;
    ] .
# Rule for MediatorRiskCount - parse error: aggregation formula must be COUNTIFS / SUMIFS / AVERAGEIFS / MAXIFS / MINIFS / COUNTIF / their bare AGG(Child!{{Col}}) forms

# === Shape with rules for Treatments ===
effortless-ntwf:TreatmentsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Treatments ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Treatments_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Treatments .
    OPTIONAL { $this effortless-ntwf:treatmentId ?treatment_id . }
                BIND(?treatment_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Treatments_TotalCases" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:totalCases ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Treatments .
                {
                    SELECT (SUM(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:CaseCells .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:treatmentLabel ?c2 . }
                    OPTIONAL { $this effortless-ntwf:treatmentLabel ?p2 . }
                    OPTIONAL { ?child effortless-ntwf:cases ?sumraw . }
                    BIND(IF(BOUND(?sumraw), xsd:double(STR(?sumraw)), 0.0) AS ?sumval)
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c2), "^.*[#/]", "") = REPLACE(STR(?p2), "^.*[#/]", ""))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Treatments_TotalSuccesses" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:totalSuccesses ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Treatments .
                {
                    SELECT (SUM(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:CaseCells .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:treatmentLabel ?c2 . }
                    OPTIONAL { $this effortless-ntwf:treatmentLabel ?p2 . }
                    OPTIONAL { ?child effortless-ntwf:successes ?sumraw . }
                    BIND(IF(BOUND(?sumraw), xsd:double(STR(?sumraw)), 0.0) AS ?sumval)
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c2), "^.*[#/]", "") = REPLACE(STR(?p2), "^.*[#/]", ""))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Treatments_PooledSuccessRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:pooledSuccessRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Treatments .
    OPTIONAL { $this effortless-ntwf:totalCases ?total_cases . }
    OPTIONAL { $this effortless-ntwf:totalSuccesses ?total_successes . }
                BIND(IF((?total_cases = 0), "", (?total_successes / ?total_cases)) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for UIComponents ===
effortless-ntwf:UIComponentsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:UIComponents ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_UIComponents_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:UIComponents .
    OPTIONAL { $this effortless-ntwf:componentId ?component_id . }
                BIND(?component_id AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for UIScreens ===
effortless-ntwf:UIScreensShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:UIScreens ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_UIScreens_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
