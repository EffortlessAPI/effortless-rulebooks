            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:stratumCases ?stratum_cases . }
    OPTIONAL { $this effortless-ntwf:stratumSuccesses ?stratum_successes . }
                BIND(IF((?stratum_cases = 0), "", (?stratum_successes / ?stratum_cases)) AS ?_result)
