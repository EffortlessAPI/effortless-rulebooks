                OPTIONAL { ?j0 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j1 ; effortless-ntwf:distortionType ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_PolicyImplication" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:policyImplication ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j1 ; effortless-ntwf:correctedPolicyImplication ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_AllocationDistortion" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:allocationDistortion ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j1 ; effortless-ntwf:allocationDistortion ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_SignalPurity" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:signalPurity ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j1 ; effortless-ntwf:signalPurity ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_IsSignFlip" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isSignFlip ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j1 ; effortless-ntwf:isSignFlip ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_CorrectedWinner" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:correctedWinner ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j1 ; effortless-ntwf:correctedWinner ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_ConfoundingVariable" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:confoundingVariable ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:StratumVariables ; effortless-ntwf:study ?j1 ; effortless-ntwf:variableName ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_CausalRole" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:causalRole ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:StratumVariables ; effortless-ntwf:study ?j1 ; effortless-ntwf:causalRole ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_IngestionCellParity" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:ingestionCellParity ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:cellCount ?cell_count . }
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j1 ; effortless-ntwf:stratumCount ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                OPTIONAL { ?j3 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j4 ; effortless-ntwf:stratumCount ?j5 . FILTER((REPLACE(STR(?j4), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j3 = ?study_id)) }
                BIND(((?j2 >= 2) && (?cell_count = (?j5 * 2))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_IngestionCompliance" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:ingestionCompliance ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:ingestionCellParity ?ingestion_cell_parity . }
                OPTIONAL { $this effortless-ntwf:isSynthetic ?is_synthetic . }
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:StratumVariables ; effortless-ntwf:study ?j1 ; effortless-ntwf:variableName ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(IF(?is_synthetic, "exempt-synthetic", IF((?ingestion_cell_parity && (?j2 != "")), "all", "partial")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_ValidTimeMidpoint" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:validTimeMidpoint ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
    OPTIONAL { $this effortless-ntwf:publicationYear ?publication_year . }
    OPTIONAL { $this effortless-ntwf:validTimeEnd ?valid_time_end . }
    OPTIONAL { $this effortless-ntwf:validTimeStart ?valid_time_start . }
                BIND(IF(((REPLACE(COALESCE(STR(?valid_time_start), ""), "^.*#", "") != "") && (REPLACE(COALESCE(STR(?valid_time_end), ""), "^.*#", "") != "")), ((?valid_time_start + ?valid_time_end) / 2), ?publication_year) AS ?_result)
            }
        """ ;
    ] .
# Rule for ValidTimeDecade - parse error: Unknown function: FLOOR

# === Shape with rules for StudyImportTemplate ===
