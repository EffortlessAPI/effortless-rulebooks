            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:otherDomainStudyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:epidemiologyStudyCount ?epidemiology_study_count . }
    OPTIONAL { $this effortless-ntwf:medicineStudyCount ?medicine_study_count . }
    OPTIONAL { $this effortless-ntwf:realStudyCount ?real_study_count . }
                BIND(((?real_study_count - ?medicine_study_count) - ?epidemiology_study_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_DomainDiversityNote" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:domainDiversityNote ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:economicsSignFlipRate ?economics_sign_flip_rate . }
    OPTIONAL { $this effortless-ntwf:educationLatentFraction ?education_latent_fraction . }
    OPTIONAL { $this effortless-ntwf:expansionWave2StudyCount ?expansion_wave2_study_count . }
    OPTIONAL { $this effortless-ntwf:realStudyCount ?real_study_count . }
    OPTIONAL { $this effortless-ntwf:sportsLatentFraction ?sports_latent_fraction . }
                BIND(CONCAT("real=", IF(isIRI(?real_study_count), REPLACE(STR(?real_study_count), "^.*[#/]", ""), STR(?real_study_count)), " studies; wave2=", IF(isIRI(?expansion_wave2_study_count), REPLACE(STR(?expansion_wave2_study_count), "^.*[#/]", ""), STR(?expansion_wave2_study_count)), "; eduLatent=", IF(isIRI((ROUND((?education_latent_fraction * 100) * STRDT(CONCAT("1e", STR(0)), xsd:double)) / STRDT(CONCAT("1e", STR(0)), xsd:double))), REPLACE(STR((ROUND((?education_latent_fraction * 100) * STRDT(CONCAT("1e", STR(0)), xsd:double)) / STRDT(CONCAT("1e", STR(0)), xsd:double))), "^.*[#/]", ""), STR((ROUND((?education_latent_fraction * 100) * STRDT(CONCAT("1e", STR(0)), xsd:double)) / STRDT(CONCAT("1e", STR(0)), xsd:double)))), "%; sportsLatent=", IF(isIRI((ROUND((?sports_latent_fraction * 100) * STRDT(CONCAT("1e", STR(0)), xsd:double)) / STRDT(CONCAT("1e", STR(0)), xsd:double))), REPLACE(STR((ROUND((?sports_latent_fraction * 100) * STRDT(CONCAT("1e", STR(0)), xsd:double)) / STRDT(CONCAT("1e", STR(0)), xsd:double))), "^.*[#/]", ""), STR((ROUND((?sports_latent_fraction * 100) * STRDT(CONCAT("1e", STR(0)), xsd:double)) / STRDT(CONCAT("1e", STR(0)), xsd:double)))), "%; econFlipRate=", IF(isIRI((ROUND((?economics_sign_flip_rate * 100) * STRDT(CONCAT("1e", STR(0)), xsd:double)) / STRDT(CONCAT("1e", STR(0)), xsd:double))), REPLACE(STR((ROUND((?economics_sign_flip_rate * 100) * STRDT(CONCAT("1e", STR(0)), xsd:double)) / STRDT(CONCAT("1e", STR(0)), xsd:double))), "^.*[#/]", ""), STR((ROUND((?economics_sign_flip_rate * 100) * STRDT(CONCAT("1e", STR(0)), xsd:double)) / STRDT(CONCAT("1e", STR(0)), xsd:double)))), "%") AS ?_result)
            }
        """ ;
    ] ;
