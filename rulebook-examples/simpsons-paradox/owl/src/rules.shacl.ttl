    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_FalsePositiveExplainedCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:falsePositiveExplainedCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_lhs) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:isParadoxExplained ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:isSignFlip ?c2 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER(BOUND(?c2) && ?c2 = false)
                    }
                }
                {
                    SELECT (COUNT(?child) AS ?_rhs) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:isParadoxExplained ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:isSignFlip ?c2 . }
                    OPTIONAL { ?child effortless-ntwf:stratumCausalRole ?c4 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER(BOUND(?c2) && ?c2 = true)
                    FILTER((STR(?c4) != "confounder"))
                    }
                }
    BIND(?_lhs + ?_rhs AS ?_result)
            }
        """ ;
    ] ;
