    OPTIONAL { $this effortless-ntwf:stratumCount ?stratum_count . }
    OPTIONAL { $this effortless-ntwf:treatmentA ?treatment_a . }
    OPTIONAL { $this effortless-ntwf:treatmentB ?treatment_b . }
                BIND(IF((?strata_won_by_a = ?stratum_count), ?treatment_a, IF((?strata_won_by_b = ?stratum_count), ?treatment_b, "none")) AS ?_result)
            }
