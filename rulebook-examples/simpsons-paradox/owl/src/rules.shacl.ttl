                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:coreConcern ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
