effortless-ntwf:TreatmentRankingsCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:TreatmentRankings ;
    sh:property [ sh:path effortless-ntwf:study ; sh:maxCount 1 ] .

effortless-ntwf:TreatmentsCardinalityShape a sh:NodeShape ;
