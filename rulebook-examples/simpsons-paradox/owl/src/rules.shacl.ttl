# === Shape with rules for ModelSummary ===
effortless-ntwf:ModelSummaryShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:ModelSummary ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:modelSummaryId ?model_summary_id . }
                BIND(?model_summary_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_ReversalCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:reversalCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:isReversal ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_NonReversalCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:nonReversalCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:isReversal ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = false)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_StudyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:studyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:nonReversalCount ?non_reversal_count . }
    OPTIONAL { $this effortless-ntwf:reversalCount ?reversal_count . }
                BIND((?reversal_count + ?non_reversal_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_ExplainedCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:explainedCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:isParadoxExplained ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_ZeroStrengthCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:zeroStrengthCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:strataWonByLoser ?c0 . }
                    FILTER(?c0 = 0)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_PartialCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:partialCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:nonReversalCount ?non_reversal_count . }
    OPTIONAL { $this effortless-ntwf:zeroStrengthCount ?zero_strength_count . }
                BIND((?non_reversal_count - ?zero_strength_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_TotalParadoxStrength" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:totalParadoxStrength ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (SUM(?sumval) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:treatmentA ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:paradoxStrength ?sumraw . }
                    BIND(COALESCE(?sumraw, 0) AS ?sumval)
                    FILTER(STR(?c0) = "A")
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_AvgParadoxStrength" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:avgParadoxStrength ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:studyCount ?study_count . }
    OPTIONAL { $this effortless-ntwf:totalParadoxStrength ?total_paradox_strength . }
                BIND(IF((?study_count = 0), "", (?total_paradox_strength / ?study_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_TypeACount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:typeACount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:distortionType ?c0 . }
                    FILTER(STR(?c0) = "A")
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_TypeBCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:typeBCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:distortionType ?c0 . }
                    FILTER(STR(?c0) = "B")
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_TypeCCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:typeCCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:distortionType ?c0 . }
                    FILTER(STR(?c0) = "C")
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_TypeDCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:typeDCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:distortionType ?c0 . }
                    FILTER(STR(?c0) = "D")
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_TypeAFraction" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:typeAFraction ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:studyCount ?study_count . }
    OPTIONAL { $this effortless-ntwf:typeACount ?type_a_count . }
                BIND(IF((?study_count = 0), "", (?type_a_count / ?study_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_ReversalCountV2" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:reversalCountV2 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:isReversal_v2 ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_NonReversalCountV2" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:nonReversalCountV2 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:isReversal_v2 ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = false)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_ExtendedReversalCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:extendedReversalCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:reversalCount ?reversal_count . }
    OPTIONAL { $this effortless-ntwf:reversalCountV2 ?reversal_count_v2 . }
                BIND((?reversal_count_v2 - ?reversal_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_ExplainedCountV2" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:explainedCountV2 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:isParadoxExplained_v2 ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_DistortionOnlyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:distortionOnlyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:typeCCount ?type_c_count . }
                BIND(?type_c_count AS ?_result)
            }
        """ ;
    ] .
# Rule for DistortionTaxonomyCoverage - parse error: Unknown function: CONCAT

# === Shape with rules for Strata ===
effortless-ntwf:StrataShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Strata ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Strata_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Strata .
    OPTIONAL { $this effortless-ntwf:stratumId ?stratum_id . }
                BIND(?stratum_id AS ?_result)
            }
        """ ;
    ] .
# Rule for TotalCases - parse error: unsupported COUNTIFS criteria: FieldRef

# === Shape with rules for StratumSummaries ===
effortless-ntwf:StratumSummariesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:StratumSummaries ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:stratumSummaryId ?stratum_summary_id . }
                BIND(?stratum_summary_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_StratumSuccessRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:stratumSuccessRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:stratumCases ?stratum_cases . }
    OPTIONAL { $this effortless-ntwf:stratumSuccesses ?stratum_successes . }
                BIND(IF((?stratum_cases = 0), "", (?stratum_successes / ?stratum_cases)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_StratumRateA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:stratumRateA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:stratumCasesA ?stratum_cases_a . }
    OPTIONAL { $this effortless-ntwf:stratumSuccessesA ?stratum_successes_a . }
                BIND(IF((?stratum_cases_a = 0), "", (?stratum_successes_a / ?stratum_cases_a)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_StratumRateB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:stratumRateB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:stratumCasesB ?stratum_cases_b . }
    OPTIONAL { $this effortless-ntwf:stratumSuccessesB ?stratum_successes_b . }
                BIND(IF((?stratum_cases_b = 0), "", (?stratum_successes_b / ?stratum_cases_b)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_StratumWinner" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:stratumWinner ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:stratumRateA ?stratum_rate_a . }
    OPTIONAL { $this effortless-ntwf:stratumRateB ?stratum_rate_b . }
                BIND(IF((?stratum_rate_a > ?stratum_rate_b), "A", "B") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_StratumFraction" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:stratumFraction ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:stratumTotalCases ?stratum_total_cases . }
    OPTIONAL { $this effortless-ntwf:studyTotalCases ?study_total_cases . }
                BIND(IF((?study_total_cases = 0), "", (?stratum_total_cases / ?study_total_cases)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_WeightedStratumRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:weightedStratumRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:stratumFraction ?stratum_fraction . }
    OPTIONAL { $this effortless-ntwf:stratumSuccessRate ?stratum_success_rate . }
                BIND(IF((REPLACE(COALESCE(STR(?stratum_fraction), ""), "^.*#", "") = ""), "", (?stratum_fraction * ?stratum_success_rate)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_AllocationFractionA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:allocationFractionA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:treatmentACasesHere ?treatment_a_cases_here . }
    OPTIONAL { $this effortless-ntwf:treatmentATotalCases ?treatment_a_total_cases . }
                BIND(IF((?treatment_a_total_cases = 0), "", (?treatment_a_cases_here / ?treatment_a_total_cases)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_AllocationFractionB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:allocationFractionB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:treatmentBCasesHere ?treatment_b_cases_here . }
    OPTIONAL { $this effortless-ntwf:treatmentBTotalCases ?treatment_b_total_cases . }
                BIND(IF((?treatment_b_total_cases = 0), "", (?treatment_b_cases_here / ?treatment_b_total_cases)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_AllocationBias" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:allocationBias ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:allocationFractionA ?allocation_fraction_a . }
    OPTIONAL { $this effortless-ntwf:allocationFractionB ?allocation_fraction_b . }
                BIND(IF((REPLACE(COALESCE(STR(?allocation_fraction_a), ""), "^.*#", "") = ""), "", (?allocation_fraction_a - ?allocation_fraction_b)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_StratumGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:stratumGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:stratumRateA ?stratum_rate_a . }
    OPTIONAL { $this effortless-ntwf:stratumRateB ?stratum_rate_b . }
                BIND(IF((REPLACE(COALESCE(STR(?stratum_rate_a), ""), "^.*#", "") = ""), "", (?stratum_rate_a - ?stratum_rate_b)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_WeightedStratumGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:weightedStratumGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:stratumFraction ?stratum_fraction . }
    OPTIONAL { $this effortless-ntwf:stratumGap ?stratum_gap . }
                BIND(IF((REPLACE(COALESCE(STR(?stratum_gap), ""), "^.*#", "") = ""), "", (?stratum_gap * ?stratum_fraction)) AS ?_result)
            }
        """ ;
    ] .
