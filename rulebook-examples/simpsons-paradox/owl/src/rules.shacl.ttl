                OPTIONAL { ?j96 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j97 ; effortless-ntwf:confounderSignFlipCount ?j98 . FILTER((REPLACE(STR(?j97), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j96 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j99 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j100 ; effortless-ntwf:falsePositiveExplainedCount ?j101 . FILTER((REPLACE(STR(?j100), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j99 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j102 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j103 ; effortless-ntwf:unexplainedConfounderSignFlipCount ?j104 . FILTER((REPLACE(STR(?j103), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j102 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j105 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j106 ; effortless-ntwf:colliderSelectionManifestCount ?j107 . FILTER((REPLACE(STR(?j106), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j105 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j108 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j109 ; effortless-ntwf:colliderSelectionCount ?j110 . FILTER((REPLACE(STR(?j109), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j108 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j111 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j112 ; effortless-ntwf:theoremCount ?j113 . FILTER((REPLACE(STR(?j112), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j111 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j114 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j115 ; effortless-ntwf:ageIdentityManifestFlipRate ?j116 . FILTER((REPLACE(STR(?j115), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j114 = "simpsons-paradox-v1")) }
