    OPTIONAL { $this effortless-ntwf:strataWonByA ?strata_won_by_a . }
    OPTIONAL { $this effortless-ntwf:strataWonByB ?strata_won_by_b . }
    OPTIONAL { $this effortless-ntwf:treatmentA ?treatment_a . }
                BIND(IF((?pooled_winner = ?treatment_a), ?strata_won_by_b, ?strata_won_by_a) AS ?_result)
