# === Shape with rules for DiscoveryHypotheses ===
effortless-ntwf:DiscoveryHypothesesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:DiscoveryHypotheses ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DiscoveryHypotheses_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DiscoveryHypotheses .
    OPTIONAL { $this effortless-ntwf:hypothesisId ?hypothesis_id . }
                BIND(?hypothesis_id AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for DomainExpansionTargets ===
effortless-ntwf:DomainExpansionTargetsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:DomainExpansionTargets ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DomainExpansionTargets_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DomainExpansionTargets .
    OPTIONAL { $this effortless-ntwf:domainTargetId ?domain_target_id . }
                BIND(?domain_target_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DomainExpansionTargets_CurrentImportedCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:currentImportedCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DomainExpansionTargets .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:Studies .
                    OPTIONAL { ?child effortless-ntwf:domain ?c0 . }
                    OPTIONAL { $this effortless-ntwf:domain ?domain . }
                    OPTIONAL { $this effortless-ntwf:legacyDomainAlias ?legacy_domain_alias . }
                    BIND(IF((REPLACE(COALESCE(STR(?legacy_domain_alias), ""), "^.*#", "") != ""), ?legacy_domain_alias, ?domain) AS ?p0)
                    OPTIONAL { ?child effortless-ntwf:isSynthetic ?c2 . }
                    FILTER(REPLACE(STR(?c0), "^.*[#/]", "") = REPLACE(STR(?p0), "^.*[#/]", ""))
                    FILTER(BOUND(?c2) && ?c2 = false)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DomainExpansionTargets_CandidateQueuedCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:candidateQueuedCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DomainExpansionTargets .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    ?child effortless-ntwf:domain ?backfk .
                    $this effortless-ntwf:domain ?backpv .
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c2 . }
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER((STR(?c2) = "candidate"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DomainExpansionTargets_ProjectedCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:projectedCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DomainExpansionTargets .
    OPTIONAL { $this effortless-ntwf:candidateQueuedCount ?candidate_queued_count . }
    OPTIONAL { $this effortless-ntwf:currentImportedCount ?current_imported_count . }
                BIND((?current_imported_count + ?candidate_queued_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DomainExpansionTargets_GapCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:gapCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DomainExpansionTargets .
    OPTIONAL { $this effortless-ntwf:projectedCount ?projected_count . }
    OPTIONAL { $this effortless-ntwf:targetMinCount ?target_min_count . }
                BIND(IF((0) > ((?target_min_count - ?projected_count)), (0), ((?target_min_count - ?projected_count))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DomainExpansionTargets_IsUnderRepresented" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isUnderRepresented ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DomainExpansionTargets .
    OPTIONAL { $this effortless-ntwf:projectedCount ?projected_count . }
    OPTIONAL { $this effortless-ntwf:targetMinCount ?target_min_count . }
                BIND((?projected_count < ?target_min_count) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for IdentityClusterSummaries ===
effortless-ntwf:IdentityClusterSummariesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:IdentityClusterSummaries ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IdentityClusterSummaries_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IdentityClusterSummaries .
    OPTIONAL { $this effortless-ntwf:identityClusterId ?identity_cluster_id . }
                BIND(?identity_cluster_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IdentityClusterSummaries_DisplayName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:displayName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IdentityClusterSummaries .
                OPTIONAL { $this effortless-ntwf:confounderIdentity ?confounder_identity . }
                OPTIONAL { ?j0 a effortless-ntwf:ConfounderIdentities ; effortless-ntwf:confounderIdentityId ?j1 ; effortless-ntwf:displayName ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?confounder_identity), "^.*[#/]", "")) || (?j0 = ?confounder_identity)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IdentityClusterSummaries_ManifestFlipRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:manifestFlipRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:IdentityClusterSummaries .
    OPTIONAL { $this effortless-ntwf:manifestFlipCount ?manifest_flip_count . }
    OPTIONAL { $this effortless-ntwf:studyCount ?study_count . }
                BIND(IF((?study_count = 0), "", (?manifest_flip_count / ?study_count)) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for IdentityDomainCells ===
effortless-ntwf:IdentityDomainCellsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:IdentityDomainCells ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_IdentityDomainCells_Name" ;
        sh:prefixes effortless-ntwf: ;
