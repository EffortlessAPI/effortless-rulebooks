                OPTIONAL { ?j0 a effortless-ntwf:Studies ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:title ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?canonical_study_id), "^.*[#/]", "")) || (?j0 = ?canonical_study_id)) }
