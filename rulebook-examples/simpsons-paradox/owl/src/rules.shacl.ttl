            }
            WHERE {
    $this a effortless-ntwf:UIScreens .
                OPTIONAL { $this effortless-ntwf:primaryConclusion ?primary_conclusion . }
                OPTIONAL { ?j0 a effortless-ntwf:Conclusions ; effortless-ntwf:conclusionId ?j1 ; effortless-ntwf:title ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?primary_conclusion), "^.*[#/]", "")) || (?j0 = ?primary_conclusion)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
