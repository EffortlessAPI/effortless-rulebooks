# === Shape with rules for SyntheticPhase ===
effortless-ntwf:SyntheticPhaseShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:SyntheticPhase ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseId ?phase_id . }
                BIND(?phase_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseS1Total" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phaseS1Total ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramStratumFraction ?param_stratum_fraction . }
                BIND(ROUND((200 * ?param_stratum_fraction)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseNA1" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phaseNA1 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramAllocationBias ?param_allocation_bias . }
    OPTIONAL { $this effortless-ntwf:phaseS1Total ?phase_s1_total . }
                BIND(ROUND((?phase_s1_total * (0.5 + (?param_allocation_bias / 2)))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseNB1" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phaseNB1 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseNA1 ?phase_na1 . }
    OPTIONAL { $this effortless-ntwf:phaseS1Total ?phase_s1_total . }
                BIND((?phase_s1_total - ?phase_na1) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseNA2" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phaseNA2 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseNA1 ?phase_na1 . }
                BIND((100 - ?phase_na1) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseNB2" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phaseNB2 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseNB1 ?phase_nb1 . }
                BIND((100 - ?phase_nb1) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseRateA1" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phaseRateA1 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramStratumGap1 ?param_stratum_gap1 . }
                BIND((0.45 + (?param_stratum_gap1 / 2)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseRateB1" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phaseRateB1 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramStratumGap1 ?param_stratum_gap1 . }
                BIND((0.45 - (?param_stratum_gap1 / 2)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseRateA2" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phaseRateA2 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramStratumGap2 ?param_stratum_gap2 . }
                BIND((0.75 + (?param_stratum_gap2 / 2)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseRateB2" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phaseRateB2 ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramStratumGap2 ?param_stratum_gap2 . }
                BIND((0.75 - (?param_stratum_gap2 / 2)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhasePooledRateA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phasePooledRateA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseNA1 ?phase_na1 . }
    OPTIONAL { $this effortless-ntwf:phaseNA2 ?phase_na2 . }
    OPTIONAL { $this effortless-ntwf:phaseRateA1 ?phase_rate_a1 . }
    OPTIONAL { $this effortless-ntwf:phaseRateA2 ?phase_rate_a2 . }
                BIND((((?phase_na1 * ?phase_rate_a1) + (?phase_na2 * ?phase_rate_a2)) / 100) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhasePooledRateB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phasePooledRateB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseNB1 ?phase_nb1 . }
    OPTIONAL { $this effortless-ntwf:phaseNB2 ?phase_nb2 . }
    OPTIONAL { $this effortless-ntwf:phaseRateB1 ?phase_rate_b1 . }
    OPTIONAL { $this effortless-ntwf:phaseRateB2 ?phase_rate_b2 . }
                BIND((((?phase_nb1 * ?phase_rate_b1) + (?phase_nb2 * ?phase_rate_b2)) / 100) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseSignedPooledGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phaseSignedPooledGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phasePooledRateA ?phase_pooled_rate_a . }
    OPTIONAL { $this effortless-ntwf:phasePooledRateB ?phase_pooled_rate_b . }
                BIND((?phase_pooled_rate_a - ?phase_pooled_rate_b) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseCorrectedGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phaseCorrectedGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramStratumFraction ?param_stratum_fraction . }
    OPTIONAL { $this effortless-ntwf:paramStratumGap1 ?param_stratum_gap1 . }
    OPTIONAL { $this effortless-ntwf:paramStratumGap2 ?param_stratum_gap2 . }
                BIND(((?param_stratum_fraction * ?param_stratum_gap1) + ((1 - ?param_stratum_fraction) * ?param_stratum_gap2)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseStrataWonByLoser" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phaseStrataWonByLoser ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:paramStratumGap1 ?param_stratum_gap1 . }
    OPTIONAL { $this effortless-ntwf:paramStratumGap2 ?param_stratum_gap2 . }
    OPTIONAL { $this effortless-ntwf:phaseSignedPooledGap ?phase_signed_pooled_gap . }
                BIND(IF((?phase_signed_pooled_gap > 0), (IF((?param_stratum_gap1 < 0), 1, 0) + IF((?param_stratum_gap2 < 0), 1, 0)), (IF((?param_stratum_gap1 > 0), 1, 0) + IF((?param_stratum_gap2 > 0), 1, 0))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseReversalIntensity" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phaseReversalIntensity ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseStrataWonByLoser ?phase_strata_won_by_loser . }
                BIND((?phase_strata_won_by_loser / 2) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SyntheticPhase_PhaseIsSignFlip" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phaseIsSignFlip ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SyntheticPhase .
    OPTIONAL { $this effortless-ntwf:phaseCorrectedGap ?phase_corrected_gap . }
    OPTIONAL { $this effortless-ntwf:phaseSignedPooledGap ?phase_signed_pooled_gap . }
                BIND(IF((?phase_corrected_gap > 0), (?phase_signed_pooled_gap < 0), (?phase_signed_pooled_gap > 0)) AS ?_result)
            }
        """ ;
    ] .
# Rule for PhaseAllocationDistortion - parse error: Unknown function: ABS
# Rule for PhaseDistortionType - parse error: Unknown function: ABS

# === Shape with rules for TreatmentRankings ===
effortless-ntwf:TreatmentRankingsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:TreatmentRankings ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:treatmentRankingId ?treatment_ranking_id . }
                BIND(?treatment_ranking_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_PooledRateA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:pooledRateA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:totalCasesA ?total_cases_a . }
    OPTIONAL { $this effortless-ntwf:totalSuccessesA ?total_successes_a . }
                BIND(IF((?total_cases_a = 0), "", (?total_successes_a / ?total_cases_a)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_PooledRateB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:pooledRateB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:TreatmentRankings .
    OPTIONAL { $this effortless-ntwf:totalCasesB ?total_cases_b . }
    OPTIONAL { $this effortless-ntwf:totalSuccessesB ?total_successes_b . }
                BIND(IF((?total_cases_b = 0), "", (?total_successes_b / ?total_cases_b)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_TreatmentRankings_PerStratumWinner" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:perStratumWinner ?_result .
