    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c0 . }
                    FILTER((STR(?c0) = "imported"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_CandidateCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:candidateCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c0 . }
                    FILTER((STR(?c0) = "candidate"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_BlockedCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:blockedCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c0 . }
                    FILTER((STR(?c0) = "blocked"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_ReadyToEncodeCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:readyToEncodeCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:isReadyToEncode ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_HighPriorityCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:highPriorityCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_lhs) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:priority ?c2 . }
                    FILTER((STR(?c0) = "candidate"))
                    FILTER(?c2 = 1)
                    }
                }
                {
                    SELECT (COUNT(?child) AS ?_rhs) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:priority ?c2 . }
                    FILTER((STR(?c0) = "candidate"))
                    FILTER(?c2 = 2)
                    }
                }
    BIND(?_lhs + ?_rhs AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_ImportSessionReady" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:importSessionReady ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
    OPTIONAL { $this effortless-ntwf:candidateCount ?candidate_count . }
    OPTIONAL { $this effortless-ntwf:readyToEncodeCount ?ready_to_encode_count . }
                BIND(((?candidate_count >= 20) && (?ready_to_encode_count >= 15)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_TypePredictionMatchCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typePredictionMatchCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:typePredictionMatch ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_TypePredictionMismatchCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typePredictionMismatchCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:isImported ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:typePredictionMatch ?c2 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER(BOUND(?c2) && ?c2 = false)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_SignFlipPredictionEligibleCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:signFlipPredictionEligibleCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:isImported ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:expectedSignFlip ?c2 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_SignFlipPredictionMatchCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:signFlipPredictionMatchCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:signFlipPredictionMatch ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_TypePredictionMatchRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typePredictionMatchRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
    OPTIONAL { $this effortless-ntwf:importedCount ?imported_count . }
    OPTIONAL { $this effortless-ntwf:typePredictionMatchCount ?type_prediction_match_count . }
                BIND(IF((?imported_count = 0), "", (?type_prediction_match_count / ?imported_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_SignFlipPredictionMatchRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:signFlipPredictionMatchRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
    OPTIONAL { $this effortless-ntwf:signFlipPredictionEligibleCount ?sign_flip_prediction_eligible_count . }
    OPTIONAL { $this effortless-ntwf:signFlipPredictionMatchCount ?sign_flip_prediction_match_count . }
                BIND(IF((?sign_flip_prediction_eligible_count = 0), "", (?sign_flip_prediction_match_count / ?sign_flip_prediction_eligible_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_CatalogWitnessNote" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:catalogWitnessNote ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
    OPTIONAL { $this effortless-ntwf:candidateCount ?candidate_count . }
    OPTIONAL { $this effortless-ntwf:dataReadyCount ?data_ready_count . }
    OPTIONAL { $this effortless-ntwf:importSessionReady ?import_session_ready . }
    OPTIONAL { $this effortless-ntwf:readyToEncodeCount ?ready_to_encode_count . }
                BIND(IF(?import_session_ready, CONCAT("READY: ", IF(isIRI(?ready_to_encode_count), REPLACE(STR(?ready_to_encode_count), "^.*[#/]", ""), STR(?ready_to_encode_count)), " encode-ready (", IF(isIRI(?data_ready_count), REPLACE(STR(?data_ready_count), "^.*[#/]", ""), STR(?data_ready_count)), " data-ready) of ", IF(isIRI(?candidate_count), REPLACE(STR(?candidate_count), "^.*[#/]", ""), STR(?candidate_count)), " candidates"), CONCAT("BUILDING: ", IF(isIRI(?candidate_count), REPLACE(STR(?candidate_count), "^.*[#/]", ""), STR(?candidate_count)), " candidates — ", IF(isIRI(?data_ready_count), REPLACE(STR(?data_ready_count), "^.*[#/]", ""), STR(?data_ready_count)), " data-ready, ", IF(isIRI(?ready_to_encode_count), REPLACE(STR(?ready_to_encode_count), "^.*[#/]", ""), STR(?ready_to_encode_count)), " encode-ready")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_CatalogPredictionWitnessNote" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:catalogPredictionWitnessNote ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
    OPTIONAL { $this effortless-ntwf:importedCount ?imported_count . }
    OPTIONAL { $this effortless-ntwf:signFlipPredictionEligibleCount ?sign_flip_prediction_eligible_count . }
    OPTIONAL { $this effortless-ntwf:signFlipPredictionMatchCount ?sign_flip_prediction_match_count . }
    OPTIONAL { $this effortless-ntwf:signFlipPredictionMatchRate ?sign_flip_prediction_match_rate . }
    OPTIONAL { $this effortless-ntwf:typePredictionMatchCount ?type_prediction_match_count . }
    OPTIONAL { $this effortless-ntwf:typePredictionMatchRate ?type_prediction_match_rate . }
                BIND(CONCAT("exact=", IF(isIRI(?type_prediction_match_count), REPLACE(STR(?type_prediction_match_count), "^.*[#/]", ""), STR(?type_prediction_match_count)), "/", IF(isIRI(?imported_count), REPLACE(STR(?imported_count), "^.*[#/]", ""), STR(?imported_count)), " (", IF(isIRI((ROUND((?type_prediction_match_rate * 100) * STRDT(CONCAT("1e", STR(1)), xsd:double)) / STRDT(CONCAT("1e", STR(1)), xsd:double))), REPLACE(STR((ROUND((?type_prediction_match_rate * 100) * STRDT(CONCAT("1e", STR(1)), xsd:double)) / STRDT(CONCAT("1e", STR(1)), xsd:double))), "^.*[#/]", ""), STR((ROUND((?type_prediction_match_rate * 100) * STRDT(CONCAT("1e", STR(1)), xsd:double)) / STRDT(CONCAT("1e", STR(1)), xsd:double)))), "%); flipPred=", IF(isIRI(?sign_flip_prediction_match_count), REPLACE(STR(?sign_flip_prediction_match_count), "^.*[#/]", ""), STR(?sign_flip_prediction_match_count)), "/", IF(isIRI(?sign_flip_prediction_eligible_count), REPLACE(STR(?sign_flip_prediction_eligible_count), "^.*[#/]", ""), STR(?sign_flip_prediction_eligible_count)), " (", IF(isIRI((ROUND((?sign_flip_prediction_match_rate * 100) * STRDT(CONCAT("1e", STR(1)), xsd:double)) / STRDT(CONCAT("1e", STR(1)), xsd:double))), REPLACE(STR((ROUND((?sign_flip_prediction_match_rate * 100) * STRDT(CONCAT("1e", STR(1)), xsd:double)) / STRDT(CONCAT("1e", STR(1)), xsd:double))), "^.*[#/]", ""), STR((ROUND((?sign_flip_prediction_match_rate * 100) * STRDT(CONCAT("1e", STR(1)), xsd:double)) / STRDT(CONCAT("1e", STR(1)), xsd:double)))), "%)") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_DataReadyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:dataReadyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:isDataReady ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c2 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER((STR(?c2) = "candidate"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_EncodePipelineReadyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:encodePipelineReadyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:isReadyToEncode ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:isDataReady ?c2 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_ExpansionCandidateCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:expansionCandidateCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:expansionWave ?c0 . }
                    FILTER((STR(?c0) = "expansion-wave-1"))
                    }
                }
            }
        """ ;
    ] .

# === Shape with rules for CorpusDomains ===
effortless-ntwf:CorpusDomainsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:CorpusDomains ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusDomains_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusDomains .
    OPTIONAL { $this effortless-ntwf:domainId ?domain_id . }
                BIND(?domain_id AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for DiscoveryFindings ===
effortless-ntwf:DiscoveryFindingsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:DiscoveryFindings ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DiscoveryFindings_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DiscoveryFindings .
    OPTIONAL { $this effortless-ntwf:findingId ?finding_id . }
                BIND(?finding_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DiscoveryFindings_HypothesisStatement" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:hypothesisStatement ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DiscoveryFindings .
                OPTIONAL { $this effortless-ntwf:hypothesisId ?hypothesis_id . }
                OPTIONAL { ?j0 a effortless-ntwf:DiscoveryHypotheses ; effortless-ntwf:hypothesisId ?j1 ; effortless-ntwf:statement ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?hypothesis_id), "^.*[#/]", "")) || (?j0 = ?hypothesis_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DiscoveryFindings_IsConfirmed" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isConfirmed ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DiscoveryFindings .
                OPTIONAL { $this effortless-ntwf:hypothesisId ?hypothesis_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j1 ; effortless-ntwf:latentTypeDFraction ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j0 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j3 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j4 ; effortless-ntwf:signFlipSignalPurityMax ?j5 . FILTER((REPLACE(STR(?j4), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j3 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j6 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j7 ; effortless-ntwf:avgPooledGapStableD ?j8 . FILTER((REPLACE(STR(?j7), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j6 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j9 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j10 ; effortless-ntwf:avgPooledGapLatentD ?j11 . FILTER((REPLACE(STR(?j10), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j9 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j12 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j13 ; effortless-ntwf:economicsSignFlipCount ?j14 . FILTER((REPLACE(STR(?j13), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j12 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j15 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j16 ; effortless-ntwf:epidemiologyAvgDistortion ?j17 . FILTER((REPLACE(STR(?j16), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j15 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j18 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j19 ; effortless-ntwf:educationAvgDistortion ?j20 . FILTER((REPLACE(STR(?j19), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j18 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j21 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j22 ; effortless-ntwf:confounderSignFlipCount ?j23 . FILTER((REPLACE(STR(?j22), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j21 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j24 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j25 ; effortless-ntwf:colliderSelectionManifestCount ?j26 . FILTER((REPLACE(STR(?j25), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j24 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j27 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j28 ; effortless-ntwf:confounderSignFlipCount ?j29 . FILTER((REPLACE(STR(?j28), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j27 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j30 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j31 ; effortless-ntwf:colliderSelectionManifestCount ?j32 . FILTER((REPLACE(STR(?j31), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j30 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j33 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j34 ; effortless-ntwf:colliderSelectionLatentOnlyCount ?j35 . FILTER((REPLACE(STR(?j34), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j33 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j36 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j37 ; effortless-ntwf:explainedConfounderCount ?j38 . FILTER((REPLACE(STR(?j37), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j36 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j39 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j40 ; effortless-ntwf:confounderSignFlipCount ?j41 . FILTER((REPLACE(STR(?j40), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j39 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j42 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j43 ; effortless-ntwf:explainedConfounderCount ?j44 . FILTER((REPLACE(STR(?j43), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j42 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j45 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j46 ; effortless-ntwf:contestedOrMediatorExplainedCount ?j47 . FILTER((REPLACE(STR(?j46), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j45 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j48 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j49 ; effortless-ntwf:typePredictionMatchRate ?j50 . FILTER((REPLACE(STR(?j49), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j48 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j51 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j52 ; effortless-ntwf:signFlipPredictionMatchRate ?j53 . FILTER((REPLACE(STR(?j52), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j51 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j54 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j55 ; effortless-ntwf:economicsHighImbalanceSignFlipCount ?j56 . FILTER((REPLACE(STR(?j55), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j54 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j57 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j58 ; effortless-ntwf:epidemiologyHighImbalanceSignFlipRate ?j59 . FILTER((REPLACE(STR(?j58), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j57 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j60 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j61 ; effortless-ntwf:colliderSelectionManifestCount ?j62 . FILTER((REPLACE(STR(?j61), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j60 = "simpsons-paradox-v1")) }
