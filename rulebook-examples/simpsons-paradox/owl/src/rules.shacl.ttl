# === Shape with rules for SweepStudySummary ===
effortless-ntwf:SweepStudySummaryShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:SweepStudySummary ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SweepStudySummary_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SweepStudySummary .
    OPTIONAL { $this effortless-ntwf:sweepStudyId ?sweep_study_id . }
                BIND(?sweep_study_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SweepStudySummary_SweepCorrectedGapRange" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:sweepCorrectedGapRange ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SweepStudySummary .
    OPTIONAL { $this effortless-ntwf:sweepCorrectedGapMax ?sweep_corrected_gap_max . }
    OPTIONAL { $this effortless-ntwf:sweepCorrectedGapMin ?sweep_corrected_gap_min . }
                BIND((?sweep_corrected_gap_max - ?sweep_corrected_gap_min) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SweepStudySummary_SweepPooledGapRange" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:sweepPooledGapRange ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SweepStudySummary .
    OPTIONAL { $this effortless-ntwf:sweepPooledGapMax ?sweep_pooled_gap_max . }
    OPTIONAL { $this effortless-ntwf:sweepPooledGapMin ?sweep_pooled_gap_min . }
                BIND((?sweep_pooled_gap_max - ?sweep_pooled_gap_min) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SweepStudySummary_PooledGapCrossesZero" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:pooledGapCrossesZero ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SweepStudySummary .
    OPTIONAL { $this effortless-ntwf:sweepPooledGapMax ?sweep_pooled_gap_max . }
    OPTIONAL { $this effortless-ntwf:sweepPooledGapMin ?sweep_pooled_gap_min . }
                BIND(((?sweep_pooled_gap_min < 0) && (?sweep_pooled_gap_max > 0)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_SweepStudySummary_InvariantWitness" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:invariantWitness ?_result .
            }
            WHERE {
    $this a effortless-ntwf:SweepStudySummary .
    OPTIONAL { $this effortless-ntwf:sweepCorrectedGapRange ?sweep_corrected_gap_range . }
                BIND(IF((?sweep_corrected_gap_range < 0.0001), "PASS: CorrectedGap invariant across allocation sweep", "FAIL: CorrectedGap varies — formula error") AS ?_result)
            }
        """ ;
    ] .
