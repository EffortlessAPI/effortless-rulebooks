                BIND(IF((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = ""), "", ((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "D") && (?pooled_gap_crosses_zero = true))) AS ?_result)
            }
