    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_OtherDomainStudyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
