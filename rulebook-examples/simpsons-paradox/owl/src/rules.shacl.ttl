                {
                    SELECT (COUNT(?child) AS ?_lhs) WHERE {
                    ?child a effortless-ntwf:DiscoveryFindings .
                    OPTIONAL { ?child effortless-ntwf:hypothesisId ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:isConfirmed ?c2 . }
                    FILTER((STR(?c0) = "H-econ-zero"))
                    FILTER(BOUND(?c2) && ?c2 = false)
                    }
                }
                {
                    SELECT (COUNT(?child) AS ?_rhs) WHERE {
                    ?child a effortless-ntwf:DiscoveryFindings .
                    OPTIONAL { ?child effortless-ntwf:hypothesisId ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:isConfirmed ?c2 . }
                    FILTER((STR(?c0) = "H-domain-dist"))
                    FILTER(BOUND(?c2) && ?c2 = false)
                    }
                }
    BIND(?_lhs + ?_rhs AS ?_lhs)
                {
                    SELECT (COUNT(?child) AS ?_rhs) WHERE {
                    ?child a effortless-ntwf:DiscoveryFindings .
                    OPTIONAL { ?child effortless-ntwf:hypothesisId ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:isConfirmed ?c2 . }
                    FILTER((STR(?c0) = "H-catalog-flip-prediction"))
                    FILTER(BOUND(?c2) && ?c2 = false)
                    }
                }
    BIND(?_lhs + ?_rhs AS ?_lhs)
                {
                    SELECT (COUNT(?child) AS ?_rhs) WHERE {
                    ?child a effortless-ntwf:DiscoveryFindings .
                    OPTIONAL { ?child effortless-ntwf:hypothesisId ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:isConfirmed ?c2 . }
                    FILTER((STR(?c0) = "H-domain-flip-geometry-controlled"))
                    FILTER(BOUND(?c2) && ?c2 = false)
                    }
                }
    BIND(?_lhs + ?_rhs AS ?_lhs)
                {
                    SELECT (COUNT(?child) AS ?_rhs) WHERE {
                    ?child a effortless-ntwf:DiscoveryFindings .
                    OPTIONAL { ?child effortless-ntwf:hypothesisId ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:isConfirmed ?c2 . }
                    FILTER((STR(?c0) = "H-econ-encoding-selection"))
                    FILTER(BOUND(?c2) && ?c2 = false)
                    }
                }
    BIND(?_lhs + ?_rhs AS ?_lhs)
                {
                    SELECT (COUNT(?child) AS ?_rhs) WHERE {
                    ?child a effortless-ntwf:DiscoveryFindings .
                    OPTIONAL { ?child effortless-ntwf:hypothesisId ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:isConfirmed ?c2 . }
                    FILTER((STR(?c0) = "H-domain-profiles-stable"))
                    FILTER(BOUND(?c2) && ?c2 = false)
                    }
                }
    BIND(?_lhs + ?_rhs AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_ExpansionWave3DiscoveryNote" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:expansionWave3DiscoveryNote ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:corpusPatternSupersededFailCount ?corpus_pattern_superseded_fail_count . }
    OPTIONAL { $this effortless-ntwf:economicsSignFlipCount ?economics_sign_flip_count . }
    OPTIONAL { $this effortless-ntwf:signFlipPredictionMatchRate ?sign_flip_prediction_match_rate . }
    OPTIONAL { $this effortless-ntwf:theoremCount ?theorem_count . }
    OPTIONAL { $this effortless-ntwf:typePredictionMatchRate ?type_prediction_match_rate . }
                BIND(CONCAT("superseded=", IF(isIRI(?corpus_pattern_superseded_fail_count), REPLACE(STR(?corpus_pattern_superseded_fail_count), "^.*[#/]", ""), STR(?corpus_pattern_superseded_fail_count)), "; econFlips=", IF(isIRI(?economics_sign_flip_count), REPLACE(STR(?economics_sign_flip_count), "^.*[#/]", ""), STR(?economics_sign_flip_count)), "; flipPred=", IF(isIRI(?sign_flip_prediction_match_rate), REPLACE(STR(?sign_flip_prediction_match_rate), "^.*[#/]", ""), STR(?sign_flip_prediction_match_rate)), "; catalogExact=", IF(isIRI(?type_prediction_match_rate), REPLACE(STR(?type_prediction_match_rate), "^.*[#/]", ""), STR(?type_prediction_match_rate)), "; theorems=", IF(isIRI(?theorem_count), REPLACE(STR(?theorem_count), "^.*[#/]", ""), STR(?theorem_count))) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for PhaseDiagramSummary ===
effortless-ntwf:PhaseDiagramSummaryShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:PhaseDiagramSummary ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_PhaseDiagramSummary_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:PhaseDiagramSummary .
    OPTIONAL { $this effortless-ntwf:phaseDiagramId ?phase_diagram_id . }
                BIND(?phase_diagram_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_PhaseDiagramSummary_PhasePointCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phasePointCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:PhaseDiagramSummary .
    OPTIONAL { $this effortless-ntwf:phaseTypeACount ?phase_type_a_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeBCount ?phase_type_b_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCMinusCount ?phase_type_c_minus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCPlusCount ?phase_type_c_plus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeDCount ?phase_type_d_count . }
                BIND(((((?phase_type_a_count + ?phase_type_b_count) + ?phase_type_c_plus_count) + ?phase_type_c_minus_count) + ?phase_type_d_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_PhaseDiagramSummary_AllFiveTypesPresent" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:allFiveTypesPresent ?_result .
            }
            WHERE {
    $this a effortless-ntwf:PhaseDiagramSummary .
    OPTIONAL { $this effortless-ntwf:phaseTypeACount ?phase_type_a_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeBCount ?phase_type_b_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCMinusCount ?phase_type_c_minus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCPlusCount ?phase_type_c_plus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeDCount ?phase_type_d_count . }
                BIND(((?phase_type_a_count > 0) && (?phase_type_b_count > 0) && (?phase_type_c_plus_count > 0) && (?phase_type_c_minus_count > 0) && (?phase_type_d_count > 0)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_PhaseDiagramSummary_PhaseTaxonomyWitness" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseTaxonomyWitness ?_result .
            }
            WHERE {
    $this a effortless-ntwf:PhaseDiagramSummary .
    OPTIONAL { $this effortless-ntwf:phaseTypeACount ?phase_type_a_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeBCount ?phase_type_b_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCMinusCount ?phase_type_c_minus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCPlusCount ?phase_type_c_plus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeDCount ?phase_type_d_count . }
                BIND(CONCAT("A:", IF(isIRI(?phase_type_a_count), REPLACE(STR(?phase_type_a_count), "^.*[#/]", ""), STR(?phase_type_a_count)), " B:", IF(isIRI(?phase_type_b_count), REPLACE(STR(?phase_type_b_count), "^.*[#/]", ""), STR(?phase_type_b_count)), " C+:", IF(isIRI(?phase_type_c_plus_count), REPLACE(STR(?phase_type_c_plus_count), "^.*[#/]", ""), STR(?phase_type_c_plus_count)), " C-:", IF(isIRI(?phase_type_c_minus_count), REPLACE(STR(?phase_type_c_minus_count), "^.*[#/]", ""), STR(?phase_type_c_minus_count)), " D:", IF(isIRI(?phase_type_d_count), REPLACE(STR(?phase_type_d_count), "^.*[#/]", ""), STR(?phase_type_d_count))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_PhaseDiagramSummary_PhaseWitnessNote" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:phaseWitnessNote ?_result .
            }
            WHERE {
    $this a effortless-ntwf:PhaseDiagramSummary .
    OPTIONAL { $this effortless-ntwf:allFiveTypesPresent ?all_five_types_present . }
                BIND(IF(?all_five_types_present, "PASS: all five distortion types populated in parameter space", "FAIL: missing distortion type in grid") AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for ResearchTraditions ===
effortless-ntwf:ResearchTraditionsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:ResearchTraditions ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ResearchTraditions_IllustratedByStudyTitle" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:illustratedByStudyTitle ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ResearchTraditions .
                OPTIONAL { $this effortless-ntwf:illustratedByStudy ?illustrated_by_study . }
                OPTIONAL { ?j0 a effortless-ntwf:Studies ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:title ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?illustrated_by_study), "^.*[#/]", "")) || (?j0 = ?illustrated_by_study)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ResearchTraditions_IllustratedByStudySource" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:illustratedByStudySource ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ResearchTraditions .
                OPTIONAL { $this effortless-ntwf:illustratedByStudy ?illustrated_by_study . }
                OPTIONAL { ?j0 a effortless-ntwf:Studies ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:source ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?illustrated_by_study), "^.*[#/]", "")) || (?j0 = ?illustrated_by_study)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ResearchTraditions_IllustratedByStudyDistortionType" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:illustratedByStudyDistortionType ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ResearchTraditions .
                OPTIONAL { $this effortless-ntwf:illustratedByStudy ?illustrated_by_study . }
                OPTIONAL { ?j0 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j1 ; effortless-ntwf:distortionType ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?illustrated_by_study), "^.*[#/]", "")) || (?j0 = ?illustrated_by_study)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ResearchTraditions_SupportingConclusionTitle" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:supportingConclusionTitle ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ResearchTraditions .
                OPTIONAL { $this effortless-ntwf:supportingConclusion ?supporting_conclusion . }
                OPTIONAL { ?j0 a effortless-ntwf:Conclusions ; effortless-ntwf:conclusionId ?j1 ; effortless-ntwf:title ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?supporting_conclusion), "^.*[#/]", "")) || (?j0 = ?supporting_conclusion)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ResearchTraditions_SupportingConclusionCategory" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:supportingConclusionCategory ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ResearchTraditions .
                OPTIONAL { $this effortless-ntwf:supportingConclusion ?supporting_conclusion . }
                OPTIONAL { ?j0 a effortless-ntwf:Conclusions ; effortless-ntwf:conclusionId ?j1 ; effortless-ntwf:category ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?supporting_conclusion), "^.*[#/]", "")) || (?j0 = ?supporting_conclusion)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ResearchTraditions_ResearcherCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:researcherCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ResearchTraditions .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:Researchers .
                    ?child effortless-ntwf:traditionId ?backfk .
                    $this effortless-ntwf:traditionId ?backpv .
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ResearchTraditions_StudyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:studyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ResearchTraditions .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:Studies .
                    ?child effortless-ntwf:traditionId ?backfk .
                    $this effortless-ntwf:traditionId ?backpv .
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ResearchTraditions_LoopCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:loopCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ResearchTraditions .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:Loops .
                    ?child effortless-ntwf:traditionId ?backfk .
                    $this effortless-ntwf:traditionId ?backpv .
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    }
                }
            }
        """ ;
    ] .

# === Shape with rules for Researchers ===
effortless-ntwf:ResearchersShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Researchers ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Researchers_TraditionName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:traditionName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Researchers .
                OPTIONAL { $this effortless-ntwf:traditionId ?tradition_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:name ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Researchers_TraditionEra" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:traditionEra ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Researchers .
                OPTIONAL { $this effortless-ntwf:traditionId ?tradition_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:era ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Researchers_CanonicalStudyTitle" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:canonicalStudyTitle ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Researchers .
                OPTIONAL { $this effortless-ntwf:canonicalStudyId ?canonical_study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:Studies ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:title ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?canonical_study_id), "^.*[#/]", "")) || (?j0 = ?canonical_study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Researchers_CanonicalStudyDistortionType" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:canonicalStudyDistortionType ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Researchers .
                OPTIONAL { $this effortless-ntwf:canonicalStudyId ?canonical_study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j1 ; effortless-ntwf:distortionType ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?canonical_study_id), "^.*[#/]", "")) || (?j0 = ?canonical_study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Researchers_CanonicalStudyPolicyImplication" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:canonicalStudyPolicyImplication ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Researchers .
                OPTIONAL { $this effortless-ntwf:canonicalStudyId ?canonical_study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j1 ; effortless-ntwf:correctedPolicyImplication ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?canonical_study_id), "^.*[#/]", "")) || (?j0 = ?canonical_study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Researchers_IllustratesConclusionTitle" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:illustratesConclusionTitle ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Researchers .
                OPTIONAL { $this effortless-ntwf:illustratesConclusion ?illustrates_conclusion . }
                OPTIONAL { ?j0 a effortless-ntwf:Conclusions ; effortless-ntwf:conclusionId ?j1 ; effortless-ntwf:title ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?illustrates_conclusion), "^.*[#/]", "")) || (?j0 = ?illustrates_conclusion)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Researchers_TraditionKeyClaimSummary" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:traditionKeyClaimSummary ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Researchers .
                OPTIONAL { $this effortless-ntwf:traditionId ?tradition_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:keyClaim ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for Strata ===
effortless-ntwf:StrataShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Strata ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Strata_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Strata .
    OPTIONAL { $this effortless-ntwf:stratumId ?stratum_id . }
                BIND(?stratum_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Strata_TotalCases" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:totalCases ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Strata .
                {
                    SELECT (SUM(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:CaseCells .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:stratumLabel ?c2 . }
                    OPTIONAL { $this effortless-ntwf:stratumLabel ?p2 . }
                    OPTIONAL { ?child effortless-ntwf:cases ?sumraw . }
                    BIND(IF(BOUND(?sumraw), xsd:double(STR(?sumraw)), 0.0) AS ?sumval)
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c2), "^.*[#/]", "") = REPLACE(STR(?p2), "^.*[#/]", ""))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] .

