                    OPTIONAL { ?child effortless-ntwf:distortionType ?c0 . }
                    FILTER((STR(?c0) = "C+"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_CCompressionCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:cCompressionCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:distortionType ?c0 . }
                    FILTER((STR(?c0) = "C-"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_SweepCorrectedGapMax" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepCorrectedGapMax ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (MAX(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:AllocationSweep .
                    OPTIONAL { ?child effortless-ntwf:studyId ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:sweepCorrectedGap ?sumraw . }
                    BIND(xsd:double(STR(?sumraw)) AS ?sumval)
                    FILTER((STR(?c0) = "kidney-1986"))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_SweepCorrectedGapMin" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepCorrectedGapMin ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (MIN(?cval) AS ?_result) WHERE {
                        SELECT ?child (MIN(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:AllocationSweep .
                    OPTIONAL { ?child effortless-ntwf:studyId ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:sweepCorrectedGap ?sumraw . }
                    BIND(xsd:double(STR(?sumraw)) AS ?sumval)
                    FILTER((STR(?c0) = "kidney-1986"))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_SweepCorrectedGapRange" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepCorrectedGapRange ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:sweepCorrectedGapMax ?sweep_corrected_gap_max . }
    OPTIONAL { $this effortless-ntwf:sweepCorrectedGapMin ?sweep_corrected_gap_min . }
                BIND(IF((REPLACE(COALESCE(STR(?sweep_corrected_gap_max), ""), "^.*#", "") = ""), "", (?sweep_corrected_gap_max - ?sweep_corrected_gap_min)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_SignalPurityGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:signalPurityGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:avgSignalPurityNonReversal ?avg_signal_purity_non_reversal . }
    OPTIONAL { $this effortless-ntwf:avgSignalPurityReversal ?avg_signal_purity_reversal . }
                BIND((?avg_signal_purity_non_reversal - ?avg_signal_purity_reversal) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_OtherDomainStudyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:otherDomainStudyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:epidemiologyStudyCount ?epidemiology_study_count . }
    OPTIONAL { $this effortless-ntwf:medicineStudyCount ?medicine_study_count . }
    OPTIONAL { $this effortless-ntwf:realStudyCount ?real_study_count . }
                BIND(((?real_study_count - ?medicine_study_count) - ?epidemiology_study_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_IngestionProtocolItemCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:ingestionProtocolItemCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:IngestionProtocol .
                    OPTIONAL { ?child effortless-ntwf:protocolId ?c0 . }
                    FILTER((STR(?c0) != ""))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_CorpusPassesIngestionContract" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:corpusPassesIngestionContract ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                OPTIONAL { ?j0 a effortless-ntwf:IngestionSummary ; effortless-ntwf:ingestionSummaryId ?j1 ; effortless-ntwf:ingestionContractPasses ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR("ingestion-v1"), "^.*[#/]", "")) || (?j0 = "ingestion-v1")) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_IngestionWitnessNote" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:ingestionWitnessNote ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                OPTIONAL { ?j0 a effortless-ntwf:IngestionSummary ; effortless-ntwf:ingestionSummaryId ?j1 ; effortless-ntwf:ingestionWitnessNote ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR("ingestion-v1"), "^.*[#/]", "")) || (?j0 = "ingestion-v1")) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_CatalogEntryCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:catalogEntryCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                OPTIONAL { ?j0 a effortless-ntwf:CorpusCatalogSummary ; effortless-ntwf:catalogSummaryId ?j1 ; effortless-ntwf:totalCatalogEntries ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR("catalog-v1"), "^.*[#/]", "")) || (?j0 = "catalog-v1")) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_PendingImportCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:pendingImportCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                OPTIONAL { ?j0 a effortless-ntwf:CorpusCatalogSummary ; effortless-ntwf:catalogSummaryId ?j1 ; effortless-ntwf:candidateCount ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR("catalog-v1"), "^.*[#/]", "")) || (?j0 = "catalog-v1")) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_ReadyToEncodeCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:readyToEncodeCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                OPTIONAL { ?j0 a effortless-ntwf:CorpusCatalogSummary ; effortless-ntwf:catalogSummaryId ?j1 ; effortless-ntwf:readyToEncodeCount ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR("catalog-v1"), "^.*[#/]", "")) || (?j0 = "catalog-v1")) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_ImportSessionReady" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:importSessionReady ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                OPTIONAL { ?j0 a effortless-ntwf:CorpusCatalogSummary ; effortless-ntwf:catalogSummaryId ?j1 ; effortless-ntwf:importSessionReady ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR("catalog-v1"), "^.*[#/]", "")) || (?j0 = "catalog-v1")) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_CatalogWitnessNote" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:catalogWitnessNote ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                OPTIONAL { ?j0 a effortless-ntwf:CorpusCatalogSummary ; effortless-ntwf:catalogSummaryId ?j1 ; effortless-ntwf:catalogWitnessNote ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR("catalog-v1"), "^.*[#/]", "")) || (?j0 = "catalog-v1")) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_LatentTypeDFraction" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:latentTypeDFraction ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:latentTypeDCount ?latent_type_d_count . }
    OPTIONAL { $this effortless-ntwf:typeDCount ?type_d_count . }
                BIND(IF((?type_d_count = 0), "", (?latent_type_d_count / ?type_d_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_ExplainedConfounderCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:explainedConfounderCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:isParadoxExplained ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_ContestedOrMediatorExplainedCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:contestedOrMediatorExplainedCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:isSignFlip ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:isParadoxExplained ?c2 . }
                    OPTIONAL { ?child effortless-ntwf:adjustmentAppropriate ?c4 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER(BOUND(?c2) && ?c2 = true)
                    FILTER(BOUND(?c4) && ?c4 = false)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_DiscoveryWitnessNote" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:discoveryWitnessNote ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:domainFlipGapSurvivesGeometryControl ?domain_flip_gap_survives_geometry_control . }
    OPTIONAL { $this effortless-ntwf:latentTypeDFraction ?latent_type_d_fraction . }
    OPTIONAL { $this effortless-ntwf:signFlipSignalPurityMax ?sign_flip_signal_purity_max . }
    OPTIONAL { $this effortless-ntwf:typePredictionMatchRate ?type_prediction_match_rate . }
                BIND(CONCAT("sweep: latentD=", IF(isIRI(?latent_type_d_fraction), REPLACE(STR(?latent_type_d_fraction), "^.*[#/]", ""), STR(?latent_type_d_fraction)), " purityMax=", IF(isIRI(?sign_flip_signal_purity_max), REPLACE(STR(?sign_flip_signal_purity_max), "^.*[#/]", ""), STR(?sign_flip_signal_purity_max)), " catalogExact=", IF(isIRI(?type_prediction_match_rate), REPLACE(STR(?type_prediction_match_rate), "^.*[#/]", ""), STR(?type_prediction_match_rate)), " domainGapSurvives=", IF(isIRI(?domain_flip_gap_survives_geometry_control), REPLACE(STR(?domain_flip_gap_survives_geometry_control), "^.*[#/]", ""), STR(?domain_flip_gap_survives_geometry_control))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_TypePredictionMatchCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typePredictionMatchCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                OPTIONAL { ?j0 a effortless-ntwf:CorpusCatalogSummary ; effortless-ntwf:catalogSummaryId ?j1 ; effortless-ntwf:typePredictionMatchCount ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR("catalog-v1"), "^.*[#/]", "")) || (?j0 = "catalog-v1")) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_TypePredictionMismatchCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typePredictionMismatchCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                OPTIONAL { ?j0 a effortless-ntwf:CorpusCatalogSummary ; effortless-ntwf:catalogSummaryId ?j1 ; effortless-ntwf:typePredictionMismatchCount ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR("catalog-v1"), "^.*[#/]", "")) || (?j0 = "catalog-v1")) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_TypePredictionMatchRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typePredictionMatchRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                OPTIONAL { ?j0 a effortless-ntwf:CorpusCatalogSummary ; effortless-ntwf:catalogSummaryId ?j1 ; effortless-ntwf:typePredictionMatchRate ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR("catalog-v1"), "^.*[#/]", "")) || (?j0 = "catalog-v1")) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_SignFlipPredictionMatchRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:signFlipPredictionMatchRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                OPTIONAL { ?j0 a effortless-ntwf:CorpusCatalogSummary ; effortless-ntwf:catalogSummaryId ?j1 ; effortless-ntwf:signFlipPredictionMatchRate ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR("catalog-v1"), "^.*[#/]", "")) || (?j0 = "catalog-v1")) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_CatalogPredictionWitnessNote" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:catalogPredictionWitnessNote ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                OPTIONAL { ?j0 a effortless-ntwf:CorpusCatalogSummary ; effortless-ntwf:catalogSummaryId ?j1 ; effortless-ntwf:catalogPredictionWitnessNote ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR("catalog-v1"), "^.*[#/]", "")) || (?j0 = "catalog-v1")) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_EconomicsExpectedAMismatchRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:economicsExpectedAMismatchRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:expansionWave1EconomicsExpectedACount ?expansion_wave1_economics_expected_a_count . }
    OPTIONAL { $this effortless-ntwf:expansionWave1EconomicsExpectedADCount ?expansion_wave1_economics_expected_ad_count . }
                BIND(IF((?expansion_wave1_economics_expected_a_count = 0), "", (?expansion_wave1_economics_expected_ad_count / ?expansion_wave1_economics_expected_a_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_MaxStudySweepCorrectedGapRange" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:maxStudySweepCorrectedGapRange ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (MAX(?v) AS ?_result) WHERE {
                        ?child a effortless-ntwf:SweepStudySummary .
                        OPTIONAL { ?child effortless-ntwf:sweepCorrectedGapRange ?raw . }
                        BIND(xsd:double(STR(?raw)) AS ?v)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_CorrectedGapInvariantFailCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:correctedGapInvariantFailCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:SweepStudySummary .
                    OPTIONAL { ?child effortless-ntwf:sweepCorrectedGapRange ?c0 . }
                    FILTER((BOUND(?c0) && xsd:double(STR(?c0)) >= 0.0001))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_UnexplainedConfounderSignFlipCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:unexplainedConfounderSignFlipCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:isSignFlip ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:stratumCausalRole ?c2 . }
                    OPTIONAL { ?child effortless-ntwf:isParadoxExplained ?c4 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER((STR(?c2) = "confounder"))
                    FILTER(BOUND(?c4) && ?c4 = false)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_CorpusPatternSupersededFailCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:corpusPatternSupersededFailCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:domainFlipGapSurvivesGeometryControl ?domain_flip_gap_survives_geometry_control . }
    OPTIONAL { $this effortless-ntwf:economicsSignFlipCount ?economics_sign_flip_count . }
                BIND(IF(((?economics_sign_flip_count > 0) && (?domain_flip_gap_survives_geometry_control = false)), 6, 0) AS ?_result)
            }
        """ ;
    ] .
