@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix effortless-ntwf: <https://w3id.org/effortless-ntwf#> .

# === Shape with rules for AllocationSweep ===
effortless-ntwf:AllocationSweepShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:AllocationSweep ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:sweepId ?sweep_id . }
                BIND(?sweep_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_NSweepStratumTotal" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:nSweepStratumTotal ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:nSweepStratumTotal ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_NSweepA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:nSweepA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:allocFractionA ?alloc_fraction_a . }
    OPTIONAL { $this effortless-ntwf:nSweepStratumTotal ?n_sweep_stratum_total . }
                BIND(ROUND((?n_sweep_stratum_total * ?alloc_fraction_a)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_NSweepB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:nSweepB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:nSweepA ?n_sweep_a . }
    OPTIONAL { $this effortless-ntwf:nSweepStratumTotal ?n_sweep_stratum_total . }
                BIND((?n_sweep_stratum_total - ?n_sweep_a) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_NFixedA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:nFixedA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:nFixedA ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_NFixedB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:nFixedB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:nFixedB ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_SweepRateA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepRateA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:sweepRateA ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_SweepRateB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepRateB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:sweepRateB ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_FixedRateA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:fixedRateA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:fixedRateA ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_FixedRateB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:fixedRateB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:fixedRateB ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_SweepPooledRateA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepPooledRateA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:fixedRateA ?fixed_rate_a . }
    OPTIONAL { $this effortless-ntwf:nFixedA ?n_fixed_a . }
    OPTIONAL { $this effortless-ntwf:nSweepA ?n_sweep_a . }
    OPTIONAL { $this effortless-ntwf:sweepRateA ?sweep_rate_a . }
                BIND(IF(((?n_sweep_a + ?n_fixed_a) = 0), "", (((?n_sweep_a * ?sweep_rate_a) + (?n_fixed_a * ?fixed_rate_a)) / (?n_sweep_a + ?n_fixed_a))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_SweepPooledRateB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepPooledRateB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:fixedRateB ?fixed_rate_b . }
    OPTIONAL { $this effortless-ntwf:nFixedB ?n_fixed_b . }
    OPTIONAL { $this effortless-ntwf:nSweepB ?n_sweep_b . }
    OPTIONAL { $this effortless-ntwf:sweepRateB ?sweep_rate_b . }
                BIND(IF(((?n_sweep_b + ?n_fixed_b) = 0), "", (((?n_sweep_b * ?sweep_rate_b) + (?n_fixed_b * ?fixed_rate_b)) / (?n_sweep_b + ?n_fixed_b))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_SweepPooledGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepPooledGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:sweepPooledRateA ?sweep_pooled_rate_a . }
    OPTIONAL { $this effortless-ntwf:sweepPooledRateB ?sweep_pooled_rate_b . }
                BIND(IF((REPLACE(COALESCE(STR(?sweep_pooled_rate_a), ""), "^.*#", "") = ""), "", (?sweep_pooled_rate_a - ?sweep_pooled_rate_b)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_SweepCorrectedGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepCorrectedGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:sweepCorrectedGap ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_AllocationDistortionWitness" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:allocationDistortionWitness ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:sweepCorrectedGap ?sweep_corrected_gap . }
    OPTIONAL { $this effortless-ntwf:sweepPooledGap ?sweep_pooled_gap . }
                BIND(IF((REPLACE(COALESCE(STR(?sweep_pooled_gap), ""), "^.*#", "") = ""), "", (?sweep_pooled_gap - ?sweep_corrected_gap)) AS ?_result)
            }
        """ ;
    ] .
# Rule for IsOriginal - parse error: unsupported lookup sub-expression: FuncCall

# === Shape with rules for CandidateStudyCatalog ===
effortless-ntwf:CandidateStudyCatalogShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:CandidateStudyCatalog ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:candidateId ?candidate_id . }
                BIND(?candidate_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_IsReadyToEncode" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isReadyToEncode ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:citation ?citation . }
    OPTIONAL { $this effortless-ntwf:ingestionStatus ?ingestion_status . }
    OPTIONAL { $this effortless-ntwf:proposedStudyId ?proposed_study_id . }
    OPTIONAL { $this effortless-ntwf:stratumVariableName ?stratum_variable_name . }
                BIND(((REPLACE(COALESCE(STR(?ingestion_status), ""), "^.*#", "") = "candidate") && (REPLACE(COALESCE(STR(?proposed_study_id), ""), "^.*#", "") != "") && (REPLACE(COALESCE(STR(?citation), ""), "^.*#", "") != "") && (REPLACE(COALESCE(STR(?stratum_variable_name), ""), "^.*#", "") != "")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_IsImported" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isImported ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:ingestionStatus ?ingestion_status . }
                BIND((REPLACE(COALESCE(STR(?ingestion_status), ""), "^.*#", "") = "imported") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_ObservedDistortionType" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:observedDistortionType ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
                OPTIONAL { $this effortless-ntwf:linkedStudyId ?linked_study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j1 ; effortless-ntwf:distortionType ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?linked_study_id), "^.*[#/]", "")) || (?j0 = ?linked_study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_TypePredictionMatch" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typePredictionMatch ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:expectedDistortionType ?expected_distortion_type . }
    OPTIONAL { $this effortless-ntwf:isImported ?is_imported . }
    OPTIONAL { $this effortless-ntwf:observedDistortionType ?observed_distortion_type . }
                BIND(IF(?is_imported, (?observed_distortion_type = ?expected_distortion_type), "") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_ExpectedSignFlip" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:expectedSignFlip ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:expectedDistortionType ?expected_distortion_type . }
                BIND(((REPLACE(COALESCE(STR(?expected_distortion_type), ""), "^.*#", "") = "A") || (REPLACE(COALESCE(STR(?expected_distortion_type), ""), "^.*#", "") = "B")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_ObservedSignFlipType" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:observedSignFlipType ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:isImported ?is_imported . }
    OPTIONAL { $this effortless-ntwf:observedDistortionType ?observed_distortion_type . }
                BIND(IF(?is_imported, ((REPLACE(COALESCE(STR(?observed_distortion_type), ""), "^.*#", "") = "A") || (REPLACE(COALESCE(STR(?observed_distortion_type), ""), "^.*#", "") = "B")), "") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_SignFlipPredictionMatch" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:signFlipPredictionMatch ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:expectedSignFlip ?expected_sign_flip . }
    OPTIONAL { $this effortless-ntwf:isImported ?is_imported . }
    OPTIONAL { $this effortless-ntwf:observedSignFlipType ?observed_sign_flip_type . }
                BIND(IF((?is_imported && ?expected_sign_flip), ?observed_sign_flip_type, "") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_IsDataReady" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isDataReady ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:dataAcquisitionStatus ?data_acquisition_status . }
                BIND(((REPLACE(COALESCE(STR(?data_acquisition_status), ""), "^.*#", "") = "downloaded") || (REPLACE(COALESCE(STR(?data_acquisition_status), ""), "^.*#", "") = "manual_only")) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for CaseCells ===
effortless-ntwf:CaseCellsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:CaseCells ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CaseCells_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CaseCells .
    OPTIONAL { $this effortless-ntwf:caseCellId ?case_cell_id . }
                BIND(?case_cell_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CaseCells_CellSuccessRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:cellSuccessRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CaseCells .
    OPTIONAL { $this effortless-ntwf:cases ?cases . }
    OPTIONAL { $this effortless-ntwf:successes ?successes . }
                BIND(IF((?cases = 0), 0, (?successes / ?cases)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CaseCells_TotalCasesForTreatment" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:totalCasesForTreatment ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CaseCells .
                {
                    SELECT (SUM(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:CaseCells .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:treatmentLabel ?c2 . }
                    OPTIONAL { $this effortless-ntwf:treatmentLabel ?p2 . }
                    OPTIONAL { ?child effortless-ntwf:cases ?sumraw . }
                    BIND(IF(BOUND(?sumraw), xsd:double(STR(?sumraw)), 0.0) AS ?sumval)
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c2), "^.*[#/]", "") = REPLACE(STR(?p2), "^.*[#/]", ""))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CaseCells_TreatmentExposureFraction" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:treatmentExposureFraction ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CaseCells .
    OPTIONAL { $this effortless-ntwf:cases ?cases . }
    OPTIONAL { $this effortless-ntwf:totalCasesForTreatment ?total_cases_for_treatment . }
                BIND(IF((?total_cases_for_treatment = 0), "", (?cases / ?total_cases_for_treatment)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CaseCells_IsValidIngestionCell" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isValidIngestionCell ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CaseCells .
    OPTIONAL { $this effortless-ntwf:cases ?cases . }
    OPTIONAL { $this effortless-ntwf:successes ?successes . }
                BIND(((?cases >= 0) && (?successes >= 0) && (?successes <= ?cases)) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for Conclusions ===
effortless-ntwf:ConclusionsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Conclusions ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
    OPTIONAL { $this effortless-ntwf:conclusionId ?conclusion_id . }
                BIND(?conclusion_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_LiveStatusConfirmed" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:liveStatusConfirmed ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:validatingHypothesis ?validating_hypothesis . }
                OPTIONAL { ?j0 a effortless-ntwf:DiscoveryFindings ; effortless-ntwf:hypothesisId ?j1 ; effortless-ntwf:isConfirmed ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?validating_hypothesis), "^.*[#/]", "")) || (?j0 = ?validating_hypothesis)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_LiveStatusObservedMetric" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:liveStatusObservedMetric ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:validatingHypothesis ?validating_hypothesis . }
                OPTIONAL { ?j0 a effortless-ntwf:DiscoveryFindings ; effortless-ntwf:hypothesisId ?j1 ; effortless-ntwf:observedMetric ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?validating_hypothesis), "^.*[#/]", "")) || (?j0 = ?validating_hypothesis)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_TraditionName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:traditionName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:traditionId ?tradition_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:name ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_TraditionKeyClaimSummary" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:traditionKeyClaimSummary ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:traditionId ?tradition_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:keyClaim ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_ResearcherName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:researcherName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:researcherId ?researcher_id . }
                OPTIONAL { ?j0 a effortless-ntwf:Researchers ; effortless-ntwf:researcherId ?j1 ; effortless-ntwf:name ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?researcher_id), "^.*[#/]", "")) || (?j0 = ?researcher_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_ResearcherAffiliation" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:researcherAffiliation ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:researcherId ?researcher_id . }
                OPTIONAL { ?j0 a effortless-ntwf:Researchers ; effortless-ntwf:researcherId ?j1 ; effortless-ntwf:affiliation ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?researcher_id), "^.*[#/]", "")) || (?j0 = ?researcher_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_ChallengesResearcherName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:challengesResearcherName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:challengesResearcher ?challenges_researcher . }
                OPTIONAL { ?j0 a effortless-ntwf:Researchers ; effortless-ntwf:researcherId ?j1 ; effortless-ntwf:name ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?challenges_researcher), "^.*[#/]", "")) || (?j0 = ?challenges_researcher)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_WitnessedInLoopTitle" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:witnessedInLoopTitle ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:witnessedInLoop ?witnessed_in_loop . }
                OPTIONAL { ?j0 a effortless-ntwf:Loops ; effortless-ntwf:loopId ?j1 ; effortless-ntwf:title ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?witnessed_in_loop), "^.*[#/]", "")) || (?j0 = ?witnessed_in_loop)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_WitnessedInLoopCommitHash" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:witnessedInLoopCommitHash ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:witnessedInLoop ?witnessed_in_loop . }
                OPTIONAL { ?j0 a effortless-ntwf:Loops ; effortless-ntwf:loopId ?j1 ; effortless-ntwf:commitHash ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?witnessed_in_loop), "^.*[#/]", "")) || (?j0 = ?witnessed_in_loop)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_WitnessedInLoopCommitShort" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:witnessedInLoopCommitShort ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:witnessedInLoop ?witnessed_in_loop . }
                OPTIONAL { ?j0 a effortless-ntwf:Loops ; effortless-ntwf:loopId ?j1 ; effortless-ntwf:commitShort ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?witnessed_in_loop), "^.*[#/]", "")) || (?j0 = ?witnessed_in_loop)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_WitnessedInLoopCommitDate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:witnessedInLoopCommitDate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:witnessedInLoop ?witnessed_in_loop . }
                OPTIONAL { ?j0 a effortless-ntwf:Loops ; effortless-ntwf:loopId ?j1 ; effortless-ntwf:commitDate ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?witnessed_in_loop), "^.*[#/]", "")) || (?j0 = ?witnessed_in_loop)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_WitnessedInLoopGitTag" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:witnessedInLoopGitTag ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:witnessedInLoop ?witnessed_in_loop . }
                OPTIONAL { ?j0 a effortless-ntwf:Loops ; effortless-ntwf:loopId ?j1 ; effortless-ntwf:gitTag ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?witnessed_in_loop), "^.*[#/]", "")) || (?j0 = ?witnessed_in_loop)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_InvariantProtectingCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:invariantProtectingCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:InvariantChecks .
                    ?child effortless-ntwf:protectsConclusion ?backfk .
                    $this effortless-ntwf:conclusionId ?backpv .
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    }
                }
            }
        """ ;
    ] .

# === Shape with rules for ConfounderDistortionTimeline ===
effortless-ntwf:ConfounderDistortionTimelineShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:ConfounderDistortionTimeline ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ConfounderDistortionTimeline_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ConfounderDistortionTimeline .
    OPTIONAL { $this effortless-ntwf:cellId ?cell_id . }
                BIND(?cell_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ConfounderDistortionTimeline_TypeDFraction" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typeDFraction ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ConfounderDistortionTimeline .
    OPTIONAL { $this effortless-ntwf:studyCount ?study_count . }
    OPTIONAL { $this effortless-ntwf:typeDCount ?type_d_count . }
                BIND(IF(((REPLACE(COALESCE(STR(?study_count), ""), "^.*#", "") = "") || (?study_count = 0)), "", (?type_d_count / ?study_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ConfounderDistortionTimeline_SignFlipFraction" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:signFlipFraction ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ConfounderDistortionTimeline .
    OPTIONAL { $this effortless-ntwf:signFlipCount ?sign_flip_count . }
    OPTIONAL { $this effortless-ntwf:studyCount ?study_count . }
                BIND(IF(((REPLACE(COALESCE(STR(?study_count), ""), "^.*#", "") = "") || (?study_count = 0)), "", (?sign_flip_count / ?study_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ConfounderDistortionTimeline_MeanSignalPurity" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:meanSignalPurity ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ConfounderDistortionTimeline .
    OPTIONAL { $this effortless-ntwf:studyCount ?study_count . }
    OPTIONAL { $this effortless-ntwf:sumSignalPurity ?sum_signal_purity . }
                BIND(IF(((REPLACE(COALESCE(STR(?study_count), ""), "^.*#", "") = "") || (?study_count = 0)), "", (?sum_signal_purity / ?study_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ConfounderDistortionTimeline_MeanAllocationDistortion" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:meanAllocationDistortion ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ConfounderDistortionTimeline .
    OPTIONAL { $this effortless-ntwf:studyCount ?study_count . }
    OPTIONAL { $this effortless-ntwf:sumAllocationDistortion ?sum_allocation_distortion . }
                BIND(IF(((REPLACE(COALESCE(STR(?study_count), ""), "^.*#", "") = "") || (?study_count = 0)), "", (?sum_allocation_distortion / ?study_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ConfounderDistortionTimeline_IdentityDisplayName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:identityDisplayName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ConfounderDistortionTimeline .
                OPTIONAL { $this effortless-ntwf:confounderIdentity ?confounder_identity . }
                OPTIONAL { ?j0 a effortless-ntwf:ConfounderIdentities ; effortless-ntwf:confounderIdentityId ?j1 ; effortless-ntwf:displayName ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?confounder_identity), "^.*[#/]", "")) || (?j0 = ?confounder_identity)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ConfounderDistortionTimeline_MechanismClass" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:mechanismClass ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ConfounderDistortionTimeline .
                OPTIONAL { $this effortless-ntwf:confounderIdentity ?confounder_identity . }
                OPTIONAL { ?j0 a effortless-ntwf:ConfounderIdentities ; effortless-ntwf:confounderIdentityId ?j1 ; effortless-ntwf:mechanismClass ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?confounder_identity), "^.*[#/]", "")) || (?j0 = ?confounder_identity)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ConfounderDistortionTimeline_IdentityEarliestDecade" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:identityEarliestDecade ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ConfounderDistortionTimeline .
                {
                    SELECT (MIN(?cval) AS ?_result) WHERE {
                        SELECT ?child (MIN(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:ConfounderDistortionTimeline .
                    ?child effortless-ntwf:confounderIdentity ?backfk .
                    $this effortless-ntwf:confounderIdentity ?backpv .
                    OPTIONAL { ?child effortless-ntwf:validTimeDecade ?sumraw . }
                    BIND(xsd:double(STR(?sumraw)) AS ?sumval)
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ConfounderDistortionTimeline_IdentityLatestDecade" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:identityLatestDecade ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ConfounderDistortionTimeline .
                {
                    SELECT (MAX(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:ConfounderDistortionTimeline .
                    ?child effortless-ntwf:confounderIdentity ?backfk .
                    $this effortless-ntwf:confounderIdentity ?backpv .
                    OPTIONAL { ?child effortless-ntwf:validTimeDecade ?sumraw . }
                    BIND(xsd:double(STR(?sumraw)) AS ?sumval)
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ConfounderDistortionTimeline_DriftDirection" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:driftDirection ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ConfounderDistortionTimeline .
    OPTIONAL { $this effortless-ntwf:identityEarliestDecade ?identity_earliest_decade . }
    OPTIONAL { $this effortless-ntwf:identityEarliestTypeDFraction ?identity_earliest_type_d_fraction . }
    OPTIONAL { $this effortless-ntwf:identityLatestDecade ?identity_latest_decade . }
    OPTIONAL { $this effortless-ntwf:identityLatestTypeDFraction ?identity_latest_type_d_fraction . }
                BIND(IF((?identity_earliest_decade = ?identity_latest_decade), "single-decade", IF(((REPLACE(COALESCE(STR(?identity_earliest_type_d_fraction), ""), "^.*#", "") = "") || (REPLACE(COALESCE(STR(?identity_latest_type_d_fraction), ""), "^.*#", "") = "")), "", IF((?identity_latest_type_d_fraction > (?identity_earliest_type_d_fraction + 0.05)), "rising", IF((?identity_latest_type_d_fraction < (?identity_earliest_type_d_fraction - 0.05)), "falling", "flat")))) AS ?_result)
            }
        """ ;
    ] .
# Rule for IdentityEarliestTypeDFraction - parse error: unsupported lookup sub-expression: FuncCall
# Rule for IdentityLatestTypeDFraction - parse error: unsupported lookup sub-expression: FuncCall

# === Shape with rules for ConfounderIdentities ===
effortless-ntwf:ConfounderIdentitiesShape a sh:NodeShape ;
