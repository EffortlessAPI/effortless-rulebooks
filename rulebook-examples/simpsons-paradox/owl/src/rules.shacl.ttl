            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
    OPTIONAL { $this effortless-ntwf:catalogSummaryId ?catalog_summary_id . }
                BIND(?catalog_summary_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_TotalCatalogEntries" ;
