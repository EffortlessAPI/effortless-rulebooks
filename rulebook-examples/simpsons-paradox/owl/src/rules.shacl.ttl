                BIND(IF((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = ""), "", IF((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "A"), "stratify-immediately", IF((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "B"), "investigate-confounder", IF(((REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "C+") || (REPLACE(COALESCE(STR(?distortion_type), ""), "^.*#", "") = "C-")), "check-allocation-bias", "pooled-analysis-trustworthy")))) AS ?_result)
