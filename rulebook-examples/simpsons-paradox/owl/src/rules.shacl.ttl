# === Shape with rules for StratumVariables ===
effortless-ntwf:StratumVariablesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:StratumVariables ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumVariables_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumVariables .
    OPTIONAL { $this effortless-ntwf:stratumVariableId ?stratum_variable_id . }
                BIND(?stratum_variable_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumVariables_IsConfounder" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isConfounder ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumVariables .
    OPTIONAL { $this effortless-ntwf:affectsOutcome ?affects_outcome . }
    OPTIONAL { $this effortless-ntwf:affectsTreatmentAssignment ?affects_treatment_assignment . }
    OPTIONAL { $this effortless-ntwf:causalRole ?causal_role . }
                BIND((?affects_treatment_assignment && ?affects_outcome && (REPLACE(COALESCE(STR(?causal_role), ""), "^.*#", "") = "confounder")) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for Studies ===
effortless-ntwf:StudiesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Studies ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
    OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                BIND(?study_id AS ?_result)
            }
        """ ;
    ] .
