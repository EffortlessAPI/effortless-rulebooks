    sh:targetClass effortless-ntwf:CaseCells ;
    sh:property [ sh:path effortless-ntwf:study ; sh:maxCount 1 ] .

effortless-ntwf:StrataCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Strata ;
    sh:property [ sh:path effortless-ntwf:study ; sh:maxCount 1 ] .

