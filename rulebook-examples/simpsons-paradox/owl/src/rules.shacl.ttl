            CONSTRUCT {
                $this effortless-ntwf:educationLatentFraction ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
                {
                    SELECT (COUNT(?child) AS ?_guard_count) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:studyDomain ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:distortionType ?c2 . }
                    FILTER((STR(?c0) = "education"))
                    FILTER((STR(?c2) = "D"))
                    }
                }
                {
                    SELECT (COUNT(?child) AS ?_lhs) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:studyDomain ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:distortionType ?c2 . }
                    OPTIONAL { ?child effortless-ntwf:isLatentOnlyFlip ?c4 . }
                    FILTER((STR(?c0) = "education"))
                    FILTER((STR(?c2) = "D"))
                    FILTER(BOUND(?c4) && ?c4 = true)
                    }
                }
                {
                    SELECT (COUNT(?child) AS ?_rhs) WHERE {
                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:studyDomain ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:distortionType ?c2 . }
                    FILTER((STR(?c0) = "education"))
                    FILTER((STR(?c2) = "D"))
                    }
                }
    BIND(IF(BOUND(?_rhs) && ?_rhs != 0, ?_lhs / ?_rhs, 0.0) AS ?_result)
    BIND(IF(BOUND(?_guard_count) && ?_guard_count = 0, "", ?_result) AS ?_result)
            }
        """ ;
    ] ;
