@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix effortless-ntwf: <https://w3id.org/effortless-ntwf#> .

# === Shape with rules for AllocationSweep ===
effortless-ntwf:AllocationSweepShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:AllocationSweep ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:sweepId ?sweep_id . }
                BIND(?sweep_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_NSweepStratumTotal" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:nSweepStratumTotal ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:nSweepStratumTotal ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_NSweepA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:nSweepA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:allocFractionA ?alloc_fraction_a . }
    OPTIONAL { $this effortless-ntwf:nSweepStratumTotal ?n_sweep_stratum_total . }
                BIND(ROUND((?n_sweep_stratum_total * ?alloc_fraction_a)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_NSweepB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:nSweepB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:nSweepA ?n_sweep_a . }
    OPTIONAL { $this effortless-ntwf:nSweepStratumTotal ?n_sweep_stratum_total . }
                BIND((?n_sweep_stratum_total - ?n_sweep_a) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_NFixedA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:nFixedA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:nFixedA ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_NFixedB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:nFixedB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:nFixedB ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_SweepRateA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepRateA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:sweepRateA ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_SweepRateB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepRateB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:sweepRateB ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_FixedRateA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:fixedRateA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:fixedRateA ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_FixedRateB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:fixedRateB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:fixedRateB ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_SweepPooledRateA" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepPooledRateA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:fixedRateA ?fixed_rate_a . }
    OPTIONAL { $this effortless-ntwf:nFixedA ?n_fixed_a . }
    OPTIONAL { $this effortless-ntwf:nSweepA ?n_sweep_a . }
    OPTIONAL { $this effortless-ntwf:sweepRateA ?sweep_rate_a . }
                BIND(IF(((?n_sweep_a + ?n_fixed_a) = 0), "", (((?n_sweep_a * ?sweep_rate_a) + (?n_fixed_a * ?fixed_rate_a)) / (?n_sweep_a + ?n_fixed_a))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_SweepPooledRateB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepPooledRateB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:fixedRateB ?fixed_rate_b . }
    OPTIONAL { $this effortless-ntwf:nFixedB ?n_fixed_b . }
    OPTIONAL { $this effortless-ntwf:nSweepB ?n_sweep_b . }
    OPTIONAL { $this effortless-ntwf:sweepRateB ?sweep_rate_b . }
                BIND(IF(((?n_sweep_b + ?n_fixed_b) = 0), "", (((?n_sweep_b * ?sweep_rate_b) + (?n_fixed_b * ?fixed_rate_b)) / (?n_sweep_b + ?n_fixed_b))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_SweepPooledGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepPooledGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:sweepPooledRateA ?sweep_pooled_rate_a . }
    OPTIONAL { $this effortless-ntwf:sweepPooledRateB ?sweep_pooled_rate_b . }
                BIND(IF((REPLACE(COALESCE(STR(?sweep_pooled_rate_a), ""), "^.*#", "") = ""), "", (?sweep_pooled_rate_a - ?sweep_pooled_rate_b)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_SweepCorrectedGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:sweepCorrectedGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:SweepStudyConfig ; effortless-ntwf:studyId ?j1 ; effortless-ntwf:sweepCorrectedGap ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AllocationSweep_AllocationDistortionWitness" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:allocationDistortionWitness ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AllocationSweep .
    OPTIONAL { $this effortless-ntwf:sweepCorrectedGap ?sweep_corrected_gap . }
    OPTIONAL { $this effortless-ntwf:sweepPooledGap ?sweep_pooled_gap . }
                BIND(IF((REPLACE(COALESCE(STR(?sweep_pooled_gap), ""), "^.*#", "") = ""), "", (?sweep_pooled_gap - ?sweep_corrected_gap)) AS ?_result)
            }
        """ ;
    ] .
# Rule for IsOriginal - parse error: unsupported lookup sub-expression: FuncCall

# === Shape with rules for CandidateStudyCatalog ===
effortless-ntwf:CandidateStudyCatalogShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:CandidateStudyCatalog ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:candidateId ?candidate_id . }
                BIND(?candidate_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_IsReadyToEncode" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isReadyToEncode ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:citation ?citation . }
    OPTIONAL { $this effortless-ntwf:ingestionStatus ?ingestion_status . }
    OPTIONAL { $this effortless-ntwf:proposedStudyId ?proposed_study_id . }
    OPTIONAL { $this effortless-ntwf:stratumVariableName ?stratum_variable_name . }
                BIND(((REPLACE(COALESCE(STR(?ingestion_status), ""), "^.*#", "") = "candidate") && (REPLACE(COALESCE(STR(?proposed_study_id), ""), "^.*#", "") != "") && (REPLACE(COALESCE(STR(?citation), ""), "^.*#", "") != "") && (REPLACE(COALESCE(STR(?stratum_variable_name), ""), "^.*#", "") != "")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_IsImported" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isImported ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:ingestionStatus ?ingestion_status . }
                BIND((REPLACE(COALESCE(STR(?ingestion_status), ""), "^.*#", "") = "imported") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_ObservedDistortionType" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:observedDistortionType ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
                OPTIONAL { $this effortless-ntwf:linkedStudyId ?linked_study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j1 ; effortless-ntwf:distortionType ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?linked_study_id), "^.*[#/]", "")) || (?j0 = ?linked_study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_TypePredictionMatch" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typePredictionMatch ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:expectedDistortionType ?expected_distortion_type . }
    OPTIONAL { $this effortless-ntwf:isImported ?is_imported . }
    OPTIONAL { $this effortless-ntwf:observedDistortionType ?observed_distortion_type . }
                BIND(IF(?is_imported, (?observed_distortion_type = ?expected_distortion_type), "") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_ExpectedSignFlip" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:expectedSignFlip ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:expectedDistortionType ?expected_distortion_type . }
                BIND(((REPLACE(COALESCE(STR(?expected_distortion_type), ""), "^.*#", "") = "A") || (REPLACE(COALESCE(STR(?expected_distortion_type), ""), "^.*#", "") = "B")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_ObservedSignFlipType" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:observedSignFlipType ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:isImported ?is_imported . }
    OPTIONAL { $this effortless-ntwf:observedDistortionType ?observed_distortion_type . }
                BIND(IF(?is_imported, ((REPLACE(COALESCE(STR(?observed_distortion_type), ""), "^.*#", "") = "A") || (REPLACE(COALESCE(STR(?observed_distortion_type), ""), "^.*#", "") = "B")), "") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_SignFlipPredictionMatch" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:signFlipPredictionMatch ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:expectedSignFlip ?expected_sign_flip . }
    OPTIONAL { $this effortless-ntwf:isImported ?is_imported . }
    OPTIONAL { $this effortless-ntwf:observedSignFlipType ?observed_sign_flip_type . }
                BIND(IF((?is_imported && ?expected_sign_flip), ?observed_sign_flip_type, "") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CandidateStudyCatalog_IsDataReady" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isDataReady ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CandidateStudyCatalog .
    OPTIONAL { $this effortless-ntwf:dataAcquisitionStatus ?data_acquisition_status . }
                BIND(((REPLACE(COALESCE(STR(?data_acquisition_status), ""), "^.*#", "") = "downloaded") || (REPLACE(COALESCE(STR(?data_acquisition_status), ""), "^.*#", "") = "manual_only")) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for CaseCells ===
effortless-ntwf:CaseCellsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:CaseCells ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CaseCells_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CaseCells .
    OPTIONAL { $this effortless-ntwf:caseCellId ?case_cell_id . }
                BIND(?case_cell_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CaseCells_CellSuccessRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:cellSuccessRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CaseCells .
    OPTIONAL { $this effortless-ntwf:cases ?cases . }
    OPTIONAL { $this effortless-ntwf:successes ?successes . }
                BIND(IF((?cases = 0), "", (?successes / ?cases)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CaseCells_TotalCasesForTreatment" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:totalCasesForTreatment ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CaseCells .
                {
                    SELECT (SUM(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:CaseCells .
                    ?child effortless-ntwf:study ?backfk .
                    $this effortless-ntwf:study ?backpv .
                    OPTIONAL { ?child effortless-ntwf:treatmentLabel ?c2 . }
                    OPTIONAL { $this effortless-ntwf:treatmentLabel ?p2 . }
                    OPTIONAL { ?child effortless-ntwf:cases ?sumraw . }
                    BIND(IF(BOUND(?sumraw), xsd:double(STR(?sumraw)), 0.0) AS ?sumval)
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    FILTER(REPLACE(STR(?c2), "^.*[#/]", "") = REPLACE(STR(?p2), "^.*[#/]", ""))
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CaseCells_TreatmentExposureFraction" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:treatmentExposureFraction ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CaseCells .
    OPTIONAL { $this effortless-ntwf:cases ?cases . }
    OPTIONAL { $this effortless-ntwf:totalCasesForTreatment ?total_cases_for_treatment . }
                BIND(IF((?total_cases_for_treatment = 0), "", (?cases / ?total_cases_for_treatment)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CaseCells_IsValidIngestionCell" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isValidIngestionCell ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CaseCells .
    OPTIONAL { $this effortless-ntwf:cases ?cases . }
    OPTIONAL { $this effortless-ntwf:successes ?successes . }
                BIND(((?cases > 0) && (?successes >= 0) && (?successes <= ?cases)) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for Conclusions ===
effortless-ntwf:ConclusionsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Conclusions ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
    OPTIONAL { $this effortless-ntwf:conclusionId ?conclusion_id . }
                BIND(?conclusion_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_TraditionName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:traditionName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:traditionId ?tradition_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:name ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_TraditionKeyClaimSummary" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:traditionKeyClaimSummary ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:traditionId ?tradition_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:keyClaim ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_ResearcherName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:researcherName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:researcherId ?researcher_id . }
                OPTIONAL { ?j0 a effortless-ntwf:Researchers ; effortless-ntwf:researcherId ?j1 ; effortless-ntwf:name ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?researcher_id), "^.*[#/]", "")) || (?j0 = ?researcher_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_ResearcherAffiliation" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:researcherAffiliation ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:researcherId ?researcher_id . }
                OPTIONAL { ?j0 a effortless-ntwf:Researchers ; effortless-ntwf:researcherId ?j1 ; effortless-ntwf:affiliation ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?researcher_id), "^.*[#/]", "")) || (?j0 = ?researcher_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_ChallengesResearcherName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:challengesResearcherName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:challengesResearcher ?challenges_researcher . }
                OPTIONAL { ?j0 a effortless-ntwf:Researchers ; effortless-ntwf:researcherId ?j1 ; effortless-ntwf:name ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?challenges_researcher), "^.*[#/]", "")) || (?j0 = ?challenges_researcher)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_WitnessedInLoopTitle" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:witnessedInLoopTitle ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:witnessedInLoop ?witnessed_in_loop . }
                OPTIONAL { ?j0 a effortless-ntwf:Loops ; effortless-ntwf:loopId ?j1 ; effortless-ntwf:title ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?witnessed_in_loop), "^.*[#/]", "")) || (?j0 = ?witnessed_in_loop)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_WitnessedInLoopCommitHash" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:witnessedInLoopCommitHash ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:witnessedInLoop ?witnessed_in_loop . }
                OPTIONAL { ?j0 a effortless-ntwf:Loops ; effortless-ntwf:loopId ?j1 ; effortless-ntwf:commitHash ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?witnessed_in_loop), "^.*[#/]", "")) || (?j0 = ?witnessed_in_loop)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_WitnessedInLoopCommitShort" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:witnessedInLoopCommitShort ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:witnessedInLoop ?witnessed_in_loop . }
                OPTIONAL { ?j0 a effortless-ntwf:Loops ; effortless-ntwf:loopId ?j1 ; effortless-ntwf:commitShort ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?witnessed_in_loop), "^.*[#/]", "")) || (?j0 = ?witnessed_in_loop)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_WitnessedInLoopCommitDate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:witnessedInLoopCommitDate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:witnessedInLoop ?witnessed_in_loop . }
                OPTIONAL { ?j0 a effortless-ntwf:Loops ; effortless-ntwf:loopId ?j1 ; effortless-ntwf:commitDate ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?witnessed_in_loop), "^.*[#/]", "")) || (?j0 = ?witnessed_in_loop)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_WitnessedInLoopGitTag" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:witnessedInLoopGitTag ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                OPTIONAL { $this effortless-ntwf:witnessedInLoop ?witnessed_in_loop . }
                OPTIONAL { ?j0 a effortless-ntwf:Loops ; effortless-ntwf:loopId ?j1 ; effortless-ntwf:gitTag ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?witnessed_in_loop), "^.*[#/]", "")) || (?j0 = ?witnessed_in_loop)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Conclusions_InvariantProtectingCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:invariantProtectingCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Conclusions .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:InvariantChecks .
                    ?child effortless-ntwf:protectsConclusion ?backfk .
                    $this effortless-ntwf:conclusionId ?backpv .
                    FILTER(REPLACE(STR(?backfk), "^.*[#/]", "") = REPLACE(STR(?backpv), "^.*[#/]", ""))
                    }
                }
            }
        """ ;
    ] .

# === Shape with rules for CorpusCatalogSummary ===
effortless-ntwf:CorpusCatalogSummaryShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:CorpusCatalogSummary ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
    OPTIONAL { $this effortless-ntwf:catalogSummaryId ?catalog_summary_id . }
                BIND(?catalog_summary_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_TotalCatalogEntries" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:totalCatalogEntries ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:candidateId ?c0 . }
                    FILTER((STR(?c0) != ""))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_ImportedCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:importedCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c0 . }
                    FILTER((STR(?c0) = "imported"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_CandidateCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:candidateCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c0 . }
                    FILTER((STR(?c0) = "candidate"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_BlockedCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:blockedCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c0 . }
                    FILTER((STR(?c0) = "blocked"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_ReadyToEncodeCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:readyToEncodeCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:isReadyToEncode ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_ImportSessionReady" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:importSessionReady ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
    OPTIONAL { $this effortless-ntwf:candidateCount ?candidate_count . }
    OPTIONAL { $this effortless-ntwf:readyToEncodeCount ?ready_to_encode_count . }
                BIND(((?candidate_count >= 20) && (?ready_to_encode_count >= 15)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_TypePredictionMatchCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typePredictionMatchCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:typePredictionMatch ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_TypePredictionMismatchCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typePredictionMismatchCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:isImported ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:typePredictionMatch ?c2 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER(BOUND(?c2) && ?c2 = false)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_SignFlipPredictionEligibleCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:signFlipPredictionEligibleCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:isImported ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:expectedSignFlip ?c2 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_SignFlipPredictionMatchCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:signFlipPredictionMatchCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:signFlipPredictionMatch ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_TypePredictionMatchRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:typePredictionMatchRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
    OPTIONAL { $this effortless-ntwf:importedCount ?imported_count . }
    OPTIONAL { $this effortless-ntwf:typePredictionMatchCount ?type_prediction_match_count . }
                BIND(IF((?imported_count = 0), "", (?type_prediction_match_count / ?imported_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_SignFlipPredictionMatchRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:signFlipPredictionMatchRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
    OPTIONAL { $this effortless-ntwf:signFlipPredictionEligibleCount ?sign_flip_prediction_eligible_count . }
    OPTIONAL { $this effortless-ntwf:signFlipPredictionMatchCount ?sign_flip_prediction_match_count . }
                BIND(IF((?sign_flip_prediction_eligible_count = 0), "", (?sign_flip_prediction_match_count / ?sign_flip_prediction_eligible_count)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_CatalogWitnessNote" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:catalogWitnessNote ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
    OPTIONAL { $this effortless-ntwf:candidateCount ?candidate_count . }
    OPTIONAL { $this effortless-ntwf:dataReadyCount ?data_ready_count . }
    OPTIONAL { $this effortless-ntwf:importSessionReady ?import_session_ready . }
    OPTIONAL { $this effortless-ntwf:readyToEncodeCount ?ready_to_encode_count . }
                BIND(IF(?import_session_ready, CONCAT("READY: ", IF(isIRI(?ready_to_encode_count), REPLACE(STR(?ready_to_encode_count), "^.*[#/]", ""), STR(?ready_to_encode_count)), " encode-ready (", IF(isIRI(?data_ready_count), REPLACE(STR(?data_ready_count), "^.*[#/]", ""), STR(?data_ready_count)), " data-ready) of ", IF(isIRI(?candidate_count), REPLACE(STR(?candidate_count), "^.*[#/]", ""), STR(?candidate_count)), " candidates"), CONCAT("BUILDING: ", IF(isIRI(?candidate_count), REPLACE(STR(?candidate_count), "^.*[#/]", ""), STR(?candidate_count)), " candidates — ", IF(isIRI(?data_ready_count), REPLACE(STR(?data_ready_count), "^.*[#/]", ""), STR(?data_ready_count)), " data-ready, ", IF(isIRI(?ready_to_encode_count), REPLACE(STR(?ready_to_encode_count), "^.*[#/]", ""), STR(?ready_to_encode_count)), " encode-ready")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_DataReadyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:dataReadyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:isDataReady ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:ingestionStatus ?c2 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER((STR(?c2) = "candidate"))
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_EncodePipelineReadyCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:encodePipelineReadyCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:isReadyToEncode ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:isDataReady ?c2 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusCatalogSummary_ExpansionCandidateCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:expansionCandidateCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusCatalogSummary .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CandidateStudyCatalog .
                    OPTIONAL { ?child effortless-ntwf:expansionWave ?c0 . }
                    FILTER((STR(?c0) = "expansion-wave-1"))
                    }
                }
            }
        """ ;
    ] .
# Rule for HighPriorityCount - parse error: aggregation formula must be COUNTIFS / SUMIFS / AVERAGEIFS / MAXIFS / MINIFS / COUNTIF / their bare AGG(Child!{{Col}}) forms
# Rule for CatalogPredictionWitnessNote - parse error: Unexpected token Token(type=<TokenType.RPAREN: 6>, value=')', pos=275) after expression

# === Shape with rules for CorpusDomains ===
effortless-ntwf:CorpusDomainsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:CorpusDomains ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_CorpusDomains_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:CorpusDomains .
    OPTIONAL { $this effortless-ntwf:domainId ?domain_id . }
                BIND(?domain_id AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for DiscoveryFindings ===
effortless-ntwf:DiscoveryFindingsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:DiscoveryFindings ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DiscoveryFindings_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DiscoveryFindings .
    OPTIONAL { $this effortless-ntwf:findingId ?finding_id . }
                BIND(?finding_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DiscoveryFindings_HypothesisStatement" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:hypothesisStatement ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DiscoveryFindings .
                OPTIONAL { $this effortless-ntwf:hypothesisId ?hypothesis_id . }
                OPTIONAL { ?j0 a effortless-ntwf:DiscoveryHypotheses ; effortless-ntwf:hypothesisId ?j1 ; effortless-ntwf:statement ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?hypothesis_id), "^.*[#/]", "")) || (?j0 = ?hypothesis_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_DiscoveryFindings_IsConfirmed" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isConfirmed ?_result .
            }
            WHERE {
    $this a effortless-ntwf:DiscoveryFindings .
                OPTIONAL { $this effortless-ntwf:hypothesisId ?hypothesis_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j1 ; effortless-ntwf:latentTypeDFraction ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j0 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j3 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j4 ; effortless-ntwf:signFlipSignalPurityMax ?j5 . FILTER((REPLACE(STR(?j4), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j3 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j6 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j7 ; effortless-ntwf:avgPooledGapStableD ?j8 . FILTER((REPLACE(STR(?j7), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j6 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j9 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j10 ; effortless-ntwf:avgPooledGapLatentD ?j11 . FILTER((REPLACE(STR(?j10), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j9 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j12 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j13 ; effortless-ntwf:economicsSignFlipCount ?j14 . FILTER((REPLACE(STR(?j13), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j12 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j15 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j16 ; effortless-ntwf:epidemiologyAvgDistortion ?j17 . FILTER((REPLACE(STR(?j16), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j15 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j18 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j19 ; effortless-ntwf:educationAvgDistortion ?j20 . FILTER((REPLACE(STR(?j19), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j18 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j21 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j22 ; effortless-ntwf:confounderSignFlipCount ?j23 . FILTER((REPLACE(STR(?j22), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j21 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j24 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j25 ; effortless-ntwf:colliderSelectionManifestCount ?j26 . FILTER((REPLACE(STR(?j25), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j24 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j27 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j28 ; effortless-ntwf:confounderSignFlipCount ?j29 . FILTER((REPLACE(STR(?j28), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j27 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j30 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j31 ; effortless-ntwf:colliderSelectionManifestCount ?j32 . FILTER((REPLACE(STR(?j31), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j30 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j33 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j34 ; effortless-ntwf:colliderSelectionLatentOnlyCount ?j35 . FILTER((REPLACE(STR(?j34), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j33 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j36 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j37 ; effortless-ntwf:explainedConfounderCount ?j38 . FILTER((REPLACE(STR(?j37), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j36 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j39 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j40 ; effortless-ntwf:confounderSignFlipCount ?j41 . FILTER((REPLACE(STR(?j40), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j39 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j42 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j43 ; effortless-ntwf:explainedConfounderCount ?j44 . FILTER((REPLACE(STR(?j43), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j42 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j45 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j46 ; effortless-ntwf:contestedOrMediatorExplainedCount ?j47 . FILTER((REPLACE(STR(?j46), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j45 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j48 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j49 ; effortless-ntwf:typePredictionMatchRate ?j50 . FILTER((REPLACE(STR(?j49), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j48 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j51 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j52 ; effortless-ntwf:signFlipPredictionMatchRate ?j53 . FILTER((REPLACE(STR(?j52), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j51 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j54 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j55 ; effortless-ntwf:economicsHighImbalanceSignFlipCount ?j56 . FILTER((REPLACE(STR(?j55), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j54 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j57 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j58 ; effortless-ntwf:epidemiologyHighImbalanceSignFlipRate ?j59 . FILTER((REPLACE(STR(?j58), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j57 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j60 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j61 ; effortless-ntwf:colliderSelectionManifestCount ?j62 . FILTER((REPLACE(STR(?j61), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j60 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j63 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j64 ; effortless-ntwf:cPlusAvgDistortion ?j65 . FILTER((REPLACE(STR(?j64), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j63 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j66 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j67 ; effortless-ntwf:cMinusAvgDistortion ?j68 . FILTER((REPLACE(STR(?j67), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j66 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j69 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j70 ; effortless-ntwf:cPlusAvgDistortion ?j71 . FILTER((REPLACE(STR(?j70), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j69 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j72 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j73 ; effortless-ntwf:typeDAvgDistortion ?j74 . FILTER((REPLACE(STR(?j73), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j72 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j75 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j76 ; effortless-ntwf:economicsExpectedAMismatchRate ?j77 . FILTER((REPLACE(STR(?j76), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j75 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j78 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j79 ; effortless-ntwf:educationLatentFraction ?j80 . FILTER((REPLACE(STR(?j79), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j78 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j81 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j82 ; effortless-ntwf:sportsLatentFraction ?j83 . FILTER((REPLACE(STR(?j82), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j81 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j84 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j85 ; effortless-ntwf:economicsSignFlipRate ?j86 . FILTER((REPLACE(STR(?j85), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j84 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j87 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j88 ; effortless-ntwf:maxStudySweepCorrectedGapRange ?j89 . FILTER((REPLACE(STR(?j88), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j87 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j90 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j91 ; effortless-ntwf:correctedGapInvariantFailCount ?j92 . FILTER((REPLACE(STR(?j91), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j90 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j93 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j94 ; effortless-ntwf:explainedConfounderCount ?j95 . FILTER((REPLACE(STR(?j94), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j93 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j96 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j97 ; effortless-ntwf:confounderSignFlipCount ?j98 . FILTER((REPLACE(STR(?j97), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j96 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j99 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j100 ; effortless-ntwf:falsePositiveExplainedCount ?j101 . FILTER((REPLACE(STR(?j100), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j99 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j102 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j103 ; effortless-ntwf:unexplainedConfounderSignFlipCount ?j104 . FILTER((REPLACE(STR(?j103), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j102 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j105 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j106 ; effortless-ntwf:colliderSelectionManifestCount ?j107 . FILTER((REPLACE(STR(?j106), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j105 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j108 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j109 ; effortless-ntwf:colliderSelectionCount ?j110 . FILTER((REPLACE(STR(?j109), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j108 = "simpsons-paradox-v1")) }
                OPTIONAL { ?j111 a effortless-ntwf:ModelSummary ; effortless-ntwf:modelSummaryId ?j112 ; effortless-ntwf:theoremCount ?j113 . FILTER((REPLACE(STR(?j112), "^.*[#/]", "") = REPLACE(STR("simpsons-paradox-v1"), "^.*[#/]", "")) || (?j111 = "simpsons-paradox-v1")) }
                BIND(IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-latent-d"), (?j2 > 0.5), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-purity"), (?j5 < 0.5), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-small-effect"), (?j8 > ?j11), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-econ-zero"), (?j14 = 0), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-domain-dist"), (?j17 > ?j20), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-causal-manifest"), ((?j23 > ?j26) && (?j29 >= 10)), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-causal-latent"), ((?j32 = 0) && (?j35 >= 5)), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-explained-confounder"), ((?j38 = ?j41) && (?j44 >= 10)), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-unexplained-nonconfounder"), (?j47 = 0), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-catalog-exact-match"), (?j50 < 0.5), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-catalog-flip-prediction"), (?j53 < 0.5), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-domain-flip-geometry-controlled"), ((?j56 = 0) && (?j59 > 0.15)), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-collider-no-manifest-v2"), (?j62 = 0), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-cplus-magnitude"), ((?j65 > ?j68) && (?j71 > ?j74)), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-econ-encoding-selection"), (?j77 > 0.5), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-domain-profiles-stable"), ((?j80 > 0.5) && (?j83 > 0.5) && (?j86 < 0.05)), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-corrected-gap-invariant"), ((?j89 < 0.0001) && (?j92 = 0)), IF((REPLACE(COALESCE(STR(?hypothesis_id), ""), "^.*#", "") = "H-explained-bidirectional"), ((?j95 = ?j98) && (?j101 = 0) && (?j104 = 0)), IF((REPLACE(