# === Shape with rules for PhaseDiagramSummary ===
effortless-ntwf:PhaseDiagramSummaryShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:PhaseDiagramSummary ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_PhaseDiagramSummary_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:PhaseDiagramSummary .
    OPTIONAL { $this effortless-ntwf:phaseDiagramId ?phase_diagram_id . }
                BIND(?phase_diagram_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_PhaseDiagramSummary_PhasePointCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phasePointCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:PhaseDiagramSummary .
    OPTIONAL { $this effortless-ntwf:phaseTypeACount ?phase_type_a_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeBCount ?phase_type_b_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCMinusCount ?phase_type_c_minus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCPlusCount ?phase_type_c_plus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeDCount ?phase_type_d_count . }
                BIND(((((?phase_type_a_count + ?phase_type_b_count) + ?phase_type_c_plus_count) + ?phase_type_c_minus_count) + ?phase_type_d_count) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_PhaseDiagramSummary_AllFiveTypesPresent" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:allFiveTypesPresent ?_result .
            }
            WHERE {
    $this a effortless-ntwf:PhaseDiagramSummary .
    OPTIONAL { $this effortless-ntwf:phaseTypeACount ?phase_type_a_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeBCount ?phase_type_b_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCMinusCount ?phase_type_c_minus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeCPlusCount ?phase_type_c_plus_count . }
    OPTIONAL { $this effortless-ntwf:phaseTypeDCount ?phase_type_d_count . }
                BIND(((?phase_type_a_count > 0) && (?phase_type_b_count > 0) && (?phase_type_c_plus_count > 0) && (?phase_type_c_minus_count > 0) && (?phase_type_d_count > 0)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_PhaseDiagramSummary_PhaseWitnessNote" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:phaseWitnessNote ?_result .
            }
            WHERE {
    $this a effortless-ntwf:PhaseDiagramSummary .
    OPTIONAL { $this effortless-ntwf:allFiveTypesPresent ?all_five_types_present . }
                BIND(IF(?all_five_types_present, "PASS: all five distortion types populated in parameter space", "FAIL: missing distortion type in grid") AS ?_result)
            }
        """ ;
    ] .
# Rule for PhaseTaxonomyWitness - parse error: Unknown function: CONCAT

