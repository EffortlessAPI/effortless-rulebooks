                    ?child a effortless-ntwf:TreatmentRankings .
                    OPTIONAL { ?child effortless-ntwf:isSignFlip ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:isParadoxExplained ?c2 . }
                    OPTIONAL { ?child effortless-ntwf:adjustmentAppropriate ?c4 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
