                        SELECT ?child (MIN(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:AllocationSweep .
                    OPTIONAL { ?child effortless-ntwf:studyId ?c0 . }
                    OPTIONAL { ?child effortless-ntwf:sweepCorrectedGap ?sumraw . }
                    BIND(xsd:double(STR(?sumraw)) AS ?sumval)
