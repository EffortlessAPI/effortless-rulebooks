                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StudyImportTemplate .
    OPTIONAL { $this effortless-ntwf:templateStepId ?template_step_id . }
                BIND(?template_step_id AS ?_result)
            }
        """ ;
    ] .

