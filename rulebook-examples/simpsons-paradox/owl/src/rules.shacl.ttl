            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:StratumVariables ; effortless-ntwf:study ?j1 ; effortless-ntwf:variableName ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_CausalRole" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:causalRole ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:StratumVariables ; effortless-ntwf:study ?j1 ; effortless-ntwf:causalRole ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_IngestionCellParity" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:ingestionCellParity ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:cellCount ?cell_count . }
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j1 ; effortless-ntwf:stratumCount ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                OPTIONAL { ?j3 a effortless-ntwf:TreatmentRankings ; effortless-ntwf:study ?j4 ; effortless-ntwf:stratumCount ?j5 . FILTER((REPLACE(STR(?j4), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j3 = ?study_id)) }
                BIND(((?j2 >= 2) && (?cell_count = (?j5 * 2))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_IngestionCompliance" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:ingestionCompliance ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:ingestionCellParity ?ingestion_cell_parity . }
                OPTIONAL { $this effortless-ntwf:isSynthetic ?is_synthetic . }
                OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                OPTIONAL { ?j0 a effortless-ntwf:StratumVariables ; effortless-ntwf:study ?j1 ; effortless-ntwf:variableName ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?study_id), "^.*[#/]", "")) || (?j0 = ?study_id)) }
                BIND(IF(?is_synthetic, "exempt-synthetic", IF((?ingestion_cell_parity && (?j2 != "")), "all", "partial")) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for StudyImportTemplate ===
