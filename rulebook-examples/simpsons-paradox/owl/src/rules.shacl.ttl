    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ModelSummary_DiscoveryWitnessNote" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:discoveryWitnessNote ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ModelSummary .
    OPTIONAL { $this effortless-ntwf:confounderIdentityCount ?confounder_identity_count . }
    OPTIONAL { $this effortless-ntwf:latentTypeDFraction ?latent_type_d_fraction . }
    OPTIONAL { $this effortless-ntwf:signFlipSignalPurityMax ?sign_flip_signal_purity_max . }
    OPTIONAL { $this effortless-ntwf:typePredictionMatchRate ?type_prediction_match_rate . }
                BIND(CONCAT("sweep: latentD=", IF(isIRI(?latent_type_d_fraction), REPLACE(STR(?latent_type_d_fraction), "^.*[#/]", ""), STR(?latent_type_d_fraction)), " purityMax=", IF(isIRI(?sign_flip_signal_purity_max), REPLACE(STR(?sign_flip_signal_purity_max), "^.*[#/]", ""), STR(?sign_flip_signal_purity_max)), " catalogExact=", IF(isIRI(?type_prediction_match_rate), REPLACE(STR(?type_prediction_match_rate), "^.*[#/]", ""), STR(?type_prediction_match_rate)), " identities=", IF(isIRI(?confounder_identity_count), REPLACE(STR(?confounder_identity_count), "^.*[#/]", ""), STR(?confounder_identity_count))) AS ?_result)
            }
        """ ;
    ] ;
