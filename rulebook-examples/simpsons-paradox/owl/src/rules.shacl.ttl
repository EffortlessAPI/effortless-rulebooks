            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:allocationFractionA ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:treatmentACasesHere ?treatment_a_cases_here . }
    OPTIONAL { $this effortless-ntwf:treatmentATotalCases ?treatment_a_total_cases . }
                BIND(IF((?treatment_a_total_cases = 0), "", (?treatment_a_cases_here / ?treatment_a_total_cases)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_AllocationFractionB" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:allocationFractionB ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:treatmentBCasesHere ?treatment_b_cases_here . }
    OPTIONAL { $this effortless-ntwf:treatmentBTotalCases ?treatment_b_total_cases . }
                BIND(IF((?treatment_b_total_cases = 0), "", (?treatment_b_cases_here / ?treatment_b_total_cases)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_AllocationBias" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:allocationBias ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:allocationFractionA ?allocation_fraction_a . }
    OPTIONAL { $this effortless-ntwf:allocationFractionB ?allocation_fraction_b . }
                BIND(IF((REPLACE(COALESCE(STR(?allocation_fraction_a), ""), "^.*#", "") = ""), "", (?allocation_fraction_a - ?allocation_fraction_b)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_StratumGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:stratumGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:stratumRateA ?stratum_rate_a . }
    OPTIONAL { $this effortless-ntwf:stratumRateB ?stratum_rate_b . }
                BIND(IF((REPLACE(COALESCE(STR(?stratum_rate_a), ""), "^.*#", "") = ""), "", (?stratum_rate_a - ?stratum_rate_b)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumSummaries_WeightedStratumGap" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:weightedStratumGap ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumSummaries .
    OPTIONAL { $this effortless-ntwf:stratumFraction ?stratum_fraction . }
    OPTIONAL { $this effortless-ntwf:stratumGap ?stratum_gap . }
                BIND(IF((REPLACE(COALESCE(STR(?stratum_gap), ""), "^.*#", "") = ""), "", (?stratum_gap * ?stratum_fraction)) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for StratumVariables ===
effortless-ntwf:StratumVariablesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:StratumVariables ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumVariables_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumVariables .
    OPTIONAL { $this effortless-ntwf:stratumVariableId ?stratum_variable_id . }
                BIND(?stratum_variable_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StratumVariables_IsConfounder" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:isConfounder ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StratumVariables .
    OPTIONAL { $this effortless-ntwf:affectsOutcome ?affects_outcome . }
    OPTIONAL { $this effortless-ntwf:affectsTreatmentAssignment ?affects_treatment_assignment . }
    OPTIONAL { $this effortless-ntwf:causalRole ?causal_role . }
                BIND((?affects_treatment_assignment && ?affects_outcome && (REPLACE(COALESCE(STR(?causal_role), ""), "^.*#", "") = "confounder")) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for Studies ===
effortless-ntwf:StudiesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Studies ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
    OPTIONAL { $this effortless-ntwf:studyId ?study_id . }
                BIND(?study_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_TotalCases" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:totalCases ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                {
                    SELECT (SUM(?cval) AS ?_result) WHERE {
                        SELECT ?child (MAX(?sumval) AS ?cval) WHERE {
                    ?child a effortless-ntwf:CaseCells .
                    ?child effortless-ntwf:study $this .
                    OPTIONAL { ?child effortless-ntwf:cases ?sumraw . }
                    BIND(IF(BOUND(?sumraw), xsd:double(STR(?sumraw)), 0.0) AS ?sumval)
                        } GROUP BY ?child
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_CellCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:cellCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:CaseCells .
                    ?child effortless-ntwf:study $this .
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_TraditionName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:traditionName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:traditionId ?tradition_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:name ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_TraditionCoreConern" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:traditionCoreConern ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:traditionId ?tradition_id . }
                OPTIONAL { ?j0 a effortless-ntwf:ResearchTraditions ; effortless-ntwf:traditionId ?j1 ; effortless-ntwf:coreConcern ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?tradition_id), "^.*[#/]", "")) || (?j0 = ?tradition_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_PrimaryResearcherName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:primaryResearcherName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:primaryResearcherId ?primary_researcher_id . }
                OPTIONAL { ?j0 a effortless-ntwf:Researchers ; effortless-ntwf:researcherId ?j1 ; effortless-ntwf:name ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?primary_researcher_id), "^.*[#/]", "")) || (?j0 = ?primary_researcher_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_PrimaryResearcherAffiliation" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:primaryResearcherAffiliation ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Studies .
                OPTIONAL { $this effortless-ntwf:primaryResearcherId ?primary_researcher_id . }
                OPTIONAL { ?j0 a effortless-ntwf:Researchers ; effortless-ntwf:researcherId ?j1 ; effortless-ntwf:affiliation ?j2 . FILTER((REPLACE(STR(?j1), "^.*[#/]", "") = REPLACE(STR(?primary_researcher_id), "^.*[#/]", "")) || (?j0 = ?primary_researcher_id)) }
                BIND(?j2 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Studies_DistortionType" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
