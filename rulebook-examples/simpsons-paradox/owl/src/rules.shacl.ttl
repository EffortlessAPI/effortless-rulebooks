# === Shape with rules for Treatments ===
effortless-ntwf:TreatmentsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Treatments ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Treatments_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Treatments .
    OPTIONAL { $this effortless-ntwf:treatmentId ?treatment_id . }
                BIND(?treatment_id AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Treatments_PooledSuccessRate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:pooledSuccessRate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Treatments .
    OPTIONAL { $this effortless-ntwf:totalCases ?total_cases . }
    OPTIONAL { $this effortless-ntwf:totalSuccesses ?total_successes . }
                BIND(IF((?total_cases = 0), "", (?total_successes / ?total_cases)) AS ?_result)
            }
        """ ;
    ] .
# Rule for TotalCases - parse error: unsupported COUNTIFS criteria: FieldRef
# Rule for TotalSuccesses - parse error: unsupported COUNTIFS criteria: FieldRef

