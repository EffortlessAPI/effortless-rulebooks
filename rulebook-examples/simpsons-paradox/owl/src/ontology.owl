# === Class: InstrumentSpec ===
effortless-ntwf:InstrumentSpec a owl:Class ;
    rdfs:label "InstrumentSpec" ;
    rdfs:comment "Table: InstrumentSpec — the complete specification of the Simpson's Paradox classification instrument. One row per component: required input fields, derived coordinates, classification outputs, and adapter requirements. Every row is machine-verifiable against the 90+ study corpus. This table is the distillation of loops 1–25 into a reusable tool." .

effortless-ntwf:specId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InstrumentSpec ;
    rdfs:range xsd:string ;
    rdfs:label "SpecId" ;
    rdfs:comment "Unique identifier for this instrument component." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:componentType a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InstrumentSpec ;
    rdfs:range xsd:string ;
    rdfs:label "ComponentType" ;
    rdfs:comment "input | derived | classification | adapter-requirement" .

effortless-ntwf:fieldName a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "FieldName" ;
    rdfs:comment "The field or variable name in the DAG." .

effortless-ntwf:dataType a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "DataType" ;
    rdfs:comment "integer | decimal | boolean | string | categorical" .

effortless-ntwf:sourceTable a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SourceTable" ;
    rdfs:comment "The DAG table where this field is computed or stored." .

effortless-ntwf:formula a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InstrumentSpec ;
    rdfs:range xsd:string ;
    rdfs:label "Formula" ;
    rdfs:comment "The ERB formula or derivation rule for this component." .

effortless-ntwf:naturalLanguage a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "NaturalLanguage" ;
    rdfs:comment "Plain-English statement of what this component represents or requires." .

effortless-ntwf:adapterNote a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InstrumentSpec ;
    rdfs:range xsd:string ;
    rdfs:label "AdapterNote" ;
    rdfs:comment "What a researcher must supply or verify to satisfy this component when hydrating a new study." .

# === Class: InvariantChecks ===
effortless-ntwf:InvariantChecks a owl:Class ;
    rdfs:label "InvariantChecks" ;
    rdfs:comment "Table: InvariantChecks — one row per algebraic invariant across the 40-study validation corpus. PassCount and FailCount are populated by run_invariant_checks() in 05b-customize-data.sql. Any critical FailCount > 0 breaks the build." .

effortless-ntwf:invariantCheckId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "InvariantCheckId" ;
    rdfs:comment "Unique slug for this invariant (e.g. inv-balanced-alloc)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:algebraicStatement a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "AlgebraicStatement" ;
    rdfs:comment "The mathematical assertion in compact symbolic form." .

effortless-ntwf:naturalLanguage a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "NaturalLanguage" ;
    rdfs:comment "Plain-English statement of what property must hold and why it is an invariant of the model." .

effortless-ntwf:sourceTable a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SourceTable" ;
    rdfs:comment "The DAG table whose rows are checked (TreatmentRankings or StratumSummaries)." .

effortless-ntwf:filterExpression a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "FilterExpression" ;
    rdfs:comment "Condition selecting the universe of rows this invariant applies to. Empty means all rows." .

effortless-ntwf:assertionExpression a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "AssertionExpression" ;
    rdfs:comment "The per-row condition that must be TRUE for every row in scope." .

effortless-ntwf:sqlFilter a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "SqlFilter" ;
    rdfs:comment "Optional SQL WHERE clause that selects the universe of rows in scope for this invariant (e.g. distortion_type = 'D'). Empty string means all rows." .

effortless-ntwf:sqlAssertion a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "SqlAssertion" ;
    rdfs:comment "The SQL WHERE clause (without WHERE keyword) that counts PASSING rows from vw_treatment_rankings for this invariant. Used by run_invariant_checks() to evaluate each assertion dynamically from the rulebook table." .

effortless-ntwf:passCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:integer ;
    rdfs:label "PassCount" ;
    rdfs:comment "Rows where the invariant holds. Populated by 05b-customize-data.sql from a live query against vw_treatment_rankings." .

effortless-ntwf:failCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:integer ;
    rdfs:label "FailCount" ;
    rdfs:comment "Rows where the invariant is violated. Any FailCount > 0 is a build-breaking bug." .

effortless-ntwf:universeCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:integer ;
    rdfs:label "UniverseCount" ;
    rdfs:comment "Total rows in scope (PassCount + FailCount)." .
    # calculated: calculated

effortless-ntwf:isGreen a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsGreen" ;
    rdfs:comment "TRUE when FailCount = 0." .
    # calculated: calculated

effortless-ntwf:statusLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "StatusLabel" ;
    rdfs:comment "PASS or FAIL(n) summary for display." .
    # calculated: calculated

effortless-ntwf:severity a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "Severity" ;
    rdfs:comment "critical | warning — critical means any FailCount > 0 is a build-breaking bug." .

effortless-ntwf:traditionId a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TraditionId" ;
    rdfs:comment "FK → ResearchTraditions.TraditionId. The tradition whose theoretical commitments this algebraic invariant protects — a failed invariant would falsify that tradition's key claim." .

effortless-ntwf:protectsConclusion a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "ProtectsConclusion" ;
    rdfs:comment "FK → Conclusions.ConclusionId. The conclusion whose witness depends on this invariant holding. If this invariant fails, that conclusion is undermined." .

effortless-ntwf:traditionName a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TraditionName" ;
    rdfs:comment "Lookup: ResearchTraditions.Name via TraditionId." .
    # calculated: lookup

effortless-ntwf:traditionKeyClaimSummary a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TraditionKeyClaimSummary" ;
    rdfs:comment "Lookup: ResearchTraditions.KeyClaim via TraditionId — a failed invariant would falsify this tradition's key claim." .
    # calculated: lookup

effortless-ntwf:protectsConclusionTitle a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "ProtectsConclusionTitle" ;
    rdfs:comment "Lookup: Conclusions.Title via ProtectsConclusion." .
    # calculated: lookup

effortless-ntwf:protectsConclusionCategory a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "ProtectsConclusionCategory" ;
    rdfs:comment "Lookup: Conclusions.Category via ProtectsConclusion." .
    # calculated: lookup

# === Class: Loops ===
effortless-ntwf:Loops a owl:Class ;
    rdfs:label "Loops" ;
    rdfs:comment "Table: Loops — build history and forward plan, carried as a first-class entity inside the model. Each row documents what new concept is introduced, what was witnessed, and (for planned rows) the next empirical question. Loops 62–67 are the corpus-scale research sweep + catalog expansion. Loops 68+ are the expansion encode waves: pre-register in DiscoveryHypotheses, encode via StudyImportTemplate, LoopReview at end of each turn before committing vocabulary." .

effortless-ntwf:loopId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Loops ;
    rdfs:range xsd:string ;
    rdfs:label "LoopId" ;
    rdfs:comment "Unique identifier: loop-01 through loop-10." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:title a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Title" ;
    rdfs:comment "Short title for what this loop adds to the domain model." .

effortless-ntwf:status a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Status" ;
    rdfs:comment "planned | in-progress | complete" .

effortless-ntwf:newConcept a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Loops ;
    rdfs:range xsd:string ;
    rdfs:label "NewConcept" ;
    rdfs:comment "The new first-class domain concept introduced this loop." .

effortless-ntwf:domainQuestion a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Loops ;
    rdfs:range xsd:string ;
    rdfs:label "DomainQuestion" ;
    rdfs:comment "The natural-language question this loop's concept answers FROM the domain data." .

effortless-ntwf:mockDataNote a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Loops ;
    rdfs:range xsd:string ;
    rdfs:label "MockDataNote" ;
    rdfs:comment "What the seed data is designed to show." .

effortless-ntwf:nextSuggestion a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Loops ;
    rdfs:range xsd:string ;
    rdfs:label "NextSuggestion" ;
    rdfs:comment "Suggestion for the next loop, written after witnessing the DAG at this loop's end." .

effortless-ntwf:traditionId a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TraditionId" ;
    rdfs:comment "FK → ResearchTraditions.TraditionId. The scholarly tradition whose conceptual vocabulary this loop primarily draws on — tracks which tradition has driven each stage of the instrument's development." .

effortless-ntwf:traditionName a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TraditionName" ;
    rdfs:comment "Lookup: ResearchTraditions.Name via TraditionId." .
    # calculated: lookup

effortless-ntwf:traditionCoreConern a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TraditionCoreConern" ;
    rdfs:comment "Lookup: ResearchTraditions.CoreConcern via TraditionId — which intellectual concern drove this loop." .
    # calculated: lookup

effortless-ntwf:commitHash a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Loops ;
    rdfs:range xsd:string ;
    rdfs:label "CommitHash" ;
    rdfs:comment "Full git SHA where this loop row first landed in effortless-rulebook.json — the replay anchor for this turn of the Leopold loop." .

effortless-ntwf:commitShort a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Loops ;
    rdfs:range xsd:string ;
    rdfs:label "CommitShort" ;
    rdfs:comment "First 7 characters of CommitHash for display and git checkout." .
    # calculated: calculated

effortless-ntwf:commitDate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Loops ;
    rdfs:range xsd:string ;
    rdfs:label "CommitDate" ;
    rdfs:comment "ISO date (YYYY-MM-DD) of the commit where this loop landed." .

effortless-ntwf:commitMessage a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Loops ;
    rdfs:range xsd:string ;
    rdfs:label "CommitMessage" ;
    rdfs:comment "Git commit subject line for this loop's landing commit." .

effortless-ntwf:gitTag a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Loops ;
    rdfs:range xsd:string ;
    rdfs:label "GitTag" ;
    rdfs:comment "Optional milestone tag pointing at this loop's landing commit (sp-loop-milestone-*). Used for discovery replay without memorizing SHAs." .

# === Class: Methodology ===
effortless-ntwf:Methodology a owl:Class ;
    rdfs:label "Methodology" ;
    rdfs:comment "Table: Methodology — the first-principles process used to build this domain model. Each row documents one methodological axiom or step. Together these rows let a reader (or an LLM) reconstruct why the model is shaped the way it is, and re-apply the same process to a new domain." .

effortless-ntwf:methodologyId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Methodology ;
    rdfs:range xsd:string ;
    rdfs:label "MethodologyId" ;
    rdfs:comment "Unique slug (e.g. method-01-cmcc, method-02-dag-first)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label, mirrors MethodologyId." .
    # calculated: calculated

effortless-ntwf:phase a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Methodology ;
    rdfs:range xsd:string ;
    rdfs:label "Phase" ;
    rdfs:comment "Broad phase: axiom | decomposition | derivation | hydration | validation | taxonomy | conclusion" .

effortless-ntwf:title a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Title" ;
    rdfs:comment "Short title of the methodological principle or step." .

effortless-ntwf:statement a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Statement" ;
    rdfs:comment "One-to-three sentence statement of the principle, precise enough to be applied or falsified." .

effortless-ntwf:whyItMatters a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Methodology ;
    rdfs:range xsd:string ;
    rdfs:label "WhyItMatters" ;
    rdfs:comment "Why this step or principle is load-bearing for this model — what breaks if you skip it." .

effortless-ntwf:illustratedByLoop a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Methodology ;
    rdfs:range xsd:string ;
    rdfs:label "IllustratedByLoop" ;
    rdfs:comment "LoopId(s) where this principle was concretely demonstrated (comma-separated)." .

effortless-ntwf:traditionId a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TraditionId" ;
    rdfs:comment "FK → ResearchTraditions.TraditionId. The scholarly tradition that introduced or most relies on this methodological approach." .

effortless-ntwf:pioneeringResearcher a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Methodology ;
    rdfs:range xsd:string ;
    rdfs:label "PioneeringResearcher" ;
    rdfs:comment "FK → Researchers.ResearcherId. The researcher most associated with developing or popularising this methodological principle in the Simpson's Paradox context." .

effortless-ntwf:traditionName a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TraditionName" ;
    rdfs:comment "Lookup: ResearchTraditions.Name via TraditionId." .
    # calculated: lookup

effortless-ntwf:traditionPrimaryVenue a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Methodology ;
    rdfs:range xsd:string ;
    rdfs:label "TraditionPrimaryVenue" ;
    rdfs:comment "Lookup: ResearchTraditions.PrimaryVenue via TraditionId." .
    # calculated: lookup

effortless-ntwf:pioneeringResearcherName a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Methodology ;
    rdfs:range xsd:string ;
    rdfs:label "PioneeringResearcherName" ;
    rdfs:comment "Lookup: Researchers.Name via PioneeringResearcher." .
    # calculated: lookup

effortless-ntwf:pioneeringResearcherAffiliation a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Methodology ;
    rdfs:range xsd:string ;
    rdfs:label "PioneeringResearcherAffiliation" ;
    rdfs:comment "Lookup: Researchers.Affiliation via PioneeringResearcher." .
    # calculated: lookup

effortless-ntwf:loopCount a owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "LoopCount" ;
    rdfs:comment "Count of Loops whose TraditionId matches this methodology entry's TraditionId — how many build iterations this methodological tradition has driven." .
    # calculated: aggregation

# === Class: ModelSummary ===
effortless-ntwf:ModelSummary a owl:Class ;
    rdfs:label "ModelSummary" ;
    rdfs:comment "Table: ModelSummary — one row describing the epistemic coverage of this entire model instance. Aggregates across all TreatmentRankings to witness how many studies were examined, how many showed a full reversal, how many were explained, and the average paradox strength. The model holds a mirror to itself." .

effortless-ntwf:modelSummaryId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "ModelSummaryId" ;
    rdfs:comment "Unique identifier for this model instance." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:reversalCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "ReversalCount" ;
    rdfs:comment "Number of studies with IsReversal=TRUE (sign-flip / allocation-driven reversal)." .
    # calculated: aggregation

effortless-ntwf:nonReversalCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "NonReversalCount" ;
    rdfs:comment "Number of studies with IsReversal=FALSE." .
    # calculated: aggregation

effortless-ntwf:studyCount a owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "StudyCount" ;
    rdfs:comment "Total number of TreatmentRankings in this model: ReversalCount + NonReversalCount." .
    # calculated: calculated

effortless-ntwf:explainedCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "ExplainedCount" ;
    rdfs:comment "Number of studies with IsParadoxExplained=TRUE (reversal AND confirmed confounder)." .
    # calculated: aggregation

effortless-ntwf:totalParadoxStrength a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "TotalParadoxStrength" ;
    rdfs:comment "Sum of ParadoxStrength across all studies. Used to compute average." .
    # calculated: aggregation

effortless-ntwf:avgParadoxStrength a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "AvgParadoxStrength" ;
    rdfs:comment "Average ParadoxStrength across all studies: TotalParadoxStrength / StudyCount. A scalar summary of how paradox-rich this dataset is." .
    # calculated: calculated

effortless-ntwf:typeACount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "TypeACount" ;
    rdfs:comment "Studies classified as Type-A: sign flip AND full reversal (ReversalIntensity=1). The canonical Simpson's Paradox — allocation distortion reverses the pooled winner." .
    # calculated: aggregation

effortless-ntwf:typeBCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "TypeBCount" ;
    rdfs:comment "Studies classified as Type-B: sign flip but partial reversal (ReversalIntensity<1). Allocation distortion creates a sign flip but the pooled signal partially reflects per-stratum reality." .
    # calculated: aggregation

effortless-ntwf:typeDCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "TypeDCount" ;
    rdfs:comment "Studies classified as Type-D: no sign flip, negligible distortion. Pooled analysis is trustworthy — allocation is sufficiently balanced." .
    # calculated: aggregation

effortless-ntwf:typeAFraction a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "TypeAFraction" ;
    rdfs:comment "Fraction of studies that are Type-A (full canonical reversals). TypeACount / StudyCount." .
    # calculated: calculated

effortless-ntwf:distortionTaxonomyCoverage a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "DistortionTaxonomyCoverage" ;
    rdfs:comment "Human-readable summary of the four-type distribution: e.g. 'A:2 B:1 C:1 D:0'. The model's self-portrait of its own distortion geometry." .
    # calculated: calculated

effortless-ntwf:distortionOnlyCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "DistortionOnlyCount" ;
    rdfs:comment "Number of studies with real allocation distortion but no sign flip: TypeCCount. The pooled winner is correct but the effect size is biased. Distinct from ZeroStrengthCount, which conflates Type-C (real distortion) with Type-D (neutral)." .
    # calculated: calculated

effortless-ntwf:cAmplificationCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "CAmplificationCount" ;
    rdfs:comment "Number of studies classified as type C+ (allocation-amplified): pooled winner is correct but pooled gap overstates true advantage. Causes researcher overconfidence — may accept higher cost/risk than true effect warrants." .
    # calculated: aggregation

effortless-ntwf:cCompressionCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "CCompressionCount" ;
    rdfs:comment "Number of studies classified as type C- (allocation-compressed): pooled winner is correct but pooled gap understates true advantage. Causes researcher underconfidence — effective treatment may be prematurely abandoned." .
    # calculated: aggregation

effortless-ntwf:avgSignalPurity a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "AvgSignalPurity" ;
    rdfs:comment "Average SignalPurity across all TreatmentRankings. Below 0.5 means allocation noise exceeds true signal on average — the corpus is predominantly misleading at the pooled level. Above 0.5 means the corpus is predominantly trustworthy." .
    # calculated: aggregation

effortless-ntwf:sweepCorrectedGapMax a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SweepCorrectedGapMax" ;
    rdfs:comment "Maximum SweepCorrectedGap across all AllocationSweep rows. Should equal SweepCorrectedGapMin — the invariant." .
    # calculated: aggregation

effortless-ntwf:sweepCorrectedGapMin a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SweepCorrectedGapMin" ;
    rdfs:comment "Minimum SweepCorrectedGap across all AllocationSweep rows. Should equal SweepCorrectedGapMax — the invariant." .
    # calculated: aggregation

effortless-ntwf:sweepCorrectedGapRange a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SweepCorrectedGapRange" ;
    rdfs:comment "SweepCorrectedGapMax − SweepCorrectedGapMin. The allocation-invariance witness: this should be zero (up to floating-point rounding). If nonzero, the corrected gap is not allocation-free." .
    # calculated: calculated

effortless-ntwf:sweepPooledGapRange a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SweepPooledGapRange" ;
    rdfs:comment "MAX(SweepPooledGap) − MIN(SweepPooledGap) across all AllocationSweep rows. Expected to be large (≈0.21) — the pooled gap wanders as allocation shifts." .
    # calculated: aggregation

effortless-ntwf:realStudyCount a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "RealStudyCount" ;
    rdfs:comment "Number of real (non-synthetic) published studies in the corpus." .
    # calculated: raw

effortless-ntwf:avgSignalPurityReversal a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "AvgSignalPurityReversal" ;
    rdfs:comment "Average SignalPurity across reversal studies (type A and B). Theorem predicts this must be < 0.5." .
    # calculated: raw

effortless-ntwf:avgSignalPurityNonReversal a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "AvgSignalPurityNonReversal" ;
    rdfs:comment "Average SignalPurity across non-reversal studies (type C+, C-, D). Theorem predicts this must be >= 0.5 except edge cases." .
    # calculated: raw

effortless-ntwf:signalPurityGap a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "SignalPurityGap" ;
    rdfs:comment "Separation between reversal and non-reversal average SignalPurity. The larger this gap, the more discriminating the threshold at 0.5." .
    # calculated: raw

effortless-ntwf:medicineStudyCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "MedicineStudyCount" ;
    rdfs:comment "Real published studies in the medicine domain." .
    # calculated: raw

effortless-ntwf:epidemiologyStudyCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "EpidemiologyStudyCount" ;
    rdfs:comment "Real published studies in the epidemiology domain." .
    # calculated: raw

effortless-ntwf:otherDomainStudyCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "OtherDomainStudyCount" ;
    rdfs:comment "Real published studies outside medicine and epidemiology (sports, legal, education, social-science)." .
    # calculated: raw

effortless-ntwf:domainDiversityNote a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "DomainDiversityNote" ;
    rdfs:comment "Human-readable domain breakdown. Witnesses corpus diversity — a prerequisite for cross-domain SignalPurity claims." .
    # calculated: raw

effortless-ntwf:syntheticPhaseCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "SyntheticPhaseCount" ;
    rdfs:comment "Number of parameter grid points in SyntheticPhase. Refreshed from vw_phase_diagram_summary by 05b-customize-data.sql." .

effortless-ntwf:phaseDiagramComplete a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:boolean ;
    rdfs:label "PhaseDiagramComplete" ;
    rdfs:comment "TRUE when all five DistortionType cells are populated in the synthetic phase grid. Refreshed from vw_phase_diagram_summary by 05b." .

effortless-ntwf:phaseTaxonomyCoverage a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "PhaseTaxonomyCoverage" ;
    rdfs:comment "Type counts across the synthetic phase grid. Refreshed from vw_phase_diagram_summary by 05b." .

effortless-ntwf:ingestionProtocolItemCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "IngestionProtocolItemCount" ;
    rdfs:comment "Number of rows in IngestionProtocol — the documented contract items." .
    # calculated: aggregation

effortless-ntwf:corpusPassesIngestionContract a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:boolean ;
    rdfs:label "CorpusPassesIngestionContract" ;
    rdfs:comment "Lookup: IngestionSummary.IngestionContractPasses." .
    # calculated: lookup

effortless-ntwf:ingestionWitnessNote a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "IngestionWitnessNote" ;
    rdfs:comment "Human-readable ingestion contract witness from IngestionSummary." .
    # calculated: lookup

effortless-ntwf:catalogEntryCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "CatalogEntryCount" ;
    rdfs:comment "Total catalog rows." .
    # calculated: lookup

effortless-ntwf:pendingImportCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "PendingImportCount" ;
    rdfs:comment "Candidate studies queued." .
    # calculated: lookup

effortless-ntwf:readyToEncodeCount a owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "ReadyToEncodeCount" ;
    rdfs:comment "Encode-ready candidates." .
    # calculated: lookup

effortless-ntwf:importSessionReady a owl:DatatypeProperty ;
    rdfs:range xsd:boolean ;
    rdfs:label "ImportSessionReady" ;
    rdfs:comment "Bulk import session readiness flag." .
    # calculated: lookup

effortless-ntwf:catalogWitnessNote a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "CatalogWitnessNote" ;
    rdfs:comment "Import backlog witness string." .
    # calculated: lookup

effortless-ntwf:latentTypeDCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "LatentTypeDCount" ;
    rdfs:comment "Type-D studies with LatentFlipPotential=TRUE." .
    # calculated: calculated

effortless-ntwf:stableTypeDCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "StableTypeDCount" ;
    rdfs:comment "Type-D studies without latent flip potential (allocation-stable at observed and counterfactual sweep)." .
    # calculated: calculated

effortless-ntwf:latentTypeDFraction a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "LatentTypeDFraction" ;
    rdfs:comment "Fraction of Type-D studies with latent flip potential." .
    # calculated: calculated

effortless-ntwf:crossZeroCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "CrossZeroCount" ;
    rdfs:comment "Studies whose pooled gap crosses zero under allocation sweep." .
    # calculated: calculated

effortless-ntwf:signFlipSignalPurityMax a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "SignFlipSignalPurityMax" ;
    rdfs:comment "Maximum SignalPurity among sign-flip studies. Must stay below 0.5 for the signal-purity theorem." .
    # calculated: calculated

effortless-ntwf:economicsSignFlipCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "EconomicsSignFlipCount" ;
    rdfs:comment "Sign-flip count in economics domain." .
    # calculated: calculated

effortless-ntwf:avgPooledGapLatentD a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "AvgPooledGapLatentD" ;
    rdfs:comment "Average PooledGap among Type-D studies with latent flip potential." .
    # calculated: calculated

effortless-ntwf:avgPooledGapStableD a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "AvgPooledGapStableD" ;
    rdfs:comment "Average PooledGap among allocation-stable Type-D studies." .
    # calculated: calculated

effortless-ntwf:epidemiologyAvgDistortion a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "EpidemiologyAvgDistortion" ;
    rdfs:comment "Mean AllocationDistortion in epidemiology studies." .
    # calculated: calculated

effortless-ntwf:educationAvgDistortion a owl:DatatypeProperty ;
