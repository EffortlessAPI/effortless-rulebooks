effortless-ntwf:mechanicalCheck a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "MechanicalCheck" ;
    rdfs:comment "How to verify compliance before classification." .

effortless-ntwf:sortOrder a owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "SortOrder" ;
    rdfs:comment "Display order in the ingestion checklist." .

