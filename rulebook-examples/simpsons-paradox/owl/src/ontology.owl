@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix effortless-ntwf: <https://w3id.org/effortless-ntwf#> .

<https://w3id.org/effortless-ntwf#> a owl:Ontology ;
    rdfs:label "NTWF Ontology (Effortless rendering)" ;
    rdfs:comment "Generated by Effortless from simpsons-paradox-rulebook.json. Vocabulary: Jessica Talisman NTWF." .

# === Class: CaseCells ===
effortless-ntwf:CaseCells a owl:Class ;
    rdfs:label "CaseCells" ;
    rdfs:comment "Table: CaseCells — the raw leaves of the DAG. One row per (study, stratum, treatment) combination recording the aggregate count of successes and total cases. Every derived fact in the model traces back to these numbers. Nothing above this row is a raw input." .

effortless-ntwf:caseCellId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CaseCells ;
    rdfs:range xsd:string ;
    rdfs:label "CaseCellId" ;
    rdfs:comment "Unique slug (e.g. kidney-1986-small-A)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:study a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:Studies ;
    rdfs:label "Study" ;
    rdfs:comment "FK to the parent Study." .

effortless-ntwf:stratumLabel a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "StratumLabel" ;
    rdfs:comment "The stratum this cell belongs to (matches Strata.StratumLabel)." .

effortless-ntwf:treatmentLabel a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentLabel" ;
    rdfs:comment "The treatment applied in this cell (matches Treatments.TreatmentLabel)." .

effortless-ntwf:successes a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CaseCells ;
    rdfs:range xsd:integer ;
    rdfs:label "Successes" ;
    rdfs:comment "Number of patients in this cell who had a successful outcome. RAW INPUT — never derived." .

effortless-ntwf:cases a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CaseCells ;
    rdfs:range xsd:integer ;
    rdfs:label "Cases" ;
    rdfs:comment "Total number of patients in this cell. RAW INPUT — never derived." .

effortless-ntwf:cellSuccessRate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CaseCells ;
    rdfs:range xsd:string ;
    rdfs:label "CellSuccessRate" ;
    rdfs:comment "Success rate within this cell: Successes / Cases. The first derived fact in the DAG." .
    # calculated: calculated

effortless-ntwf:totalCasesForTreatment a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CaseCells ;
    rdfs:range xsd:integer ;
    rdfs:label "TotalCasesForTreatment" ;
    rdfs:comment "Total cases across ALL strata for this treatment in this study — the denominator for TreatmentExposureFraction." .
    # calculated: aggregation

effortless-ntwf:treatmentExposureFraction a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CaseCells ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentExposureFraction" ;
    rdfs:comment "Fraction of this treatment's total cases that fall in this stratum: Cases / TotalCasesForTreatment. High imbalance across strata is the mechanism of confounding — when treatments are allocated very differently across strata, the pooled rate conflates treatment effect with stratum difficulty." .
    # calculated: calculated

# === Class: Conclusions ===
effortless-ntwf:Conclusions a owl:Class ;
    rdfs:label "Conclusions" ;
    rdfs:comment "Table: Conclusions — the substantive epistemic findings that this model has produced or is designed to produce. Each row is one conclusion: a claim about the domain, about the instrument, or about the methodology that is either already witnessed or is the target of a planned loop." .

effortless-ntwf:conclusionId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "ConclusionId" ;
    rdfs:comment "Unique slug (e.g. conc-01-paradox-is-derived)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label, mirrors ConclusionId." .
    # calculated: calculated

effortless-ntwf:category a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "Category" ;
    rdfs:comment "domain | instrument | methodology | open-question" .

effortless-ntwf:status a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Status" ;
    rdfs:comment "witnessed | planned | open" .

effortless-ntwf:title a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Title" ;
    rdfs:comment "One-line statement of the conclusion." .

effortless-ntwf:evidence a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "Evidence" ;
    rdfs:comment "The specific DB query result, loop outcome, or argument that establishes or will establish this conclusion." .

effortless-ntwf:witnessedInLoop a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "WitnessedInLoop" ;
    rdfs:comment "LoopId where this conclusion was first witnessed (if status=witnessed)." .

effortless-ntwf:targetLoop a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "TargetLoop" ;
    rdfs:comment "LoopId that is designed to witness this conclusion (if status=planned)." .

# === Class: InstrumentSpec ===
effortless-ntwf:InstrumentSpec a owl:Class ;
    rdfs:label "InstrumentSpec" ;
    rdfs:comment "Table: InstrumentSpec — the complete specification of the Simpson's Paradox classification instrument. One row per component: required input fields, derived coordinates, classification outputs, and adapter requirements. Every row is machine-verifiable against the 16 hydrated studies. This table is the distillation of loops 1–25 into a reusable tool." .

effortless-ntwf:specId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InstrumentSpec ;
    rdfs:range xsd:string ;
    rdfs:label "SpecId" ;
    rdfs:comment "Unique identifier for this instrument component." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:componentType a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InstrumentSpec ;
    rdfs:range xsd:string ;
    rdfs:label "ComponentType" ;
    rdfs:comment "input | derived | classification | adapter-requirement" .

effortless-ntwf:fieldName a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InstrumentSpec ;
    rdfs:range xsd:string ;
    rdfs:label "FieldName" ;
    rdfs:comment "The field or variable name in the DAG." .

effortless-ntwf:dataType a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InstrumentSpec ;
    rdfs:range xsd:string ;
    rdfs:label "DataType" ;
    rdfs:comment "integer | decimal | boolean | string | categorical" .

effortless-ntwf:sourceTable a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SourceTable" ;
    rdfs:comment "The DAG table where this field is computed or stored." .

effortless-ntwf:formula a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InstrumentSpec ;
    rdfs:range xsd:string ;
    rdfs:label "Formula" ;
    rdfs:comment "The ERB formula or derivation rule for this component." .

effortless-ntwf:naturalLanguage a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "NaturalLanguage" ;
    rdfs:comment "Plain-English statement of what this component represents or requires." .

effortless-ntwf:adapterNote a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InstrumentSpec ;
    rdfs:range xsd:string ;
    rdfs:label "AdapterNote" ;
    rdfs:comment "What a researcher must supply or verify to satisfy this component when hydrating a new study." .

# === Class: InvariantChecks ===
effortless-ntwf:InvariantChecks a owl:Class ;
    rdfs:label "InvariantChecks" ;
    rdfs:comment "Table: InvariantChecks — one row per algebraic invariant that must hold across the full validation set. PassCount and FailCount are populated by 05b-customize-data.sql from live queries against vw_treatment_rankings. Any FailCount > 0 is a build-breaking bug." .

effortless-ntwf:invariantCheckId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "InvariantCheckId" ;
    rdfs:comment "Unique slug for this invariant (e.g. inv-balanced-alloc)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:algebraicStatement a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "AlgebraicStatement" ;
    rdfs:comment "The mathematical assertion in compact symbolic form." .

effortless-ntwf:naturalLanguage a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "NaturalLanguage" ;
    rdfs:comment "Plain-English statement of what property must hold and why it is an invariant of the model." .

effortless-ntwf:sourceTable a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SourceTable" ;
    rdfs:comment "The DAG table whose rows are checked (TreatmentRankings or StratumSummaries)." .

effortless-ntwf:filterExpression a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "FilterExpression" ;
    rdfs:comment "Condition selecting the universe of rows this invariant applies to. Empty means all rows." .

effortless-ntwf:assertionExpression a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "AssertionExpression" ;
    rdfs:comment "The per-row condition that must be TRUE for every row in scope." .

effortless-ntwf:sqlFilter a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "SqlFilter" ;
    rdfs:comment "Optional SQL WHERE clause that selects the universe of rows in scope for this invariant (e.g. distortion_type = 'D'). Empty string means all rows." .

effortless-ntwf:sqlAssertion a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "SqlAssertion" ;
    rdfs:comment "The SQL WHERE clause (without WHERE keyword) that counts PASSING rows from vw_treatment_rankings for this invariant. Used by run_invariant_checks() to evaluate each assertion dynamically from the rulebook table." .

effortless-ntwf:passCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:integer ;
    rdfs:label "PassCount" ;
    rdfs:comment "Rows where the invariant holds. Populated by 05b-customize-data.sql from a live query against vw_treatment_rankings." .

effortless-ntwf:failCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:integer ;
    rdfs:label "FailCount" ;
    rdfs:comment "Rows where the invariant is violated. Any FailCount > 0 is a build-breaking bug." .

effortless-ntwf:universeCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:integer ;
    rdfs:label "UniverseCount" ;
    rdfs:comment "Total rows in scope (PassCount + FailCount)." .
    # calculated: calculated

effortless-ntwf:isGreen a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsGreen" ;
    rdfs:comment "TRUE when FailCount = 0." .
    # calculated: calculated

effortless-ntwf:statusLabel a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "StatusLabel" ;
    rdfs:comment "PASS or FAIL(n) summary for display." .
    # calculated: calculated

effortless-ntwf:severity a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:InvariantChecks ;
    rdfs:range xsd:string ;
    rdfs:label "Severity" ;
    rdfs:comment "critical | warning — critical means any FailCount > 0 is a build-breaking bug." .

# === Class: Loops ===
effortless-ntwf:Loops a owl:Class ;
    rdfs:label "Loops" ;
    rdfs:comment "Table: Loops — the 10-loop build plan, carried as a first-class entity inside the model. Each row documents what new concept is introduced and why." .

effortless-ntwf:loopId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Loops ;
    rdfs:range xsd:string ;
    rdfs:label "LoopId" ;
    rdfs:comment "Unique identifier: loop-01 through loop-10." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:title a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Title" ;
    rdfs:comment "Short title for what this loop adds to the domain model." .

effortless-ntwf:status a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Status" ;
    rdfs:comment "planned | in-progress | complete" .

effortless-ntwf:newConcept a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Loops ;
    rdfs:range xsd:string ;
    rdfs:label "NewConcept" ;
    rdfs:comment "The new first-class domain concept introduced this loop." .

effortless-ntwf:domainQuestion a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Loops ;
    rdfs:range xsd:string ;
    rdfs:label "DomainQuestion" ;
    rdfs:comment "The natural-language question this loop's concept answers FROM the domain data." .

effortless-ntwf:mockDataNote a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Loops ;
    rdfs:range xsd:string ;
    rdfs:label "MockDataNote" ;
    rdfs:comment "What the seed data is designed to show." .

effortless-ntwf:nextSuggestion a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Loops ;
    rdfs:range xsd:string ;
    rdfs:label "NextSuggestion" ;
    rdfs:comment "Suggestion for the next loop, written after witnessing the DAG at this loop's end." .

# === Class: Methodology ===
effortless-ntwf:Methodology a owl:Class ;
    rdfs:label "Methodology" ;
    rdfs:comment "Table: Methodology — the first-principles process used to build this domain model. Each row documents one methodological axiom or step. Together these rows let a reader (or an LLM) reconstruct why the model is shaped the way it is, and re-apply the same process to a new domain." .

effortless-ntwf:methodologyId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Methodology ;
    rdfs:range xsd:string ;
    rdfs:label "MethodologyId" ;
    rdfs:comment "Unique slug (e.g. method-01-cmcc, method-02-dag-first)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label, mirrors MethodologyId." .
    # calculated: calculated

effortless-ntwf:phase a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Methodology ;
    rdfs:range xsd:string ;
    rdfs:label "Phase" ;
    rdfs:comment "Broad phase: axiom | decomposition | derivation | hydration | validation | taxonomy | conclusion" .

effortless-ntwf:title a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Title" ;
    rdfs:comment "Short title of the methodological principle or step." .

effortless-ntwf:statement a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Methodology ;
    rdfs:range xsd:string ;
    rdfs:label "Statement" ;
    rdfs:comment "One-to-three sentence statement of the principle, precise enough to be applied or falsified." .

effortless-ntwf:whyItMatters a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Methodology ;
    rdfs:range xsd:string ;
    rdfs:label "WhyItMatters" ;
    rdfs:comment "Why this step or principle is load-bearing for this model — what breaks if you skip it." .

effortless-ntwf:illustratedByLoop a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Methodology ;
    rdfs:range xsd:string ;
    rdfs:label "IllustratedByLoop" ;
    rdfs:comment "LoopId(s) where this principle was concretely demonstrated (comma-separated)." .

# === Class: ModelSummary ===
effortless-ntwf:ModelSummary a owl:Class ;
    rdfs:label "ModelSummary" ;
    rdfs:comment "Table: ModelSummary — one row describing the epistemic coverage of this entire model instance. Aggregates across all TreatmentRankings to witness how many studies were examined, how many showed a full reversal, how many were explained, and the average paradox strength. The model holds a mirror to itself." .

effortless-ntwf:modelSummaryId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "ModelSummaryId" ;
    rdfs:comment "Unique identifier for this model instance." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:reversalCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "ReversalCount" ;
    rdfs:comment "Number of studies with IsReversal=TRUE (strict full reversal)." .
    # calculated: aggregation

effortless-ntwf:nonReversalCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "NonReversalCount" ;
    rdfs:comment "Number of studies with IsReversal=FALSE." .
    # calculated: aggregation

effortless-ntwf:studyCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "StudyCount" ;
    rdfs:comment "Total number of TreatmentRankings in this model: ReversalCount + NonReversalCount." .
    # calculated: calculated

effortless-ntwf:explainedCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "ExplainedCount" ;
    rdfs:comment "Number of studies with IsParadoxExplained=TRUE (reversal AND confirmed confounder)." .
    # calculated: aggregation

effortless-ntwf:zeroStrengthCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "ZeroStrengthCount" ;
    rdfs:comment "Studies with StrataWonByLoser=0: no strata go against the pooled winner. These are structurally paradox-free." .
    # calculated: aggregation

effortless-ntwf:partialCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "PartialCount" ;
    rdfs:comment "Studies with ParadoxStrength > 0 but IsReversal=FALSE: partial paradoxes real but not formally complete." .
    # calculated: calculated

effortless-ntwf:totalParadoxStrength a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "TotalParadoxStrength" ;
    rdfs:comment "Sum of ParadoxStrength across all studies. Used to compute average." .
    # calculated: aggregation

effortless-ntwf:avgParadoxStrength a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "AvgParadoxStrength" ;
    rdfs:comment "Average ParadoxStrength across all studies: TotalParadoxStrength / StudyCount. A scalar summary of how paradox-rich this dataset is." .
    # calculated: calculated

effortless-ntwf:typeACount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "TypeACount" ;
    rdfs:comment "Studies classified as Type-A: sign flip AND full reversal (ReversalIntensity=1). The canonical Simpson's Paradox — allocation distortion reverses the pooled winner." .
    # calculated: aggregation

effortless-ntwf:typeBCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "TypeBCount" ;
    rdfs:comment "Studies classified as Type-B: sign flip but partial reversal (ReversalIntensity<1). Allocation distortion creates a sign flip but the pooled signal partially reflects per-stratum reality." .
    # calculated: aggregation

effortless-ntwf:typeCCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "TypeCCount" ;
    rdfs:comment "Studies classified as Type-C: no sign flip but substantial allocation distortion (>0.01). The pooled winner is correct but the pooled magnitude is distorted by allocation imbalance." .
    # calculated: aggregation

effortless-ntwf:typeDCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "TypeDCount" ;
    rdfs:comment "Studies classified as Type-D: no sign flip, negligible distortion. Pooled analysis is trustworthy — allocation is sufficiently balanced." .
    # calculated: aggregation

effortless-ntwf:typeAFraction a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "TypeAFraction" ;
    rdfs:comment "Fraction of studies that are Type-A (full canonical reversals). TypeACount / StudyCount." .
    # calculated: calculated

effortless-ntwf:distortionTaxonomyCoverage a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:string ;
    rdfs:label "DistortionTaxonomyCoverage" ;
    rdfs:comment "Human-readable summary of the four-type distribution: e.g. 'A:2 B:1 C:1 D:0'. The model's self-portrait of its own distortion geometry." .
    # calculated: calculated

effortless-ntwf:reversalCountV2 a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "ReversalCountV2" ;
    rdfs:comment "Number of studies with IsReversal_v2=TRUE (sign-flip definition). Includes both Type-A (strict/unanimous) and Type-B (extended/partial sign-flip). This is the primary reversal count under the v2 definition; ReversalCount (unanimity) is now the Type-A subtype." .
    # calculated: aggregation

effortless-ntwf:nonReversalCountV2 a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "NonReversalCountV2" ;
    rdfs:comment "Number of studies with IsReversal_v2=FALSE (no sign flip under the v2 definition). Covers Type-C and Type-D only — studies where the equal-weight and actual pooled signals point in the same direction." .
    # calculated: aggregation

effortless-ntwf:extendedReversalCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "ExtendedReversalCount" ;
    rdfs:comment "Number of studies that are reversals under the v2 definition but not under the unanimity criterion: ReversalCountV2 minus ReversalCount. These are the Type-B studies — the ones the old definition missed. In the current dataset: 2 (berkeley-1973 and appleton-1996)." .
    # calculated: calculated

effortless-ntwf:explainedCountV2 a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "ExplainedCountV2" ;
    rdfs:comment "Number of studies with IsParadoxExplained_v2=TRUE: sign-flip reversal AND confirmed confounder. Includes the Type-B studies that IsParadoxExplained missed. The gap between ExplainedCountV2 and ExplainedCount is the number of extended reversals with causal accounts." .
    # calculated: aggregation

effortless-ntwf:distortionOnlyCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ModelSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "DistortionOnlyCount" ;
    rdfs:comment "Number of studies with real allocation distortion but no sign flip: TypeCCount. The pooled winner is correct but the effect size is biased. Distinct from ZeroStrengthCount, which conflates Type-C (real distortion) with Type-D (neutral)." .
    # calculated: calculated

# === Class: Strata ===
effortless-ntwf:Strata a owl:Class ;
    rdfs:label "Strata" ;
    rdfs:comment "Table: Strata — the subdivisions of patients within a study by the value of the confounding variable (e.g. stone size). Each stratum belongs to one study." .

effortless-ntwf:stratumId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Strata ;
    rdfs:range xsd:string ;
    rdfs:label "StratumId" ;
    rdfs:comment "Unique slug (e.g. kidney-1986-small, kidney-1986-large)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:study a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:Studies ;
    rdfs:label "Study" ;
    rdfs:comment "FK to the parent Study." .

effortless-ntwf:stratumLabel a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "StratumLabel" ;
    rdfs:comment "Short label used in CaseCells (e.g. small, large, dept-A)." .

effortless-ntwf:description a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Description" ;
    rdfs:comment "Plain-language description of what defines this stratum." .

effortless-ntwf:totalCases a owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "TotalCases" ;
    rdfs:comment "Total cases in this stratum across all treatments." .
    # calculated: aggregation

# === Class: StratumSummaries ===
effortless-ntwf:StratumSummaries a owl:Class ;
    rdfs:label "StratumSummaries" ;
    rdfs:comment "Table: StratumSummaries — one row per (study, stratum, treatment). Computes the success rate WITHIN each stratum for each treatment. This is the stratified view that contradicts the pooled conclusion when a Simpson's Paradox reversal is present. Each row belongs to both a Stratum and a Treatment in the same Study." .

effortless-ntwf:stratumSummaryId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:string ;
    rdfs:label "StratumSummaryId" ;
    rdfs:comment "Unique slug (e.g. kidney-1986-small-A)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:study a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:Studies ;
    rdfs:label "Study" ;
    rdfs:comment "FK to the parent Study." .

effortless-ntwf:stratumLabel a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "StratumLabel" ;
    rdfs:comment "Which stratum (matches Strata.StratumLabel)." .

effortless-ntwf:treatmentLabel a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentLabel" ;
    rdfs:comment "Which treatment (matches Treatments.TreatmentLabel)." .

effortless-ntwf:stratumSuccesses a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:integer ;
    rdfs:label "StratumSuccesses" ;
    rdfs:comment "Total successes in this (stratum, treatment) cell for this study." .
    # calculated: aggregation

effortless-ntwf:stratumCases a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:integer ;
    rdfs:label "StratumCases" ;
    rdfs:comment "Total cases in this (stratum, treatment) cell for this study." .
    # calculated: aggregation

effortless-ntwf:stratumSuccessRate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:string ;
    rdfs:label "StratumSuccessRate" ;
    rdfs:comment "Success rate within this stratum for this treatment: StratumSuccesses / StratumCases. The true per-stratum picture." .
    # calculated: calculated

effortless-ntwf:stratumSuccessesA a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:integer ;
    rdfs:label "StratumSuccessesA" ;
    rdfs:comment "Successes for treatment A in this (study, stratum) — used to determine the per-stratum winner." .
    # calculated: aggregation

effortless-ntwf:stratumCasesA a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:integer ;
    rdfs:label "StratumCasesA" ;
    rdfs:comment "Cases for treatment A in this (study, stratum)." .
    # calculated: aggregation

effortless-ntwf:stratumRateA a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:string ;
    rdfs:label "StratumRateA" ;
    rdfs:comment "Success rate for treatment A in this stratum." .
    # calculated: calculated

effortless-ntwf:stratumSuccessesB a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:integer ;
    rdfs:label "StratumSuccessesB" ;
    rdfs:comment "Successes for treatment B in this (study, stratum)." .
    # calculated: aggregation

effortless-ntwf:stratumCasesB a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:integer ;
    rdfs:label "StratumCasesB" ;
    rdfs:comment "Cases for treatment B in this (study, stratum)." .
    # calculated: aggregation

effortless-ntwf:stratumRateB a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:string ;
    rdfs:label "StratumRateB" ;
    rdfs:comment "Success rate for treatment B in this stratum." .
    # calculated: calculated

effortless-ntwf:stratumWinner a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:string ;
    rdfs:label "StratumWinner" ;
    rdfs:comment "Which treatment wins in this stratum: 'A' if StratumRateA > StratumRateB, else 'B'. Used by TreatmentRankings to detect paradox." .
    # calculated: calculated

effortless-ntwf:studyTotalCases a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:integer ;
    rdfs:label "StudyTotalCases" ;
    rdfs:comment "Total cases across ALL strata and ALL treatments in this study. The denominator for StratumFraction." .
    # calculated: aggregation

effortless-ntwf:stratumTotalCases a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:integer ;
    rdfs:label "StratumTotalCases" ;
    rdfs:comment "Total cases in this stratum across both treatments (A + B combined). Numerator for StratumFraction." .
    # calculated: aggregation

effortless-ntwf:stratumFraction a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:string ;
    rdfs:label "StratumFraction" ;
    rdfs:comment "Fraction of the study's total cases that fall in this stratum: StratumTotalCases / StudyTotalCases. The weight the confounder assigns to each stratum. A large StratumFraction on a low-success stratum pulls the pooled rate down; when that stratum is also over-allocated to one treatment, it creates the reversal." .
    # calculated: calculated

effortless-ntwf:weightedStratumRate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:string ;
    rdfs:label "WeightedStratumRate" ;
    rdfs:comment "StratumFraction × StratumSuccessRate. The contribution of this (stratum, treatment) row to the study-level pooled rate. Summing WeightedStratumRate across all strata for a given treatment reconstructs that treatment's pooled rate from stratum weights — witnessing the mechanism equation." .
    # calculated: calculated

effortless-ntwf:treatmentACasesHere a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:integer ;
    rdfs:label "TreatmentACasesHere" ;
    rdfs:comment "Cases for treatment A in this stratum — used to compute TreatmentA's allocation fraction in this stratum." .
    # calculated: aggregation

effortless-ntwf:treatmentBCasesHere a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:integer ;
    rdfs:label "TreatmentBCasesHere" ;
    rdfs:comment "Cases for treatment B in this stratum — used to compute TreatmentB's allocation fraction in this stratum." .
    # calculated: aggregation

effortless-ntwf:treatmentATotalCases a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:integer ;
    rdfs:label "TreatmentATotalCases" ;
    rdfs:comment "Total cases for treatment A across all strata in this study — denominator for AllocationFractionA." .
    # calculated: aggregation

effortless-ntwf:treatmentBTotalCases a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:integer ;
    rdfs:label "TreatmentBTotalCases" ;
    rdfs:comment "Total cases for treatment B across all strata in this study — denominator for AllocationFractionB." .
    # calculated: aggregation

effortless-ntwf:allocationFractionA a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:string ;
    rdfs:label "AllocationFractionA" ;
    rdfs:comment "Fraction of treatment A's total cases that land in this stratum: TreatmentACasesHere / TreatmentATotalCases. Equivalent to TreatmentExposureFraction for A." .
    # calculated: calculated

effortless-ntwf:allocationFractionB a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:string ;
    rdfs:label "AllocationFractionB" ;
    rdfs:comment "Fraction of treatment B's total cases that land in this stratum: TreatmentBCasesHere / TreatmentBTotalCases." .
    # calculated: calculated

effortless-ntwf:allocationBias a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:string ;
    rdfs:label "AllocationBias" ;
    rdfs:comment "AllocationFractionA minus AllocationFractionB: how much more of treatment A (relative to B) is concentrated in this stratum. Positive = A is over-allocated here; negative = B is over-allocated here. When AllocationBias is large and negative in a low-success stratum, treatment A is under-represented in the hard cases — making A look worse in the pooled view than it is in any stratum. This is the confounder's fingerprint as a signed number." .
    # calculated: calculated

effortless-ntwf:stratumGap a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:string ;
    rdfs:label "StratumGap" ;
    rdfs:comment "Signed rate difference within this stratum: StratumRateA minus StratumRateB. Positive = A wins here; negative = B wins here; zero = tied. When every stratum has StratumGap > 0 but the pooled gap is negative, the contradiction IS Simpson's Paradox made arithmetically visible in one column. Multiply StratumGap × StratumFraction and sum across strata to get the equal-weight pooled gap (the signal allocation would produce without confounding)." .
    # calculated: calculated

effortless-ntwf:weightedStratumGap a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumSummaries ;
    rdfs:range xsd:string ;
    rdfs:label "WeightedStratumGap" ;
    rdfs:comment "StratumGap × StratumFraction: the contribution of this stratum's treatment-rate difference to the equal-weight pooled gap. Summing WeightedStratumGap across all TreatmentA rows for a study gives WeightedStratumGapSum — the pooled gap the study would show under balanced allocation. This is the per-stratum building block of the sign-flip test." .
    # calculated: calculated

# === Class: StratumVariables ===
effortless-ntwf:StratumVariables a owl:Class ;
    rdfs:label "StratumVariables" ;
    rdfs:comment "Table: StratumVariables — one row per study, naming the variable that defines the strata and describing its causal role. A confounder affects both treatment assignment AND outcome; a mediator is downstream of treatment; a contested variable is one where the causal role is disputed. IsConfounder is derived from these two boolean flags." .

effortless-ntwf:stratumVariableId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumVariables ;
    rdfs:range xsd:string ;
    rdfs:label "StratumVariableId" ;
    rdfs:comment "Unique slug (e.g. kidney-1986-stone-size)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:study a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:Studies ;
    rdfs:label "Study" ;
    rdfs:comment "FK to the parent Study." .

effortless-ntwf:variableName a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumVariables ;
    rdfs:range xsd:string ;
    rdfs:label "VariableName" ;
    rdfs:comment "The name of the stratifying variable (e.g. stone_size, department, age_group)." .

effortless-ntwf:causalRole a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumVariables ;
    rdfs:range xsd:string ;
    rdfs:label "CausalRole" ;
    rdfs:comment "The variable's causal role: 'confounder' (affects both assignment and outcome), 'mediator' (downstream of treatment), 'contested' (causal role disputed), 'unknown'." .

effortless-ntwf:affectsTreatmentAssignment a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumVariables ;
    rdfs:range xsd:boolean ;
    rdfs:label "AffectsTreatmentAssignment" ;
    rdfs:comment "TRUE if this variable causally influences which treatment a patient receives. Required for confounding." .

effortless-ntwf:affectsOutcome a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumVariables ;
    rdfs:range xsd:boolean ;
    rdfs:label "AffectsOutcome" ;
    rdfs:comment "TRUE if this variable causally influences the outcome independently of treatment. Required for confounding." .

effortless-ntwf:isConfounder a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumVariables ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsConfounder" ;
    rdfs:comment "TRUE when AffectsTreatmentAssignment AND AffectsOutcome AND CausalRole = 'confounder'. A confounder is the classic driver of Simpson's Paradox." .
    # calculated: calculated

effortless-ntwf:mechanismNote a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumVariables ;
    rdfs:range xsd:string ;
    rdfs:label "MechanismNote" ;
    rdfs:comment "Plain-language description of how this variable creates the confounding: why it affects both assignment and outcome." .

effortless-ntwf:conditioningRisk a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:StratumVariables ;
    rdfs:range xsd:string ;
    rdfs:label "ConditioningRisk" ;
    rdfs:comment "The causal hazard posed by conditioning on this variable. Values: confounder (safe to condition — removes bias), mediator (conditioning blocks the causal path of interest — harmful), collider (conditioning opens a spurious backdoor — harmful), proxy (conditioning on a noisy proxy of the true confounder — risky), none (no conditioning risk identified). NULL means unclassified." .

# === Class: Studies ===
effortless-ntwf:Studies a owl:Class ;
    rdfs:label "Studies" ;
    rdfs:comment "Table: Studies — a clinical or empirical study comparing two or more treatments for a condition, with patient cases stratified by a confounding variable. The top-level entity in the domain." .

effortless-ntwf:studyId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Studies ;
    rdfs:range xsd:string ;
    rdfs:label "StudyId" ;
    rdfs:comment "Unique slug for this study (e.g. kidney-1986, berkeley-1973)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label, mirrors StudyId." .
    # calculated: calculated

effortless-ntwf:title a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Title" ;
    rdfs:comment "Human-readable title of the study." .

effortless-ntwf:source a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Studies ;
    rdfs:range xsd:string ;
    rdfs:label "Source" ;
    rdfs:comment "Citation or description of the original data source." .

effortless-ntwf:sourceUrl a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Studies ;
    rdfs:range xsd:string ;
    rdfs:label "SourceUrl" ;
    rdfs:comment "URL to the original source." .

effortless-ntwf:totalCases a owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "TotalCases" ;
    rdfs:comment "Total number of cases (trials) across all CaseCells in this study." .
    # calculated: aggregation

effortless-ntwf:cellCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Studies ;
    rdfs:range xsd:integer ;
    rdfs:label "CellCount" ;
    rdfs:comment "Number of CaseCell rows for this study." .
    # calculated: aggregation

# === Class: TreatmentRankings ===
effortless-ntwf:TreatmentRankings a owl:Class ;
    rdfs:label "TreatmentRankings" ;
    rdfs:comment "Table: TreatmentRankings — one row per treatment-pair comparison within a study. Derives the pooled winner, the per-stratum winner, and the IsReversal boolean. The paradox emerges here as a derived fact: IsReversal is true when the pooled winner and the per-stratum winner disagree." .

effortless-ntwf:treatmentRankingId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentRankingId" ;
    rdfs:comment "Unique slug (e.g. kidney-1986-A-vs-B)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:study a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:Studies ;
    rdfs:label "Study" ;
    rdfs:comment "FK to the parent Study." .

effortless-ntwf:treatmentA a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentA" ;
    rdfs:comment "Label for the first treatment in the comparison (matches Treatments.TreatmentLabel)." .

effortless-ntwf:treatmentB a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentB" ;
    rdfs:comment "Label for the second treatment in the comparison." .

effortless-ntwf:totalCasesA a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:integer ;
    rdfs:label "TotalCasesA" ;
    rdfs:comment "Total cases for TreatmentA across all strata in this study." .
    # calculated: aggregation

effortless-ntwf:totalSuccessesA a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:integer ;
    rdfs:label "TotalSuccessesA" ;
    rdfs:comment "Total successes for TreatmentA across all strata." .
    # calculated: aggregation

effortless-ntwf:pooledRateA a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "PooledRateA" ;
    rdfs:comment "Pooled success rate for TreatmentA: TotalSuccessesA / TotalCasesA." .
    # calculated: calculated

effortless-ntwf:totalCasesB a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:integer ;
    rdfs:label "TotalCasesB" ;
    rdfs:comment "Total cases for TreatmentB across all strata." .
    # calculated: aggregation

effortless-ntwf:totalSuccessesB a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:integer ;
    rdfs:label "TotalSuccessesB" ;
    rdfs:comment "Total successes for TreatmentB across all strata." .
    # calculated: aggregation

effortless-ntwf:pooledRateB a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "PooledRateB" ;
    rdfs:comment "Pooled success rate for TreatmentB: TotalSuccessesB / TotalCasesB." .
    # calculated: calculated

effortless-ntwf:pooledWinner a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "PooledWinner" ;
    rdfs:comment "Which treatment wins when strata are ignored: the one with the higher pooled rate." .
    # calculated: calculated

effortless-ntwf:stratumCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:integer ;
    rdfs:label "StratumCount" ;
    rdfs:comment "Number of strata in this study. Counted from StratumSummaries filtered to TreatmentA rows (one row per stratum)." .
    # calculated: aggregation

effortless-ntwf:strataWonByA a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:integer ;
    rdfs:label "StrataWonByA" ;
    rdfs:comment "Number of strata where A wins: count StratumSummaries rows whose TreatmentLabel=TreatmentA AND StratumWinner=TreatmentA. These are the one-per-stratum sentinel rows." .
    # calculated: aggregation

effortless-ntwf:strataWonByB a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:integer ;
    rdfs:label "StrataWonByB" ;
    rdfs:comment "Number of strata where B wins: count StratumSummaries rows whose TreatmentLabel=TreatmentA AND StratumWinner=TreatmentB." .
    # calculated: aggregation

effortless-ntwf:perStratumWinner a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "PerStratumWinner" ;
    rdfs:comment "The treatment that wins in every stratum — 'A' if StrataWonByA = StratumCount, 'B' if StrataWonByB = StratumCount, else 'none' (no unanimous per-stratum winner)." .
    # calculated: calculated

effortless-ntwf:isReversal a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsReversal" ;
    rdfs:comment "TRUE when the pooled winner and the per-stratum winner disagree — i.e. Simpson's Paradox is present. FALSE otherwise. This is the paradox as a derived fact, not a modeled entity." .
    # calculated: calculated

effortless-ntwf:confoundersInStudy a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:integer ;
    rdfs:label "ConfoundersInStudy" ;
    rdfs:comment "Count of StratumVariables in this study whose IsConfounder = TRUE. When > 0, the paradox has a causal explanation." .
    # calculated: aggregation

effortless-ntwf:isParadoxExplained a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsParadoxExplained" ;
    rdfs:comment "TRUE when IsReversal is present AND at least one confirmed confounder exists in the study. The model witnesses its own explanatory completeness — or its limits." .
    # calculated: calculated

effortless-ntwf:isParadoxExplained_v2 a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsParadoxExplained_v2" ;
    rdfs:comment "TRUE when IsReversal_v2 is present AND at least one confirmed confounder exists in the study. The v2 counterpart to IsParadoxExplained — captures berkeley-1973 and appleton-1996, which have confirmed confounders but do not satisfy the unanimity criterion. Together with IsParadoxExplained, this field witnesses exactly which studies the old definition left unexplained despite having a causal account." .
    # calculated: calculated

effortless-ntwf:pooledGap a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "PooledGap" ;
    rdfs:comment "Absolute difference between the two pooled rates: |PooledRateA - PooledRateB|. The size of the aggregate misleading signal." .
    # calculated: calculated

effortless-ntwf:strataWonByLoser a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:integer ;
    rdfs:label "StrataWonByLoser" ;
    rdfs:comment "Number of strata won by the pooled loser — the counter-signal. For full reversals this equals StratumCount; for partial paradoxes it is between 0 and StratumCount." .
    # calculated: calculated

effortless-ntwf:paradoxStrength a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "ParadoxStrength" ;
    rdfs:comment "Scalar severity of the paradox: PooledGap × (StrataWonByLoser / StratumCount). Zero when no strata go against the pooled winner. Positive for partial paradoxes. Maximum when every stratum contradicts the pooled result." .
    # calculated: calculated

effortless-ntwf:pooledRateFromWeightsA a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "PooledRateFromWeightsA" ;
    rdfs:comment "Pooled rate for TreatmentA reconstructed as a weighted average of stratum rates: SUM(WeightedStratumRate) across all stratum rows for TreatmentA. Must match PooledRateA — this witnesses the mechanism equation: the pooled rate IS a weighted average of stratum rates, weighted by StratumFraction." .
    # calculated: aggregation

effortless-ntwf:pooledRateFromWeightsB a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "PooledRateFromWeightsB" ;
    rdfs:comment "Pooled rate for TreatmentB reconstructed as a weighted average. Must match PooledRateB. If it does, the mechanism equation is verified: reversal is purely a consequence of differential weighting." .
    # calculated: aggregation

effortless-ntwf:reversalIntensity a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "ReversalIntensity" ;
    rdfs:comment "StrataWonByLoser / StratumCount: the fraction of strata that go against the pooled winner. Zero for no paradox, 1.0 for full reversal, between 0 and 1 for partial. This is the allocation-side measure of how deeply the confounding has penetrated the stratified view." .
    # calculated: calculated

effortless-ntwf:thresholdMargin a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "ThresholdMargin" ;
    rdfs:comment "ReversalIntensity minus 0.5: positive when more than half the strata go against the pooled winner (reversal is robust), zero at the tipping point (exactly half), negative when fewer than half oppose the pooled winner (reversal is fragile or absent). A study with ThresholdMargin > 0 is robustly paradoxical; one with ThresholdMargin < 0 has a weak or absent paradox." .
    # calculated: calculated

effortless-ntwf:signedPooledGap a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "SignedPooledGap" ;
    rdfs:comment "Signed difference between pooled rates: PooledRateA minus PooledRateB. Positive = A wins pooled; negative = B wins pooled. Unlike PooledGap (which is absolute), this preserves direction — essential for detecting sign flips between the equal-weight and actual pooled signals." .
    # calculated: calculated

effortless-ntwf:weightedStratumGapSum a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "WeightedStratumGapSum" ;
    rdfs:comment "Sum of WeightedStratumGap (= StratumGap × StratumFraction) across all StratumSummaries rows where TreatmentLabel = TreatmentA for this study. This is the equal-weight pooled gap — the gap the pooled analysis would produce if allocation were perfectly balanced across strata. When this has the opposite sign to SignedPooledGap, the allocation has not merely compressed the signal: it has flipped it entirely." .
    # calculated: aggregation

effortless-ntwf:isSignFlip a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsSignFlip" ;
    rdfs:comment "TRUE when WeightedStratumGapSum and SignedPooledGap have opposite signs — the allocation has reversed the direction of the pooled signal relative to what equal-weight strata would show. This is the continuous generalisation of IsReversal: it does not require every stratum to agree, only that the equal-weight estimate and the actual pooled estimate point in opposite directions. Berkeley 1973 satisfies IsSignFlip=TRUE despite IsReversal=FALSE." .
    # calculated: calculated

effortless-ntwf:allocationDistortion a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "AllocationDistortion" ;
    rdfs:comment "The magnitude of how far the allocation has bent the pooled signal: |WeightedStratumGapSum − SignedPooledGap|. Zero means the allocation is neutral — the pooled analysis faithfully represents the equal-weight stratum evidence. A large AllocationDistortion means the allocation is doing most of the work: the pooled number is mostly noise from how cases were assigned, not signal about which treatment is better. This measure does NOT require a sign flip to be nonzero — it captures any allocation-induced distortion, not just reversals." .
    # calculated: calculated

effortless-ntwf:distortionType a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "DistortionType" ;
    rdfs:comment "Geometric classification of this study's allocation-induced distortion. Four exhaustive types: A = full sign-flip with unanimous per-stratum reversal (IsSignFlip=TRUE AND ReversalIntensity=1.0); B = sign-flip but not unanimous (IsSignFlip=TRUE AND ReversalIntensity<1.0); C = distortion without sign flip (IsSignFlip=FALSE AND AllocationDistortion>0.01 — the allocation has compressed or inflated the pooled margin but not reversed it); D = effectively neutral (AllocationDistortion≤0.01 — pooled analysis is trustworthy with respect to this stratification). The taxonomy is derived purely from the geometric coordinates; it does not depend on causal attribution." .
    # calculated: calculated

effortless-ntwf:policyImplication a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "PolicyImplication" ;
    rdfs:comment "The researcher action implied by the geometric classification. Derived from DistortionType: type A (full reversal) → 'stratify-immediately' — the pooled conclusion is directionally wrong; do not act on it without stratifying. Type B (partial sign-flip) → 'investigate-confounder' — the equal-weight signal opposes the pooled signal, but the per-stratum picture is mixed; the causal mechanism needs examination before trusting either estimate. Type C (compression without flip) → 'check-allocation-bias' — the pooled winner is probably correct but the effect size is distorted; report adjusted or standardized margins rather than the raw pooled gap. Type D (neutral) → 'pooled-analysis-trustworthy' — allocation is not materially distorting the signal; the pooled conclusion is safe with respect to this stratification." .
    # calculated: calculated

effortless-ntwf:isReversal_v2 a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsReversal_v2" ;
    rdfs:comment "The sign-flip definition of reversal: TRUE when the equal-weight pooled signal (WeightedStratumGapSum) and the actual pooled signal (SignedPooledGap) point in opposite directions. Strictly generalizes the unanimity criterion — every Type-A study satisfies both IsReversal and IsReversal_v2, but Berkeley-1973 and Appleton-1996 satisfy IsReversal_v2 without satisfying IsReversal. The unanimity criterion (IsReversal) is now understood as the Type-A subtype of this broader definition." .
    # calculated: calculated

effortless-ntwf:definitionDelta a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:boolean ;
    rdfs:label "DefinitionDelta" ;
    rdfs:comment "TRUE when IsReversal_v2 and IsReversal disagree — i.e. when the sign-flip definition fires but the unanimity criterion does not. These are the studies the old definition misclassified as non-reversals. In the current dataset: berkeley-1973 and appleton-1996. A non-empty DefinitionDelta set is the empirical proof that the unanimity criterion is a strict subset of the sign-flip criterion." .
    # calculated: calculated

effortless-ntwf:strictReversalSubtype a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "StrictReversalSubtype" ;
    rdfs:comment "Classifies each study's relationship to the two reversal definitions. 'strict' = unanimity reversal (IsReversal=TRUE, DistortionType=A — the old definition's true positives). 'extended' = sign-flip only, not unanimous (IsReversal_v2=TRUE, IsReversal=FALSE — the studies the old definition missed). 'none' = no reversal under either definition." .
    # calculated: calculated

effortless-ntwf:correctedGap a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "CorrectedGap" ;
    rdfs:comment "The allocation-corrected treatment gap: WeightedStratumGapSum, i.e. what SignedPooledGap would be if allocation were equal across strata. Positive means A is favoured in the corrected world; negative means B is favoured." .
    # calculated: calculated

effortless-ntwf:correctedWinner a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "CorrectedWinner" ;
    rdfs:comment "Which treatment wins once allocation bias is removed. Derived from CorrectedGap: positive → TreatmentA; negative → TreatmentB; zero → tie." .
    # calculated: calculated

effortless-ntwf:correctedVsPooledAgreement a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:boolean ;
    rdfs:label "CorrectedVsPooledAgreement" ;
    rdfs:comment "TRUE when the allocation-corrected winner matches the pooled winner. FALSE when removing allocation bias would change which treatment appears to win — the machine-readable definition of a reversal recovery." .
    # calculated: calculated

effortless-ntwf:correctedPolicyImplication a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "CorrectedPolicyImplication" ;
    rdfs:comment "The allocation-aware researcher action: what to do when the corrected verdict is available. Derived from DistortionType and CorrectedWinner together, making the instrument self-consistent with Reversal Recovery (loop-27). Type A (full sign-flip, unanimous per-stratum reversal): CorrectedWinner is the true signal — 'use-corrected-winner'. The pooled analysis was directionally wrong; act on CorrectedWinner, not PooledWinner. Type B (partial sign-flip, non-unanimous): CorrectedWinner points against the pooled signal but strata disagree among themselves — 'use-corrected-winner-with-caution'. Trust the corrected direction but acknowledge residual uncertainty. Type C (compression, no sign flip): PooledWinner is directionally correct; the distortion is in the magnitude, not the direction — 'check-allocation-bias'. Same as PolicyImplication. Type D (neutral): allocation is not materially distorting the signal — 'pooled-analysis-trustworthy'. Same as PolicyImplication. For Types C and D, CorrectedPolicyImplication and PolicyImplication always agree; for Types A and B, CorrectedPolicyImplication supersedes PolicyImplication with the allocation-corrected verdict." .
    # calculated: calculated

effortless-ntwf:confirmedCausalRoleCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:integer ;
    rdfs:label "ConfirmedCausalRoleCount" ;
    rdfs:comment "Count of StratumVariables in this study whose CausalRole is \"confounder\" — includes variables that confound the outcome regardless of whether allocation was balanced." .
    # calculated: aggregation

effortless-ntwf:mediatorRiskCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:integer ;
    rdfs:label "MediatorRiskCount" ;
    rdfs:comment "Count of StratumVariables in this study whose ConditioningRisk is mediator or collider — the hazardous conditioning types." .
    # calculated: aggregation

effortless-ntwf:contestedStratumCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:integer ;
    rdfs:label "ContestedStratumCount" ;
    rdfs:comment "Count of StratumVariables in this study whose CausalRole is contested — the causal interpretation is disputed." .
    # calculated: aggregation

effortless-ntwf:unknownCausalRoleCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:integer ;
    rdfs:label "UnknownCausalRoleCount" ;
    rdfs:comment "Count of StratumVariables in this study whose CausalRole is unknown — no causal account has been established." .
    # calculated: aggregation

effortless-ntwf:causalClaimStatus a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "CausalClaimStatus" ;
    rdfs:comment "The epistemic status of the causal interpretation for this study. Values: established (all stratum variables are confirmed confounders with known mechanisms), contested (at least one stratum variable has a disputed causal role — e.g. Berkeley 1973 where department choice may be endogenous), geometric-only (no stratum variable has an established causal role — the distortion is a geometric fact, not a causal claim). Derived from StratumVariables.CausalRole and ConditioningRisk." .
    # calculated: calculated

effortless-ntwf:adjustmentAppropriate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:boolean ;
    rdfs:label "AdjustmentAppropriate" ;
    rdfs:comment "TRUE only when it is epistemically safe to act on CorrectedGap as the causal treatment effect estimate: no mediator/collider conditioning risk AND causal claim is established (not contested or geometric-only). FALSE for the birth-weight paradox (mediator), berkeley-1973 (contested), and synthetic/degenerate studies (geometric-only)." .
    # calculated: calculated

effortless-ntwf:adjustmentRationale a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:TreatmentRankings ;
    rdfs:range xsd:string ;
    rdfs:label "AdjustmentRationale" ;
    rdfs:comment "Human-authored note explaining why AdjustmentAppropriate is TRUE or FALSE for this study. Covers mediator/collider hazards, contested causal roles, and cases where geometric correction is valid but causal interpretation is uncertain." .

# === Class: Treatments ===
effortless-ntwf:Treatments a owl:Class ;
    rdfs:label "Treatments" ;
    rdfs:comment "Table: Treatments — the interventions being compared within a study. Each treatment belongs to one study." .

effortless-ntwf:treatmentId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Treatments ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentId" ;
    rdfs:comment "Unique slug (e.g. kidney-1986-A, kidney-1986-B)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:study a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:Studies ;
    rdfs:label "Study" ;
    rdfs:comment "FK to the parent Study." .

effortless-ntwf:treatmentLabel a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentLabel" ;
    rdfs:comment "Short label used in CaseCells and comparisons (e.g. A, B)." .

effortless-ntwf:description a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Description" ;
    rdfs:comment "Plain-language description of what this treatment is." .

effortless-ntwf:totalCases a owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "TotalCases" ;
    rdfs:comment "Total cases for this treatment across all strata." .
    # calculated: aggregation

effortless-ntwf:totalSuccesses a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Treatments ;
    rdfs:range xsd:integer ;
    rdfs:label "TotalSuccesses" ;
    rdfs:comment "Total successes for this treatment across all strata." .
    # calculated: aggregation

effortless-ntwf:pooledSuccessRate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Treatments ;
    rdfs:range xsd:string ;
    rdfs:label "PooledSuccessRate" ;
    rdfs:comment "Pooled (across all strata) success rate for this treatment: TotalSuccesses / TotalCases." .
    # calculated: calculated

# === Class: UIComponents ===
effortless-ntwf:UIComponents a owl:Class ;
    rdfs:label "UIComponents" ;
    rdfs:comment "Table: UIComponents — the reusable visual building blocks used across UIScreens. Each row defines one component: what it renders, which entity it reads, and what props it requires. A developer can implement the full UI by composing these components onto the screens defined in UIScreens." .

effortless-ntwf:componentId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:UIComponents ;
    rdfs:range xsd:string ;
    rdfs:label "ComponentId" ;
    rdfs:comment "Unique slug (e.g. comp-01-distortion-badge)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label, mirrors ComponentId." .
    # calculated: calculated

effortless-ntwf:componentName a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:UIComponents ;
    rdfs:range xsd:string ;
    rdfs:label "ComponentName" ;
    rdfs:comment "Code-level component name (PascalCase, e.g. DistortionBadge)." .

effortless-ntwf:usedOnScreens a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:UIComponents ;
    rdfs:range xsd:string ;
    rdfs:label "UsedOnScreens" ;
    rdfs:comment "Comma-separated ScreenIds where this component appears." .

effortless-ntwf:primaryEntity a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "PrimaryEntity" ;
    rdfs:comment "The rulebook entity this component reads (the vw_* view)." .

effortless-ntwf:description a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Description" ;
    rdfs:comment "What this component renders and what decisions a developer must make to implement it." .

effortless-ntwf:requiredFields a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:UIComponents ;
    rdfs:range xsd:string ;
    rdfs:label "RequiredFields" ;
    rdfs:comment "Comma-separated rulebook fields this component must receive as props." .

effortless-ntwf:visualSpec a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:UIComponents ;
    rdfs:range xsd:string ;
    rdfs:label "VisualSpec" ;
    rdfs:comment "Plain-English description of the visual output: shape, color coding, interactivity." .

# === Class: UIScreens ===
effortless-ntwf:UIScreens a owl:Class ;
    rdfs:label "UIScreens" ;
    rdfs:comment "Table: UIScreens — the canonical screens that comprise the Simpson's Paradox Explorer UI. Each row defines one screen: its purpose, its primary data source (which rulebook view it reads), and the user action it supports. A developer can reconstruct the full UI from this table without any prior knowledge of the application." .

effortless-ntwf:screenId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:UIScreens ;
    rdfs:range xsd:string ;
    rdfs:label "ScreenId" ;
    rdfs:comment "Unique slug (e.g. screen-01-study-list)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label, mirrors ScreenId." .
    # calculated: calculated

effortless-ntwf:title a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Title" ;
    rdfs:comment "Human-readable screen title shown in the UI." .

effortless-ntwf:route a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:UIScreens ;
    rdfs:range xsd:string ;
    rdfs:label "Route" ;
    rdfs:comment "URL path pattern (e.g. /, /study/:studyId, /compare)." .

effortless-ntwf:primaryEntity a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "PrimaryEntity" ;
    rdfs:comment "The main rulebook entity this screen reads from (the vw_* view name without prefix)." .

effortless-ntwf:purpose a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:UIScreens ;
    rdfs:range xsd:string ;
    rdfs:label "Purpose" ;
    rdfs:comment "One sentence: what a user can learn or do on this screen." .

effortless-ntwf:keyFields a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:UIScreens ;
    rdfs:range xsd:string ;
    rdfs:label "KeyFields" ;
    rdfs:comment "Comma-separated list of the most important fields displayed on this screen." .

effortless-ntwf:userAction a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:UIScreens ;
    rdfs:range xsd:string ;
    rdfs:label "UserAction" ;
    rdfs:comment "Primary user action available on this screen (e.g. select a study, drill into a stratum)." .
