    rdfs:comment "Rulebook table this item applies to." .

effortless-ntwf:fieldName a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "FieldName" ;
    rdfs:comment "Column name when RuleType=required-input." .

effortless-ntwf:requirementStatement a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:IngestionProtocol ;
