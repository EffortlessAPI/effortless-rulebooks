effortless-ntwf:phaseTypeCMinusCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:PhaseDiagramSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "PhaseTypeCMinusCount" ;
    rdfs:comment "Grid points classified as type C-. Populated from vw_synthetic_phase by 05b-customize-data.sql." .

effortless-ntwf:phaseTypeDCount a owl:DatatypeProperty ;
