@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix effortless-ntwf: <https://w3id.org/effortless-ntwf#> .

<https://w3id.org/effortless-ntwf#> a owl:Ontology ;
    rdfs:label "NTWF Ontology (Effortless rendering)" ;
    rdfs:comment "Generated by Effortless from simpsons-paradox-rulebook.json. Vocabulary: Jessica Talisman NTWF." .

# === Class: AllocationSweep ===
effortless-ntwf:AllocationSweep a owl:Class ;
    rdfs:label "AllocationSweep" ;
    rdfs:comment "Table: AllocationSweep — parametric sweep of treatment-A allocation fraction within each study's most confounded stratum (see SweepStudyConfig). Ten fractions from 0.05 to 0.95 per study. SweepCorrectedGap is invariant; SweepPooledGap wanders." .

effortless-ntwf:sweepId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:AllocationSweep ;
    rdfs:range xsd:string ;
    rdfs:label "SweepId" ;
    rdfs:comment "Unique row identifier: <study>-f<pct> where pct is AllocFractionA*100." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:studyId a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "StudyId" ;
    rdfs:comment "The study being swept — all 90+ studies in the corpus." .

effortless-ntwf:allocFractionA a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:AllocationSweep ;
    rdfs:range xsd:string ;
    rdfs:label "AllocFractionA" ;
    rdfs:comment "Fraction of the sweep-stratum cases assigned to treatment A. Ranges from 0.05 to 0.95. The sweep stratum is the one whose allocation was most confounded in the original study." .

effortless-ntwf:isOriginal a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:AllocationSweep ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsOriginal" ;
    rdfs:comment "TRUE for the row closest to the actual original study allocation." .
    # calculated: calculated

effortless-ntwf:nSweepStratumTotal a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "NSweepStratumTotal" ;
    rdfs:comment "Total cases in the sweep stratum (the stratum whose allocation is being varied). Fixed per study." .
    # calculated: calculated

effortless-ntwf:nSweepA a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:AllocationSweep ;
    rdfs:range xsd:string ;
    rdfs:label "NSweepA" ;
    rdfs:comment "Cases in the sweep stratum assigned to treatment A = ROUND(NSweepStratumTotal * AllocFractionA)." .
    # calculated: calculated

effortless-ntwf:nSweepB a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:AllocationSweep ;
    rdfs:range xsd:string ;
    rdfs:label "NSweepB" ;
    rdfs:comment "Cases in the sweep stratum assigned to treatment B = NSweepStratumTotal - NSweepA." .
    # calculated: calculated

effortless-ntwf:nFixedA a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "NFixedA" ;
    rdfs:comment "Total A-treatment cases in all NON-swept strata (held fixed across sweep rows). For kidney-1986 = 87 (small-stratum A). For berkeley-1973 = 1302 (depts B+C+D male). For compressed-synthetic = 80 (easy-stratum A). For balanced-synthetic = 100 (hard-stratum A)." .
    # calculated: calculated

effortless-ntwf:nFixedB a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "NFixedB" ;
    rdfs:comment "Total B-treatment cases in all NON-swept strata (held fixed across sweep rows). For kidney-1986 = 270 (small-stratum B). For berkeley-1973 = 993 (depts B+C+D female). For compressed-synthetic = 120 (easy-stratum B). For balanced-synthetic = 100 (hard-stratum B)." .
    # calculated: calculated

effortless-ntwf:sweepRateA a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SweepRateA" ;
    rdfs:comment "Per-cell success rate for treatment A in the sweep stratum. Fixed per study." .
    # calculated: calculated

effortless-ntwf:sweepRateB a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SweepRateB" ;
    rdfs:comment "Per-cell success rate for treatment B in the sweep stratum. Fixed per study." .
    # calculated: calculated

effortless-ntwf:fixedRateA a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "FixedRateA" ;
    rdfs:comment "Weighted success rate for treatment A across all fixed (non-swept) strata. Constant per study." .
    # calculated: calculated

effortless-ntwf:fixedRateB a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "FixedRateB" ;
    rdfs:comment "Weighted success rate for treatment B across all fixed (non-swept) strata. Constant per study." .
    # calculated: calculated

effortless-ntwf:sweepPooledRateA a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:AllocationSweep ;
    rdfs:range xsd:string ;
    rdfs:label "SweepPooledRateA" ;
    rdfs:comment "Pooled success rate for treatment A = (NSweepA * SweepRateA + NFixedA * FixedRateA) / (NSweepA + NFixedA). Changes as AllocFractionA varies." .
    # calculated: calculated

effortless-ntwf:sweepPooledRateB a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:AllocationSweep ;
    rdfs:range xsd:string ;
    rdfs:label "SweepPooledRateB" ;
    rdfs:comment "Pooled success rate for treatment B = (NSweepB * SweepRateB + NFixedB * FixedRateB) / (NSweepB + NFixedB). Changes as AllocFractionA varies." .
    # calculated: calculated

effortless-ntwf:sweepPooledGap a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:AllocationSweep ;
    rdfs:range xsd:string ;
    rdfs:label "SweepPooledGap" ;
    rdfs:comment "SweepPooledRateA minus SweepPooledRateB. Wanders as AllocFractionA varies because pooled rates mix stratum sizes unequally. Crosses zero at some allocation (the paradox reversal point)." .
    # calculated: calculated

effortless-ntwf:sweepCorrectedGap a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SweepCorrectedGap" ;
    rdfs:comment "Allocation-free signal: sum over strata of (n_s/N) * (rate_As - rate_Bs). Constant across the sweep by construction — the allocation variable does not appear. This is the conserved quantity under re-stratification." .
    # calculated: calculated

effortless-ntwf:allocationDistortionWitness a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:AllocationSweep ;
    rdfs:range xsd:string ;
    rdfs:label "AllocationDistortionWitness" ;
    rdfs:comment "SweepPooledGap minus SweepCorrectedGap. The allocation distortion: how much the pooled signal has been inflated or deflated by differential stratum allocation. Zero only when allocation is balanced." .
    # calculated: calculated

# === Class: CandidateStudyCatalog ===
effortless-ntwf:CandidateStudyCatalog a owl:Class ;
    rdfs:label "CandidateStudyCatalog" ;
    rdfs:comment "Table: CandidateStudyCatalog — curated backlog of published Simpson's-paradox-eligible studies. Tracks import status, expected distortion type, and encoding metadata before CaseCells exist." .

effortless-ntwf:candidateId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:string ;
    rdfs:label "CandidateId" ;
    rdfs:comment "Unique slug for this catalog entry." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:proposedStudyId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:string ;
    rdfs:label "ProposedStudyId" ;
    rdfs:comment "Stable slug to assign in Studies when imported." .

effortless-ntwf:title a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Title" ;
    rdfs:comment "Human-readable study title." .

effortless-ntwf:citation a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:string ;
    rdfs:label "Citation" ;
    rdfs:comment "Primary publication citation." .

effortless-ntwf:sourceUrl a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "SourceUrl" ;
    rdfs:comment "URL to source paper or data." .

effortless-ntwf:domain a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Domain" ;
    rdfs:comment "Domain tag: medicine, epidemiology, legal, sports, education, economics, social-science." .

effortless-ntwf:stratumVariableName a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:string ;
    rdfs:label "StratumVariableName" ;
    rdfs:comment "Pre-registered stratifying variable name for encoding." .

effortless-ntwf:expectedDistortionType a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:string ;
    rdfs:label "ExpectedDistortionType" ;
    rdfs:comment "Hypothesized DistortionType after classification: A, B, C+, C-, D, or unknown." .

effortless-ntwf:ingestionStatus a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:string ;
    rdfs:label "IngestionStatus" ;
    rdfs:comment "imported | candidate | blocked | rejected" .

effortless-ntwf:priority a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:integer ;
    rdfs:label "Priority" ;
    rdfs:comment "1=high priority encode next; 5=blocked/duplicate." .

effortless-ntwf:stratumCountEstimate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:integer ;
    rdfs:label "StratumCountEstimate" ;
    rdfs:comment "Expected number of strata (minimum 2)." .

effortless-ntwf:dataSourceNote a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:string ;
    rdfs:label "DataSourceNote" ;
    rdfs:comment "Where to find cell counts and encoding notes." .

effortless-ntwf:linkedStudyId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:string ;
    rdfs:label "LinkedStudyId" ;
    rdfs:comment "Studies.StudyId when IngestionStatus=imported." .

effortless-ntwf:publicationYear a owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "PublicationYear" ;
    rdfs:comment "Publication year when known." .

effortless-ntwf:isReadyToEncode a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsReadyToEncode" ;
    rdfs:comment "TRUE when candidate has citation, proposed id, and stratum variable — ready for an import session." .
    # calculated: calculated

effortless-ntwf:isImported a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsImported" ;
    rdfs:comment "TRUE when already in corpus." .
    # calculated: calculated

effortless-ntwf:observedDistortionType a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:string ;
    rdfs:label "ObservedDistortionType" ;
    rdfs:comment "Actual DistortionType from TreatmentRankings when imported." .
    # calculated: lookup

effortless-ntwf:typePredictionMatch a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:boolean ;
    rdfs:label "TypePredictionMatch" ;
    rdfs:comment "TRUE when observed type matches expected (imported rows only)." .
    # calculated: calculated

effortless-ntwf:expectedSignFlip a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:boolean ;
    rdfs:label "ExpectedSignFlip" ;
    rdfs:comment "TRUE when curator tagged ExpectedDistortionType as A or B (sign-flip expectation)." .
    # calculated: calculated

effortless-ntwf:observedSignFlipType a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:boolean ;
    rdfs:label "ObservedSignFlipType" ;
    rdfs:comment "TRUE when observed DistortionType is A or B (imported rows only)." .
    # calculated: calculated

effortless-ntwf:signFlipPredictionMatch a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:boolean ;
    rdfs:label "SignFlipPredictionMatch" ;
    rdfs:comment "TRUE when Expected A∪B and observed is A∪B — weaker flip-type prediction test." .
    # calculated: calculated

effortless-ntwf:dataAcquisitionStatus a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:string ;
    rdfs:label "DataAcquisitionStatus" ;
    rdfs:comment "not_started | downloaded | manual_only | blocked" .

effortless-ntwf:reversalMechanism a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:string ;
    rdfs:label "ReversalMechanism" ;
    rdfs:comment "Plain-language reversal mechanism from expansion plan." .

effortless-ntwf:paradoxConfirmation a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:string ;
    rdfs:label "ParadoxConfirmation" ;
    rdfs:comment "confirmed | plausible | pending | not_applicable" .

effortless-ntwf:expansionWave a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:string ;
    rdfs:label "ExpansionWave" ;
    rdfs:comment "Catalog wave tag; loop-67 expansion rows = expansion-wave-1." .

effortless-ntwf:isDataReady a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CandidateStudyCatalog ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsDataReady" ;
    rdfs:comment "TRUE when stratified data is downloaded or available from published tables." .
    # calculated: calculated

# === Class: CaseCells ===
effortless-ntwf:CaseCells a owl:Class ;
    rdfs:label "CaseCells" ;
    rdfs:comment "Table: CaseCells — the raw leaves of the DAG. One row per (study, stratum, treatment) combination recording the aggregate count of successes and total cases. Every derived fact in the model traces back to these numbers. Nothing above this row is a raw input." .

effortless-ntwf:caseCellId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CaseCells ;
    rdfs:range xsd:string ;
    rdfs:label "CaseCellId" ;
    rdfs:comment "Unique slug (e.g. kidney-1986-small-A)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:study a owl:ObjectProperty ;
    rdfs:range effortless-ntwf:Studies ;
    rdfs:label "Study" ;
    rdfs:comment "FK to the parent Study." .

effortless-ntwf:stratumLabel a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "StratumLabel" ;
    rdfs:comment "The stratum this cell belongs to (matches Strata.StratumLabel)." .

effortless-ntwf:treatmentLabel a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentLabel" ;
    rdfs:comment "The treatment applied in this cell (matches Treatments.TreatmentLabel)." .

effortless-ntwf:successes a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CaseCells ;
    rdfs:range xsd:integer ;
    rdfs:label "Successes" ;
    rdfs:comment "Number of patients in this cell who had a successful outcome. RAW INPUT — never derived." .

effortless-ntwf:cases a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CaseCells ;
    rdfs:range xsd:integer ;
    rdfs:label "Cases" ;
    rdfs:comment "Total number of patients in this cell. RAW INPUT — never derived." .

effortless-ntwf:cellSuccessRate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CaseCells ;
    rdfs:range xsd:string ;
    rdfs:label "CellSuccessRate" ;
    rdfs:comment "Success rate within this cell: Successes / Cases. The first derived fact in the DAG." .
    # calculated: calculated

effortless-ntwf:totalCasesForTreatment a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CaseCells ;
    rdfs:range xsd:integer ;
    rdfs:label "TotalCasesForTreatment" ;
    rdfs:comment "Total cases across ALL strata for this treatment in this study — the denominator for TreatmentExposureFraction." .
    # calculated: aggregation

effortless-ntwf:treatmentExposureFraction a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CaseCells ;
    rdfs:range xsd:string ;
    rdfs:label "TreatmentExposureFraction" ;
    rdfs:comment "Fraction of this treatment's total cases that fall in this stratum: Cases / TotalCasesForTreatment. High imbalance across strata is the mechanism of confounding — when treatments are allocated very differently across strata, the pooled rate conflates treatment effect with stratum difficulty." .
    # calculated: calculated

effortless-ntwf:isValidIngestionCell a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CaseCells ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsValidIngestionCell" ;
    rdfs:comment "TRUE when Cases>0, Successes>=0, and Successes<=Cases." .
    # calculated: calculated

# === Class: Conclusions ===
effortless-ntwf:Conclusions a owl:Class ;
    rdfs:label "Conclusions" ;
    rdfs:comment "Table: Conclusions — the substantive epistemic findings that this model has produced or is designed to produce. Each row is one conclusion: a claim about the domain, about the instrument, or about the methodology that is either already witnessed or is the target of a planned loop." .

effortless-ntwf:conclusionId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "ConclusionId" ;
    rdfs:comment "Unique slug (e.g. conc-01-paradox-is-derived)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label, mirrors ConclusionId." .
    # calculated: calculated

effortless-ntwf:category a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "Category" ;
    rdfs:comment "domain | instrument | methodology | open-question" .

effortless-ntwf:status a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Status" ;
    rdfs:comment "witnessed | planned | open" .

effortless-ntwf:title a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Title" ;
    rdfs:comment "One-line statement of the conclusion." .

effortless-ntwf:evidence a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Evidence" ;
    rdfs:comment "The specific DB query result, loop outcome, or argument that establishes or will establish this conclusion." .

effortless-ntwf:witnessedInLoop a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "WitnessedInLoop" ;
    rdfs:comment "LoopId where this conclusion was first witnessed (if status=witnessed)." .

effortless-ntwf:targetLoop a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "TargetLoop" ;
    rdfs:comment "LoopId that is designed to witness this conclusion (if status=planned)." .

effortless-ntwf:traditionId a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TraditionId" ;
    rdfs:comment "FK → ResearchTraditions.TraditionId. The tradition whose theoretical framework this conclusion primarily vindicates, refines, or challenges." .

effortless-ntwf:researcherId a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "ResearcherId" ;
    rdfs:comment "FK → Researchers.ResearcherId. The researcher whose specific claim, definition, or framework this conclusion directly affirms." .

effortless-ntwf:challengesResearcher a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "ChallengesResearcher" ;
    rdfs:comment "FK → Researchers.ResearcherId. A researcher whose position this conclusion refutes or qualifies (e.g. conc-03 refutes Blyth's unanimity criterion as the primary definition)." .

effortless-ntwf:traditionName a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TraditionName" ;
    rdfs:comment "Lookup: ResearchTraditions.Name via TraditionId." .
    # calculated: lookup

effortless-ntwf:traditionKeyClaimSummary a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TraditionKeyClaimSummary" ;
    rdfs:comment "Lookup: ResearchTraditions.KeyClaim via TraditionId — shows which tradition's central claim this conclusion validates or refines." .
    # calculated: lookup

effortless-ntwf:researcherName a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "ResearcherName" ;
    rdfs:comment "Lookup: Researchers.Name via ResearcherId." .
    # calculated: lookup

effortless-ntwf:researcherAffiliation a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "ResearcherAffiliation" ;
    rdfs:comment "Lookup: Researchers.Affiliation via ResearcherId." .
    # calculated: lookup

effortless-ntwf:challengesResearcherName a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "ChallengesResearcherName" ;
    rdfs:comment "Lookup: Researchers.Name via ChallengesResearcher." .
    # calculated: lookup

effortless-ntwf:witnessedInLoopTitle a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "WitnessedInLoopTitle" ;
    rdfs:comment "Lookup: Loops.Title via WitnessedInLoop." .
    # calculated: lookup

effortless-ntwf:witnessedInLoopCommitHash a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "WitnessedInLoopCommitHash" ;
    rdfs:comment "Lookup: Loops.CommitHash via WitnessedInLoop — git checkout this SHA to replay the instrument state when this conclusion was first witnessed." .
    # calculated: lookup

effortless-ntwf:witnessedInLoopCommitShort a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "WitnessedInLoopCommitShort" ;
    rdfs:comment "Lookup: Loops.CommitShort via WitnessedInLoop." .
    # calculated: lookup

effortless-ntwf:witnessedInLoopCommitDate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "WitnessedInLoopCommitDate" ;
    rdfs:comment "Lookup: Loops.CommitDate via WitnessedInLoop." .
    # calculated: lookup

effortless-ntwf:witnessedInLoopGitTag a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:string ;
    rdfs:label "WitnessedInLoopGitTag" ;
    rdfs:comment "Lookup: Loops.GitTag via WitnessedInLoop — preferred replay entry point when a milestone tag exists." .
    # calculated: lookup

effortless-ntwf:invariantProtectingCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Conclusions ;
    rdfs:range xsd:integer ;
    rdfs:label "InvariantProtectingCount" ;
    rdfs:comment "Count of InvariantChecks whose ProtectsConclusion FK points to this conclusion — how many algebraic invariants stand behind this finding." .
    # calculated: aggregation

# === Class: CorpusCatalogSummary ===
effortless-ntwf:CorpusCatalogSummary a owl:Class ;
    rdfs:label "CorpusCatalogSummary" ;
    rdfs:comment "Table: CorpusCatalogSummary — one row witnessing import-backlog readiness for bulk encoding sessions." .

effortless-ntwf:catalogSummaryId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CorpusCatalogSummary ;
    rdfs:range xsd:string ;
    rdfs:label "CatalogSummaryId" ;
    rdfs:comment "Unique identifier." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:totalCatalogEntries a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CorpusCatalogSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "TotalCatalogEntries" ;
    rdfs:comment "All catalog rows." .
    # calculated: aggregation

effortless-ntwf:importedCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CorpusCatalogSummary ;
    rdfs:range xsd:integer ;
    rdfs:label "ImportedCount" ;
    rdfs:comment "Rows already imported." .
    # calculated: aggregation

effortless-ntwf:candidateCount a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:CorpusCatalogSummary ;
