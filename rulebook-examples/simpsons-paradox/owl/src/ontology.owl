    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:hypothesisId a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "HypothesisId" ;
    rdfs:comment "FK → DiscoveryHypotheses.HypothesisId." .

effortless-ntwf:hypothesisStatement a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:DiscoveryFindings ;
    rdfs:range xsd:string ;
    rdfs:label "HypothesisStatement" ;
    rdfs:comment "Lookup: DiscoveryHypotheses.Statement." .
    # calculated: lookup

effortless-ntwf:observedMetric a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:DiscoveryFindings ;
    rdfs:range xsd:string ;
    rdfs:label "ObservedMetric" ;
    rdfs:comment "Witnessed metric value from ModelSummary for this hypothesis." .
    # calculated: calculated

effortless-ntwf:isConfirmed a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:DiscoveryFindings ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsConfirmed" ;
    rdfs:comment "TRUE when the witnessed metric satisfies the pre-registered ExpectedOutcome." .
    # calculated: calculated

effortless-ntwf:evidence a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Evidence" ;
    rdfs:comment "Pass/fail witness string for UI and conclusions." .
    # calculated: calculated

effortless-ntwf:witnessedInLoop a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "WitnessedInLoop" ;
    rdfs:comment "LoopId where this finding was witnessed." .

# === Class: DiscoveryHypotheses ===
effortless-ntwf:DiscoveryHypotheses a owl:Class ;
    rdfs:label "DiscoveryHypotheses" ;
    rdfs:comment "Table: DiscoveryHypotheses — pre-registered empirical claims tested against the corpus at loop-61. Each row states an expected pattern before querying the DAG." .

effortless-ntwf:hypothesisId a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "HypothesisId" ;
    rdfs:comment "Unique slug (e.g. H-latent-d)." .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Display label." .
    # calculated: calculated

effortless-ntwf:statement a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Statement" ;
    rdfs:comment "Natural-language claim under test." .

effortless-ntwf:expectedOutcome a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:DiscoveryHypotheses ;
    rdfs:range xsd:string ;
    rdfs:label "ExpectedOutcome" ;
    rdfs:comment "Pass criterion in plain language." .

effortless-ntwf:registeredInLoop a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:DiscoveryHypotheses ;
    rdfs:range xsd:string ;
    rdfs:label "RegisteredInLoop" ;
    rdfs:comment "LoopId where this hypothesis was registered." .

effortless-ntwf:traditionId a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "TraditionId" ;
    rdfs:comment "FK → ResearchTraditions.TraditionId." .

effortless-ntwf:epistemicTier a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:DiscoveryHypotheses ;
    rdfs:range xsd:string ;
    rdfs:label "EpistemicTier" ;
    rdfs:comment "consistency-check (definition-linked regression) | corpus-hypothesis (contingent corpus pattern) | corpus-pattern-superseded (witnessed FAIL at scale — retire in loop-80 prune)" .

