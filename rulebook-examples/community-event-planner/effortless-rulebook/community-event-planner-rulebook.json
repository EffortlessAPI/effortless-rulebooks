      },
      {
        "name": "EventRef",
        "datatype": "string",
        "type": "relationship",
        "nullable": false,
        "Description": "Related event",
        "RelatedTo": "Events"
      },
      {
        "name": "EventName",
        "datatype": "string",
        "type": "lookup",
        "nullable": false,
        "Description": "Looked up event name",
        "formula": "={{EventRef}}"
      },
      {
        "name": "SpeakerRef",
        "datatype": "string",
        "type": "relationship",
        "nullable": false,
        "Description": "Related speaker",
        "RelatedTo": "Speakers"
      },
      {
        "name": "SpeakerName",
        "datatype": "string",
        "type": "lookup",
        "nullable": false,
        "Description": "Looked up speaker name",
        "formula": "={{SpeakerRef}}"
      },
      {
        "name": "EventDate",
        "datatype": "datetime",
        "type": "lookup",
        "nullable": false,
        "Description": "Looked up event date",
        "formula": "=INDEX(Events!{{EventDate}}, MATCH({{EventRef}}, Events!{{EventId}}, 0))"
      },
      {
        "name": "SpeakerAvailStart",
        "datatype": "datetime",
        "type": "lookup",
        "nullable": true,
        "Description": "Looked up speaker availability start",
        "formula": "=INDEX(Speakers!{{AvailabilityStart}}, MATCH({{SpeakerRef}}, Speakers!{{SpeakerId}}, 0))"
      },
      {
        "name": "SpeakerAvailEnd",
        "datatype": "datetime",
        "type": "lookup",
        "nullable": true,
        "Description": "Looked up speaker availability end",
        "formula": "=INDEX(Speakers!{{AvailabilityEnd}}, MATCH({{SpeakerRef}}, Speakers!{{SpeakerId}}, 0))"
      },
      {
        "name": "IsAvailable",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": false,
        "Description": "Is speaker available for this event?",
        "formula": "=AND({{EventDate}} >= {{SpeakerAvailStart}}, {{EventDate}} <= {{SpeakerAvailEnd}})"
      }
    ],
    "data": [
