{
  "$schema": "https://example.com/cmcc-schema/v1",
  "Name": "Community Event Planner",
  "Description": "Venues, events, speakers, attendees with capacity, scheduling, and attendance-forecast cascades.",
  "Venues": {
    "Description": "Table: Venues",
    "schema": [
      {
        "name": "VenueId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Unique venue identifier (slug)"
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": false,
        "Description": "Display name for the venue",
        "formula": "={{VenueId}}"
      },
      {
        "name": "Location",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Physical location/address"
      },
      {
        "name": "Capacity",
        "datatype": "integer",
        "type": "raw",
        "nullable": false,
        "Description": "Total seating capacity"
      }
    ],
    "data": [
      {
        "VenueId": "main-hall",
        "Location": "Downtown Community Center",
        "Capacity": 150
      },
      {
        "VenueId": "conference-room",
        "Location": "Tech Hub Building",
        "Capacity": 50
      },
      {
        "VenueId": "outdoor-amphitheater",
        "Location": "Central Park",
        "Capacity": 300
      }
    ]
  },
  "Speakers": {
    "Description": "Table: Speakers",
    "important": true,
    "summary_rich": "The **cast** — anyone who can be pinned to an event. Each speaker has an availability window and a running `AssignmentCount` rolled up from the `Assignments` table; once that count clears three, `IsOverbooked` flips and the corkboard surfaces the workload alert. The window is also what powers `Assignments.IsAvailable` — a speaker assigned outside their hours fails the check the moment the row is written.",
    "important_fields": ["Name", "AssignmentCount", "IsOverbooked", "AvailabilityStart"],
    "schema": [
      {
        "name": "SpeakerId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Unique speaker identifier (email)"
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": false,
        "Description": "Display name for the speaker",
        "formula": "={{SpeakerId}}"
      },
      {
        "name": "AvailabilityStart",
        "datatype": "datetime",
        "type": "raw",
        "nullable": true,
        "Description": "Start of speaker availability window"
      },
      {
        "name": "AvailabilityEnd",
        "datatype": "datetime",
        "type": "raw",
        "nullable": true,
        "Description": "End of speaker availability window"
      },
      {
        "name": "AssignmentCount",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": false,
        "Description": "Total number of event assignments for this speaker",
        "formula": "=COUNTIFS(Assignments!{{SpeakerRef}}, {{SpeakerId}})"
      },
      {
        "name": "IsOverbooked",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": false,
        "Description": "Is speaker assigned to more than 3 events (workload alert)?",
        "formula": "={{AssignmentCount}} > 3",
        "important": true,
        "explanation_rich": "**The workload alarm.** `IsOverbooked` watches the rollup `AssignmentCount` and trips the moment a speaker passes three engagements. Worked example: `overbooked@speakers.local` is assigned to `tech-talk-1`, `workshop-1`, `panel-1`, and `meetup-1` — `AssignmentCount = 4`, so this evaluates to `TRUE` and the corkboard surfaces the alert. Drop one of those assignments and the same field flips back to `FALSE` on the next read, in every substrate, without any application code firing."
      }
    ],
    "data": [
      {
        "SpeakerId": "alice@speakers.local",
        "AvailabilityStart": "2026-05-24 14:00:00",
        "AvailabilityEnd": "2026-05-24 21:00:00"
      },
      {
        "SpeakerId": "bob@speakers.local",
        "AvailabilityStart": "2026-05-25 09:00:00",
        "AvailabilityEnd": "2026-05-25 18:00:00"
      },
      {
        "SpeakerId": "carol@speakers.local",
        "AvailabilityStart": "2026-05-23 15:00:00",
        "AvailabilityEnd": "2026-05-23 20:00:00"
      },
      {
        "SpeakerId": "dave@speakers.local",
        "AvailabilityStart": "2026-05-25 14:00:00",
        "AvailabilityEnd": "2026-05-25 18:00:00"
      },
      {
        "SpeakerId": "overbooked@speakers.local",
        "AvailabilityStart": "2026-05-23 09:00:00",
        "AvailabilityEnd": "2026-05-25 21:00:00"
      }
    ]
  },
  "Events": {
    "Description": "Table: Events",
    "important": true,
    "summary_rich": "The **board** — every pin is an event. Each row pulls capacity from its `Venue`, counts confirmed `RSVPs` against it, counts assigned `Speakers`, checks the same venue for time clashes, and rolls all of it into a single `EventStatus` of `ready` or `issues`. Move a pin (change `Venue`, change `EventDate`, add or remove an `Assignment`) and the status recomputes everywhere the rulebook runs.",
    "important_fields": ["Name", "VenueName", "EventStatus", "BookedCapacity"],
    "schema": [
      {
        "name": "EventId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Unique event identifier"
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": false,
        "Description": "Display name for the event",
        "formula": "={{EventId}}"
      },
      {
        "name": "Venue",
        "datatype": "string",
        "type": "relationship",
        "nullable": false,
        "Description": "Related venue",
        "RelatedTo": "Venues"
      },
      {
        "name": "VenueName",
        "datatype": "string",
        "type": "lookup",
        "nullable": false,
        "Description": "Looked up venue name",
        "formula": "={{Venue}}"
      },
      {
        "name": "VenueCapacity",
        "datatype": "integer",
        "type": "lookup",
        "nullable": false,
        "Description": "Looked up venue capacity",
        "formula": "=INDEX(Venues!{{Capacity}}, MATCH({{Venue}}, Venues!{{VenueId}}, 0))"
      },
      {
        "name": "EventDate",
        "datatype": "datetime",
        "type": "raw",
        "nullable": false,
        "Description": "Event date and start time"
      },
      {
        "name": "DurationMinutes",
        "datatype": "integer",
        "type": "raw",
        "nullable": false,
        "Description": "Event duration in minutes"
      },
      {
        "name": "Category",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Event category or track (e.g. Tech, Community, Learning)"
      },
      {
        "name": "EventEnd",
        "datatype": "datetime",
        "type": "calculated",
        "nullable": false,
        "Description": "Calculated end time",
        "formula": "={{EventDate}}"
      },
      {
        "name": "TotalSpeakersAssigned",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": false,
        "Description": "Count of speakers assigned to this event",
        "formula": "=COUNTIFS(Assignments!{{EventRef}}, {{EventId}})"
      },
      {
        "name": "HasSpeakers",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": false,
        "Description": "Is at least one speaker assigned?",
        "formula": "={{TotalSpeakersAssigned}} > 0"
      },
      {
        "name": "BookedCapacity",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": false,
        "Description": "Total attendees booked for this event",
        "formula": "=COUNTIFS(RSVPs!{{EventRef}}, {{EventId}}, RSVPs!{{Status}}, \"confirmed\")"
      },
      {
        "name": "AvailableCapacity",
        "datatype": "integer",
        "type": "calculated",
        "nullable": false,
        "Description": "Remaining capacity after bookings",
        "formula": "={{VenueCapacity}} - {{BookedCapacity}}",
        "important": true,
        "explanation_rich": "**The capacity cascade in one cell.** `VenueCapacity` is looked up from the `Venues` row referenced by `Venue`; `BookedCapacity` is a COUNTIFS rollup over the `RSVPs` table filtered to `Status = \"confirmed\"`. Worked example: `tech-talk-1` is pinned to `main-hall` (capacity 150) and has two confirmed RSVPs (`rsvp-1`, `rsvp-2`), so this resolves to `150 - 2 = 148`. Add a confirmed RSVP and it drops to 147 on the next read in every substrate. Drive it to zero and `AtCapacity` flips, dragging `EventStatus` down to `issues`."
      },
      {
        "name": "AtCapacity",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": false,
        "Description": "Is event at or over capacity?",
        "formula": "={{AvailableCapacity}} <= 0"
      },
      {
        "name": "VenueConflictCount",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": false,
        "Description": "Count of other events at same venue within 30 min window",
        "formula": "=COUNTIFS(Events!{{Venue}}, {{Venue}})"
      },
      {
        "name": "HasVenueConflict",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": false,
        "Description": "Are there venue scheduling conflicts?",
        "formula": "={{VenueConflictCount}} > 1"
      },
      {
        "name": "EventStatus",
        "datatype": "string",
        "type": "calculated",
        "nullable": false,
        "Description": "Event readiness status",
        "formula": "=IF(AND({{HasSpeakers}}, NOT({{AtCapacity}}), NOT({{HasVenueConflict}})), \"ready\", \"issues\")",
        "important": true,
        "explanation_rich": "**The single field every event is judged by.** An event is `ready` only if it has at least one assigned speaker, has not hit capacity, and shares its venue with no other event in the rulebook. Worked example: `tech-talk-1` has three speakers (`HasSpeakers = TRUE`), 148 seats left (`AtCapacity = FALSE`) — but `main-hall` is also booked for `meetup-1`, so `VenueConflictCount = 2` and `HasVenueConflict = TRUE`. The AND fails and `EventStatus` resolves to `\"issues\"`. Move `meetup-1` to a different venue and the same row recomputes to `\"ready\"` on the next read, in every substrate."
      },
      {
        "name": "RegistrationCloseDaysBeforeEvent",
        "datatype": "integer",
        "type": "raw",
        "nullable": false,
        "Description": "Number of days before the event that registration closes"
      },
      {
        "name": "RegistrationDeadline",
        "datatype": "datetime",
        "type": "calculated",
        "nullable": false,
        "Description": "Calculated registration deadline (EventDate minus RegistrationCloseDaysBeforeEvent)",
        "formula": "={{EventDate}} - {{RegistrationCloseDaysBeforeEvent}}"
      },
      {
        "name": "IsRegistrationOpen",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": false,
        "Description": "Is registration still open (before deadline)?",
        "formula": "={{RegistrationDeadline}} > NOW()"
      },
      {
        "name": "CapacityHeadroom",
        "datatype": "integer",
        "type": "calculated",
        "nullable": false,
        "Description": "Available capacity minus booked attendees",
        "formula": "={{AvailableCapacity}} - {{BookedCapacity}}"
      },
      {
        "name": "HasHeadroomForOverbooking",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": false,
        "Description": "Is there enough headroom to safely overbook by 20%?",
        "formula": "={{CapacityHeadroom}} >= ({{BookedCapacity}} * 0.2)"
      },
      {
        "name": "RecommendedOverbookingFactor",
        "datatype": "number",
        "type": "calculated",
        "nullable": false,
        "Description": "Safe overbooking multiplier (if headroom allows)",
        "formula": "=IF({{HasHeadroomForOverbooking}}, 1.2, 1.0)"
      }
    ],
    "data": [
      {
        "EventId": "tech-talk-1",
        "Venue": "main-hall",
        "EventDate": "2026-05-24 14:00:00",
        "DurationMinutes": 60,
        "RegistrationCloseDaysBeforeEvent": 0,
        "Category": "Tech"
      },
      {
        "EventId": "workshop-1",
        "Venue": "conference-room",
        "EventDate": "2026-05-25 10:00:00",
        "DurationMinutes": 120,
        "RegistrationCloseDaysBeforeEvent": 1,
        "Category": "Learning"
      },
      {
        "EventId": "panel-1",
        "Venue": "outdoor-amphitheater",
        "EventDate": "2026-05-25 15:00:00",
        "DurationMinutes": 90,
        "RegistrationCloseDaysBeforeEvent": 1,
        "Category": "Community"
      },
      {
        "EventId": "meetup-1",
        "Venue": "main-hall",
        "EventDate": "2026-05-23 18:00:00",
        "DurationMinutes": 120,
        "RegistrationCloseDaysBeforeEvent": 1,
        "Category": "Community"
      }
    ]
  },
  "Assignments": {
    "Description": "Table: Assignments (many-to-many: Events to Speakers)",
    "schema": [
