  "Customers": {
    "Description": "Table: Customers",
    "schema": [
      {
        "name": "CustomerId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "formula": "=SUBSTITUTE(LOWER({{FullName}}), \u0022 \u0022, \u0022-\u0022)"
      },
      {
        "name": "FirstName",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "LastName",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "FullName",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "formula": "={{FirstName}} \u0026 \u0022 \u0022 \u0026 {{LastName}}"
      },
      {
        "name": "Notes",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "StatusDisplayName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Statuses!{{DisplayName}}, MATCH(Customers!{{Status}}, Statuses!{{StatuseId}}, 0))"
      },
      {
        "name": "StatusIsBlocking",
        "datatype": "boolean",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Statuses!{{IsBlocking}}, MATCH(Customers!{{Status}}, Statuses!{{StatuseId}}, 0))"
      },
      {
        "name": "IsStopped",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "formula": "=IF(AND({{StatusIsBlocking}}, {{FirstName}} = \u0022Bob\u0022), TRUE(), FALSE())"
      },
      {
        "name": "StatusDescription",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Statuses!{{Description}}, MATCH(Customers!{{Status}}, Statuses!{{StatuseId}}, 0))"
      },
      {
        "name": "Status",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "RelatedTo": "Statuses",
        "isReversed": false,
        "prefersSingleRecordLink": true,
        "InverseField": "Customers"
      },
      {
        "name": "OwnerEmail",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Email address of the user who owns this customer record. Used by Row-Level Security to scope visibility to the JWT email of the requester."
      }
    ],
