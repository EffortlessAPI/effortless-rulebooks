  "Shifts": {
    "Description": "Table: Shifts — a time block within an event needing N people with a required skill.",
    "schema": [
      {
        "name": "ShiftId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Short label (e.g. \"Setup Morning\")."
      },
      {
        "name": "Event",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "RelatedTo": "Events",
        "isReversed": false,
        "prefersSingleRecordLink": true,
        "Description": "Parent event."
      },
      {
        "name": "EventName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Events!{{Name}}, MATCH(Shifts!{{Event}}, Events!{{EventId}}, 0))"
      },
      {
        "name": "RequiredSkill",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Free-text skill tag (e.g. \"setup\", \"intake\", \"food-handler\")."
      },
      {
        "name": "DurationHours",
        "datatype": "number",
        "type": "raw",
        "nullable": true,
        "Description": "Length of the shift in hours; drives per-volunteer load."
      },
      {
        "name": "NeededCount",
        "datatype": "integer",
        "type": "raw",
        "nullable": true,
        "Description": "How many volunteers the coordinator wants on this shift."
      },
      {
        "name": "FilledCount",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Number of volunteers currently assigned.",
        "formula": "=COUNTIFS(Assignments!{{Shift}}, Shifts!{{ShiftId}})"
      },
      {
        "name": "CoverageStatus",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "understaffed | covered | overstaffed.",
        "formula": "=IF({{FilledCount}}<{{NeededCount}}, \"understaffed\", IF({{FilledCount}}>{{NeededCount}}, \"overstaffed\", \"covered\"))"
      }
    ],
