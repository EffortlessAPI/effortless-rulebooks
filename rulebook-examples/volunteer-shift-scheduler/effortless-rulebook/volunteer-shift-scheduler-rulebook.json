  "Assignments": {
    "Description": "Table: Assignments — a volunteer slotted into a shift. Join table between Volunteers and Shifts (ERB does not allow direct many-to-many).",
    "schema": [
      {
        "name": "AssignmentId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Display label (VolunteerName @ ShiftName).",
        "formula": "={{VolunteerName}} & \" @ \" & {{ShiftName}}"
      },
      {
        "name": "Volunteer",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "RelatedTo": "Volunteers",
        "isReversed": false,
        "prefersSingleRecordLink": true
      },
      {
        "name": "Shift",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "RelatedTo": "Shifts",
        "isReversed": false,
        "prefersSingleRecordLink": true
      },
      {
        "name": "VolunteerName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Volunteers!{{Name}}, MATCH(Assignments!{{Volunteer}}, Volunteers!{{VolunteerId}}, 0))"
      },
      {
        "name": "ShiftName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Shifts!{{Name}}, MATCH(Assignments!{{Shift}}, Shifts!{{ShiftId}}, 0))"
      },
      {
        "name": "ShiftDurationHours",
        "datatype": "number",
        "type": "lookup",
        "nullable": true,
        "Description": "Pulled through to support per-volunteer AssignedHours aggregation.",
        "formula": "=INDEX(Shifts!{{DurationHours}}, MATCH(Assignments!{{Shift}}, Shifts!{{ShiftId}}, 0))"
      }
    ],
