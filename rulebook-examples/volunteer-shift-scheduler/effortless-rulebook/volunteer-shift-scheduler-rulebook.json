{
  "$schema": "https://example.com/cmcc-schema/v1",
  "Name": "Volunteer Shift Scheduler",
  "Description": "Coordinate volunteers across event shifts. The live cascade: coordinator edits raw inputs (needed count, shift hours, required skill, volunteer reliability, assignments) → per-shift coverage status, per-volunteer load (under/ok/over), and an event-level A-F staffing grade all fall out automatically.",
  "Events": {
    "Description": "Table: Events — top-level container (a festival, food bank shift, conference, etc.).",
    "schema": [
      {
        "name": "EventId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Display name of the event."
      },
      {
        "name": "EventDate",
        "datatype": "datetime",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "ShiftCount",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Total shifts attached to this event.",
        "formula": "=COUNTIFS(Shifts!{{Event}}, Events!{{EventId}})"
      },
      {
        "name": "TotalSlotsNeeded",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Sum of needed-count across all shifts in this event.",
        "formula": "=SUMIFS(Shifts!{{NeededCount}}, Shifts!{{Event}}, Events!{{EventId}})"
      },
      {
        "name": "TotalSlotsFilled",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Sum of filled-count across all shifts in this event.",
        "formula": "=SUMIFS(Shifts!{{FilledCount}}, Shifts!{{Event}}, Events!{{EventId}})"
      },
      {
        "name": "CoveragePercent",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "Description": "TotalSlotsFilled / TotalSlotsNeeded (0..1).",
        "formula": "=IF({{TotalSlotsNeeded}}>0, {{TotalSlotsFilled}}/{{TotalSlotsNeeded}}, 0)"
      },
      {
        "name": "StaffingGrade",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "A-F letter grade from CoveragePercent. A: >=95%, B: >=85%, C: >=70%, D: >=50%, F: below.",
        "formula": "=IF({{CoveragePercent}}>=0.95, \"A\", IF({{CoveragePercent}}>=0.85, \"B\", IF({{CoveragePercent}}>=0.70, \"C\", IF({{CoveragePercent}}>=0.50, \"D\", \"F\"))))"
      }
    ],
    "data": [
      {
        "EventId": "harvest-festival-2026",
        "Name": "Harvest Festival",
        "EventDate": "2026-10-12T09:00:00Z",
        "ShiftCount": 4,
        "TotalSlotsNeeded": 14,
        "TotalSlotsFilled": 12,
        "CoveragePercent": 0.857,
        "StaffingGrade": "B"
      },
      {
        "EventId": "food-bank-saturday",
        "Name": "Food Bank Saturday",
        "EventDate": "2026-11-07T08:00:00Z",
        "ShiftCount": 2,
        "TotalSlotsNeeded": 6,
        "TotalSlotsFilled": 6,
        "CoveragePercent": 1.0,
        "StaffingGrade": "A"
      }
    ]
  },
  "Volunteers": {
    "Description": "Table: Volunteers — people available to be slotted into shifts.",
    "schema": [
      {
        "name": "VolunteerId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Display name.",
        "formula": "={{FirstName}} & \" \" & {{LastName}}"
      },
      {
        "name": "FirstName",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "LastName",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "EmailAddress",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Used as the click-to-login identity."
      },
      {
        "name": "ReliabilityScore",
        "datatype": "number",
        "type": "raw",
        "nullable": true,
        "Description": "0..1 — coordinator's confidence the volunteer will show up. Drives per-shift coverage weighting."
      },
      {
        "name": "MaxHours",
        "datatype": "number",
        "type": "raw",
        "nullable": true,
        "Description": "Volunteer's stated maximum hours for this scheduling period."
      },
      {
        "name": "AssignmentCount",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Number of shifts this volunteer is assigned to.",
        "formula": "=COUNTIFS(Assignments!{{Volunteer}}, Volunteers!{{VolunteerId}})"
      },
      {
        "name": "AssignedHours",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "Description": "Sum of DurationHours across this volunteer's assigned shifts.",
        "formula": "=SUMIFS(Assignments!{{ShiftDurationHours}}, Assignments!{{Volunteer}}, Volunteers!{{VolunteerId}})"
      },
      {
        "name": "LoadStatus",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "under | ok | over. Under: <50% of MaxHours. Over: >100%. Otherwise ok.",
        "formula": "=IF({{MaxHours}}>0, IF({{AssignedHours}}>{{MaxHours}}, \"over\", IF({{AssignedHours}}<({{MaxHours}}*0.5), \"under\", \"ok\")), \"under\")"
      }
    ],
