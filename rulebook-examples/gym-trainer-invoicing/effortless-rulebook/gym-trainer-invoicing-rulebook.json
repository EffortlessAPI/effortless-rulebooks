  "Clients": {
    "Description": "Trainer's clients.",
    "important": true,
    "summary_rich": "The **roster**. Each client is paired to exactly one trainer, which fixes the per-session rate. Aggregations roll up sessions into invoice totals and invoices into an outstanding balance — so `Status` (Paid Up / Has Balance / Overdue) is never stored, it's *derived* on every read.",
    "important_fields": ["FullName", "TrainerName", "OutstandingBalance", "Status"],
    "schema": [
      {
        "name": "ClientId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "Email",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "FullName",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "Trainer",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "RelatedTo": "Trainers"
      },
      {
        "name": "TrainerName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Trainers!{{FullName}}, MATCH(Clients!{{Trainer}}, Trainers!{{TrainerId}}, 0))"
      },
      {
        "name": "TrainerEmail",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Trainers!{{Email}}, MATCH(Clients!{{Trainer}}, Trainers!{{TrainerId}}, 0))"
      },
      {
        "name": "TrainerHourlyRate",
        "datatype": "number",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Trainers!{{HourlyRate}}, MATCH(Clients!{{Trainer}}, Trainers!{{TrainerId}}, 0))"
      },
      {
        "name": "SessionCount",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "formula": "=COUNTIFS(Sessions!{{Client}}, Clients!{{ClientId}})"
      },
      {
        "name": "TotalInvoiced",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "formula": "=SUMIFS(Invoices!{{Total}}, Invoices!{{Client}}, Clients!{{ClientId}})"
      },
      {
        "name": "OutstandingBalance",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "formula": "=SUMIFS(Invoices!{{Balance}}, Invoices!{{Client}}, Clients!{{ClientId}})",
        "important": true,
        "explanation_rich": "**What this client still owes.** Sums `Balance` across every invoice tied to this client — and `Balance` is itself a calculated chain (`Subtotal` from session rollups, plus tax and late fee, minus discount and payments). Worked example: **Sam Patel** has two open invoices — `INV-001` (three sessions on the default $80/hr = $280, +8% tax = $302.40) and `INV-002` (one $80 session + one $100 override × 2hr = $280, +8% tax, −$20 discount = $282.40). Nothing paid yet, so `OutstandingBalance` = **$584.80**. Pay $300 on `INV-002` and the same field drops to $284.80 on the next read, in every substrate."
      },
      {
        "name": "OverdueCount",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "formula": "=COUNTIFS(Invoices!{{Client}}, Clients!{{ClientId}}, Invoices!{{IsOverdue}}, TRUE())"
      },
      {
        "name": "Status",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "formula": "=IF({{OverdueCount}}>0, \"Overdue\", IF({{OutstandingBalance}}>0, \"Has Balance\", \"Paid Up\"))"
      }
    ],
    "data": [
