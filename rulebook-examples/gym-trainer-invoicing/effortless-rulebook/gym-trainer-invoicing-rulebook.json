        "TaxRate": 0.08,
        "DiscountAmount": 0,
        "PaidAmount": 0
      }
    ]
  },
  "Sessions": {
    "Description": "A logged training session. The atomic line item that rolls up into an invoice.",
    "schema": [
      {
        "name": "SessionId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "Client",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "RelatedTo": "Clients"
      },
      {
        "name": "ClientName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Clients!{{FullName}}, MATCH(Sessions!{{Client}}, Clients!{{ClientId}}, 0))"
      },
      {
        "name": "Trainer",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Clients!{{Trainer}}, MATCH(Sessions!{{Client}}, Clients!{{ClientId}}, 0))"
      },
      {
        "name": "ClientHourlyRate",
        "datatype": "number",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Clients!{{TrainerHourlyRate}}, MATCH(Sessions!{{Client}}, Clients!{{ClientId}}, 0))"
      },
      {
        "name": "SessionDate",
        "datatype": "datetime",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "DurationHours",
        "datatype": "number",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "RateOverride",
        "datatype": "number",
        "type": "raw",
        "nullable": true,
        "Description": "If > 0, overrides the trainer's HourlyRate for this session."
      },
      {
        "name": "Notes",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "EffectiveRate",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "formula": "=IF({{RateOverride}}>0, {{RateOverride}}, {{ClientHourlyRate}})",
        "important": true,
        "explanation_rich": "**What this one session actually costs per hour.** Each client inherits their trainer's `HourlyRate` via lookup chain (Session → Client → Trainer.HourlyRate), but any session can override it — special assessments, intro pricing, package deals. The IF picks: nonzero override wins, else the trainer's posted rate. Worked example: session `s-005` (Sam, 2.0 hours) has `RateOverride = 100`, so `EffectiveRate` = **$100/hr** and `LineTotal` = $200 — even though Sam's trainer Alex normally bills $80. Drop the override to 0 and the same session re-prices to $160 instantly, and `INV-002.Subtotal` shifts to match."
      },
      {
        "name": "LineTotal",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "formula": "={{EffectiveRate}} * {{DurationHours}}"
      },
      {
        "name": "Invoice",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "RelatedTo": "Invoices"
      },
      {
        "name": "InvoiceName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Invoices!{{Name}}, MATCH(Sessions!{{Invoice}}, Invoices!{{InvoiceId}}, 0))"
      },
      {
        "name": "IsBilled",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "formula": "=NOT(ISBLANK({{Invoice}}))"
      }
    ],
