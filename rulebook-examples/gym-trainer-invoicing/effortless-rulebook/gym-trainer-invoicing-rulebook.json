  "Trainers": {
    "Description": "Personal trainers who log sessions and bill clients.",
    "schema": [
      {
        "name": "TrainerId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "Email",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "FullName",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "HourlyRate",
        "datatype": "number",
        "type": "raw",
        "nullable": true,
        "Description": "Default $/hour charged to clients."
      },
      {
        "name": "TotalSessions",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "formula": "=COUNTIFS(Sessions!{{Trainer}}, Trainers!{{TrainerId}})"
      },
      {
        "name": "TotalBilled",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "formula": "=SUMIFS(Invoices!{{Total}}, Invoices!{{Trainer}}, Trainers!{{TrainerId}})"
      },
      {
        "name": "TotalOutstanding",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "formula": "=SUMIFS(Invoices!{{Balance}}, Invoices!{{Trainer}}, Trainers!{{TrainerId}})"
      }
    ],
