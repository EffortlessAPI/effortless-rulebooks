  "Invoices": {
    "Description": "An invoice bundles one or more sessions billed to a client.",
    "important": true,
    "summary_rich": "The **paperwork**. An invoice is a wrapper — its `Subtotal` is the sum of every session linked to it, its tax is computed from the rate, and `Status` (Open / Paid / Overdue) falls out of the date math against `DueDate` plus a 45-day grace window. Edit a single session's duration and the invoice's total moves with it.",
    "important_fields": ["Name", "ClientName", "Total", "Balance", "Status", "DueDate"],
    "schema": [
      {
        "name": "InvoiceId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "Client",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "RelatedTo": "Clients"
      },
      {
        "name": "ClientName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Clients!{{FullName}}, MATCH(Invoices!{{Client}}, Clients!{{ClientId}}, 0))"
      },
      {
        "name": "ClientEmail",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Clients!{{Email}}, MATCH(Invoices!{{Client}}, Clients!{{ClientId}}, 0))"
      },
      {
        "name": "Trainer",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Clients!{{Trainer}}, MATCH(Invoices!{{Client}}, Clients!{{ClientId}}, 0))"
      },
      {
        "name": "TrainerName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Clients!{{TrainerName}}, MATCH(Invoices!{{Client}}, Clients!{{ClientId}}, 0))"
      },
      {
        "name": "IssueDate",
        "datatype": "datetime",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "DueDate",
        "datatype": "datetime",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "TaxRate",
        "datatype": "number",
        "type": "raw",
        "nullable": true,
        "Description": "Decimal (e.g. 0.08 = 8%)."
      },
      {
        "name": "DiscountAmount",
        "datatype": "number",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "PaidAmount",
        "datatype": "number",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "Subtotal",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "formula": "=SUMIFS(Sessions!{{LineTotal}}, Sessions!{{Invoice}}, Invoices!{{InvoiceId}})"
      },
      {
        "name": "TaxAmount",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "formula": "={{Subtotal}} * {{TaxRate}}"
      },
      {
        "name": "GraceDays",
        "datatype": "integer",
        "type": "calculated",
        "nullable": true,
        "Description": "Grace period (in days) after the DueDate before an invoice is considered late.",
        "formula": "=45"
      },
      {
        "name": "DaysSinceDueDate",
        "datatype": "integer",
        "type": "calculated",
        "nullable": true,
        "Description": "Raw whole days from DueDate to now (can be negative if not yet due).",
        "formula": "=DATETIME_DIFF(NOW(), {{DueDate}}, \"day\")"
      },
      {
        "name": "DaysPastDue",
        "datatype": "integer",
        "type": "calculated",
        "nullable": true,
        "Description": "Whole days past DueDate after the GraceDays window; 0 inside the grace window.",
        "formula": "=MAX(0, {{DaysSinceDueDate}} - {{GraceDays}})"
      },
      {
        "name": "LateFee",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "Description": "$15 flat fee once an invoice is past the 45-day grace period.",
        "formula": "=IF({{DaysPastDue}} > 0, 15, 0)"
      },
      {
        "name": "Total",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "formula": "={{Subtotal}} + {{TaxAmount}} + {{LateFee}} - {{DiscountAmount}}",
        "important": true,
        "explanation_rich": "**What the client owes on this invoice.** A four-input calculation pinned to the rulebook — `Subtotal` (rolled up from session line items via SUMIFS), `TaxAmount` (Subtotal × TaxRate), `LateFee` ($15 once past the grace window, else $0), minus `DiscountAmount`. Worked example: `INV-002` for Sam — two sessions billed against Alex's $80/hr trainer rate, with one $100 override for 2 hours = `Subtotal` $260, tax at 8% = $20.80, no late fee yet, $20 discount → `Total` = **$260.80**. Bump session `s-005` from 2.0 to 2.5 hours and the total moves to $304.80 *without any application code touching the math*."
      },
      {
        "name": "Balance",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "formula": "={{Total}} - {{PaidAmount}}"
      },
      {
        "name": "IsPaid",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "formula": "={{Balance}} <= 0"
      },
      {
        "name": "IsOverdue",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "Description": "True only after the GraceDays window has elapsed.",
        "formula": "=AND(NOT({{IsPaid}}), {{DaysPastDue}} > 0)",
        "important": true,
        "explanation_rich": "**The grace window is a rule, not a convention.** An invoice is *overdue* only when (a) `IsPaid` is still false AND (b) it's been past `DueDate` for more than `GraceDays` (45 days). The day math walks `DueDate` → `DaysSinceDueDate` → `DaysPastDue` (clamped at 0 inside the window) → `IsOverdue`. Worked example: `INV-001` for Sam was due **2026-04-15**; as of today (2026-05-27) that's 42 days past due — still *inside* the 45-day grace window, so `IsOverdue` = **FALSE** and `Status` = `Open`. Wait 4 more days and the same field flips to TRUE without a cron job."
      },
      {
        "name": "Status",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "formula": "=IF({{IsPaid}}, \"Paid\", IF({{IsOverdue}}, \"Overdue\", \"Open\"))"
      }
    ],
