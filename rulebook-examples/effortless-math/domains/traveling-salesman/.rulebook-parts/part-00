{
  "$schema": "https://example.com/cmcc-schema/v1",
  "Name": "traveling-salesman",
  "Description": "Traveling Salesman research domain at city/neighborhood/address scale. The initial rulebook normalizes a finite weighted city graph, validates explicit ordered-tour witnesses, records search metrics, and keeps optimality and complexity claims outside the closed frontier.",
  "__meta__": {
    "Description": "Rulebook metadata and explicit research-program guardrails.",
    "schema": [
      {"name": "MetaKey", "datatype": "string", "type": "raw", "nullable": false, "Description": "Stable metadata key."},
      {"name": "Name", "datatype": "string", "type": "calculated", "nullable": true, "Description": "Display alias for the metadata row.", "formula": "={{MetaKey}}"},
      {"name": "ValueType", "datatype": "string", "type": "raw", "nullable": true, "Description": "Declared type of the metadata value."},
      {"name": "StringValue", "datatype": "string", "type": "raw", "nullable": true, "Description": "String-valued metadata."},
      {"name": "IntegerValue", "datatype": "integer", "type": "raw", "nullable": true, "Description": "Integer-valued metadata."},
      {"name": "BooleanValue", "datatype": "boolean", "type": "raw", "nullable": true, "Description": "Boolean-valued metadata."}
    ],
    "data": [
      {"MetaKey": "research_status", "ValueType": "string", "StringValue": "RESEARCH_PROGRAM", "IntegerValue": null, "BooleanValue": null},
      {"MetaKey": "canonical_scope", "ValueType": "string", "StringValue": "symmetric finite weighted city graph", "IntegerValue": null, "BooleanValue": null},
      {"MetaKey": "first_loop", "ValueType": "integer", "StringValue": null, "IntegerValue": 577, "BooleanValue": null},
      {"MetaKey": "last_loop", "ValueType": "integer", "StringValue": null, "IntegerValue": 581, "BooleanValue": null},
      {"MetaKey": "claims_p_equals_np", "ValueType": "boolean", "StringValue": null, "IntegerValue": null, "BooleanValue": false},
      {"MetaKey": "claims_optimality", "ValueType": "boolean", "StringValue": null, "IntegerValue": null, "BooleanValue": false}
    ]
  },
  "Cities": {
    "Description": "Cities provide the outer spatial boundary for TSP instances.",
    "schema": [
      {"name": "CityId", "datatype": "string", "type": "raw", "nullable": false, "Description": "Stable city identifier."},
      {"name": "Name", "datatype": "string", "type": "calculated", "nullable": true, "Description": "Human-readable city label.", "formula": "={{DisplayName}}"},
      {"name": "DisplayName", "datatype": "string", "type": "raw", "nullable": false, "Description": "Human-readable city name."},
      {"name": "CountryCode", "datatype": "string", "type": "raw", "nullable": false, "Description": "ISO-style country code for the city."},
      {"name": "CoordinateSystem", "datatype": "string", "type": "raw", "nullable": false, "Description": "Coordinate convention used by addresses in this city."},
      {"name": "Description", "datatype": "string", "type": "raw", "nullable": true, "Description": "Purpose of the city fixture."}
    ],
    "data": [
      {"CityId": "gridville", "DisplayName": "Gridville", "CountryCode": "US", "CoordinateSystem": "LOCAL_INTEGER_GRID_V1", "Description": "Deterministic five-address fixture used to bring the TSP Postgres substrate online."}
    ]
  },
  "Neighborhoods": {
    "Description": "Neighborhoods partition a city into first-class spatial clusters.",
    "schema": [
      {"name": "NeighborhoodId", "datatype": "string", "type": "raw", "nullable": false, "Description": "Stable neighborhood identifier."},
      {"name": "Name", "datatype": "string", "type": "calculated", "nullable": true, "Description": "Human-readable neighborhood label.", "formula": "={{DisplayName}}"},
      {"name": "DisplayName", "datatype": "string", "type": "raw", "nullable": false, "Description": "Human-readable neighborhood name."},
      {"name": "City", "datatype": "string", "type": "relationship", "nullable": false, "Description": "City containing this neighborhood.", "RelatedTo": "Cities"},
