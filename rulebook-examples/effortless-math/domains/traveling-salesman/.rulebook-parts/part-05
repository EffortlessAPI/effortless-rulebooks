      {"name": "Name", "datatype": "string", "type": "calculated", "nullable": true, "Description": "Display alias for the leg.", "formula": "={{TourLegId}}"},
      {"name": "CandidateTour", "datatype": "string", "type": "relationship", "nullable": false, "Description": "Candidate tour containing the leg.", "RelatedTo": "CandidateTours"},
      {"name": "FromTourStop", "datatype": "string", "type": "relationship", "nullable": false, "Description": "Ordered visit at the start of the leg.", "RelatedTo": "TourStops"},
      {"name": "ToTourStop", "datatype": "string", "type": "relationship", "nullable": false, "Description": "Ordered visit at the end of the leg.", "RelatedTo": "TourStops"},
      {"name": "TravelEdge", "datatype": "string", "type": "relationship", "nullable": false, "Description": "Canonical undirected edge traversed by the leg.", "RelatedTo": "TravelEdges"},
      {"name": "LegOrder", "datatype": "integer", "type": "raw", "nullable": false, "Description": "One-based order of the leg."},
      {"name": "TourTSPInstance", "datatype": "string", "type": "lookup", "nullable": true, "Description": "TSP instance owned by the candidate tour.", "formula": "=INDEX(CandidateTours!{{TSPInstance}}, MATCH({{CandidateTour}}, CandidateTours!{{CandidateTourId}}, 0))", "RelatedTo": "CandidateTours"},
      {"name": "RequiredStopCount", "datatype": "integer", "type": "lookup", "nullable": true, "Description": "Required stop count reached through the candidate's TSP instance and used to recognize the closing leg.", "formula": "=INDEX(TSPInstances!{{CountOfRequiredStops}}, MATCH({{TourTSPInstance}}, TSPInstances!{{TSPInstanceId}}, 0))", "RelatedTo": "TSPInstances"},
      {"name": "FromTourCandidate", "datatype": "string", "type": "lookup", "nullable": true, "Description": "Candidate tour owning the from visit.", "formula": "=INDEX(TourStops!{{CandidateTour}}, MATCH({{FromTourStop}}, TourStops!{{TourStopId}}, 0))", "RelatedTo": "TourStops"},
      {"name": "ToTourCandidate", "datatype": "string", "type": "lookup", "nullable": true, "Description": "Candidate tour owning the to visit.", "formula": "=INDEX(TourStops!{{CandidateTour}}, MATCH({{ToTourStop}}, TourStops!{{TourStopId}}, 0))", "RelatedTo": "TourStops"},
      {"name": "FromInstanceStop", "datatype": "string", "type": "lookup", "nullable": true, "Description": "Instance stop at the start of the leg.", "formula": "=INDEX(TourStops!{{InstanceStop}}, MATCH({{FromTourStop}}, TourStops!{{TourStopId}}, 0))", "RelatedTo": "TourStops"},
      {"name": "ToInstanceStop", "datatype": "string", "type": "lookup", "nullable": true, "Description": "Instance stop at the end of the leg.", "formula": "=INDEX(TourStops!{{InstanceStop}}, MATCH({{ToTourStop}}, TourStops!{{TourStopId}}, 0))", "RelatedTo": "TourStops"},
      {"name": "FromSequencePosition", "datatype": "integer", "type": "lookup", "nullable": true, "Description": "Sequence position at the start of the leg.", "formula": "=INDEX(TourStops!{{SequencePosition}}, MATCH({{FromTourStop}}, TourStops!{{TourStopId}}, 0))", "RelatedTo": "TourStops"},
      {"name": "ToSequencePosition", "datatype": "integer", "type": "lookup", "nullable": true, "Description": "Sequence position at the end of the leg.", "formula": "=INDEX(TourStops!{{SequencePosition}}, MATCH({{ToTourStop}}, TourStops!{{TourStopId}}, 0))", "RelatedTo": "TourStops"},
      {"name": "EdgeTSPInstance", "datatype": "string", "type": "lookup", "nullable": true, "Description": "TSP instance owning the selected edge.", "formula": "=INDEX(TravelEdges!{{TSPInstance}}, MATCH({{TravelEdge}}, TravelEdges!{{TravelEdgeId}}, 0))", "RelatedTo": "TravelEdges"},
      {"name": "EdgeFromStop", "datatype": "string", "type": "lookup", "nullable": true, "Description": "First canonical edge endpoint.", "formula": "=INDEX(TravelEdges!{{FromStop}}, MATCH({{TravelEdge}}, TravelEdges!{{TravelEdgeId}}, 0))", "RelatedTo": "TravelEdges"},
      {"name": "EdgeToStop", "datatype": "string", "type": "lookup", "nullable": true, "Description": "Second canonical edge endpoint.", "formula": "=INDEX(TravelEdges!{{ToStop}}, MATCH({{TravelEdge}}, TravelEdges!{{TravelEdgeId}}, 0))", "RelatedTo": "TravelEdges"},
      {"name": "EdgeTravelCost", "datatype": "number", "type": "lookup", "nullable": true, "Description": "Optimization cost of the selected edge.", "formula": "=INDEX(TravelEdges!{{TravelCost}}, MATCH({{TravelEdge}}, TravelEdges!{{TravelEdgeId}}, 0))", "RelatedTo": "TravelEdges"},
      {"name": "EdgeIsAdmissible", "datatype": "boolean", "type": "lookup", "nullable": true, "Description": "Whether the selected edge passes first-order normalization.", "formula": "=INDEX(TravelEdges!{{IsAdmissible}}, MATCH({{TravelEdge}}, TravelEdges!{{TravelEdgeId}}, 0))", "RelatedTo": "TravelEdges"},
      {"name": "IsCandidateMembershipValid", "datatype": "boolean", "type": "calculated", "nullable": true, "Description": "Whether both ordered visits belong to this candidate.", "formula": "=AND({{CandidateTour}} = {{FromTourCandidate}}, {{CandidateTour}} = {{ToTourCandidate}})"},
      {"name": "IsSequenceTransition", "datatype": "boolean", "type": "calculated", "nullable": true, "Description": "Whether the leg follows the next visit or closes the route from n back to one.", "formula": "=OR({{ToSequencePosition}} = {{FromSequencePosition}} + 1, AND({{FromSequencePosition}} = {{RequiredStopCount}}, {{ToSequencePosition}} = 1))"},
      {"name": "IsEdgeEndpointMatch", "datatype": "boolean", "type": "calculated", "nullable": true, "Description": "Whether the directed leg traverses the selected undirected edge in either direction.", "formula": "=OR(AND({{FromInstanceStop}} = {{EdgeFromStop}}, {{ToInstanceStop}} = {{EdgeToStop}}), AND({{FromInstanceStop}} = {{EdgeToStop}}, {{ToInstanceStop}} = {{EdgeFromStop}}))"},
      {"name": "IsInTourInstance", "datatype": "boolean", "type": "calculated", "nullable": true, "Description": "Whether the edge belongs to the candidate's TSP instance.", "formula": "={{EdgeTSPInstance}} = {{TourTSPInstance}}"},
      {"name": "IsValid", "datatype": "boolean", "type": "calculated", "nullable": true, "Description": "Whether the leg passes all represented structural checks.", "formula": "=AND({{IsCandidateMembershipValid}}, {{IsSequenceTransition}}, {{IsEdgeEndpointMatch}}, {{IsInTourInstance}}, {{EdgeIsAdmissible}})"},
      {"name": "TravelCost", "datatype": "number", "type": "calculated", "nullable": true, "Description": "Cost contributed by a valid leg; invalid legs contribute zero and are counted separately.", "formula": "=IF({{IsValid}}, {{EdgeTravelCost}}, 0)"}
