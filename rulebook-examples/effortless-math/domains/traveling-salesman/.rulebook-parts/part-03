  "CandidateTours": {
    "Description": "Explicit candidate tours. Validity is derived; optimality is deliberately not inferred.",
    "schema": [
      {"name": "CandidateTourId", "datatype": "string", "type": "raw", "nullable": false, "Description": "Stable candidate-tour identifier."},
      {"name": "Name", "datatype": "string", "type": "calculated", "nullable": true, "Description": "Human-readable tour label.", "formula": "={{DisplayName}}"},
      {"name": "DisplayName", "datatype": "string", "type": "raw", "nullable": false, "Description": "Human-readable candidate-tour name."},
      {"name": "TSPInstance", "datatype": "string", "type": "relationship", "nullable": false, "Description": "TSP instance evaluated by this candidate.", "RelatedTo": "TSPInstances"},
      {"name": "CandidateKind", "datatype": "string", "type": "raw", "nullable": false, "Description": "Role of this candidate in the fixture."},
      {"name": "SearchBranchesExplored", "datatype": "integer", "type": "raw", "nullable": false, "Description": "Branches explored to obtain this candidate; zero means supplied witness, not solved."},
      {"name": "BacktrackCount", "datatype": "integer", "type": "raw", "nullable": false, "Description": "Backtracking performed to obtain this candidate."},
      {"name": "RequiredStopCount", "datatype": "integer", "type": "lookup", "nullable": true, "Description": "Required stop count supplied by the instance.", "formula": "=INDEX(TSPInstances!{{CountOfRequiredStops}}, MATCH({{TSPInstance}}, TSPInstances!{{TSPInstanceId}}, 0))", "RelatedTo": "TSPInstances"},
      {"name": "CountOfTourStops", "datatype": "integer", "type": "aggregation", "nullable": true, "Description": "Number of ordered tour-stop rows.", "formula": "=COUNTIFS(TourStops!{{CandidateTour}}, {{CandidateTourId}})"},
      {"name": "CountOfTourLegs", "datatype": "integer", "type": "aggregation", "nullable": true, "Description": "Number of ordered tour-leg rows.", "formula": "=COUNTIFS(TourLegs!{{CandidateTour}}, {{CandidateTourId}})"},
      {"name": "CountOfNonUniqueVisits", "datatype": "integer", "type": "aggregation", "nullable": true, "Description": "Tour-stop rows whose instance stop appears more than once.", "formula": "=COUNTIFS(TourStops!{{CandidateTour}}, {{CandidateTourId}}, TourStops!{{IsUniqueVisit}}, FALSE())"},
      {"name": "CountOfNonUniqueSequences", "datatype": "integer", "type": "aggregation", "nullable": true, "Description": "Tour-stop rows whose sequence position is duplicated.", "formula": "=COUNTIFS(TourStops!{{CandidateTour}}, {{CandidateTourId}}, TourStops!{{IsUniqueSequence}}, FALSE())"},
      {"name": "CountOfOutOfInstanceStops", "datatype": "integer", "type": "aggregation", "nullable": true, "Description": "Tour stops that do not belong to the candidate's instance.", "formula": "=COUNTIFS(TourStops!{{CandidateTour}}, {{CandidateTourId}}, TourStops!{{IsInTourInstance}}, FALSE())"},
      {"name": "CountOfNonRequiredStops", "datatype": "integer", "type": "aggregation", "nullable": true, "Description": "Tour stops not marked required by the instance.", "formula": "=COUNTIFS(TourStops!{{CandidateTour}}, {{CandidateTourId}}, TourStops!{{StopIsRequired}}, FALSE())"},
      {"name": "CountOfDepotStops", "datatype": "integer", "type": "aggregation", "nullable": true, "Description": "Number of depot visits in the ordered stop list.", "formula": "=COUNTIFS(TourStops!{{CandidateTour}}, {{CandidateTourId}}, TourStops!{{StopIsDepot}}, TRUE())"},
      {"name": "CountOfDepotPositionViolations", "datatype": "integer", "type": "aggregation", "nullable": true, "Description": "Depot rows not placed at sequence position one.", "formula": "=COUNTIFS(TourStops!{{CandidateTour}}, {{CandidateTourId}}, TourStops!{{IsDepotAtFirstPosition}}, FALSE())"},
      {"name": "CountOfInvalidLegs", "datatype": "integer", "type": "aggregation", "nullable": true, "Description": "Tour legs failing membership, sequence, edge, or instance checks.", "formula": "=COUNTIFS(TourLegs!{{CandidateTour}}, {{CandidateTourId}}, TourLegs!{{IsValid}}, FALSE())"},
      {"name": "TotalTravelCost", "datatype": "number", "type": "aggregation", "nullable": true, "Description": "Sum of validated tour-leg costs.", "formula": "=SUMIFS(TourLegs!{{TravelCost}}, TourLegs!{{CandidateTour}}, {{CandidateTourId}})"},
      {"name": "IsHamiltonianCycleWitness", "datatype": "boolean", "type": "calculated", "nullable": true, "Description": "Whether this explicit ordered route is a valid single Hamiltonian cycle for the instance.", "formula": "=AND({{CountOfTourStops}} = {{RequiredStopCount}}, {{CountOfTourLegs}} = {{RequiredStopCount}}, {{CountOfNonUniqueVisits}} = 0, {{CountOfNonUniqueSequences}} = 0, {{CountOfOutOfInstanceStops}} = 0, {{CountOfNonRequiredStops}} = 0, {{CountOfDepotStops}} = 1, {{CountOfDepotPositionViolations}} = 0, {{CountOfInvalidLegs}} = 0)"},
