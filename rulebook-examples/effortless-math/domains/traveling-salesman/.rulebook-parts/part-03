      {"name": "IsAdmissible", "datatype": "boolean", "type": "calculated", "nullable": true, "Description": "First-order edge admissibility.", "formula": "=AND({{IsAvailable}}, NOT({{IsSelfLoop}}), {{IsWithinInstance}})"}
