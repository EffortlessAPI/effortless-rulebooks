    effortless-ntwf:status "complete" ;
    effortless-ntwf:newConcept "peano-truncated-subtraction-internalized" ;
    effortless-ntwf:domainQuestion "Does truncated subtraction stay total on the naturals while remaining definitionally exact for 4-2?" ;
    effortless-ntwf:witnessSummary "Four-step reduction cancelling successors pairwise then n-0=n; normal form S(S(0)) = numeral 2." ;
    effortless-ntwf:nextFrontier "Add multiplication, reusing internalized addition." ;
    effortless-ntwf:epistemicTier "foundation-internalization" ;
    effortless-ntwf:domainId "domain-natural-number-arithmetic" .

