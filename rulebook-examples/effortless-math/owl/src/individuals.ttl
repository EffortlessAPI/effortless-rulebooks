    effortless-ntwf:derivationKind "definition" ;
    effortless-ntwf:contradiction false ;
    effortless-ntwf:notes "S(S(Z)) is the normal form of numeral 2. QED." ;
    effortless-ntwf:domainId "domain-natural-number-arithmetic" .

