    effortless-ntwf:derivationKind "reduction" ;
    effortless-ntwf:contradiction false ;
    effortless-ntwf:notes "Reduce (1*2): 2 + (2 + (0*2))." ;
    effortless-ntwf:domainId "domain-natural-number-arithmetic" .

effortless-ntwf:proof-nna-mul-04 a effortless-ntwf:ProofFacts ;
    effortless-ntwf:factId "proof-nna-mul-04" ;
    effortless-ntwf:stepNo 127 ;
    effortless-ntwf:ruleId "nat-mul-zero-left" ;
    effortless-ntwf:derivedFact "mul_step_SSO_plus_SSO_plus_O" ;
    effortless-ntwf:antecedentsJson "[\"mul_step_SSO_plus_SSO_plus_mul_O\"]" ;
    effortless-ntwf:derivationKind "reduction" ;
    effortless-ntwf:contradiction false ;
    effortless-ntwf:notes "0*n = 0: 2 + (2 + 0)." ;
    effortless-ntwf:domainId "domain-natural-number-arithmetic" .

effortless-ntwf:proof-nna-mul-05 a effortless-ntwf:ProofFacts ;
    effortless-ntwf:factId "proof-nna-mul-05" ;
    effortless-ntwf:stepNo 128 ;
    effortless-ntwf:ruleId "nat-add-reduce" ;
    effortless-ntwf:derivedFact "mul_add_reduces_to_SSSSO" ;
    effortless-ntwf:antecedentsJson "[\"mul_step_SSO_plus_SSO_plus_O\", \"add_2_2_equals_4\"]" ;
    effortless-ntwf:derivationKind "reduction" ;
    effortless-ntwf:contradiction false ;
    effortless-ntwf:notes "Reduce the additions via internalized addition: 2 + 2 = 4." ;
    effortless-ntwf:domainId "domain-natural-number-arithmetic" .

effortless-ntwf:proof-nna-mul-06 a effortless-ntwf:ProofFacts ;
    effortless-ntwf:factId "proof-nna-mul-06" ;
    effortless-ntwf:stepNo 129 ;
    effortless-ntwf:ruleId "recognize-numeral" ;
    effortless-ntwf:derivedFact "mul_2_2_equals_4" ;
    effortless-ntwf:antecedentsJson "[\"mul_add_reduces_to_SSSSO\"]" ;
    effortless-ntwf:derivationKind "definition" ;
    effortless-ntwf:contradiction false ;
    effortless-ntwf:notes "Normal form S(S(S(S(Z)))) is numeral 4. QED." ;
    effortless-ntwf:domainId "domain-natural-number-arithmetic" .

