    effortless-ntwf:theoremKind "foundation-internalized" ;
    effortless-ntwf:statement "NaturalDiv(4,2) = 2 in the Peano naturals (exact division; partial where the divisor does not divide the dividend)." ;
    effortless-ntwf:scope "Closed derivation using div-base and div-sub-step (repeated truncated subtraction); exact because the remainder reaches zero; no imported theorem." ;
