    effortless-ntwf:nextFrontier "Model remainder r and the division algorithm 4 = 2q + r; then close the domain in the cleanup loop." ;
    effortless-ntwf:epistemicTier "foundation-internalization" ;
    effortless-ntwf:domainId "domain-natural-number-arithmetic" .

