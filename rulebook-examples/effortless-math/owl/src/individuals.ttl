    effortless-ntwf:derivationKind "reduction" ;
    effortless-ntwf:contradiction false ;
    effortless-ntwf:notes "0<2 so 0/2 = 0 (base case: dividend below divisor)." ;
    effortless-ntwf:domainId "domain-natural-number-arithmetic" .

effortless-ntwf:proof-nna-div-05 a effortless-ntwf:ProofFacts ;
    effortless-ntwf:factId "proof-nna-div-05" ;
    effortless-ntwf:stepNo 134 ;
    effortless-ntwf:ruleId "nat-add-count" ;
    effortless-ntwf:derivedFact "div_normal_form_SSO" ;
    effortless-ntwf:antecedentsJson "[\"div_step_zero_dividend\"]" ;
    effortless-ntwf:derivationKind "reduction" ;
    effortless-ntwf:contradiction false ;
    effortless-ntwf:notes "Sum the quotient increments: 1 + 1 + 0 = S(S(Z))." ;
    effortless-ntwf:domainId "domain-natural-number-arithmetic" .

effortless-ntwf:proof-nna-div-06 a effortless-ntwf:ProofFacts ;
    effortless-ntwf:factId "proof-nna-div-06" ;
    effortless-ntwf:stepNo 135 ;
    effortless-ntwf:ruleId "recognize-numeral" ;
