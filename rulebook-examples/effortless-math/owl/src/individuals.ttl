    effortless-ntwf:witnessSummary "mul-succ-left x2 and mul-zero-left expand 2*2 to 2+(2+0), which reduces to 4 via internalized addition." ;
    effortless-ntwf:nextFrontier "Add exact division as repeated truncated subtraction." ;
    effortless-ntwf:epistemicTier "foundation-internalization" ;
    effortless-ntwf:domainId "domain-natural-number-arithmetic" .

