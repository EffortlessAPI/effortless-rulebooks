    effortless-ntwf:title "Peano naturals and the four elementary operations" ;
    effortless-ntwf:mathematical_scope "Natural numbers as Zero/Successor; addition, truncated subtraction, multiplication, and exact (partial) division defined by structural recursion." ;
    effortless-ntwf:input_contract_json "[\"Zero constructor\", \"Successor constructor\", \"structural recursion\", \"decidable structural equality\"]" ;
    effortless-ntwf:output_contract_json "[\"NaturalAdd(m,n) by add-zero-left/add-succ-left\", \"NaturalSub(m,n) truncated by sub-n-zero/sub-succ-succ\", \"NaturalMul(m,n) by mul-zero-left/mul-succ-left\", \"NaturalDiv(m,n) exact by div-base/div-sub-step\"]" ;
