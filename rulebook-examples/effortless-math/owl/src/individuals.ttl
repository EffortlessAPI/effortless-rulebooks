    effortless-ntwf:notes "S(m)*n = n + (m*n): 2 + (1*2)." ;
    effortless-ntwf:domainId "domain-natural-number-arithmetic" .

effortless-ntwf:proof-nna-mul-03 a effortless-ntwf:ProofFacts ;
    effortless-ntwf:factId "proof-nna-mul-03" ;
    effortless-ntwf:stepNo 126 ;
    effortless-ntwf:ruleId "nat-mul-succ-left" ;
    effortless-ntwf:derivedFact "mul_step_SSO_plus_SSO_plus_mul_O" ;
