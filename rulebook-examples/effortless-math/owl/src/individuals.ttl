    effortless-ntwf:factId "proof-nna-div-01" ;
    effortless-ntwf:stepNo 130 ;
    effortless-ntwf:ruleId "expand-numeral" ;
    effortless-ntwf:derivedFact "div_term_SSSSO_div_SSO" ;
    effortless-ntwf:antecedentsJson "[\"numeral_4_is_SSSSO\", \"numeral_2_is_SSO\"]" ;
    effortless-ntwf:derivationKind "definition" ;
    effortless-ntwf:contradiction false ;
    effortless-ntwf:notes "Expand: NaturalDiv(S(S(S(S(Z)))),S(S(Z)))." ;
    effortless-ntwf:domainId "domain-natural-number-arithmetic" .

effortless-ntwf:proof-nna-div-02 a effortless-ntwf:ProofFacts ;
    effortless-ntwf:factId "proof-nna-div-02" ;
    effortless-ntwf:stepNo 131 ;
    effortless-ntwf:ruleId "nat-div-sub-step" ;
    effortless-ntwf:derivedFact "div_step_1_plus_div_SSO" ;
    effortless-ntwf:antecedentsJson "[\"div_term_SSSSO_div_SSO\", \"sub_4_2_equals_2\"]" ;
    effortless-ntwf:derivationKind "reduction" ;
    effortless-ntwf:contradiction false ;
    effortless-ntwf:notes "4>=2 so 4/2 = 1 + ((4-2)/2) = 1 + (2/2), using internalized 4-2=2." ;
    effortless-ntwf:domainId "domain-natural-number-arithmetic" .

effortless-ntwf:proof-nna-div-03 a effortless-ntwf:ProofFacts ;
    effortless-ntwf:factId "proof-nna-div-03" ;
    effortless-ntwf:stepNo 132 ;
    effortless-ntwf:ruleId "nat-div-sub-step" ;
    effortless-ntwf:derivedFact "div_step_1_plus_1_plus_div_O" ;
    effortless-ntwf:antecedentsJson "[\"div_step_1_plus_div_SSO\"]" ;
    effortless-ntwf:derivationKind "reduction" ;
    effortless-ntwf:contradiction false ;
    effortless-ntwf:notes "2>=2 so 2/2 = 1 + ((2-2)/2) = 1 + (0/2)." ;
    effortless-ntwf:domainId "domain-natural-number-arithmetic" .

effortless-ntwf:proof-nna-div-04 a effortless-ntwf:ProofFacts ;
    effortless-ntwf:factId "proof-nna-div-04" ;
    effortless-ntwf:stepNo 133 ;
    effortless-ntwf:ruleId "nat-div-base" ;
    effortless-ntwf:derivedFact "div_step_zero_dividend" ;
