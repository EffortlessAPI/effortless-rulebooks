    effortless-ntwf:domainQuestion "Can 2+2=4 be derived from Zero/Successor without importing its own conclusion?" ;
    effortless-ntwf:witnessSummary "Five-step reduction S(S(0))+S(S(0)) -> S(S(S(S(0)))) via add-succ-left x2 and add-zero-left; recognized as numeral 4." ;
    effortless-ntwf:nextFrontier "Add truncated subtraction as the first partial operation." ;
    effortless-ntwf:epistemicTier "foundation-internalization" ;
    effortless-ntwf:domainId "domain-natural-number-arithmetic" .

