effortless-ntwf:artifactId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ArtifactRegistry ;
    rdfs:range xsd:string ;
    rdfs:label "ArtifactId" ;
    rdfs:comment "ArtifactId" .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Name" .
    # calculated: calculated

