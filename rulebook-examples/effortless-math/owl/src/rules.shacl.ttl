@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix effortless-ntwf: <https://w3id.org/effortless-ntwf#> .

# === Shape with rules for ArtifactRegistry ===
effortless-ntwf:ArtifactRegistryShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:ArtifactRegistry ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ArtifactRegistry_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            PREFIX math: <http://www.w3.org/2005/xpath-functions/math#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ArtifactRegistry .
    OPTIONAL { $this effortless-ntwf:artifactId ?artifact_id . }
                BIND(?artifact_id AS ?_result)
            }
        """ ;
    ] .

