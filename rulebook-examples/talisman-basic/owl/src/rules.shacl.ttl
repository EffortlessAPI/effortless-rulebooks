# === Shape with rules for StepPrecedence ===
erb:StepPrecedenceShape a sh:NodeShape ;
    sh:targetClass erb:StepPrecedence ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StepPrecedence_ParentPath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:parentPath ?_result .
            }
            WHERE {
    $this a erb:StepPrecedence .
                $this erb:fromStep ?j0 .
                OPTIONAL { ?j0 erb:relativePath ?j1 . }
                BIND(?j1 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StepPrecedence_RelativePath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:relativePath ?_result .
            }
            WHERE {
    $this a erb:StepPrecedence .
    OPTIONAL { $this erb:parentPath ?parent_path . }
    OPTIONAL { $this erb:stepPrecedenceId ?step_precedence_id . }
                BIND(CONCAT(?parent_path, "/precedence/", ?step_precedence_id) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StepPrecedence_Iri" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:iri ?_result .
            }
            WHERE {
    $this a erb:StepPrecedence .
    OPTIONAL { $this erb:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StepPrecedence_Name" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:name ?_result .
            }
            WHERE {
    $this a erb:StepPrecedence .
    OPTIONAL { $this erb:fromStep ?from_step . }
    OPTIONAL { $this erb:toStep ?to_step . }
                BIND(CONCAT(?from_step, " -> ", ?to_step) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for WorkflowArtifacts ===
erb:WorkflowArtifactsShape a sh:NodeShape ;
    sh:targetClass erb:WorkflowArtifacts ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowArtifacts_ParentPath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:parentPath ?_result .
            }
            WHERE {
    $this a erb:WorkflowArtifacts .
                $this erb:producedByStep ?j0 .
                OPTIONAL { ?j0 erb:relativePath ?j1 . }
                BIND(?j1 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowArtifacts_RelativePath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:relativePath ?_result .
            }
            WHERE {
    $this a erb:WorkflowArtifacts .
    OPTIONAL { $this erb:artifactId ?artifact_id . }
    OPTIONAL { $this erb:parentPath ?parent_path . }
                BIND(CONCAT(?parent_path, "/artifacts/", ?artifact_id) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowArtifacts_Iri" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:iri ?_result .
            }
            WHERE {
    $this a erb:WorkflowArtifacts .
    OPTIONAL { $this erb:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowArtifacts_ProducingAgentType" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:producingAgentType ?_result .
            }
            WHERE {
    $this a erb:WorkflowArtifacts .
    OPTIONAL { $this erb:attributedToAIAgent ?attributed_to_ai_agent . }
    OPTIONAL { $this erb:attributedToAutomatedPipeline ?attributed_to_automated_pipeline . }
    OPTIONAL { $this erb:attributedToHumanAgent ?attributed_to_human_agent . }
                BIND(IF((!((!BOUND(?attributed_to_human_agent) || STR(?attributed_to_human_agent) = ""))), "HumanAgent", IF((!((!BOUND(?attributed_to_ai_agent) || STR(?attributed_to_ai_agent) = ""))), "AIAgent", IF((!((!BOUND(?attributed_to_automated_pipeline) || STR(?attributed_to_automated_pipeline) = ""))), "AutomatedPipeline", ""))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowArtifacts_HasDerivationParent" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:hasDerivationParent ?_result .
            }
            WHERE {
    $this a erb:WorkflowArtifacts .
    OPTIONAL { $this erb:derivedFromArtifact ?derived_from_artifact . }
                BIND((!((!BOUND(?derived_from_artifact) || STR(?derived_from_artifact) = ""))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowArtifacts_ProducedByWorkflow" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:producedByWorkflow ?_result .
            }
            WHERE {
    $this a erb:WorkflowArtifacts .
                $this erb:producedByStep ?j0 .
                OPTIONAL { ?j0 erb:workflow ?j1 . }
                BIND(?j1 AS ?_result)
            }
        """ ;
    ] .

