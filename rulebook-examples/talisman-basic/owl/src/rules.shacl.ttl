# === Shape with rules for ComplianceVerdicts ===
erb:ComplianceVerdictsShape a sh:NodeShape ;
    sh:targetClass erb:ComplianceVerdicts ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_ParentPath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:parentPath ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
                $this erb:workflow ?j0 .
                OPTIONAL { ?j0 erb:relativePath ?j1 . }
                BIND(?j1 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_RelativePath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:relativePath ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
    OPTIONAL { $this erb:complianceVerdictId ?compliance_verdict_id . }
    OPTIONAL { $this erb:parentPath ?parent_path . }
                BIND(CONCAT(?parent_path, "/verdicts/", ?compliance_verdict_id) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_Iri" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:iri ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
    OPTIONAL { $this erb:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_Name" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:name ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
    OPTIONAL { $this erb:workflowTitle ?workflow_title . }
                BIND(REPLACE(LCASE(?workflow_title), " ", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_WorkflowTitle" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:workflowTitle ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
                $this erb:workflow ?j0 .
                OPTIONAL { ?j0 erb:title ?j1 . }
                BIND(?j1 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_MonthsSinceReview" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:monthsSinceReview ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
                $this erb:workflow ?j0 .
                OPTIONAL { ?j0 erb:monthsSinceModified ?j1 . }
                BIND(?j1 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_IsStale" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:isStale ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
                $this erb:workflow ?j0 .
                OPTIONAL { ?j0 erb:isStale ?j1 . }
                BIND(?j1 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_AIStepCount" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:aIStepCount ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
                $this erb:workflow ?j0 .
                OPTIONAL { ?j0 erb:countAISteps ?j1 . }
                BIND(?j1 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_HasAIExecutedStep" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:hasAIExecutedStep ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
                $this erb:workflow ?j0 .
                OPTIONAL { ?j0 erb:hasAIAgentStep ?j1 . }
                BIND(?j1 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_TotalPlanMinutes" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:totalPlanMinutes ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
                $this erb:workflow ?j0 .
                OPTIONAL { ?j0 erb:countTotalPlanMinutes ?j1 . }
                BIND(?j1 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_TimeBudgetMinutes" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:timeBudgetMinutes ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
                $this erb:workflow ?j0 .
                OPTIONAL { ?j0 erb:maxPlanMinutes ?j1 . }
                BIND(?j1 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_IsOverTimeBudget" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:isOverTimeBudget ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
                $this erb:workflow ?j0 .
                OPTIONAL { ?j0 erb:isOverTimeBudget ?j1 . }
                BIND(?j1 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_HasConsistencyViolation" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:hasConsistencyViolation ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
                $this erb:workflow ?j0 .
                OPTIONAL { ?j0 erb:hasConsistencyViolation ?j1 . }
                BIND(?j1 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_IsAtComplianceRisk" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:isAtComplianceRisk ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
    OPTIONAL { $this erb:hasAIExecutedStep ?has_ai_executed_step . }
    OPTIONAL { $this erb:hasConsistencyViolation ?has_consistency_violation . }
    OPTIONAL { $this erb:isOverTimeBudget ?is_over_time_budget . }
    OPTIONAL { $this erb:isStale ?is_stale . }
                BIND(((?is_stale && ?has_ai_executed_step) || ?is_over_time_budget || ?has_consistency_violation) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_VerdictConcept" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:verdictConcept ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
    OPTIONAL { $this erb:isAtComplianceRisk ?is_at_compliance_risk . }
                BIND(IRI(CONCAT("http://example.org/erb#", STR(IF(?is_at_compliance_risk, "verdict-at-risk", "verdict-ok")))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ComplianceVerdicts_Verdict" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:verdict ?_result .
            }
            WHERE {
    $this a erb:ComplianceVerdicts .
                $this erb:verdictConcept ?j0 .
                OPTIONAL { ?j0 erb:prefLabel ?j1 . }
                BIND(?j1 AS ?_result)
            }
        """ ;
    ] .

