  "$schema": "https://example.com/cmcc-schema/v1",
  "Name": "Fantasy Football",
  "Description": "Multi-hop DAG: raw player stats \u2192 roster aggregations \u2192 matchup scoring \u2192 standings & seeding.",
  "DevUsers": {
    "Description": "Table: DevUsers",
    "schema": [
      {
        "name": "Email",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "User email (also PK)"
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": false,
        "Description": "Display name",
        "formula": "={{Email}}"
      },
      {
        "name": "Role",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "commissioner, owner, or spectator"
      }
    ],
    "data": [
      {
        "Email": "commissioner@league.local",
        "Role": "commissioner"
      },
      {
        "Email": "owner@league.local",
        "Role": "owner"
      },
