  "Matchups": {
    "Description": "Table: Matchups",
    "important": true,
    "summary_rich": "The **weekly head-to-heads**. Each matchup pairs two rosters in a given week; the rulebook looks up each side's `ProjectedScore`, subtracts to get the margin, and declares a winner — all through calculated fields, no \"update score\" button anywhere. Reshuffle a roster mid-week and the matchup result flips automatically.",
    "important_fields": ["Name", "Week", "Team1Score", "Team2Score", "Margin", "Winner"],
    "schema": [
      {
        "name": "MatchupId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Unique matchup ID (PK)"
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": false,
        "Description": "Display name",
        "formula": "={{MatchupId}}"
      },
      {
        "name": "Week",
        "datatype": "integer",
        "type": "raw",
        "nullable": false,
        "Description": "Week number"
      },
      {
        "name": "Team1",
        "datatype": "string",
        "type": "relationship",
        "nullable": false,
        "Description": "First roster",
        "RelatedTo": "Rosters"
      },
      {
        "name": "Team2",
        "datatype": "string",
        "type": "relationship",
        "nullable": false,
        "Description": "Second roster",
        "RelatedTo": "Rosters"
      },
      {
        "name": "Team1Score",
        "datatype": "number",
        "type": "lookup",
        "nullable": false,
        "Description": "Team1's projected score",
        "formula": "=INDEX(Rosters!{{ProjectedScore}}, MATCH({{Team1}}, Rosters!{{RosterId}}, 0))"
      },
      {
        "name": "Team2Score",
        "datatype": "number",
        "type": "lookup",
        "nullable": false,
        "Description": "Team2's projected score",
        "formula": "=INDEX(Rosters!{{ProjectedScore}}, MATCH({{Team2}}, Rosters!{{RosterId}}, 0))"
      },
      {
        "name": "Margin",
        "datatype": "number",
        "type": "calculated",
        "nullable": false,
        "Description": "Team1 score minus Team2 score",
        "formula": "={{Team1Score}} - {{Team2Score}}"
      },
      {
        "name": "Winner",
        "datatype": "string",
        "type": "calculated",
        "nullable": false,
        "Description": "Winning roster ID",
        "formula": "=IF({{Margin}} > 0, {{Team1}}, {{Team2}})",
        "important": true,
        "explanation_rich": "**The winner is whoever has the higher roster score — that's it, the whole rule.** `Margin = Team1Score - Team2Score`; if it's positive, `Team1` wins, otherwise `Team2`. Both scores are themselves lookups into `Rosters.ProjectedScore`, which is itself an aggregation over each team's players' stats. Worked example: *week1-mob-hustlers* — Mahomes Mob (1076.00) vs Hurts Hustlers; margin > 0, so `Winner = mahomes-mob`. Swap a single player on either roster and the winner can flip without anyone editing a matchup row by hand. (Ties — margin = 0 — are flagged separately by `IsTieGame`; the Winner field still defaults to Team2 in that case, which the league treats as a no-decision.)"
      },
      {
        "name": "Loser",
        "datatype": "string",
        "type": "calculated",
        "nullable": false,
        "Description": "Losing roster ID",
        "formula": "=IF({{Margin}} > 0, {{Team2}}, {{Team1}})"
      },
      {
        "name": "IsTieGame",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": false,
        "Description": "True if scores are equal",
        "formula": "={{Margin}} = 0"
      }
    ],
