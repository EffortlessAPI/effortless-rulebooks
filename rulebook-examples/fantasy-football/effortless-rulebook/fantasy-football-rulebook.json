  "Players": {
    "Description": "Table: Players",
    "important": true,
    "summary_rich": "The **raw stat sheet**. Every player has a position (QB, RB, WR, TE) and a season line — passing yards, rushing yards, receptions, touchdowns, picks. `ProjectedScore` turns those numbers into fantasy points using the league's scoring formula: 1 point per 25 passing yards, 6 per TD, minus 2 per interception. Edit any stat and the whole DAG — roster totals, matchup margins, standings — re-evaluates downstream.",
    "important_fields": ["Name", "Position", "TotalTouchdowns", "Interceptions", "ProjectedScore"],
    "schema": [
      {
        "name": "PlayerId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Player slug (PK)"
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": false,
        "Description": "Display name",
        "formula": "={{PlayerId}}"
      },
      {
        "name": "Position",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "QB, RB, WR, TE"
      },
      {
        "name": "PassingYards",
        "datatype": "integer",
        "type": "raw",
        "nullable": false,
        "Description": "Season passing yards"
      },
      {
        "name": "PassingTouchdowns",
        "datatype": "integer",
        "type": "raw",
        "nullable": false,
        "Description": "Season passing TDs"
      },
      {
        "name": "Interceptions",
        "datatype": "integer",
        "type": "raw",
        "nullable": false,
        "Description": "Season INTs"
      },
      {
        "name": "RushingYards",
        "datatype": "integer",
        "type": "raw",
        "nullable": false,
        "Description": "Season rushing yards"
      },
      {
        "name": "RushingTouchdowns",
        "datatype": "integer",
        "type": "raw",
        "nullable": false,
        "Description": "Season rushing TDs"
      },
      {
        "name": "Receptions",
        "datatype": "integer",
        "type": "raw",
        "nullable": false,
        "Description": "Season receptions"
      },
      {
        "name": "ReceivedYards",
        "datatype": "integer",
        "type": "raw",
        "nullable": false,
        "Description": "Season receiving yards"
      },
      {
        "name": "ReceivedTouchdowns",
        "datatype": "integer",
        "type": "raw",
        "nullable": false,
        "Description": "Season receiving TDs"
      },
      {
        "name": "TotalTouchdowns",
        "datatype": "integer",
        "type": "calculated",
        "nullable": false,
        "Description": "Sum of all TDs",
        "formula": "={{PassingTouchdowns}} + {{RushingTouchdowns}} + {{ReceivedTouchdowns}}",
        "important": true,
        "explanation_rich": "**Six points per touchdown, no matter how you got there.** A passing TD, a rushing TD, and a receiving TD all count the same in standard scoring — so the rulebook collapses them into one number before the scoring formula runs. Worked example: *Christian McCaffrey* has 15 rushing TDs + 3 receiving TDs + 0 passing TDs, so `TotalTouchdowns = 18`. That single number then drives his `ProjectedScore` and rolls up into his roster's total."
      },
      {
        "name": "ProjectedScore",
        "datatype": "number",
        "type": "calculated",
        "nullable": false,
        "Description": "Calculated fantasy points",
        "formula": "=ROUND(({{PassingYards}} / 25) + ({{TotalTouchdowns}} * 6) - ({{Interceptions}} * 2), 2)",
        "important": true,
        "explanation_rich": "**The league's scoring rule, encoded once.** Fantasy points = passing-yards/25 + total-TDs*6 - interceptions*2, rounded. Change the constants and every player, every roster, every matchup, and every standing recomputes — no application code touched. Worked example: *Patrick Mahomes* has 5500 passing yards, 51 total TDs (48 pass + 3 rush), 8 INTs → `(5500/25) + (51*6) - (8*2) = 220 + 306 - 16 = 510.00`. *Bryce Young* with 2200 yards, 15 TDs, 15 INTs → `88 + 90 - 30 = 148.00`. Same formula, opposite tier."
      }
    ],
