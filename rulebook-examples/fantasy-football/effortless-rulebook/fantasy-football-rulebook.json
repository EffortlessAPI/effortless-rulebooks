  "RosterAssignments": {
    "Description": "Table: RosterAssignments (join table linking Players to Rosters)",
    "schema": [
      {
        "name": "AssignmentId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Unique assignment ID (PK)"
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "calculated",
        "nullable": false,
        "Description": "Display name",
        "formula": "={{AssignmentId}}"
      },
      {
        "name": "Roster",
        "datatype": "string",
        "type": "relationship",
        "nullable": false,
        "Description": "Roster FK",
        "RelatedTo": "Rosters"
      },
      {
        "name": "Player",
        "datatype": "string",
        "type": "relationship",
        "nullable": false,
        "Description": "Player FK",
        "RelatedTo": "Players"
      },
      {
        "name": "PlayerName",
        "datatype": "string",
        "type": "lookup",
        "nullable": false,
        "Description": "Player display name",
        "formula": "=INDEX(Players!{{Name}}, MATCH({{Player}}, Players!{{PlayerId}}, 0))"
      },
      {
        "name": "Position",
        "datatype": "string",
        "type": "lookup",
        "nullable": false,
        "Description": "Player position",
        "formula": "=INDEX(Players!{{Position}}, MATCH({{Player}}, Players!{{PlayerId}}, 0))"
      },
      {
        "name": "PassingYards",
        "datatype": "integer",
        "type": "lookup",
        "nullable": false,
        "Description": "Player passing yards",
        "formula": "=INDEX(Players!{{PassingYards}}, MATCH({{Player}}, Players!{{PlayerId}}, 0))"
      },
      {
        "name": "PassingTouchdowns",
        "datatype": "integer",
        "type": "lookup",
        "nullable": false,
        "Description": "Player passing TDs",
        "formula": "=INDEX(Players!{{PassingTouchdowns}}, MATCH({{Player}}, Players!{{PlayerId}}, 0))"
      },
      {
        "name": "Interceptions",
        "datatype": "integer",
        "type": "lookup",
        "nullable": false,
        "Description": "Player INTs",
        "formula": "=INDEX(Players!{{Interceptions}}, MATCH({{Player}}, Players!{{PlayerId}}, 0))"
      },
      {
        "name": "RushingYards",
        "datatype": "integer",
        "type": "lookup",
        "nullable": false,
        "Description": "Player rushing yards",
        "formula": "=INDEX(Players!{{RushingYards}}, MATCH({{Player}}, Players!{{PlayerId}}, 0))"
      },
      {
        "name": "RushingTouchdowns",
        "datatype": "integer",
        "type": "lookup",
        "nullable": false,
        "Description": "Player rushing TDs",
        "formula": "=INDEX(Players!{{RushingTouchdowns}}, MATCH({{Player}}, Players!{{PlayerId}}, 0))"
      },
      {
        "name": "Receptions",
        "datatype": "integer",
        "type": "lookup",
        "nullable": false,
        "Description": "Player receptions",
        "formula": "=INDEX(Players!{{Receptions}}, MATCH({{Player}}, Players!{{PlayerId}}, 0))"
      },
      {
        "name": "ReceivedYards",
        "datatype": "integer",
        "type": "lookup",
        "nullable": false,
        "Description": "Player receiving yards",
        "formula": "=INDEX(Players!{{ReceivedYards}}, MATCH({{Player}}, Players!{{PlayerId}}, 0))"
      },
      {
        "name": "ReceivedTouchdowns",
        "datatype": "integer",
        "type": "lookup",
        "nullable": false,
        "Description": "Player receiving TDs",
        "formula": "=INDEX(Players!{{ReceivedTouchdowns}}, MATCH({{Player}}, Players!{{PlayerId}}, 0))"
      },
      {
        "name": "TotalTouchdowns",
        "datatype": "integer",
        "type": "lookup",
        "nullable": false,
        "Description": "Player total TDs",
        "formula": "=INDEX(Players!{{TotalTouchdowns}}, MATCH({{Player}}, Players!{{PlayerId}}, 0))"
      },
      {
        "name": "ProjectedScore",
        "datatype": "number",
        "type": "lookup",
        "nullable": false,
        "Description": "Player projected score",
        "formula": "=INDEX(Players!{{ProjectedScore}}, MATCH({{Player}}, Players!{{PlayerId}}, 0))"
      }
    ],
