  "ConstructionFamilies": {
    "Description": "Table: ConstructionFamilies. A parametrized family {P_n} of point sets. SourceNumberField and SourceLattice are optional — non-null only for algebraic constructions. Each row produces a sequence of ConstructionInstances which feed a GrowthSequence.",
    "important": true,
    "important_fields": ["InstanceCount", "MaxObservedDensityExponentEstimate"],
    "schema": [
      { "name": "ConstructionFamilyId", "datatype": "string", "type": "raw", "nullable": false, "is_primary_key": true },
      { "name": "Name", "datatype": "string", "type": "calculated", "nullable": true, "formula": "=SUBSTITUTE(LOWER({{DisplayName}}), \" \", \"-\")" },
      { "name": "DisplayName", "datatype": "string", "type": "raw" },
      { "name": "DescriptionOfNthMember", "datatype": "string", "type": "raw" },
      { "name": "SourceNumberField", "datatype": "string", "type": "relationship", "RelatedTo": "NumberFields", "nullable": true },
      { "name": "SourceMinkowskiLattice", "datatype": "string", "type": "relationship", "RelatedTo": "MinkowskiLattices", "nullable": true },
      { "name": "Instances", "datatype": "string", "type": "relationship", "RelatedTo": "ConstructionInstances" },
      { "name": "InstanceCount", "datatype": "integer", "type": "aggregation", "formula": "=COUNTIFS(ConstructionInstances!{{ConstructionFamily}}, ConstructionFamilies!{{ConstructionFamilyId}})" }
    ],
    "data": [
      { "ConstructionFamilyId": "sqrt-lattice-projection", "DisplayName": "Sqrt Lattice Projection", "DescriptionOfNthMember": "Project the first n short vectors of the Minkowski lattice of Q(sqrt(-3)) into R^2 via the embedding's first two real coordinates.", "SourceNumberField": "q-sqrt-neg3", "SourceMinkowskiLattice": "lat-q-sqrt-neg3" }
    ]
  },

  "ConstructionInstances": {
    "Description": "Table: ConstructionInstances. The materialized P_n for a specific n. The PointSet it produces is a real row in PointSets — so all the geometry-layer aggregations apply to it without re-implementation. EdgeCount and DensityExponentEstimate are LOOKUPS, not duplicates.",
    "important": true,
    "important_fields": ["ParamN", "EdgeCount", "DensityExponentEstimate"],
    "schema": [
      { "name": "ConstructionInstanceId", "datatype": "string", "type": "raw", "nullable": false, "is_primary_key": true },
      { "name": "Name", "datatype": "string", "type": "calculated", "nullable": true, "formula": "={{ConstructionFamily}}-n{{ParamN}}" },
      { "name": "ConstructionFamily", "datatype": "string", "type": "relationship", "RelatedTo": "ConstructionFamilies" },
      { "name": "ParamN", "datatype": "integer", "type": "raw" },
      { "name": "PointSet", "datatype": "string", "type": "relationship", "RelatedTo": "PointSets" },
      { "name": "PointCount", "datatype": "integer", "type": "lookup", "formula": "=LOOKUP(PointSets!{{PointCount}}, ConstructionInstances!{{PointSet}}, PointSets!{{PointSetId}})" },
      { "name": "EdgeCount", "datatype": "integer", "type": "lookup", "formula": "=LOOKUP(PointSets!{{UnitDistancePairCount}}, ConstructionInstances!{{PointSet}}, PointSets!{{PointSetId}})" },
      { "name": "DensityExponentEstimate", "datatype": "decimal", "type": "lookup", "formula": "=LOOKUP(PointSets!{{DensityExponentEstimate}}, ConstructionInstances!{{PointSet}}, PointSets!{{PointSetId}})" },
      { "name": "ParamNMatchesPointCount", "datatype": "boolean", "type": "calculated", "formula": "={{ParamN}}={{PointCount}}", "Description": "Sanity check: did the n-th instance actually produce n points?" }
    ],
    "data": [
      { "ConstructionInstanceId": "sqrt-lat-n3", "ConstructionFamily": "sqrt-lattice-projection", "ParamN": 3, "PointSet": "unit-triangle" },
      { "ConstructionInstanceId": "sqrt-lat-n4", "ConstructionFamily": "sqrt-lattice-projection", "ParamN": 4, "PointSet": "unit-square" }
    ]
  },

  "GrowthSequences": {
    "Description": "Table: GrowthSequences. The sequence (n, e(P_n)) realized by a ConstructionFamily, summarized as aggregations over its instances. MaxObservedDensityExponentEstimate is the strongest finite-sample witness the family currently provides — and is the value AsymptoticLowerBounds compares against to decide whether a claimed bound is finitely consistent.",
    "important": true,
    "important_fields": ["MaxParamN", "MaxObservedDensityExponentEstimate"],
    "schema": [
      { "name": "GrowthSequenceId", "datatype": "string", "type": "raw", "nullable": false, "is_primary_key": true },
      { "name": "Name", "datatype": "string", "type": "calculated", "nullable": true, "formula": "={{ConstructionFamily}}-growth" },
      { "name": "ConstructionFamily", "datatype": "string", "type": "relationship", "RelatedTo": "ConstructionFamilies" },
      { "name": "ObservedInstanceCount", "datatype": "integer", "type": "aggregation", "formula": "=COUNTIFS(ConstructionInstances!{{ConstructionFamily}}, GrowthSequences!{{ConstructionFamily}})" },
      { "name": "MaxParamN", "datatype": "integer", "type": "aggregation", "formula": "=MAXIFS(ConstructionInstances!{{ParamN}}, ConstructionInstances!{{ConstructionFamily}}, GrowthSequences!{{ConstructionFamily}})" },
      { "name": "MaxEdgeCount", "datatype": "integer", "type": "aggregation", "formula": "=MAXIFS(ConstructionInstances!{{EdgeCount}}, ConstructionInstances!{{ConstructionFamily}}, GrowthSequences!{{ConstructionFamily}})" },
      { "name": "MaxObservedDensityExponentEstimate", "datatype": "decimal", "type": "aggregation", "formula": "=MAXIFS(ConstructionInstances!{{DensityExponentEstimate}}, ConstructionInstances!{{ConstructionFamily}}, GrowthSequences!{{ConstructionFamily}})" }
    ],
    "data": [
      { "GrowthSequenceId": "sqrt-lat-growth", "ConstructionFamily": "sqrt-lattice-projection" }
    ]
  },

  "AsymptoticFunctions": {
    "Description": "Table: AsymptoticFunctions. Named asymptotic functions like U(n). DefinitionText is the human-readable definition; the function's content is fully specified by the AsymptoticLowerBounds and (eventually) AsymptoticUpperBounds that reference it.",
    "important": true,
    "important_fields": ["BestKnownLowerBoundExponent"],
    "schema": [
      { "name": "AsymptoticFunctionId", "datatype": "string", "type": "raw", "nullable": false, "is_primary_key": true },
      { "name": "Name", "datatype": "string", "type": "calculated", "nullable": true, "formula": "=SUBSTITUTE(LOWER({{DisplayName}}), \" \", \"-\")" },
      { "name": "DisplayName", "datatype": "string", "type": "raw" },
      { "name": "DefinitionText", "datatype": "string", "type": "raw" },
      { "name": "LowerBounds", "datatype": "string", "type": "relationship", "RelatedTo": "AsymptoticLowerBounds" },
      { "name": "LowerBoundCount", "datatype": "integer", "type": "aggregation", "formula": "=COUNTIFS(AsymptoticLowerBounds!{{AsymptoticFunction}}, AsymptoticFunctions!{{AsymptoticFunctionId}})" },
      { "name": "BestKnownLowerBoundExponent", "datatype": "decimal", "type": "aggregation", "formula": "=MAXIFS(AsymptoticLowerBounds!{{Exponent}}, AsymptoticLowerBounds!{{AsymptoticFunction}}, AsymptoticFunctions!{{AsymptoticFunctionId}})", "important": true, "Description": "The best (largest) lower-bound exponent currently asserted for this function." }
    ],
    "data": [
      { "AsymptoticFunctionId": "u-n", "DisplayName": "U(n)", "DefinitionText": "U(n) = max over P ⊂ R^2 with |P|=n of e(G(P)) — the maximum number of unit-distance pairs among n planar points." }
    ]
  },

  "AsymptoticLowerBounds": {
    "Description": "Table: AsymptoticLowerBounds. A claim of the form 'AsymptoticFunction(n) ≥ Coefficient · n^Exponent for sufficiently large n'. Exponent is raw. IsSuperlinear, WitnessConsistent, and ExceedsTrivialLinearBound are all first-class calculated checks. WitnessConsistent compares the claimed exponent against MaxObservedDensityExponentEstimate from the supporting GrowthSequence — a finite-sample sanity check that doesn't replace the proof but does flag inconsistency.",
    "important": true,
    "important_fields": ["Exponent", "IsSuperlinear", "WitnessConsistent"],
    "schema": [
      { "name": "AsymptoticLowerBoundId", "datatype": "string", "type": "raw", "nullable": false, "is_primary_key": true },
      { "name": "Name", "datatype": "string", "type": "calculated", "nullable": true, "formula": "=SUBSTITUTE(LOWER({{DisplayName}}), \" \", \"-\")" },
      { "name": "DisplayName", "datatype": "string", "type": "raw" },
      { "name": "AsymptoticFunction", "datatype": "string", "type": "relationship", "RelatedTo": "AsymptoticFunctions" },
      { "name": "GrowthSequence", "datatype": "string", "type": "relationship", "RelatedTo": "GrowthSequences", "nullable": true },
      { "name": "Exponent", "datatype": "decimal", "type": "raw" },
      { "name": "Coefficient", "datatype": "decimal", "type": "raw" },
      { "name": "StatementText", "datatype": "string", "type": "raw" },
      { "name": "SourceCitation", "datatype": "string", "type": "raw" },
      { "name": "IsExplicit", "datatype": "boolean", "type": "raw", "Description": "True if the exponent is named numerically (e.g. 1.014), false if only existential ('some ε > 0')." },
      { "name": "IsSuperlinear", "datatype": "boolean", "type": "calculated", "formula": "={{Exponent}}>1" },
      { "name": "ExceedsTrivialLinearBound", "datatype": "boolean", "type": "calculated", "formula": "={{Exponent}}>=1" },
      { "name": "WitnessedByMaxDensityExponent", "datatype": "decimal", "type": "lookup", "formula": "=LOOKUP(GrowthSequences!{{MaxObservedDensityExponentEstimate}}, AsymptoticLowerBounds!{{GrowthSequence}}, GrowthSequences!{{GrowthSequenceId}})" },
      { "name": "WitnessConsistent", "datatype": "boolean", "type": "calculated", "formula": "={{WitnessedByMaxDensityExponent}}>={{Exponent}}", "important": true, "Description": "Finite-sample sanity check: do the family's observed instances achieve at least the claimed exponent? FALSE means either more instances are needed or the claim is wrong for this family." }
    ],
    "data": [
      { "AsymptoticLowerBoundId": "erdos-sqrt-bound", "DisplayName": "Erdős sqrt(log n) bound", "AsymptoticFunction": "u-n", "GrowthSequence": "sqrt-lat-growth", "Exponent": 1, "Coefficient": 1, "StatementText": "U(n) ≥ n^{1+c/log log n} (Erdős 1946)", "SourceCitation": "Erdős, 1946", "IsExplicit": false },
      { "AsymptoticLowerBoundId": "sawin-n1014", "DisplayName": "Sawin n^1.014 bound", "AsymptoticFunction": "u-n", "GrowthSequence": "sqrt-lat-growth", "Exponent": 1.014, "Coefficient": 1, "StatementText": "U(n) > n^{1.014} for arbitrarily large n", "SourceCitation": "Sawin, arXiv:2605.20579", "IsExplicit": true }
    ]
  },

  "Theorems": {
    "Description": "Table: Theorems. Fixed-point anchors. A theorem refers to an AsymptoticFunction and (when anchoring a bound) a specific AsymptoticLowerBound. AnchorMatchesBoundExponent is a calculated check that the anchor's named exponent equals the referenced bound's exponent — the kind of paperwork mistake that should be caught at read-time, not in review.",
    "important": true,
    "important_fields": ["IsAnchor", "AnchorMatchesBoundExponent"],
    "schema": [
      { "name": "TheoremId", "datatype": "string", "type": "raw", "nullable": false, "is_primary_key": true },
      { "name": "Name", "datatype": "string", "type": "calculated", "nullable": true, "formula": "=SUBSTITUTE(LOWER({{DisplayName}}), \" \", \"-\")" },
      { "name": "DisplayName", "datatype": "string", "type": "raw" },
      { "name": "StatementText", "datatype": "string", "type": "raw" },
      { "name": "IsAnchor", "datatype": "boolean", "type": "raw" },
      { "name": "IsProven", "datatype": "boolean", "type": "raw" },
      { "name": "ProofCitation", "datatype": "string", "type": "raw" },
      { "name": "AsymptoticFunction", "datatype": "string", "type": "relationship", "RelatedTo": "AsymptoticFunctions" },
      { "name": "AnchoredLowerBound", "datatype": "string", "type": "relationship", "RelatedTo": "AsymptoticLowerBounds" },
      { "name": "AnchoredBoundExponent", "datatype": "decimal", "type": "lookup", "formula": "=LOOKUP(AsymptoticLowerBounds!{{Exponent}}, Theorems!{{AnchoredLowerBound}}, AsymptoticLowerBounds!{{AsymptoticLowerBoundId}})" },
      { "name": "AnchoredBoundIsSuperlinear", "datatype": "boolean", "type": "lookup", "formula": "=LOOKUP(AsymptoticLowerBounds!{{IsSuperlinear}}, Theorems!{{AnchoredLowerBound}}, AsymptoticLowerBounds!{{AsymptoticLowerBoundId}})" },
      { "name": "ClaimedExponent", "datatype": "decimal", "type": "raw", "Description": "The exponent the theorem statement claims, recorded redundantly so the read-time check below can compare it against the bound's recorded exponent." },
      { "name": "AnchorMatchesBoundExponent", "datatype": "boolean", "type": "calculated", "formula": "=ABS({{ClaimedExponent}}-{{AnchoredBoundExponent}})<0.0001", "important": true, "Description": "Read-time integrity check that the theorem and its anchored bound agree on the exponent." }
    ],
    "data": [
      { "TheoremId": "thm-superlinear-unit-distance", "DisplayName": "Superlinear Unit Distance Theorem", "StatementText": "U(n) > n^{1.014} for arbitrarily large n.", "IsAnchor": true, "IsProven": true, "ProofCitation": "Sawin, arXiv:2605.20579", "AsymptoticFunction": "u-n", "AnchoredLowerBound": "sawin-n1014", "ClaimedExponent": 1.014 }
    ]
  }
