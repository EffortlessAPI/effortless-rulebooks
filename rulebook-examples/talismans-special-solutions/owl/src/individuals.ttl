@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix effortless-ntwf: <https://w3id.org/effortless-ntwf#> .

# === Individuals: AIAgents ===

effortless-ntwf:ntwf-risk-ai a effortless-ntwf:AIAgents ;
    effortless-ntwf:aIAgentId "ntwf-risk-ai" ;
    effortless-ntwf:name "RiskAnalysis-AI" ;
    effortless-ntwf:title "Risk Analysis AI Agent" ;
    effortless-ntwf:displayName "RiskAnalysis-AI" ;
    effortless-ntwf:modelVersion "risk-classifier-v2.4.1" ;
    effortless-ntwf:deployedOn "2026-01-10" .

effortless-ntwf:ntwf-health-ai a effortless-ntwf:AIAgents ;
    effortless-ntwf:aIAgentId "ntwf-health-ai" ;
    effortless-ntwf:name "DeploymentHealth-AI" ;
    effortless-ntwf:title "Deployment Health AI Agent" ;
    effortless-ntwf:displayName "DeploymentHealth-AI" ;
    effortless-ntwf:modelVersion "health-summarizer-v1.2.0" ;
    effortless-ntwf:deployedOn "2026-02-20" .

# === Individuals: AgentCapabilityConcepts ===

effortless-ntwf:cap-human-judgment a effortless-ntwf:AgentCapabilityConcepts ;
    effortless-ntwf:conceptId "cap-human-judgment" ;
    effortless-ntwf:prefLabel "Human Judgment" ;
    effortless-ntwf:altLabel "Human Decision" ;
    effortless-ntwf:definition "The filler must be a human agent capable of contextual, ethical, and legally binding decisions." ;
    effortless-ntwf:scopeNote "Used for ApprovalGate steps where requiresHumanApproval is true. AI agents may not fill roles with this capability." .

effortless-ntwf:cap-risk-analysis a effortless-ntwf:AgentCapabilityConcepts ;
    effortless-ntwf:conceptId "cap-risk-analysis" ;
    effortless-ntwf:prefLabel "Risk Analysis" ;
    effortless-ntwf:altLabel "Risk Assessment" ;
    effortless-ntwf:definition "The filler must be capable of probabilistic risk scoring over structured datasets." ;
    effortless-ntwf:scopeNote "Can be satisfied by an AIAgent with an appropriate model version (e.g. risk-classifier-v2.4.1)." .

effortless-ntwf:cap-legal-review a effortless-ntwf:AgentCapabilityConcepts ;
    effortless-ntwf:conceptId "cap-legal-review" ;
    effortless-ntwf:prefLabel "Legal Review" ;
    effortless-ntwf:altLabel "Compliance Review" ;
    effortless-ntwf:definition "The filler must have authority to certify regulatory and contractual compliance." ;
    effortless-ntwf:scopeNote "Requires a human agent. Cannot be delegated to AI or automated pipeline." .

effortless-ntwf:cap-ci-execution a effortless-ntwf:AgentCapabilityConcepts ;
    effortless-ntwf:conceptId "cap-ci-execution" ;
    effortless-ntwf:prefLabel "CI/CD Execution" ;
    effortless-ntwf:altLabel "Pipeline Execution" ;
    effortless-ntwf:definition "The filler must be an automated pipeline capable of running a deterministic build, test, and deploy sequence." ;
    effortless-ntwf:scopeNote "Satisfied by AutomatedPipelines. HumanAgents should not fill roles requiring only this capability." .

effortless-ntwf:cap-executive-authorization a effortless-ntwf:AgentCapabilityConcepts ;
    effortless-ntwf:conceptId "cap-executive-authorization" ;
    effortless-ntwf:prefLabel "Executive Authorization" ;
    effortless-ntwf:altLabel "C-Level Sign-off" ;
    effortless-ntwf:definition "The filler must hold executive authority to approve high-impact organizational changes." ;
    effortless-ntwf:scopeNote "Reserved for the top of delegation chains. Maps to the ntwf:delegatesTo escalation pattern." .

# === Individuals: ApprovalGates ===

effortless-ntwf:ntwf-release-approval-gate a effortless-ntwf:ApprovalGates ;
    effortless-ntwf:approvalGateId "ntwf-release-approval-gate" ;
    effortless-ntwf:displayName "Release Approval Gate" ;
    effortless-ntwf:workflowStep effortless-ntwf:prod-deploy-step-3 ;
    effortless-ntwf:escalationThresholdHours 4 .

# === Individuals: ArtifactTypeConcepts ===

effortless-ntwf:type-report a effortless-ntwf:ArtifactTypeConcepts ;
    effortless-ntwf:conceptId "type-report" ;
    effortless-ntwf:prefLabel "Report" ;
    effortless-ntwf:altLabel "Assessment" ;
    effortless-ntwf:definition "A human- or AI-authored analytical document (e.g. a risk assessment report)." ;
    effortless-ntwf:scopeNote "Use for narrative analytical artifacts, not for raw datasets or machine logs." .

effortless-ntwf:type-decision-record a effortless-ntwf:ArtifactTypeConcepts ;
    effortless-ntwf:conceptId "type-decision-record" ;
    effortless-ntwf:prefLabel "Decision Record" ;
    effortless-ntwf:altLabel "Authorization" ;
    effortless-ntwf:definition "An artifact recording an approval or authorization decision (e.g. a release authorization, a legal clearance)." ;
    effortless-ntwf:scopeNote "Use for sign-off / clearance / authorization artifacts." .

effortless-ntwf:type-log a effortless-ntwf:ArtifactTypeConcepts ;
    effortless-ntwf:conceptId "type-log" ;
    effortless-ntwf:prefLabel "Log" ;
    effortless-ntwf:altLabel "Machine Output" ;
    effortless-ntwf:definition "A machine-generated record of an automated activity (e.g. a deployment log)." ;
    effortless-ntwf:scopeNote "Use for deterministic pipeline/system output, not human analysis." .

# === Individuals: AutomatedPipelines ===

effortless-ntwf:ntwf-ci-pipeline a effortless-ntwf:AutomatedPipelines ;
    effortless-ntwf:automatedPipelineId "ntwf-ci-pipeline" ;
    effortless-ntwf:name "CI/CD Deploy Pipeline" ;
    effortless-ntwf:description "Automated build, test, and deployment pipeline for production releases. Deterministic execution — no probabilistic output." ;
    effortless-ntwf:displayName "CI/CD Deploy Pipeline" .

# === Individuals: ChangeLog ===

effortless-ntwf:change-1-0-0 a effortless-ntwf:ChangeLog ;
    effortless-ntwf:changeLogId "change-1-0-0" ;
    effortless-ntwf:version "1.0.0" ;
    effortless-ntwf:changeDate "2026-01-15" ;
    effortless-ntwf:changeKind "major" ;
    effortless-ntwf:motivatingQuestion "All eight competency questions (CQ1-CQ8)." ;
    effortless-ntwf:termsAffected "Initial release: 9 classes, 13 object properties, 5 datatype properties, 2 CBox schemes." ;
    effortless-ntwf:rationale "First validated release of the NTWF workflow ontology; passes the 104-test suite." ;
    effortless-ntwf:approvedBy effortless-ntwf:gov-authority .

effortless-ntwf:change-1-1-0 a effortless-ntwf:ChangeLog ;
    effortless-ntwf:changeLogId "change-1-1-0" ;
    effortless-ntwf:version "1.1.0" ;
    effortless-ntwf:changeDate "2026-03-20" ;
    effortless-ntwf:changeKind "minor" ;
    effortless-ntwf:motivatingQuestion "Which AI agent was executing this step on March 1, 2026?" ;
    effortless-ntwf:termsAffected "Added filledBy assignment history (RoleAssignments) with validity periods; AIAgent deployment date; agent-type-change audit witnesses." ;
    effortless-ntwf:rationale "Operational governance needed retained filledBy history so historical 'as of date' and blast-radius queries are answerable without discarding provenance. Additive and backward compatible — a minor, backward-compatible change, so the steward is authorized to approve and deploy it without authority review." ;
    effortless-ntwf:approvedBy effortless-ntwf:gov-steward .

# === Individuals: CompetencyQuestions ===

effortless-ntwf:cq-1 a effortless-ntwf:CompetencyQuestions ;
    effortless-ntwf:competencyQuestionId "cq-1" ;
    effortless-ntwf:number "1" ;
    effortless-ntwf:displayName "Steps and order" ;
    effortless-ntwf:questionText "What are all the steps in the release process, and in what order do they execute?" ;
    effortless-ntwf:targetTable "Workflows" ;
    effortless-ntwf:targetField "CountOfPrecedenceClosurePairs" ;
    effortless-ntwf:answerKind "list" ;
    effortless-ntwf:expectedAnswer "5 steps, ordered 1 -> 2 -> 3 -> 4 -> 5 (10 closure pairs)" ;
    effortless-ntwf:explanation "WorkflowSteps ordered by SequencePosition; the order is the transitive closure of the asserted StepPrecedence edges, materialized as ntwf:precedesStep." ;
    effortless-ntwf:sortOrder "1" ;
    effortless-ntwf:isActive true .

effortless-ntwf:cq-2 a effortless-ntwf:CompetencyQuestions ;
    effortless-ntwf:competencyQuestionId "cq-2" ;
    effortless-ntwf:number "2" ;
    effortless-ntwf:displayName "Who approves" ;
    effortless-ntwf:questionText "Who or what is responsible for approving a production deployment?" ;
    effortless-ntwf:targetTable "ApprovalGates" ;
    effortless-ntwf:targetField "GateApproverHuman" ;
    effortless-ntwf:answerKind "scalar" ;
    effortless-ntwf:expectedAnswer "Maria Gonzalez" ;
    effortless-ntwf:explanation "The Release Approval Gate (step 3) -> its AssignedRole (Release Manager) -> FilledByHumanAgent. The role-agent indirection is resolved by the GateApproverHuman lookup." ;
    effortless-ntwf:sortOrder "2" ;
    effortless-ntwf:isActive true .

effortless-ntwf:cq-3 a effortless-ntwf:CompetencyQuestions ;
    effortless-ntwf:competencyQuestionId "cq-3" ;
    effortless-ntwf:number "3" ;
    effortless-ntwf:displayName "AI vs human steps" ;
    effortless-ntwf:questionText "Which steps are executed by AI agents, and which require human decision?" ;
    effortless-ntwf:targetTable "Workflows" ;
    effortless-ntwf:targetField "CountAISteps" ;
    effortless-ntwf:answerKind "list" ;
    effortless-ntwf:expectedAnswer "AI-executed: steps 1, 5 - human-required: steps 2, 3" ;
    effortless-ntwf:explanation "Each step's ExecutingAgentType (via its role's filler type) classifies AI vs pipeline vs human; RequiresHumanApproval marks the human-decision steps. CountAISteps aggregates the AI side." ;
    effortless-ntwf:sortOrder "3" ;
    effortless-ntwf:isActive true .

effortless-ntwf:cq-4 a effortless-ntwf:CompetencyQuestions ;
    effortless-ntwf:competencyQuestionId "cq-4" ;
    effortless-ntwf:number "4" ;
    effortless-ntwf:displayName "Artifact lineage" ;
    effortless-ntwf:questionText "What artifacts does the review produce, and what consumes them downstream?" ;
    effortless-ntwf:targetTable "WorkflowArtifacts" ;
    effortless-ntwf:targetField "DerivedFromArtifact" ;
    effortless-ntwf:answerKind "list" ;
    effortless-ntwf:expectedAnswer "5 artifacts in a wasDerivedFrom chain: Risk Report -> Legal Clearance -> Release Authorization -> Deployment Log -> Post-Deployment Report" ;
    effortless-ntwf:explanation "WorkflowArtifacts.ProducedByStep gives the producer; DerivedFromArtifact gives the PROV wasDerivedFrom parent; RequiredBySteps gives the downstream consumer." ;
    effortless-ntwf:sortOrder "4" ;
    effortless-ntwf:isActive true .

effortless-ntwf:cq-5 a effortless-ntwf:CompetencyQuestions ;
    effortless-ntwf:competencyQuestionId "cq-5" ;
    effortless-ntwf:number "5" ;
    effortless-ntwf:displayName "Stale over 12 months" ;
    effortless-ntwf:questionText "Which workflows have not been reviewed or updated in twelve months?" ;
    effortless-ntwf:targetTable "Workflows" ;
    effortless-ntwf:targetField "IsStale" ;
    effortless-ntwf:answerKind "scalar" ;
    effortless-ntwf:expectedAnswer "No - Production Deployment is not stale (MonthsSinceModified 2 <= 12)" ;
    effortless-ntwf:explanation "IsStale = MonthsSinceModified > StalenessThresholdMonths. The seed workflow was modified 2 months ago against a 12-month threshold, so it is not stale." ;
    effortless-ntwf:sortOrder "5" ;
    effortless-ntwf:isActive true .

effortless-ntwf:cq-6 a effortless-ntwf:CompetencyQuestions ;
    effortless-ntwf:competencyQuestionId "cq-6" ;
    effortless-ntwf:number "6" ;
    effortless-ntwf:displayName "Escalation path" ;
    effortless-ntwf:questionText "What happens when the VP of Engineering is unavailable during escalation?" ;
    effortless-ntwf:targetTable "Roles" ;
    effortless-ntwf:targetField "DelegatesTo" ;
    effortless-ntwf:answerKind "scalar" ;
    effortless-ntwf:expectedAnswer "Escalates Release Manager -> VP of Engineering -> Chief Technology Officer" ;
    effortless-ntwf:explanation "Roles.DelegatesTo is a transitive chain. With the VP of Engineering unavailable, the next hop in the closure is the CTO." ;
    effortless-ntwf:sortOrder "6" ;
    effortless-ntwf:isActive true .

effortless-ntwf:cq-7 a effortless-ntwf:CompetencyQuestions ;
    effortless-ntwf:competencyQuestionId "cq-7" ;
    effortless-ntwf:number "7" ;
    effortless-ntwf:displayName "Engineering and Legal" ;
    effortless-ntwf:questionText "Which workflows involve both Engineering and Legal?" ;
    effortless-ntwf:targetTable "Workflows" ;
    effortless-ntwf:targetField "InvolvesEngineeringAndLegal" ;
    effortless-ntwf:answerKind "scalar" ;
    effortless-ntwf:expectedAnswer "Yes - Production Deployment involves both (Engineering-owned steps and Legal-owned steps)" ;
    effortless-ntwf:explanation "InvolvesEngineeringAndLegal = AND(CountEngineeringOwnedSteps > 0, CountLegalOwnedSteps > 0). Step 2 is Legal-owned; steps 1/3/4/5 are Engineering-owned." ;
    effortless-ntwf:sortOrder "7" ;
    effortless-ntwf:isActive true .

effortless-ntwf:cq-8 a effortless-ntwf:CompetencyQuestions ;
    effortless-ntwf:competencyQuestionId "cq-8" ;
    effortless-ntwf:number "8" ;
    effortless-ntwf:displayName "Datasets and AI" ;
    effortless-ntwf:questionText "What datasets does the review consume, and which AI agents processed them?" ;
    effortless-ntwf:targetTable "Datasets" ;
    effortless-ntwf:targetField "ConsumedBySteps" ;
    effortless-ntwf:answerKind "list" ;
    effortless-ntwf:expectedAnswer "Q1 2026 Risk Metrics, consumed by the AI Risk Assessment step and processed by RiskAnalysis-AI" ;
    effortless-ntwf:explanation "Datasets.ConsumedBySteps (inverse of WorkflowSteps.ConsumesDataset) gives the consuming step; that step's role filler resolves the processing AI agent." ;
    effortless-ntwf:sortOrder "8" ;
    effortless-ntwf:isActive true .

