# === Individuals: Workflows ===

effortless-ntwf:production-deployment a effortless-ntwf:Workflows ;
    effortless-ntwf:workflowId "production-deployment" ;
    effortless-ntwf:displayName "Production Deployment" ;
    effortless-ntwf:title "Production Deployment Workflow" ;
    effortless-ntwf:description "The primary NTWF ABox example. A 5-step workflow for deploying software to production at Talisman's Special Solutions. Steps involve a human Release Manager (step 1), an AI Risk Analysis Agent (step 2), a human Legal Compliance Reviewer at an Approval Gate (step 3), an automated CI/CD pipeline (step 4), and the Release Manager again for the post-deployment report (step 5). Demonstrates all three agent types, the delegation chain, artifact provenance, and DCAT dataset consumption." ;
    effortless-ntwf:identifier "WF-PROD-DEPLOY-001" ;
    effortless-ntwf:modified "2026-04-03T00:00:00-05:00" ;
    effortless-ntwf:created "2026-01-10T00:00:00-06:00" ;
