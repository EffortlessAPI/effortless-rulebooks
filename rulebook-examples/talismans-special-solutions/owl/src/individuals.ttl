# === Individuals: GovernanceRoles ===

effortless-ntwf:gov-steward a effortless-ntwf:GovernanceRoles ;
    effortless-ntwf:governanceRoleId "gov-steward" ;
    effortless-ntwf:displayName "Ontology Steward" ;
    effortless-ntwf:kind "Steward" ;
    effortless-ntwf:responsibilities "Monitors the ontology for drift, tracks external-dependency updates (PROV-O, FOAF, Dublin Core, DCAT, Schema.org), fields questions from users, maintains documentation, and keeps the validation suite current. Identifies that a change is needed but does not approve it. Runs the periodic (at minimum quarterly) competency-question review: new unanswerable questions become scope-change requests, obsolete questions become deprecation candidates, and questions that return wrong answers are defects." ;
    effortless-ntwf:approvalScope "none" ;
    effortless-ntwf:heldBy "Engineering Knowledge Infrastructure team" .

effortless-ntwf:gov-authority a effortless-ntwf:GovernanceRoles ;
    effortless-ntwf:governanceRoleId "gov-authority" ;
    effortless-ntwf:displayName "Ontology Authority" ;
    effortless-ntwf:kind "Authority" ;
    effortless-ntwf:responsibilities "Holds the power to approve changes to the CBox, ABox, and TBox. Decides how and where a change is made. Reviews changes proposed by the steward so that no single person alters the knowledge graph's semantic integrity unchecked." ;
    effortless-ntwf:approvalScope "CBox, ABox, TBox" ;
    effortless-ntwf:heldBy "Workflow Governance function" .

