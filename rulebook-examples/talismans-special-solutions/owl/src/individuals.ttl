# === Individuals: WorkflowStatusConcepts ===

erb:status-draft a erb:WorkflowStatusConcepts ;
    erb:conceptId "status-draft" ;
    erb:prefLabel "Draft" ;
    erb:altLabel "In Progress" ;
    erb:definition "Workflow is being authored or reviewed and is not yet in production use." ;
    erb:scopeNote "Set this status when the workflow has not completed its initial review cycle." .

erb:status-active a erb:WorkflowStatusConcepts ;
    erb:conceptId "status-active" ;
    erb:prefLabel "Active" ;
    erb:altLabel "In Use" ;
    erb:definition "Workflow is approved and currently being executed by the organization." ;
    erb:scopeNote "Only active workflows should be assigned to running process instances." .

erb:status-deprecated a erb:WorkflowStatusConcepts ;
    erb:conceptId "status-deprecated" ;
    erb:prefLabel "Deprecated" ;
    erb:altLabel "Superseded" ;
    erb:definition "Workflow has been replaced by a newer version and should not be used for new instances." ;
    erb:scopeNote "Deprecated workflows may still have in-flight instances; do not archive until all instances close." .

erb:status-archived a erb:WorkflowStatusConcepts ;
