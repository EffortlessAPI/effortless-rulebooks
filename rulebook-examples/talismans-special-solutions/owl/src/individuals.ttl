    erb:workflowId "production-deployment" ;
    erb:displayName "Production Deployment" ;
    erb:title "Production Deployment Workflow" ;
    erb:description "The primary NTWF ABox example. A 5-step workflow for deploying software to production at Talisman's Special Solutions. Steps involve an AI Risk Analysis Agent (step 1), a human Legal Compliance Reviewer (step 2), a human Release Manager at the Release Approval Gate (step 3), an automated CI/CD pipeline (step 4), and the Release Manager again for the post-deployment report (step 5). Demonstrates all three agent types, the delegation chain, artifact provenance, and DCAT dataset consumption." ;
    erb:identifier "WF-PROD-DEPLOY-001" ;
    erb:modified "2025-07-11T05:00:00.000Z" ;
    erb:created "2026-01-10T06:00:00.000Z" ;
    erb:maxPlanMinutes 240 ;
    erb:stalenessThresholdMonths 12 ;
    erb:isOffHoursDeployment false ;
    erb:workflowStatus erb:status-active .

