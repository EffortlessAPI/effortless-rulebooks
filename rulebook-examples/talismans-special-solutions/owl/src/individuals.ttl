effortless-ntwf:mut-ai-at-human-gate a effortless-ntwf:ConformanceTests ;
    effortless-ntwf:conformanceTestId "mut-ai-at-human-gate" ;
    effortless-ntwf:displayName "Assign AI to the human-only gate fires the violation" ;
    effortless-ntwf:featureRef "II-3,Suite-4" ;
    effortless-ntwf:section "Mutation" ;
    effortless-ntwf:testKind "mutation" ;
    effortless-ntwf:targetRef "Roles/ntwf-release-manager-role" ;
    effortless-ntwf:expect "{\"edits\": [{\"class\": \"Roles\", \"id\": \"ntwf-release-manager-role\", \"set\": {\"filledByHumanAgent\": \"\", \"filledByAIAgent\": \"ntwf-risk-ai\", \"filledByAutomatedPipeline\": \"\"}}], \"assert\": [{\"class\": \"WorkflowSteps\", \"id\": \"prod-deploy-step-3\", \"field\": \"approvalConsistencyViolation\", \"equals\": true}, {\"class\": \"Workflows\", \"id\": \"production-deployment\", \"field\": \"hasConsistencyViolation\", \"equals\": true}]}" ;
    effortless-ntwf:explanation "Suite-4 inject-an-error: filling the gate role with an AI must flip ApprovalConsistencyViolation on the step AND roll up to the workflow, on BOTH engines." ;
    effortless-ntwf:sortOrder 690 ;
    effortless-ntwf:isEnabled true .

effortless-ntwf:mut-backdate-goes-stale a effortless-ntwf:ConformanceTests ;
    effortless-ntwf:conformanceTestId "mut-backdate-goes-stale" ;
    effortless-ntwf:displayName "Backdating the review makes the workflow stale" ;
    effortless-ntwf:featureRef "IV-1,CQ5" ;
    effortless-ntwf:section "Mutation" ;
    effortless-ntwf:testKind "mutation" ;
    effortless-ntwf:targetRef "Workflows/production-deployment" ;
    effortless-ntwf:expect "{\"edits\": [{\"class\": \"Workflows\", \"id\": \"production-deployment\", \"set\": {\"modified\": \"2024-01-01T00:00:00-05:00\"}}], \"assert\": [{\"class\": \"Workflows\", \"id\": \"production-deployment\", \"field\": \"isStale\", \"equals\": true}]}" ;
    effortless-ntwf:explanation "Backdate dct:modified past the staleness window: IsStale must flip true." ;
    effortless-ntwf:sortOrder 700 ;
    effortless-ntwf:isEnabled true .

effortless-ntwf:mut-stale-and-ai-join a effortless-ntwf:ConformanceTests ;
    effortless-ntwf:conformanceTestId "mut-stale-and-ai-join" ;
    effortless-ntwf:displayName "Backdating fires the stale-AND-AI compliance join" ;
    effortless-ntwf:featureRef "IV-2" ;
    effortless-ntwf:section "Mutation" ;
    effortless-ntwf:testKind "mutation" ;
    effortless-ntwf:targetRef "Workflows/production-deployment" ;
    effortless-ntwf:expect "{\"edits\": [{\"class\": \"Workflows\", \"id\": \"production-deployment\", \"set\": {\"modified\": \"2024-01-01T00:00:00-05:00\"}}], \"assert\": [{\"class\": \"Workflows\", \"id\": \"production-deployment\", \"field\": \"isStaleAndHasAIAgent\", \"equals\": true}]}" ;
    effortless-ntwf:explanation "Seed facts already include AI-executed steps, so staleness alone completes the IsStaleAndHasAIAgent join." ;
    effortless-ntwf:sortOrder 710 ;
    effortless-ntwf:isEnabled true .

effortless-ntwf:mut-gate-not-required a effortless-ntwf:ConformanceTests ;
    effortless-ntwf:conformanceTestId "mut-gate-not-required" ;
    effortless-ntwf:displayName "Dropping the sign-off requirement clears the violation" ;
    effortless-ntwf:featureRef "II-3" ;
    effortless-ntwf:section "Mutation" ;
    effortless-ntwf:testKind "mutation" ;
    effortless-ntwf:targetRef "WorkflowSteps/prod-deploy-step-3" ;
    effortless-ntwf:expect "{\"edits\": [{\"class\": \"Roles\", \"id\": \"ntwf-release-manager-role\", \"set\": {\"filledByHumanAgent\": \"\", \"filledByAIAgent\": \"ntwf-risk-ai\", \"filledByAutomatedPipeline\": \"\"}}, {\"class\": \"WorkflowSteps\", \"id\": \"prod-deploy-step-3\", \"set\": {\"requiresHumanApproval\": false}}], \"assert\": [{\"class\": \"WorkflowSteps\", \"id\": \"prod-deploy-step-3\", \"field\": \"approvalConsistencyViolation\", \"equals\": false}]}" ;
    effortless-ntwf:explanation "The violation is an AND of requiresHumanApproval and a non-human filler: with the requirement off, an AI filler is consistent." ;
    effortless-ntwf:sortOrder 720 ;
    effortless-ntwf:isEnabled true .

