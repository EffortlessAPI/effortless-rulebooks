    effortless-ntwf:roleId "ntwf-vp-engineering-role" ;
    effortless-ntwf:displayName "VP of Engineering" ;
    effortless-ntwf:label "VP of Engineering" ;
    effortless-ntwf:comment "First escalation target when Release Manager is unavailable. Demonstrates ntwf:delegatesTo chain: Release Manager → VP Engineering → CTO." ;
    effortless-ntwf:hasCapability effortless-ntwf:cap-human-judgment ;
    effortless-ntwf:filledByHumanAgent effortless-ntwf:ntwf-david-chen ;
    effortless-ntwf:ownedBy effortless-ntwf:ntwf-engineering ;
    effortless-ntwf:delegatesTo effortless-ntwf:ntwf-cto-role ;
    effortless-ntwf:fromDelegatesTo effortless-ntwf:ntwf-release-manager-role .

