# === Shape with rules for RoleAssignments ===
erb:RoleAssignmentsShape a sh:NodeShape ;
    sh:targetClass erb:RoleAssignments ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_ParentPath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:parentPath ?_result .
            }
            WHERE {
    $this a erb:RoleAssignments .
                OPTIONAL { $this erb:role ?j0 . }
                OPTIONAL { ?j1 a erb:Roles ; erb:roleId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 erb:relativePath ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_RelativePath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:relativePath ?_result .
            }
            WHERE {
    $this a erb:RoleAssignments .
    OPTIONAL { $this erb:parentPath ?parent_path . }
    OPTIONAL { $this erb:roleAssignmentId ?role_assignment_id . }
                BIND(CONCAT(?parent_path, "/assignments/", ?role_assignment_id) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_Iri" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:iri ?_result .
            }
            WHERE {
    $this a erb:RoleAssignments .
    OPTIONAL { $this erb:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_Name" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:name ?_result .
            }
            WHERE {
    $this a erb:RoleAssignments .
    OPTIONAL { $this erb:role ?role . }
    OPTIONAL { $this erb:validFrom ?valid_from . }
    OPTIONAL { $this erb:validTo ?valid_to . }
                BIND(CONCAT(?role, " [", ?valid_from, " -> ", IF((!BOUND(?valid_to) || STR(?valid_to) = ""), "open", ?valid_to), "]") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_FillerType" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:fillerType ?_result .
            }
            WHERE {
    $this a erb:RoleAssignments .
    OPTIONAL { $this erb:filledByAIAgent ?filled_by_ai_agent . }
    OPTIONAL { $this erb:filledByAutomatedPipeline ?filled_by_automated_pipeline . }
    OPTIONAL { $this erb:filledByHumanAgent ?filled_by_human_agent . }
                BIND(IF((!((!BOUND(?filled_by_human_agent) || STR(?filled_by_human_agent) = ""))), "HumanAgent", IF((!((!BOUND(?filled_by_ai_agent) || STR(?filled_by_ai_agent) = ""))), "AIAgent", IF((!((!BOUND(?filled_by_automated_pipeline) || STR(?filled_by_automated_pipeline) = ""))), "AutomatedPipeline", ""))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_IsCurrent" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:isCurrent ?_result .
            }
            WHERE {
    $this a erb:RoleAssignments .
    OPTIONAL { $this erb:validTo ?valid_to . }
                BIND((!BOUND(?valid_to) || STR(?valid_to) = "") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_WasActiveAsOfAuditDate" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:wasActiveAsOfAuditDate ?_result .
            }
            WHERE {
    $this a erb:RoleAssignments .
    OPTIONAL { $this erb:validFrom ?valid_from . }
    OPTIONAL { $this erb:validTo ?valid_to . }
                BIND(((?valid_from <= "2026-03-01") && ((!BOUND(?valid_to) || STR(?valid_to) = "") || (?valid_to > "2026-03-01"))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_IsAgentTypeChange" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:isAgentTypeChange ?_result .
            }
            WHERE {
    $this a erb:RoleAssignments .
    OPTIONAL { $this erb:fillerType ?filler_type . }
    OPTIONAL { $this erb:priorFillerType ?prior_filler_type . }
                BIND(((!((!BOUND(?prior_filler_type) || STR(?prior_filler_type) = ""))) && (?prior_filler_type != ?filler_type)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_RequiresComplianceAudit" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:requiresComplianceAudit ?_result .
            }
            WHERE {
    $this a erb:RoleAssignments .
    OPTIONAL { $this erb:fillerType ?filler_type . }
    OPTIONAL { $this erb:priorFillerType ?prior_filler_type . }
                BIND(((!((!BOUND(?prior_filler_type) || STR(?prior_filler_type) = ""))) && (REPLACE(STR(?prior_filler_type), "^.*#", "") = "AIAgent") && (REPLACE(STR(?filler_type), "^.*#", "") = "HumanAgent")) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for Roles ===
erb:RolesShape a sh:NodeShape ;
    sh:targetClass erb:Roles ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Roles_RelativePath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:relativePath ?_result .
            }
            WHERE {
    $this a erb:Roles .
    OPTIONAL { $this erb:roleId ?role_id . }
                BIND(CONCAT("roles/", ?role_id) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Roles_Iri" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:iri ?_result .
            }
            WHERE {
    $this a erb:Roles .
    OPTIONAL { $this erb:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Roles_Name" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:name ?_result .
            }
            WHERE {
    $this a erb:Roles .
    OPTIONAL { $this erb:displayName ?display_name . }
                BIND(REPLACE(LCASE(?display_name), " ", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Roles_FilledByArmCount" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:filledByArmCount ?_result .
            }
            WHERE {
    $this a erb:Roles .
    OPTIONAL { $this erb:filledByAIAgent ?filled_by_ai_agent . }
    OPTIONAL { $this erb:filledByAutomatedPipeline ?filled_by_automated_pipeline . }
    OPTIONAL { $this erb:filledByHumanAgent ?filled_by_human_agent . }
                BIND(((IF((!((!BOUND(?filled_by_human_agent) || STR(?filled_by_human_agent) = ""))), 1, 0) + IF((!((!BOUND(?filled_by_ai_agent) || STR(?filled_by_ai_agent) = ""))), 1, 0)) + IF((!((!BOUND(?filled_by_automated_pipeline) || STR(?filled_by_automated_pipeline) = ""))), 1, 0)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Roles_HasExactlyOneFiller" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:hasExactlyOneFiller ?_result .
            }
            WHERE {
    $this a erb:Roles .
    OPTIONAL { $this erb:filledByArmCount ?filled_by_arm_count . }
                BIND((?filled_by_arm_count = 1) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Roles_FillerType" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:fillerType ?_result .
            }
            WHERE {
    $this a erb:Roles .
    OPTIONAL { $this erb:filledByAIAgent ?filled_by_ai_agent . }
    OPTIONAL { $this erb:filledByAutomatedPipeline ?filled_by_automated_pipeline . }
    OPTIONAL { $this erb:filledByHumanAgent ?filled_by_human_agent . }
                BIND(IF((!((!BOUND(?filled_by_human_agent) || STR(?filled_by_human_agent) = ""))), "HumanAgent", IF((!((!BOUND(?filled_by_ai_agent) || STR(?filled_by_ai_agent) = ""))), "AIAgent", IF((!((!BOUND(?filled_by_automated_pipeline) || STR(?filled_by_automated_pipeline) = ""))), "AutomatedPipeline", ""))) AS ?_result)
            }
        """ ;
    ] .

