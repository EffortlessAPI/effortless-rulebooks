# === Shape with rules for RoleAssignments ===
effortless-ntwf:RoleAssignmentsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:RoleAssignments ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:RoleAssignments .
                OPTIONAL { $this effortless-ntwf:role ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Roles ; effortless-ntwf:roleId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:RoleAssignments .
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
    OPTIONAL { $this effortless-ntwf:roleAssignmentId ?role_assignment_id . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/assignments/", IF(isIRI(?role_assignment_id), REPLACE(STR(?role_assignment_id), "^.*[#/]", ""), STR(?role_assignment_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_Iri" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:iri ?_result .
            }
            WHERE {
    $this a effortless-ntwf:RoleAssignments .
    OPTIONAL { $this effortless-ntwf:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:RoleAssignments .
    OPTIONAL { $this effortless-ntwf:role ?role . }
    OPTIONAL { $this effortless-ntwf:validFrom ?valid_from . }
    OPTIONAL { $this effortless-ntwf:validTo ?valid_to . }
                BIND(CONCAT(IF(isIRI(?role), REPLACE(STR(?role), "^.*[#/]", ""), STR(?role)), " [", IF(isIRI(?valid_from), REPLACE(STR(?valid_from), "^.*[#/]", ""), STR(?valid_from)), " -> ", IF(isIRI(IF((!BOUND(?valid_to) || STR(?valid_to) = ""), "open", ?valid_to)), REPLACE(STR(IF((!BOUND(?valid_to) || STR(?valid_to) = ""), "open", ?valid_to)), "^.*[#/]", ""), STR(IF((!BOUND(?valid_to) || STR(?valid_to) = ""), "open", ?valid_to))), "]") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_FillerType" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:fillerType ?_result .
            }
            WHERE {
    $this a effortless-ntwf:RoleAssignments .
    OPTIONAL { $this effortless-ntwf:filledByAIAgent ?filled_by_ai_agent . }
    OPTIONAL { $this effortless-ntwf:filledByAutomatedPipeline ?filled_by_automated_pipeline . }
    OPTIONAL { $this effortless-ntwf:filledByHumanAgent ?filled_by_human_agent . }
                BIND(IF((!((!BOUND(?filled_by_human_agent) || STR(?filled_by_human_agent) = ""))), "HumanAgent", IF((!((!BOUND(?filled_by_ai_agent) || STR(?filled_by_ai_agent) = ""))), "AIAgent", IF((!((!BOUND(?filled_by_automated_pipeline) || STR(?filled_by_automated_pipeline) = ""))), "AutomatedPipeline", ""))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_IsCurrent" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isCurrent ?_result .
            }
            WHERE {
    $this a effortless-ntwf:RoleAssignments .
    OPTIONAL { $this effortless-ntwf:validTo ?valid_to . }
                BIND((!BOUND(?valid_to) || STR(?valid_to) = "") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_WasActiveAsOfAuditDate" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:wasActiveAsOfAuditDate ?_result .
            }
            WHERE {
    $this a effortless-ntwf:RoleAssignments .
    OPTIONAL { $this effortless-ntwf:validFrom ?valid_from . }
    OPTIONAL { $this effortless-ntwf:validTo ?valid_to . }
                BIND(((STR(?valid_from) <= "2026-03-01") && ((!BOUND(?valid_to) || STR(?valid_to) = "") || (STR(?valid_to) > "2026-03-01"))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_IsAgentTypeChange" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isAgentTypeChange ?_result .
            }
            WHERE {
    $this a effortless-ntwf:RoleAssignments .
    OPTIONAL { $this effortless-ntwf:fillerType ?filler_type . }
    OPTIONAL { $this effortless-ntwf:priorFillerType ?prior_filler_type . }
                BIND(((!((!BOUND(?prior_filler_type) || STR(?prior_filler_type) = ""))) && (?prior_filler_type != ?filler_type)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_RoleAssignments_RequiresComplianceAudit" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:requiresComplianceAudit ?_result .
            }
            WHERE {
    $this a effortless-ntwf:RoleAssignments .
    OPTIONAL { $this effortless-ntwf:fillerType ?filler_type . }
    OPTIONAL { $this effortless-ntwf:priorFillerType ?prior_filler_type . }
                BIND(((!((!BOUND(?prior_filler_type) || STR(?prior_filler_type) = ""))) && (REPLACE(COALESCE(STR(?prior_filler_type), ""), "^.*#", "") = "AIAgent") && (REPLACE(COALESCE(STR(?filler_type), ""), "^.*#", "") = "HumanAgent")) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for Roles ===
effortless-ntwf:RolesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Roles ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Roles_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Roles .
    OPTIONAL { $this effortless-ntwf:roleId ?role_id . }
                BIND(CONCAT("roles/", IF(isIRI(?role_id), REPLACE(STR(?role_id), "^.*[#/]", ""), STR(?role_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Roles_Iri" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:iri ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Roles .
    OPTIONAL { $this effortless-ntwf:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Roles_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Roles .
    OPTIONAL { $this effortless-ntwf:displayName ?display_name . }
                BIND(REPLACE(LCASE(?display_name), " ", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Roles_FilledByArmCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:filledByArmCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Roles .
    OPTIONAL { $this effortless-ntwf:filledByAIAgent ?filled_by_ai_agent . }
    OPTIONAL { $this effortless-ntwf:filledByAutomatedPipeline ?filled_by_automated_pipeline . }
    OPTIONAL { $this effortless-ntwf:filledByHumanAgent ?filled_by_human_agent . }
                BIND(((IF((!((!BOUND(?filled_by_human_agent) || STR(?filled_by_human_agent) = ""))), 1, 0) + IF((!((!BOUND(?filled_by_ai_agent) || STR(?filled_by_ai_agent) = ""))), 1, 0)) + IF((!((!BOUND(?filled_by_automated_pipeline) || STR(?filled_by_automated_pipeline) = ""))), 1, 0)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Roles_HasExactlyOneFiller" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:hasExactlyOneFiller ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Roles .
    OPTIONAL { $this effortless-ntwf:filledByArmCount ?filled_by_arm_count . }
                BIND((?filled_by_arm_count = 1) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Roles_FillerType" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:fillerType ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Roles .
    OPTIONAL { $this effortless-ntwf:filledByAIAgent ?filled_by_ai_agent . }
    OPTIONAL { $this effortless-ntwf:filledByAutomatedPipeline ?filled_by_automated_pipeline . }
    OPTIONAL { $this effortless-ntwf:filledByHumanAgent ?filled_by_human_agent . }
                BIND(IF((!((!BOUND(?filled_by_human_agent) || STR(?filled_by_human_agent) = ""))), "HumanAgent", IF((!((!BOUND(?filled_by_ai_agent) || STR(?filled_by_ai_agent) = ""))), "AIAgent", IF((!((!BOUND(?filled_by_automated_pipeline) || STR(?filled_by_automated_pipeline) = ""))), "AutomatedPipeline", ""))) AS ?_result)
            }
        """ ;
    ] .

