@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix effortless-ntwf: <https://w3id.org/effortless-ntwf#> .

# === Shape with rules for AIAgents ===
effortless-ntwf:AIAgentsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:AIAgents ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AIAgents_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AIAgents .
    OPTIONAL { $this effortless-ntwf:aIAgentId ?ai_agent_id . }
                BIND(CONCAT("ai-agents/", IF(isIRI(?ai_agent_id), REPLACE(STR(?ai_agent_id), "^.*[#/]", ""), STR(?ai_agent_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AIAgents_Iri" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:iri ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AIAgents .
    OPTIONAL { $this effortless-ntwf:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AIAgents_CountAttributedArtifacts" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countAttributedArtifacts ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AIAgents .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:WorkflowArtifacts .
                    ?child effortless-ntwf:attributedToAIAgent $this .
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AIAgents_CountImpactedWorkflows" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countImpactedWorkflows ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AIAgents .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:WorkflowArtifacts .
                    ?child effortless-ntwf:attributedToAIAgent $this .
                    OPTIONAL { ?child effortless-ntwf:hasProducingWorkflow ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] .

# === Shape with rules for AgentCapabilityConcepts ===
effortless-ntwf:AgentCapabilityConceptsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:AgentCapabilityConcepts ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AgentCapabilityConcepts_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AgentCapabilityConcepts .
    OPTIONAL { $this effortless-ntwf:conceptId ?concept_id . }
                BIND(CONCAT("concepts/agent-capability/", IF(isIRI(?concept_id), REPLACE(STR(?concept_id), "^.*[#/]", ""), STR(?concept_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AgentCapabilityConcepts_Iri" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:iri ?_result .
            }
            WHERE {
    $this a effortless-ntwf:AgentCapabilityConcepts .
    OPTIONAL { $this effortless-ntwf:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for ApprovalGates ===
effortless-ntwf:ApprovalGatesShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:ApprovalGates ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ApprovalGates_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ApprovalGates .
                OPTIONAL { $this effortless-ntwf:workflowStep ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:WorkflowSteps ; effortless-ntwf:workflowStepId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ApprovalGates_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ApprovalGates .
    OPTIONAL { $this effortless-ntwf:approvalGateId ?approval_gate_id . }
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/approval-gates/", IF(isIRI(?approval_gate_id), REPLACE(STR(?approval_gate_id), "^.*[#/]", ""), STR(?approval_gate_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ApprovalGates_Iri" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:iri ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ApprovalGates .
    OPTIONAL { $this effortless-ntwf:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ApprovalGates_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ApprovalGates .
    OPTIONAL { $this effortless-ntwf:displayName ?display_name . }
                BIND(REPLACE(LCASE(?display_name), " ", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ApprovalGates_GateRole" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:gateRole ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ApprovalGates .
                OPTIONAL { $this effortless-ntwf:workflowStep ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:WorkflowSteps ; effortless-ntwf:workflowStepId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 effortless-ntwf:assignedRole ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ApprovalGates_GateApproverHuman" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:gateApproverHuman ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ApprovalGates .
                OPTIONAL { $this effortless-ntwf:gateRole ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Roles ; effortless-ntwf:roleId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 effortless-ntwf:filledByHumanAgent ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] .

