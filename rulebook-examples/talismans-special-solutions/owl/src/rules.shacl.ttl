                $this erb:iri ?_result .
            }
            WHERE {
    $this a erb:AgentCapabilityConcepts .
    OPTIONAL { $this erb:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for ApprovalGates ===
erb:ApprovalGatesShape a sh:NodeShape ;
    sh:targetClass erb:ApprovalGates ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ApprovalGates_ParentPath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:parentPath ?_result .
            }
            WHERE {
    $this a erb:ApprovalGates .
                OPTIONAL { $this erb:workflowStep ?j0 . }
                OPTIONAL { ?j1 a erb:WorkflowSteps ; erb:workflowStepId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 erb:relativePath ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ApprovalGates_RelativePath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:relativePath ?_result .
            }
            WHERE {
    $this a erb:ApprovalGates .
    OPTIONAL { $this erb:approvalGateId ?approval_gate_id . }
    OPTIONAL { $this erb:parentPath ?parent_path . }
                BIND(CONCAT(?parent_path, "/approval-gates/", ?approval_gate_id) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ApprovalGates_Iri" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:iri ?_result .
            }
            WHERE {
    $this a erb:ApprovalGates .
    OPTIONAL { $this erb:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ApprovalGates_Name" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:name ?_result .
            }
            WHERE {
    $this a erb:ApprovalGates .
    OPTIONAL { $this erb:displayName ?display_name . }
                BIND(REPLACE(LCASE(?display_name), " ", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ApprovalGates_GateRole" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:gateRole ?_result .
            }
            WHERE {
    $this a erb:ApprovalGates .
                OPTIONAL { $this erb:workflowStep ?j0 . }
                OPTIONAL { ?j1 a erb:WorkflowSteps ; erb:workflowStepId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 erb:assignedRole ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ApprovalGates_GateApproverHuman" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:gateApproverHuman ?_result .
            }
            WHERE {
    $this a erb:ApprovalGates .
                OPTIONAL { $this erb:gateRole ?j0 . }
                OPTIONAL { ?j1 a erb:Roles ; erb:roleId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 erb:filledByHumanAgent ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] .

