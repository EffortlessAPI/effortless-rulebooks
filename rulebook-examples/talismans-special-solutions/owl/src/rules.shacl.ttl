# === Shape with rules for StepPrecedence ===
effortless-ntwf:StepPrecedenceShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:StepPrecedence ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StepPrecedence_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StepPrecedence .
                OPTIONAL { $this effortless-ntwf:fromStep ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:WorkflowSteps ; effortless-ntwf:workflowStepId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StepPrecedence_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StepPrecedence .
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
    OPTIONAL { $this effortless-ntwf:stepPrecedenceId ?step_precedence_id . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/precedence/", IF(isIRI(?step_precedence_id), REPLACE(STR(?step_precedence_id), "^.*[#/]", ""), STR(?step_precedence_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StepPrecedence_Iri" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:iri ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StepPrecedence .
    OPTIONAL { $this effortless-ntwf:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StepPrecedence_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:StepPrecedence .
    OPTIONAL { $this effortless-ntwf:fromStep ?from_step . }
    OPTIONAL { $this effortless-ntwf:toStep ?to_step . }
                BIND(CONCAT(IF(isIRI(?from_step), REPLACE(STR(?from_step), "^.*[#/]", ""), STR(?from_step)), " -> ", IF(isIRI(?to_step), REPLACE(STR(?to_step), "^.*[#/]", ""), STR(?to_step))) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for VocabularyReconciliations ===
effortless-ntwf:VocabularyReconciliationsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:VocabularyReconciliations ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_VocabularyReconciliations_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
