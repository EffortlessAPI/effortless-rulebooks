# === Shape with rules for ChangeLog ===
erb:ChangeLogShape a sh:NodeShape ;
    sh:targetClass erb:ChangeLog ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ChangeLog_RelativePath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:relativePath ?_result .
            }
            WHERE {
    $this a erb:ChangeLog .
    OPTIONAL { $this erb:changeLogId ?change_log_id . }
                BIND(CONCAT("change-log/", ?change_log_id) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ChangeLog_Iri" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:iri ?_result .
            }
            WHERE {
    $this a erb:ChangeLog .
    OPTIONAL { $this erb:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ChangeLog_Name" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:name ?_result .
            }
            WHERE {
    $this a erb:ChangeLog .
    OPTIONAL { $this erb:changeDate ?change_date . }
    OPTIONAL { $this erb:version ?version . }
                BIND(CONCAT(?version, " (", ?change_date, ")") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ChangeLog_IsBreakingChange" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:isBreakingChange ?_result .
            }
            WHERE {
    $this a erb:ChangeLog .
    OPTIONAL { $this erb:changeKind ?change_kind . }
                BIND((REPLACE(STR(?change_kind), "^.*#", "") = "major") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ChangeLog_IsBackwardCompatible" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:isBackwardCompatible ?_result .
            }
            WHERE {
    $this a erb:ChangeLog .
    OPTIONAL { $this erb:changeKind ?change_kind . }
                BIND(((REPLACE(STR(?change_kind), "^.*#", "") = "patch") || (REPLACE(STR(?change_kind), "^.*#", "") = "minor")) AS ?_result)
            }
        """ ;
    ] .

