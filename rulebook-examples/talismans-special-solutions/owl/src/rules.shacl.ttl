    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_GovernanceRoles_CanApproveChanges" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:canApproveChanges ?_result .
            }
            WHERE {
    $this a erb:GovernanceRoles .
    OPTIONAL { $this erb:kind ?kind . }
                BIND((REPLACE(STR(?kind), "^.*#", "") = "Authority") AS ?_result)
            }
        """ ;
    ] .

