            }
            WHERE {
    $this a effortless-ntwf:GovernanceRoles .
    OPTIONAL { $this effortless-ntwf:kind ?kind . }
                BIND((REPLACE(COALESCE(STR(?kind), ""), "^.*#", "") = "Authority") AS ?_result)
            }
        """ ;
    ] .

