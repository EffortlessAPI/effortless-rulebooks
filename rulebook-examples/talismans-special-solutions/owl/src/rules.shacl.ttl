@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix erb: <http://example.org/erb#> .

# === Shape with rules for AIAgents ===
erb:AIAgentsShape a sh:NodeShape ;
    sh:targetClass erb:AIAgents ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AIAgents_RelativePath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:relativePath ?_result .
            }
            WHERE {
    $this a erb:AIAgents .
    OPTIONAL { $this erb:aIAgentId ?ai_agent_id . }
                BIND(CONCAT("ai-agents/", ?ai_agent_id) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AIAgents_Iri" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:iri ?_result .
            }
            WHERE {
    $this a erb:AIAgents .
    OPTIONAL { $this erb:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AIAgents_CountAttributedArtifacts" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countAttributedArtifacts ?_result .
            }
            WHERE {
    $this a erb:AIAgents .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a erb:WorkflowArtifacts .
                    ?child erb:attributedToAIAgent $this .
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AIAgents_CountImpactedWorkflows" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countImpactedWorkflows ?_result .
            }
            WHERE {
    $this a erb:AIAgents .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a erb:WorkflowArtifacts .
                    ?child erb:attributedToAIAgent $this .
                    OPTIONAL { ?child erb:hasProducingWorkflow ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] .

# === Shape with rules for AgentCapabilityConcepts ===
erb:AgentCapabilityConceptsShape a sh:NodeShape ;
    sh:targetClass erb:AgentCapabilityConcepts ;
