            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:VocabularyReconciliations .
    OPTIONAL { $this effortless-ntwf:reconciliationId ?reconciliation_id . }
                BIND(CONCAT("reconciliations/", IF(isIRI(?reconciliation_id), REPLACE(STR(?reconciliation_id), "^.*[#/]", ""), STR(?reconciliation_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_VocabularyReconciliations_Iri" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:iri ?_result .
            }
            WHERE {
    $this a effortless-ntwf:VocabularyReconciliations .
    OPTIONAL { $this effortless-ntwf:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_VocabularyReconciliations_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:VocabularyReconciliations .
    OPTIONAL { $this effortless-ntwf:deprecatedTerm ?deprecated_term . }
    OPTIONAL { $this effortless-ntwf:replacementTerm ?replacement_term . }
                BIND(CONCAT(IF(isIRI(?deprecated_term), REPLACE(STR(?deprecated_term), "^.*[#/]", ""), STR(?deprecated_term)), " owl:sameAs ", IF(isIRI(?replacement_term), REPLACE(STR(?replacement_term), "^.*[#/]", ""), STR(?replacement_term))) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for WorkflowArtifacts ===
effortless-ntwf:WorkflowArtifactsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:WorkflowArtifacts ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowArtifacts_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowArtifacts .
                OPTIONAL { $this effortless-ntwf:producedByStep ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:WorkflowSteps ; effortless-ntwf:workflowStepId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowArtifacts_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowArtifacts .
    OPTIONAL { $this effortless-ntwf:artifactId ?artifact_id . }
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/artifacts/", IF(isIRI(?artifact_id), REPLACE(STR(?artifact_id), "^.*[#/]", ""), STR(?artifact_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowArtifacts_Iri" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:iri ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowArtifacts .
    OPTIONAL { $this effortless-ntwf:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowArtifacts_ProducingAgentType" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:producingAgentType ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowArtifacts .
    OPTIONAL { $this effortless-ntwf:attributedToAIAgent ?attributed_to_ai_agent . }
    OPTIONAL { $this effortless-ntwf:attributedToAutomatedPipeline ?attributed_to_automated_pipeline . }
    OPTIONAL { $this effortless-ntwf:attributedToHumanAgent ?attributed_to_human_agent . }
                BIND(IF((!((!BOUND(?attributed_to_human_agent) || STR(?attributed_to_human_agent) = ""))), "HumanAgent", IF((!((!BOUND(?attributed_to_ai_agent) || STR(?attributed_to_ai_agent) = ""))), "AIAgent", IF((!((!BOUND(?attributed_to_automated_pipeline) || STR(?attributed_to_automated_pipeline) = ""))), "AutomatedPipeline", ""))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowArtifacts_HasDerivationParent" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:hasDerivationParent ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowArtifacts .
    OPTIONAL { $this effortless-ntwf:derivedFromArtifact ?derived_from_artifact . }
                BIND((!((!BOUND(?derived_from_artifact) || STR(?derived_from_artifact) = ""))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowArtifacts_ProducedByWorkflow" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:producedByWorkflow ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowArtifacts .
                OPTIONAL { $this effortless-ntwf:producedByStep ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:WorkflowSteps ; effortless-ntwf:workflowStepId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 effortless-ntwf:workflow ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowArtifacts_HasProducingWorkflow" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:hasProducingWorkflow ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowArtifacts .
    OPTIONAL { $this effortless-ntwf:producedByWorkflow ?produced_by_workflow . }
                BIND((!((!BOUND(?produced_by_workflow) || STR(?produced_by_workflow) = ""))) AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for WorkflowStatusConcepts ===
