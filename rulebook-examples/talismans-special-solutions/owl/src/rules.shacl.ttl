            }
            WHERE {
    $this a effortless-ntwf:WorkflowStatusConcepts .
    OPTIONAL { $this effortless-ntwf:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for WorkflowSteps ===
effortless-ntwf:WorkflowStepsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:WorkflowSteps ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_ParentPath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:parentPath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
                OPTIONAL { $this effortless-ntwf:workflow ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Workflows ; effortless-ntwf:workflowId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 effortless-ntwf:relativePath ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
    OPTIONAL { $this effortless-ntwf:parentPath ?parent_path . }
    OPTIONAL { $this effortless-ntwf:workflowStepId ?workflow_step_id . }
                BIND(CONCAT(IF(isIRI(?parent_path), REPLACE(STR(?parent_path), "^.*[#/]", ""), STR(?parent_path)), "/steps/", IF(isIRI(?workflow_step_id), REPLACE(STR(?workflow_step_id), "^.*[#/]", ""), STR(?workflow_step_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_Iri" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:iri ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
    OPTIONAL { $this effortless-ntwf:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
    OPTIONAL { $this effortless-ntwf:displayName ?display_name . }
                BIND(REPLACE(LCASE(?display_name), " ", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_PrecedingStepCount" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:precedingStepCount ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
                {
                    SELECT (COUNT(*) AS ?_result) WHERE {
                        ?a effortless-ntwf:precedesStep+ $this .
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_InferredSequencePosition" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:inferredSequencePosition ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
    OPTIONAL { $this effortless-ntwf:precedingStepCount ?preceding_step_count . }
                BIND((?preceding_step_count + 1) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_SequencePosition" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:sequencePosition ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
    OPTIONAL { $this effortless-ntwf:inferredSequencePosition ?inferred_sequence_position . }
    OPTIONAL { $this effortless-ntwf:sequencePositionOverride ?sequence_position_override . }
                BIND(IF((REPLACE(COALESCE(STR(?sequence_position_override), ""), "^.*#", "") != ""), ?sequence_position_override, ?inferred_sequence_position) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_ExecutingHumanAgent" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:executingHumanAgent ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
                OPTIONAL { $this effortless-ntwf:assignedRole ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Roles ; effortless-ntwf:roleId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 effortless-ntwf:filledByHumanAgent ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_ExecutingAIAgent" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:executingAIAgent ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
                OPTIONAL { $this effortless-ntwf:assignedRole ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Roles ; effortless-ntwf:roleId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 effortless-ntwf:filledByAIAgent ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_ExecutingAutomatedPipeline" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:executingAutomatedPipeline ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
                OPTIONAL { $this effortless-ntwf:assignedRole ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Roles ; effortless-ntwf:roleId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 effortless-ntwf:filledByAutomatedPipeline ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_ExecutingAgentType" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:executingAgentType ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
    OPTIONAL { $this effortless-ntwf:executingAIAgent ?executing_ai_agent . }
    OPTIONAL { $this effortless-ntwf:executingAutomatedPipeline ?executing_automated_pipeline . }
    OPTIONAL { $this effortless-ntwf:executingHumanAgent ?executing_human_agent . }
                BIND(IF((!((!BOUND(?executing_human_agent) || STR(?executing_human_agent) = ""))), "HumanAgent", IF((!((!BOUND(?executing_ai_agent) || STR(?executing_ai_agent) = ""))), "AIAgent", IF((!((!BOUND(?executing_automated_pipeline) || STR(?executing_automated_pipeline) = ""))), "AutomatedPipeline", ""))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_IsExecutedByAI" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isExecutedByAI ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
    OPTIONAL { $this effortless-ntwf:executingAIAgent ?executing_ai_agent . }
                BIND((!((!BOUND(?executing_ai_agent) || STR(?executing_ai_agent) = ""))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_IsExecutedByHuman" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isExecutedByHuman ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
    OPTIONAL { $this effortless-ntwf:executingHumanAgent ?executing_human_agent . }
                BIND((!((!BOUND(?executing_human_agent) || STR(?executing_human_agent) = ""))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_ApprovalConsistencyViolation" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:approvalConsistencyViolation ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
    OPTIONAL { $this effortless-ntwf:executingHumanAgent ?executing_human_agent . }
    OPTIONAL { $this effortless-ntwf:requiresHumanApproval ?requires_human_approval . }
                BIND((?requires_human_approval && (!BOUND(?executing_human_agent) || STR(?executing_human_agent) = "")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_ApprovalIsHumanFilled" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:approvalIsHumanFilled ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
    OPTIONAL { $this effortless-ntwf:executingHumanAgent ?executing_human_agent . }
    OPTIONAL { $this effortless-ntwf:requiresHumanApproval ?requires_human_approval . }
                BIND(IF(?requires_human_approval, (!((!BOUND(?executing_human_agent) || STR(?executing_human_agent) = ""))), true) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_OwningDepartment" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:owningDepartment ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
                OPTIONAL { $this effortless-ntwf:assignedRole ?j0 . }
                OPTIONAL { ?j1 a effortless-ntwf:Roles ; effortless-ntwf:roleId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 effortless-ntwf:ownedBy ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_IsLegalOwned" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isLegalOwned ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
    OPTIONAL { $this effortless-ntwf:owningDepartment ?owning_department . }
                BIND((REPLACE(COALESCE(STR(?owning_department), ""), "^.*#", "") = "ntwf-legal-dept") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_IsEngineeringOwned" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isEngineeringOwned ?_result .
            }
            WHERE {
    $this a effortless-ntwf:WorkflowSteps .
    OPTIONAL { $this effortless-ntwf:owningDepartment ?owning_department . }
                BIND((REPLACE(COALESCE(STR(?owning_department), ""), "^.*#", "") = "ntwf-engineering") AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for Workflows ===
effortless-ntwf:WorkflowsShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Workflows ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
    OPTIONAL { $this effortless-ntwf:workflowId ?workflow_id . }
                BIND(CONCAT("workflows/", IF(isIRI(?workflow_id), REPLACE(STR(?workflow_id), "^.*[#/]", ""), STR(?workflow_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_Iri" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:iri ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
    OPTIONAL { $this effortless-ntwf:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
    OPTIONAL { $this effortless-ntwf:displayName ?display_name . }
                BIND(REPLACE(LCASE(?display_name), " ", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountOfNonProposedSteps" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countOfNonProposedSteps ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:WorkflowSteps .
                    ?child effortless-ntwf:workflow $this .
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_HasMoreThan1Step" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:hasMoreThan1Step ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
    OPTIONAL { $this effortless-ntwf:countOfNonProposedSteps ?count_of_non_proposed_steps . }
                BIND((?count_of_non_proposed_steps > 1) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountAISteps" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countAISteps ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:WorkflowSteps .
                    ?child effortless-ntwf:workflow $this .
                    OPTIONAL { ?child effortless-ntwf:isExecutedByAI ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountHumanSteps" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countHumanSteps ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:WorkflowSteps .
                    ?child effortless-ntwf:workflow $this .
                    OPTIONAL { ?child effortless-ntwf:isExecutedByHuman ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountHumanRequiredSteps" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countHumanRequiredSteps ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:WorkflowSteps .
                    ?child effortless-ntwf:workflow $this .
                    OPTIONAL { ?child effortless-ntwf:requiresHumanApproval ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountApprovalConsistencyViolations" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countApprovalConsistencyViolations ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:WorkflowSteps .
                    ?child effortless-ntwf:workflow $this .
                    OPTIONAL { ?child effortless-ntwf:approvalConsistencyViolation ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_HasConsistencyViolation" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:hasConsistencyViolation ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
    OPTIONAL { $this effortless-ntwf:countApprovalConsistencyViolations ?count_approval_consistency_violations . }
                BIND((?count_approval_consistency_violations > 0) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_HasAIAgentStep" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:hasAIAgentStep ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
    OPTIONAL { $this effortless-ntwf:countAISteps ?count_ai_steps . }
                BIND((?count_ai_steps > 0) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_MonthsSinceModified" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:monthsSinceModified ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
    OPTIONAL { $this effortless-ntwf:modified ?modified . }
                BIND(((YEAR(NOW()) - YEAR(?modified)) * 12 + (MONTH(NOW()) - MONTH(?modified)) - IF(DAY(NOW()) < DAY(?modified), 1, 0)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_IsStale" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isStale ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
    OPTIONAL { $this effortless-ntwf:monthsSinceModified ?months_since_modified . }
    OPTIONAL { $this effortless-ntwf:stalenessThresholdMonths ?staleness_threshold_months . }
                BIND((?months_since_modified > ?staleness_threshold_months) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_IsStaleAndHasAIAgent" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isStaleAndHasAIAgent ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
    OPTIONAL { $this effortless-ntwf:hasAIAgentStep ?has_ai_agent_step . }
    OPTIONAL { $this effortless-ntwf:isStale ?is_stale . }
                BIND((?is_stale && ?has_ai_agent_step) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountDerivationLinks" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countDerivationLinks ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:WorkflowArtifacts .
                    ?child effortless-ntwf:producedByWorkflow $this .
                    OPTIONAL { ?child effortless-ntwf:hasDerivationParent ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountLegalOwnedSteps" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countLegalOwnedSteps ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:WorkflowSteps .
                    ?child effortless-ntwf:workflow $this .
                    OPTIONAL { ?child effortless-ntwf:isLegalOwned ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountEngineeringOwnedSteps" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countEngineeringOwnedSteps ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:WorkflowSteps .
                    ?child effortless-ntwf:workflow $this .
                    OPTIONAL { ?child effortless-ntwf:isEngineeringOwned ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_InvolvesEngineeringAndLegal" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:involvesEngineeringAndLegal ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
    OPTIONAL { $this effortless-ntwf:countEngineeringOwnedSteps ?count_engineering_owned_steps . }
    OPTIONAL { $this effortless-ntwf:countLegalOwnedSteps ?count_legal_owned_steps . }
                BIND(((?count_engineering_owned_steps > 0) && (?count_legal_owned_steps > 0)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountInferredPrecedencePairs" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countInferredPrecedencePairs ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
                {
                    SELECT (COUNT(*) AS ?_result) WHERE {
                        ?a effortless-ntwf:precedesStep+ ?b .
                        FILTER(NOT EXISTS { ?e a effortless-ntwf:StepPrecedence ; effortless-ntwf:fromStep ?a ; effortless-ntwf:toStep ?b . })
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountAssertedPrecedencePairs" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countAssertedPrecedencePairs ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
                {
                    SELECT (COUNT(*) AS ?_result) WHERE {
                        ?a effortless-ntwf:precedesStep+ ?b .
                        FILTER(EXISTS { ?e a effortless-ntwf:StepPrecedence ; effortless-ntwf:fromStep ?a ; effortless-ntwf:toStep ?b . })
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountOfPrecedenceClosurePairs" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countOfPrecedenceClosurePairs ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
    OPTIONAL { $this effortless-ntwf:countAssertedPrecedencePairs ?count_asserted_precedence_pairs . }
    OPTIONAL { $this effortless-ntwf:countInferredPrecedencePairs ?count_inferred_precedence_pairs . }
                BIND((?count_asserted_precedence_pairs + ?count_inferred_precedence_pairs) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountRolesWithBadFillerCardinality" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countRolesWithBadFillerCardinality ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:Roles .
                    OPTIONAL { ?child effortless-ntwf:hasExactlyOneFiller ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = false)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountAgentTypeChanges" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countAgentTypeChanges ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:RoleAssignments .
                    OPTIONAL { ?child effortless-ntwf:isAgentTypeChange ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountComplianceAuditChanges" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:countComplianceAuditChanges ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a effortless-ntwf:RoleAssignments .
                    OPTIONAL { ?child effortless-ntwf:requiresComplianceAudit ?c0 . }
                    FILTER(BOUND(?c0) && ?c0 = true)
                    }
                }
            }
        """ ;
    ] .

# === Cardinality: single-valued forward FK properties ===
effortless-ntwf:AIAgentsCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:AIAgents ;
    sh:property [ sh:path effortless-ntwf:attributedArtifacts ; sh:maxCount 1 ] ;
    sh:property [ sh:path effortless-ntwf:roleAssignments ; sh:maxCount 1 ] ;
    sh:property [ sh:path effortless-ntwf:roles ; sh:maxCount 1 ] .

effortless-ntwf:AgentCapabilityConceptsCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:AgentCapabilityConcepts ;
    sh:property [ sh:path effortless-ntwf:roles ; sh:maxCount 1 ] .

effortless-ntwf:ApprovalGatesCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:ApprovalGates ;
    sh:property [ sh:path effortless-ntwf:workflowStep ; sh:maxCount 1 ] .

effortless-ntwf:ArtifactTypeConceptsCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:ArtifactTypeConcepts ;
    sh:property [ sh:path effortless-ntwf:workflowArtifacts ; sh:maxCount 1 ] .

effortless-ntwf:AutomatedPipelinesCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:AutomatedPipelines ;
    sh:property [ sh:path effortless-ntwf:roleAssignments ; sh:maxCount 1 ] ;
    sh:property [ sh:path effortless-ntwf:roles ; sh:maxCount 1 ] .

effortless-ntwf:ChangeLogCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:ChangeLog ;
    sh:property [ sh:path effortless-ntwf:approvedBy ; sh:maxCount 1 ] .

effortless-ntwf:DatasetsCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Datasets ;
    sh:property [ sh:path effortless-ntwf:consumedBySteps ; sh:maxCount 1 ] .

effortless-ntwf:DepartmentsCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Departments ;
    sh:property [ sh:path effortless-ntwf:roles ; sh:maxCount 1 ] .

effortless-ntwf:HumanAgentsCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:HumanAgents ;
    sh:property [ sh:path effortless-ntwf:roleAssignments ; sh:maxCount 1 ] ;
    sh:property [ sh:path effortless-ntwf:roles ; sh:maxCount 1 ] .

effortless-ntwf:RoleAssignmentsCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:RoleAssignments ;
    sh:property [ sh:path effortless-ntwf:role ; sh:maxCount 1 ] .

effortless-ntwf:RolesCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Roles ;
    sh:property [ sh:path effortless-ntwf:workflowSteps ; sh:maxCount 1 ] .

effortless-ntwf:StepPrecedenceCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:StepPrecedence ;
    sh:property [ sh:path effortless-ntwf:fromStep ; sh:maxCount 1 ] ;
    sh:property [ sh:path effortless-ntwf:toStep ; sh:maxCount 1 ] .

effortless-ntwf:WorkflowArtifactsCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:WorkflowArtifacts ;
    sh:property [ sh:path effortless-ntwf:attributedToAutomatedPipeline ; sh:maxCount 1 ] ;
    sh:property [ sh:path effortless-ntwf:attributedToHumanAgent ; sh:maxCount 1 ] ;
    sh:property [ sh:path effortless-ntwf:derivedFromArtifact ; sh:maxCount 1 ] ;
    sh:property [ sh:path effortless-ntwf:producedByStep ; sh:maxCount 1 ] ;
    sh:property [ sh:path effortless-ntwf:requiredBySteps ; sh:maxCount 1 ] .

effortless-ntwf:WorkflowStatusConceptsCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:WorkflowStatusConcepts ;
    sh:property [ sh:path effortless-ntwf:workflows ; sh:maxCount 1 ] .

effortless-ntwf:WorkflowStepsCardinalityShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:WorkflowSteps ;
    sh:property [ sh:path effortless-ntwf:workflow ; sh:maxCount 1 ] .

# Generated 114 SHACL rules