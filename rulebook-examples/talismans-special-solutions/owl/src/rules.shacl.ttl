# === Shape with rules for WorkflowSteps ===
erb:WorkflowStepsShape a sh:NodeShape ;
    sh:targetClass erb:WorkflowSteps ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_ParentPath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:parentPath ?_result .
            }
            WHERE {
    $this a erb:WorkflowSteps .
                OPTIONAL { $this erb:workflow ?j0 . }
                OPTIONAL { ?j1 a erb:Workflows ; erb:workflowId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 erb:relativePath ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_RelativePath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:relativePath ?_result .
            }
            WHERE {
    $this a erb:WorkflowSteps .
    OPTIONAL { $this erb:parentPath ?parent_path . }
    OPTIONAL { $this erb:workflowStepId ?workflow_step_id . }
                BIND(CONCAT(?parent_path, "/steps/", ?workflow_step_id) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_Iri" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:iri ?_result .
            }
            WHERE {
    $this a erb:WorkflowSteps .
    OPTIONAL { $this erb:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_Name" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:name ?_result .
            }
            WHERE {
    $this a erb:WorkflowSteps .
    OPTIONAL { $this erb:displayName ?display_name . }
                BIND(REPLACE(LCASE(?display_name), " ", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_ExecutingHumanAgent" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:executingHumanAgent ?_result .
            }
            WHERE {
    $this a erb:WorkflowSteps .
                OPTIONAL { $this erb:assignedRole ?j0 . }
                OPTIONAL { ?j1 a erb:Roles ; erb:roleId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 erb:filledByHumanAgent ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_ExecutingAIAgent" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:executingAIAgent ?_result .
            }
            WHERE {
    $this a erb:WorkflowSteps .
                OPTIONAL { $this erb:assignedRole ?j0 . }
                OPTIONAL { ?j1 a erb:Roles ; erb:roleId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 erb:filledByAIAgent ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_ExecutingAutomatedPipeline" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:executingAutomatedPipeline ?_result .
            }
            WHERE {
    $this a erb:WorkflowSteps .
                OPTIONAL { $this erb:assignedRole ?j0 . }
                OPTIONAL { ?j1 a erb:Roles ; erb:roleId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 erb:filledByAutomatedPipeline ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_ExecutingAgentType" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:executingAgentType ?_result .
            }
            WHERE {
    $this a erb:WorkflowSteps .
    OPTIONAL { $this erb:executingAIAgent ?executing_ai_agent . }
    OPTIONAL { $this erb:executingAutomatedPipeline ?executing_automated_pipeline . }
    OPTIONAL { $this erb:executingHumanAgent ?executing_human_agent . }
                BIND(IF((!((!BOUND(?executing_human_agent) || STR(?executing_human_agent) = ""))), "HumanAgent", IF((!((!BOUND(?executing_ai_agent) || STR(?executing_ai_agent) = ""))), "AIAgent", IF((!((!BOUND(?executing_automated_pipeline) || STR(?executing_automated_pipeline) = ""))), "AutomatedPipeline", ""))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_IsExecutedByAI" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:isExecutedByAI ?_result .
            }
            WHERE {
    $this a erb:WorkflowSteps .
    OPTIONAL { $this erb:executingAIAgent ?executing_ai_agent . }
                BIND((!((!BOUND(?executing_ai_agent) || STR(?executing_ai_agent) = ""))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_IsExecutedByHuman" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:isExecutedByHuman ?_result .
            }
            WHERE {
    $this a erb:WorkflowSteps .
    OPTIONAL { $this erb:executingHumanAgent ?executing_human_agent . }
                BIND((!((!BOUND(?executing_human_agent) || STR(?executing_human_agent) = ""))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_ApprovalConsistencyViolation" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:approvalConsistencyViolation ?_result .
            }
            WHERE {
    $this a erb:WorkflowSteps .
    OPTIONAL { $this erb:executingHumanAgent ?executing_human_agent . }
    OPTIONAL { $this erb:requiresHumanApproval ?requires_human_approval . }
                BIND((?requires_human_approval && (!BOUND(?executing_human_agent) || STR(?executing_human_agent) = "")) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_ApprovalIsHumanFilled" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:approvalIsHumanFilled ?_result .
            }
            WHERE {
    $this a erb:WorkflowSteps .
    OPTIONAL { $this erb:executingHumanAgent ?executing_human_agent . }
    OPTIONAL { $this erb:requiresHumanApproval ?requires_human_approval . }
                BIND(IF(?requires_human_approval, (!((!BOUND(?executing_human_agent) || STR(?executing_human_agent) = ""))), true) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_OwningDepartment" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:owningDepartment ?_result .
            }
            WHERE {
    $this a erb:WorkflowSteps .
                OPTIONAL { $this erb:assignedRole ?j0 . }
                OPTIONAL { ?j1 a erb:Roles ; erb:roleId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 erb:ownedBy ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_IsLegalOwned" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:isLegalOwned ?_result .
            }
            WHERE {
    $this a erb:WorkflowSteps .
    OPTIONAL { $this erb:owningDepartment ?owning_department . }
                BIND((REPLACE(STR(?owning_department), "^.*#", "") = "ntwf-legal-dept") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_WorkflowSteps_IsEngineeringOwned" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:isEngineeringOwned ?_result .
            }
            WHERE {
    $this a erb:WorkflowSteps .
    OPTIONAL { $this erb:owningDepartment ?owning_department . }
                BIND((REPLACE(STR(?owning_department), "^.*#", "") = "ntwf-engineering") AS ?_result)
            }
        """ ;
    ] .

# === Shape with rules for Workflows ===
erb:WorkflowsShape a sh:NodeShape ;
    sh:targetClass erb:Workflows ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_RelativePath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:relativePath ?_result .
            }
            WHERE {
    $this a erb:Workflows .
    OPTIONAL { $this erb:workflowId ?workflow_id . }
                BIND(CONCAT("workflows/", ?workflow_id) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_Iri" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:iri ?_result .
            }
            WHERE {
    $this a erb:Workflows .
    OPTIONAL { $this erb:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_Name" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:name ?_result .
            }
            WHERE {
    $this a erb:Workflows .
    OPTIONAL { $this erb:displayName ?display_name . }
                BIND(REPLACE(LCASE(?display_name), " ", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountOfNonProposedSteps" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countOfNonProposedSteps ?_result .
            }
            WHERE {
    $this a erb:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a erb:WorkflowSteps .
                    ?child erb:workflow $this .
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_HasMoreThan1Step" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:hasMoreThan1Step ?_result .
            }
            WHERE {
    $this a erb:Workflows .
    OPTIONAL { $this erb:countOfNonProposedSteps ?count_of_non_proposed_steps . }
                BIND((?count_of_non_proposed_steps > 1) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountAISteps" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countAISteps ?_result .
            }
            WHERE {
    $this a erb:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a erb:WorkflowSteps .
                    ?child erb:workflow $this .
                    OPTIONAL { ?child erb:isExecutedByAI ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountHumanSteps" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countHumanSteps ?_result .
            }
            WHERE {
    $this a erb:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a erb:WorkflowSteps .
                    ?child erb:workflow $this .
                    OPTIONAL { ?child erb:isExecutedByHuman ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountHumanRequiredSteps" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countHumanRequiredSteps ?_result .
            }
            WHERE {
    $this a erb:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a erb:WorkflowSteps .
                    ?child erb:workflow $this .
                    OPTIONAL { ?child erb:requiresHumanApproval ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountApprovalConsistencyViolations" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countApprovalConsistencyViolations ?_result .
            }
            WHERE {
    $this a erb:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a erb:WorkflowSteps .
                    ?child erb:workflow $this .
                    OPTIONAL { ?child erb:approvalConsistencyViolation ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_HasConsistencyViolation" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:hasConsistencyViolation ?_result .
            }
            WHERE {
    $this a erb:Workflows .
    OPTIONAL { $this erb:countApprovalConsistencyViolations ?count_approval_consistency_violations . }
                BIND((?count_approval_consistency_violations > 0) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_HasAIAgentStep" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:hasAIAgentStep ?_result .
            }
            WHERE {
    $this a erb:Workflows .
    OPTIONAL { $this erb:countAISteps ?count_ai_steps . }
                BIND((?count_ai_steps > 0) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_MonthsSinceModified" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:monthsSinceModified ?_result .
            }
            WHERE {
    $this a erb:Workflows .
    OPTIONAL { $this erb:modified ?modified . }
                BIND(((YEAR(NOW()) - YEAR(?modified)) * 12 + (MONTH(NOW()) - MONTH(?modified)) - IF(DAY(NOW()) < DAY(?modified), 1, 0)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_IsStale" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:isStale ?_result .
            }
            WHERE {
    $this a erb:Workflows .
    OPTIONAL { $this erb:monthsSinceModified ?months_since_modified . }
    OPTIONAL { $this erb:stalenessThresholdMonths ?staleness_threshold_months . }
                BIND((?months_since_modified > ?staleness_threshold_months) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_IsStaleAndHasAIAgent" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:isStaleAndHasAIAgent ?_result .
            }
            WHERE {
    $this a erb:Workflows .
    OPTIONAL { $this erb:hasAIAgentStep ?has_ai_agent_step . }
    OPTIONAL { $this erb:isStale ?is_stale . }
                BIND((?is_stale && ?has_ai_agent_step) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountDerivationLinks" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countDerivationLinks ?_result .
            }
            WHERE {
    $this a erb:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a erb:WorkflowArtifacts .
                    ?child erb:producedByWorkflow $this .
                    OPTIONAL { ?child erb:hasDerivationParent ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountLegalOwnedSteps" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countLegalOwnedSteps ?_result .
            }
            WHERE {
    $this a erb:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a erb:WorkflowSteps .
                    ?child erb:workflow $this .
                    OPTIONAL { ?child erb:isLegalOwned ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountEngineeringOwnedSteps" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countEngineeringOwnedSteps ?_result .
            }
            WHERE {
    $this a erb:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a erb:WorkflowSteps .
                    ?child erb:workflow $this .
                    OPTIONAL { ?child erb:isEngineeringOwned ?c2 . }
                    FILTER(BOUND(?c2) && ?c2 = true)
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_InvolvesEngineeringAndLegal" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:involvesEngineeringAndLegal ?_result .
            }
            WHERE {
    $this a erb:Workflows .
    OPTIONAL { $this erb:countEngineeringOwnedSteps ?count_engineering_owned_steps . }
    OPTIONAL { $this erb:countLegalOwnedSteps ?count_legal_owned_steps . }
                BIND(((?count_engineering_owned_steps > 0) && (?count_legal_owned_steps > 0)) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountInferredPrecedencePairs" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countInferredPrecedencePairs ?_result .
            }
            WHERE {
    $this a erb:Workflows .
                {
                    SELECT (COUNT(*) AS ?_result) WHERE {
                        ?a erb:precedesStep ?b .
                        FILTER(NOT EXISTS { ?e a erb:StepPrecedence ; erb:fromStep ?a ; erb:toStep ?b . })
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountAssertedPrecedencePairs" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countAssertedPrecedencePairs ?_result .
            }
            WHERE {
    $this a erb:Workflows .
                {
                    SELECT (COUNT(*) AS ?_result) WHERE {
                        ?a erb:precedesStep ?b .
                        FILTER(EXISTS { ?e a erb:StepPrecedence ; erb:fromStep ?a ; erb:toStep ?b . })
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountOfPrecedenceClosurePairs" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countOfPrecedenceClosurePairs ?_result .
            }
            WHERE {
    $this a erb:Workflows .
    OPTIONAL { $this erb:countAssertedPrecedencePairs ?count_asserted_precedence_pairs . }
    OPTIONAL { $this erb:countInferredPrecedencePairs ?count_inferred_precedence_pairs . }
                BIND((?count_asserted_precedence_pairs + ?count_inferred_precedence_pairs) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountRolesWithBadFillerCardinality" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countRolesWithBadFillerCardinality ?_result .
            }
            WHERE {
    $this a erb:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a erb:Roles .
                    ?child erb:hasExactlyOneFiller $this .
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountAgentTypeChanges" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countAgentTypeChanges ?_result .
            }
            WHERE {
    $this a erb:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a erb:RoleAssignments .
                    ?child erb:isAgentTypeChange $this .
                    }
                }
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Workflows_CountComplianceAuditChanges" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:countComplianceAuditChanges ?_result .
            }
            WHERE {
    $this a erb:Workflows .
                {
                    SELECT (COUNT(?child) AS ?_result) WHERE {
                    ?child a erb:RoleAssignments .
                    ?child erb:requiresComplianceAudit $this .
                    }
                }
            }
        """ ;
    ] .

