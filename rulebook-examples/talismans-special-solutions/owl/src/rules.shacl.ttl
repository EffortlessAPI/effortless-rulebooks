                $this erb:relativePath ?_result .
            }
            WHERE {
    $this a erb:AgentCapabilityConcepts .
    OPTIONAL { $this erb:conceptId ?concept_id . }
                BIND(CONCAT("concepts/agent-capability/", ?concept_id) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_AgentCapabilityConcepts_Iri" ;
        sh:prefixes erb: ;
