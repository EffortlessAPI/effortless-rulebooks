# === Shape with rules for ChangeLog ===
effortless-ntwf:ChangeLogShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:ChangeLog ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ChangeLog_RelativePath" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:relativePath ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ChangeLog .
    OPTIONAL { $this effortless-ntwf:changeLogId ?change_log_id . }
                BIND(CONCAT("change-log/", IF(isIRI(?change_log_id), REPLACE(STR(?change_log_id), "^.*[#/]", ""), STR(?change_log_id))) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ChangeLog_Iri" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:iri ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ChangeLog .
    OPTIONAL { $this effortless-ntwf:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ChangeLog_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ChangeLog .
    OPTIONAL { $this effortless-ntwf:changeDate ?change_date . }
    OPTIONAL { $this effortless-ntwf:version ?version . }
                BIND(CONCAT(IF(isIRI(?version), REPLACE(STR(?version), "^.*[#/]", ""), STR(?version)), " (", IF(isIRI(?change_date), REPLACE(STR(?change_date), "^.*[#/]", ""), STR(?change_date)), ")") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ChangeLog_IsBreakingChange" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isBreakingChange ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ChangeLog .
    OPTIONAL { $this effortless-ntwf:changeKind ?change_kind . }
                BIND((REPLACE(COALESCE(STR(?change_kind), ""), "^.*#", "") = "major") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_ChangeLog_IsBackwardCompatible" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:isBackwardCompatible ?_result .
            }
            WHERE {
    $this a effortless-ntwf:ChangeLog .
    OPTIONAL { $this effortless-ntwf:changeKind ?change_kind . }
                BIND(((REPLACE(COALESCE(STR(?change_kind), ""), "^.*#", "") = "patch") || (REPLACE(COALESCE(STR(?change_kind), ""), "^.*#", "") = "minor")) AS ?_result)
            }
        """ ;
    ] .

