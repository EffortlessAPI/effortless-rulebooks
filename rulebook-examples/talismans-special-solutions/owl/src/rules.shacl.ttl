# === Shape with rules for StepPrecedence ===
erb:StepPrecedenceShape a sh:NodeShape ;
    sh:targetClass erb:StepPrecedence ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StepPrecedence_ParentPath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:parentPath ?_result .
            }
            WHERE {
    $this a erb:StepPrecedence .
                OPTIONAL { $this erb:fromStep ?j0 . }
                OPTIONAL { ?j1 a erb:WorkflowSteps ; erb:workflowStepId ?j2 . FILTER(REPLACE(STR(?j2), "^.*[#/]", "") = REPLACE(STR(?j0), "^.*[#/]", "")) }
                OPTIONAL { ?j1 erb:relativePath ?j3 . }
                BIND(?j3 AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StepPrecedence_RelativePath" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:relativePath ?_result .
            }
            WHERE {
    $this a erb:StepPrecedence .
    OPTIONAL { $this erb:parentPath ?parent_path . }
    OPTIONAL { $this erb:stepPrecedenceId ?step_precedence_id . }
                BIND(CONCAT(?parent_path, "/precedence/", ?step_precedence_id) AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StepPrecedence_Iri" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:iri ?_result .
            }
            WHERE {
    $this a erb:StepPrecedence .
    OPTIONAL { $this erb:relativePath ?relative_path . }
                BIND(REPLACE(?relative_path, "/", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_StepPrecedence_Name" ;
        sh:prefixes erb: ;
        sh:construct """
            PREFIX erb: <http://example.org/erb#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this erb:name ?_result .
            }
            WHERE {
    $this a erb:StepPrecedence .
    OPTIONAL { $this erb:fromStep ?from_step . }
    OPTIONAL { $this erb:toStep ?to_step . }
                BIND(CONCAT(?from_step, " -> ", ?to_step) AS ?_result)
            }
        """ ;
    ] .

