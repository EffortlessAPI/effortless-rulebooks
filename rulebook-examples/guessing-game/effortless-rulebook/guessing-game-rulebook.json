        "formula": "=SUMIFS(边!{{角度}}, 边!{{形状}}, 形状!{{形状Id}})"
      },
      {
        "name": "最大边长",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "formula": "=SUMIFS(边!{{长度}}, 边!{{形状}}, 形状!{{形状Id}})"
      },
      {
        "name": "非斜边角度总和",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "formula": "=SUMIFS(边!{{长度平方}}, 边!{{形状}}, 形状!{{形状Id}})"
      },
