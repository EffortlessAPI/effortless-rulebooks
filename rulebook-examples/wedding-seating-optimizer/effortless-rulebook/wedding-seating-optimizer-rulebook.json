  "Relationships": {
    "Description": "Directed-but-symmetric guest-pair affinities. Kind is loves | prefers | avoid | must-not, with a Weight (positive = affinity, negative = friction).",
    "schema": [
      {
        "name": "RelId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "GuestA",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "RelatedTo": "Guests"
      },
      {
        "name": "GuestB",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "RelatedTo": "Guests"
      },
      {
        "name": "Kind",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "loves | prefers | avoid | must-not"
      },
      {
        "name": "Weight",
        "datatype": "number",
        "type": "raw",
        "nullable": true,
        "Description": "Signed magnitude (positive = wants near, negative = wants apart)."
      },
      {
        "name": "GuestAName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Guests!{{FullName}}, MATCH(Relationships!{{GuestA}}, Guests!{{GuestId}}, 0))"
      },
      {
        "name": "GuestBName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Guests!{{FullName}}, MATCH(Relationships!{{GuestB}}, Guests!{{GuestId}}, 0))"
      },
      {
        "name": "GuestATable",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Guests!{{AssignedTable}}, MATCH(Relationships!{{GuestA}}, Guests!{{GuestId}}, 0))"
      },
      {
        "name": "GuestBTable",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Guests!{{AssignedTable}}, MATCH(Relationships!{{GuestB}}, Guests!{{GuestId}}, 0))"
      },
      {
        "name": "SameTable",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "Description": "True iff both ends sit at the same non-empty table.",
        "formula": "=AND({{GuestATable}}<>\"\", {{GuestATable}}={{GuestBTable}})"
      },
      {
        "name": "SeatedTable",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "If both guests share a table, that table's id; else blank. Drives the per-table aggregations.",
        "formula": "=IF({{SameTable}}, {{GuestATable}}, \"\")"
      },
      {
        "name": "EffectiveScore",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "Description": "Weight when co-seated; else 0. Must-not pairs co-seated produce a large penalty regardless of Weight sign.",
        "formula": "=IF({{SameTable}}, IF({{Kind}}=\"must-not\", -50, {{Weight}}), 0)"
      },
      {
        "name": "IsMustNotViolation",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "formula": "=AND({{Kind}}=\"must-not\", {{SameTable}})"
      },
      {
        "name": "IsSatisfied",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "Description": "Positive-affinity pair sitting together, or negative-affinity pair sitting apart.",
        "formula": "=OR(AND({{Weight}}>0, {{SameTable}}), AND({{Weight}}<0, NOT({{SameTable}})))"
      },
      {
        "name": "ViolationTable",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "TableId if this is a must-not violation; else blank.",
        "formula": "=IF({{IsMustNotViolation}}, {{GuestATable}}, \"\")"
      },
      {
        "name": "ViolationFlag",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "Description": "1 if must-not pair co-seated; else 0. Feeds the per-table ViolationCount aggregation.",
        "formula": "=IF({{IsMustNotViolation}}, 1, 0)"
      }
    ],
