{
  "$schema": "https://example.com/cmcc-schema/v1",
  "model_name": "wedding-seating-optimizer",
  "Description": "Seating plan as a DAG \u2014 per-table happiness, capacity flags, per-guest satisfaction recompute on every move.",
  "Users": {
    "Description": "Login identities for the demo (stub auth).",
    "schema": [
      {
        "name": "UserId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "Email",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "Role",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "coordinator | bride | groom"
      },
      {
        "name": "DisplayName",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      }
    ],
    "data": [
      {
        "UserId": "u-coord",
        "Name": "coord@wed.test",
        "Email": "coord@wed.test",
        "Role": "coordinator",
        "DisplayName": "Casey (Coordinator)"
      },
      {
        "UserId": "u-bride",
        "Name": "bride@wed.test",
        "Email": "bride@wed.test",
        "Role": "bride",
        "DisplayName": "Alex (Bride)"
      },
      {
        "UserId": "u-groom",
        "Name": "groom@wed.test",
        "Email": "groom@wed.test",
        "Role": "groom",
        "DisplayName": "Sam (Groom)"
      }
    ]
  },
  "Tables": {
    "Description": "Physical reception tables. Guests are assigned to one Table each.",
    "schema": [
      {
        "name": "TableId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "Label",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Friendly label e.g. 'Head Table', 'Cousins'."
      },
      {
        "name": "Seats",
        "datatype": "integer",
        "type": "raw",
        "nullable": true,
        "Description": "Physical capacity."
      },
      {
        "name": "HeadCount",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "formula": "=COUNTIFS(Guests!{{AssignedTable}}, Tables!{{TableId}})"
      },
      {
        "name": "OpenSeats",
        "datatype": "integer",
        "type": "calculated",
        "nullable": true,
        "formula": "={{Seats}} - {{HeadCount}}"
      },
      {
        "name": "OverCapacity",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": true,
        "formula": "={{HeadCount}} > {{Seats}}"
      },
      {
        "name": "RawHappiness",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "Description": "Sum of EffectiveScore for relationships whose seated table matches this one.",
        "formula": "=SUMIFS(Relationships!{{EffectiveScore}}, Relationships!{{SeatedTable}}, Tables!{{TableId}})"
      },
      {
        "name": "ViolationCount",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Number of must-not pairs seated at this table.",
        "formula": "=SUMIFS(Relationships!{{ViolationFlag}}, Relationships!{{SeatedTable}}, Tables!{{TableId}})"
      },
      {
        "name": "Happiness",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "Description": "Net happiness: raw affinity minus capacity penalty minus side-skew penalty.",
        "formula": "={{RawHappiness}} - (IF({{OverCapacity}}, 25, 0) + {{SideSkew}})"
      },
      {
        "name": "Grade",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "formula": "=IF({{ViolationCount}}>0, \"Conflict\", IF({{OverCapacity}}, \"Over Capacity\", IF({{Happiness}}>=15, \"Great\", IF({{Happiness}}>=5, \"OK\", \"Cold\"))))"
      },
      {
        "name": "BrideSideCount",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Number of bride-side guests at this table.",
        "formula": "=SUMIFS(Guests!{{BrideFlag}}, Guests!{{AssignedTable}}, Tables!{{TableId}})"
      },
      {
        "name": "GroomSideCount",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "Description": "Number of groom-side guests at this table.",
        "formula": "=SUMIFS(Guests!{{GroomFlag}}, Guests!{{AssignedTable}}, Tables!{{TableId}})"
      },
      {
        "name": "SideSkew",
        "datatype": "integer",
        "type": "calculated",
        "nullable": true,
        "Description": "Absolute difference between bride and groom side counts.",
        "formula": "=IF({{BrideSideCount}}>{{GroomSideCount}}, {{BrideSideCount}}-{{GroomSideCount}}, {{GroomSideCount}}-{{BrideSideCount}})"
      }
    ],
    "data": [
      {
        "TableId": "t-head",
        "Name": "t-head",
        "Label": "Head Table",
        "Seats": 6
      },
      {
        "TableId": "t-family-b",
        "Name": "t-family-b",
        "Label": "Bride Family",
        "Seats": 8
      },
      {
        "TableId": "t-family-g",
        "Name": "t-family-g",
        "Label": "Groom Family",
        "Seats": 8
      },
      {
        "TableId": "t-friends",
        "Name": "t-friends",
        "Label": "College Friends",
        "Seats": 6
      },
      {
        "TableId": "t-misc",
        "Name": "t-misc",
        "Label": "Plus Ones",
        "Seats": 4
      }
    ]
  },
  "Guests": {
    "Description": "Wedding guests. Each is assigned to one Table.",
    "schema": [
      {
        "name": "GuestId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Name",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "FullName",
        "datatype": "string",
        "type": "raw",
        "nullable": true
      },
      {
        "name": "Side",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "bride | groom | both"
      },
      {
        "name": "Dietary",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "none | veg | vegan | gf | kosher"
      },
      {
        "name": "Language",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "en | es | fr"
      },
      {
        "name": "AgeBand",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "child | adult | senior"
      },
      {
        "name": "AssignedTable",
        "datatype": "string",
        "type": "relationship",
        "nullable": true,
        "RelatedTo": "Tables",
        "Description": "FK to Tables.TableId. Editable \u2014 moves the guest."
      },
      {
        "name": "TableLabel",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Tables!{{Label}}, MATCH(Guests!{{AssignedTable}}, Tables!{{TableId}}, 0))"
      },
      {
        "name": "TableSeats",
        "datatype": "integer",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Tables!{{Seats}}, MATCH(Guests!{{AssignedTable}}, Tables!{{TableId}}, 0))"
      },
      {
        "name": "TableHeadCount",
        "datatype": "integer",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Tables!{{HeadCount}}, MATCH(Guests!{{AssignedTable}}, Tables!{{TableId}}, 0))"
      },
      {
        "name": "RelationshipsAsA",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "formula": "=COUNTIFS(Relationships!{{GuestA}}, Guests!{{GuestId}})"
      },
      {
        "name": "RelationshipsAsB",
        "datatype": "integer",
        "type": "aggregation",
        "nullable": true,
        "formula": "=COUNTIFS(Relationships!{{GuestB}}, Guests!{{GuestId}})"
      },
      {
        "name": "SatisfactionA",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "Description": "Sum of EffectiveScore on relationships where this guest is GuestA and the pair is co-seated.",
        "formula": "=SUMIFS(Relationships!{{EffectiveScore}}, Relationships!{{GuestA}}, Guests!{{GuestId}})"
      },
      {
        "name": "SatisfactionB",
        "datatype": "number",
        "type": "aggregation",
        "nullable": true,
        "formula": "=SUMIFS(Relationships!{{EffectiveScore}}, Relationships!{{GuestB}}, Guests!{{GuestId}})"
      },
      {
        "name": "Satisfaction",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "Description": "Per-guest happiness rollup.",
        "formula": "={{SatisfactionA}} + {{SatisfactionB}}"
      },
      {
        "name": "Mood",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "formula": "=IF({{Satisfaction}}>=10, \"Happy\", IF({{Satisfaction}}>=0, \"Neutral\", \"Unhappy\"))"
      },
      {
        "name": "BrideFlag",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "Description": "1 if bride-side guest; else 0. Feeds Tables.BrideSideCount.",
        "formula": "=IF({{Side}}=\"bride\", 1, 0)"
      },
      {
        "name": "GroomFlag",
        "datatype": "number",
        "type": "calculated",
        "nullable": true,
        "Description": "1 if groom-side guest; else 0. Feeds Tables.GroomSideCount.",
        "formula": "=IF({{Side}}=\"groom\", 1, 0)"
      }
    ],
