<div class="container mt-5">
  <h1>Customers</h1>
  <p class="text-muted">Data from Effortless rulebook — all fields including calculated fields</p>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th>ID</th>
          <th>First Name</th>
          <th>Last Name</th>
          <th>Full Name <small>(calculated)</small></th>
          <th>Initials <small>(calculated)</small></th>
        </tr>
      </thead>
      <tbody>
        <% @customers.each do |customer| %>
          <tr>
            <td><%= link_to customer.customer_id, customer_path(customer.customer_id) %></td>
            <td><%= customer.first_name %></td>
            <td><%= customer.last_name %></td>
            <td><strong><%= customer.name %></strong></td>
            <td><code><%= customer.initials %></code></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-3">
    <p class="text-muted small">
      <strong>Note:</strong> The "Full Name" and "Initials" columns are calculated fields.
      They are not stored in the table — instead, they are computed by SQL formulas in the <code>vw_customers</code> view.
      Every read goes through the view, ensuring calculated values are always up-to-date.
    </p>
  </div>
</div>

<style>
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  }
  code {
    background: #f5f5f5;
    padding: 2px 6px;
    border-radius: 3px;
  }
</style>
