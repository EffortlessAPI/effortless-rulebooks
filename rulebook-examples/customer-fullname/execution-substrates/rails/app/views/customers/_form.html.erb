<% url = customer.persisted? ? customer_path(customer.customer_id) : customers_path %>
<% method = customer.persisted? ? :patch : :post %>
<form action="<%= url %>" method="post" accept-charset="UTF-8">
  <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>" autocomplete="off" />
  <% if method == :patch %>
    <input type="hidden" name="_method" value="patch" />
  <% end %>

  <% if customer.errors.any? %>
    <div id="error_explanation" class="alert alert-danger">
      <h4><%= pluralize(customer.errors.count, "error") %> prohibited this customer from being saved:</h4>
      <ul>
        <% customer.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <label for="customer_customer_id">Customer ID</label>
    <input class="form-control" type="text" value="<%= customer.customer_id %>" name="customer[customer_id]" id="customer_customer_id" />
  </div>

  <div class="mb-3">
    <label for="customer_first_name">First Name</label>
    <input class="form-control" type="text" value="<%= customer.first_name %>" name="customer[first_name]" id="customer_first_name" />
  </div>

  <div class="mb-3">
    <label for="customer_last_name">Last Name</label>
    <input class="form-control" type="text" value="<%= customer.last_name %>" name="customer[last_name]" id="customer_last_name" />
  </div>

  <div class="mb-3">
    <label for="customer_email_address">Email Address</label>
    <input class="form-control" type="email" value="<%= customer.email_address %>" name="customer[email_address]" id="customer_email_address" />
  </div>

  <div class="mb-3">
    <input type="submit" value="<%= customer.persisted? ? 'Update Customer' : 'Create Customer' %>" class="btn btn-primary" />
    <a class="btn btn-secondary" href="<%= customers_path %>">Cancel</a>
  </div>
</form>
