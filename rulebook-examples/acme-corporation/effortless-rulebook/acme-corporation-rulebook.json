        "FirstName": "Bob",
        "FullName": "Bob Smith"
      },
      {
        "ClientId": "cust0002",
        "EmailAddress": "john.doe@email.com",
        "LastName": "Doe",
        "Customer": "CUST0002",
        "FirstName": "John",
        "FullName": "John Doe"
      },
      {
        "ClientId": "cust0003",
        "EmailAddress": "emily.jones@email.com",
        "LastName": "Jones",
        "Customer": "CUST0003",
        "FirstName": "Emily",
        "FullName": "Emily Jones"
      }
    ]
  },
  "Projects": {
