      {
        "name": "ProjectTypeName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(TypesOfProject!{{Name}}, MATCH(Projects!{{ProjectType}}, TypesOfProject!{{TypesOfProjectId}}, 0))"
      },
      {
        "name": "ProjectTypeDescription",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(TypesOfProject!{{Description}}, MATCH(Projects!{{ProjectType}}, TypesOfProject!{{TypesOfProjectId}}, 0))"
      },
      {
        "name": "ProjectTypeRequiresManagerApproval",
        "datatype": "boolean",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(TypesOfProject!{{RequiresManagerApproval}}, MATCH(Projects!{{ProjectType}}, TypesOfProject!{{TypesOfProjectId}}, 0))"
      },
