        "nullable": true,
        "RelatedTo": "Employees",
        "isReversed": false,
        "prefersSingleRecordLink": true,
        "InverseField": "Projects"
      },
      {
        "name": "ApprovedByRoleIsManager",
        "datatype": "boolean",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Employees!{{RoleIsManager}}, MATCH(Projects!{{ApprovedBy}}, Employees!{{EmployeeId}}, 0))"
      },
      {
        "name": "ApprovedByName",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Employees!{{Name}}, MATCH(Projects!{{ApprovedBy}}, Employees!{{EmployeeId}}, 0))"
      },
      {
        "name": "ApprovedByEmailAddress",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Employees!{{EmailAddress}}, MATCH(Projects!{{ApprovedBy}}, Employees!{{EmployeeId}}, 0))"
      },
      {
        "name": "ApprovedByPhoneNumber",
        "datatype": "string",
        "type": "lookup",
        "nullable": true,
        "formula": "=INDEX(Employees!{{PhoneNumber}}, MATCH(Projects!{{ApprovedBy}}, Employees!{{EmployeeId}}, 0))"
