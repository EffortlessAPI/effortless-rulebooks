{
  "$schema": "https://example.com/cmcc-schema/v1",
  "Name": "ACME Corporation",
  "Description": "CRUD starter template \u2014 clients, projects, employees, roles. The \"starter-sized\" demo for new authors.",
  "Client": {
    "Description": "Table: Client",
    "schema": [
      {
        "name": "ClientId",
        "datatype": "string",
        "type": "raw",
        "nullable": false
      },
      {
        "name": "Customer",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Identifier for the customers."
      },
      {
        "name": "EmailAddress",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Thec ustomers email address"
      },
      {
        "name": "FirstName",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "First Name of the customer - used to make the full name"
      },
      {
        "name": "LastName",
        "datatype": "string",
        "type": "raw",
        "nullable": true,
        "Description": "Last Name of the customer - used to make the full name"
      },
      {
        "name": "FullName",
        "datatype": "string",
        "type": "calculated",
        "nullable": true,
        "Description": "Full name is computed from the first and last name of the customer",
        "formula": "={{FirstName}} & \" \" & {{LastName}}"
      }
    ],
    "data": [
      {
