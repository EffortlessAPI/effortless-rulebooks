@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix erb: <http://example.org/erb#> .

# === Individuals: Customers ===

erb:Customers_0 a erb:Customers ;
    erb:customerId "jane-smith-email-com" ;
    erb:emailAddress "jane.smith@email.com" ;
    erb:firstName "Bobby" ;
    erb:lastName "Smith" .

erb:Customers_1 a erb:Customers ;
    erb:customerId "john-doe-email-com" ;
    erb:emailAddress "john.doe@email.com" ;
    erb:firstName "Jimmy" ;
    erb:lastName "Doe" .

erb:Customers_2 a erb:Customers ;
    erb:customerId "emily-jones-email-com" ;
    erb:emailAddress "emily.jones@email.com" ;
