@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix effortless-ntwf: <https://w3id.org/effortless-ntwf#> .

<https://w3id.org/effortless-ntwf#> a owl:Ontology ;
    rdfs:label "NTWF Ontology (Effortless rendering)" ;
    rdfs:comment "Generated by Effortless from acme-llc-rulebook.json. Vocabulary: Jessica Talisman NTWF." .

# === Class: Customers ===
effortless-ntwf:Customers a owl:Class ;
    rdfs:label "Customers" ;
    rdfs:comment "Table: Customers" .

effortless-ntwf:customerId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Customers ;
    rdfs:range xsd:string ;
    rdfs:label "CustomerId" .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" ;
    rdfs:comment "Identifier for the customer." .
    # calculated: calculated

effortless-ntwf:emailAddress a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Customers ;
    rdfs:range xsd:string ;
    rdfs:label "EmailAddress" ;
    rdfs:comment "The customer's email address" .

effortless-ntwf:firstName a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Customers ;
    rdfs:range xsd:string ;
    rdfs:label "FirstName" ;
    rdfs:comment "First Name of the customer - used to make the full name" .

effortless-ntwf:initials a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Customers ;
    rdfs:range xsd:string ;
    rdfs:label "Initials" ;
    rdfs:comment "Customer initials — the first letter of FirstName followed by the first letter of LastName." .
    # calculated: calculated

effortless-ntwf:lastName a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Customers ;
    rdfs:range xsd:string ;
    rdfs:label "LastName" ;
    rdfs:comment "Last Name of the customer - used to make the full name" .

effortless-ntwf:fullName a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:Customers ;
    rdfs:range xsd:string ;
    rdfs:label "FullName" ;
    rdfs:comment "Full name is computed from the first and last name of the customer" .
    # calculated: calculated

# === Class: ERBCustomizations ===
effortless-ntwf:ERBCustomizations a owl:Class ;
    rdfs:label "ERBCustomizations" ;
    rdfs:comment "Table: ERBCustomizations" .

effortless-ntwf:eRBCustomizationId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ERBCustomizations ;
    rdfs:range xsd:string ;
    rdfs:label "ERBCustomizationId" .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" .

effortless-ntwf:title a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ERBCustomizations ;
    rdfs:range xsd:string ;
    rdfs:label "Title" .

effortless-ntwf:sQLCode a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ERBCustomizations ;
    rdfs:range xsd:string ;
    rdfs:label "SQLCode" .

effortless-ntwf:sQLTarget a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ERBCustomizations ;
    rdfs:range xsd:string ;
    rdfs:label "SQLTarget" .

effortless-ntwf:customizationType a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ERBCustomizations ;
    rdfs:range xsd:string ;
    rdfs:label "CustomizationType" .

# === Class: ERBVersions ===
effortless-ntwf:ERBVersions a owl:Class ;
    rdfs:label "ERBVersions" ;
    rdfs:comment "Table: ERBVersions" .

effortless-ntwf:eRBVersionId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ERBVersions ;
    rdfs:range xsd:string ;
    rdfs:label "ERBVersionId" .

effortless-ntwf:baseId a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ERBVersions ;
    rdfs:range xsd:string ;
    rdfs:label "BaseId" .

effortless-ntwf:name a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "Name" .

effortless-ntwf:message a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ERBVersions ;
    rdfs:range xsd:string ;
    rdfs:label "Message" .

effortless-ntwf:notes a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ERBVersions ;
    rdfs:range xsd:string ;
    rdfs:label "Notes" .

effortless-ntwf:commitDate a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ERBVersions ;
    rdfs:range xsd:string ;
    rdfs:label "CommitDate" .

effortless-ntwf:isPublished a owl:DatatypeProperty ;
    rdfs:domain effortless-ntwf:ERBVersions ;
    rdfs:range xsd:boolean ;
    rdfs:label "IsPublished" .
