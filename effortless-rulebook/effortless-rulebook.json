{
  "$schema": "https://example.com/cmcc-schema/v1",
  "Name": "Jessica's Ontology Series-v3",
  "Description": "Rulebook implementing the NTWF ontology from Jessica Talisman's Ontology Series. Models workflows at Special Solutions with role-agent separation, PROV-O provenance tracking, and Dublin Core metadata.",
  "Workflows": {
    "Description": "Table: Workflows. Subclass of prov:Plan and schema:CreativeWork per NTWF ontology.",
    "schema": [
      {"name": "WorkflowId", "datatype": "string", "type": "raw", "nullable": false},
      {"name": "Title", "datatype": "string", "type": "raw", "nullable": true, "Description": "Human-readable name. Maps to dct:title."},
      {"name": "Description", "datatype": "string", "type": "raw", "nullable": true, "Description": "Workflow purpose and scope. Maps to dct:description."},
      {"name": "Created", "datatype": "datetime", "type": "raw", "nullable": true, "Description": "Creation date. Maps to dct:created."},
      {"name": "Modified", "datatype": "datetime", "type": "raw", "nullable": true, "Description": "Last modified date. Maps to dct:modified. Answers CQ5 (stale workflows)."},
      {"name": "Identifier", "datatype": "string", "type": "raw", "nullable": true, "Description": "External reference (ticket number). Maps to dct:identifier."},
      {"name": "WorkflowSteps", "datatype": "string", "type": "relationship", "nullable": true, "RelatedTo": "WorkflowSteps", "Description": "Steps in this workflow. Maps to ntwf:hasStep."},
      {"name": "CountOfWorkflowSteps", "datatype": "integer", "type": "aggregation", "nullable": true, "formula": "=COUNTIFS(WorkflowSteps!{{IsStepOf}}, Workflows!{{WorkflowId}})"}
    ],
    "data": [
      {
        "WorkflowId": "production-deployment",
        "Title": "Production Deployment Workflow",
        "Description": "End-to-end workflow for deploying software releases. Involves AI risk analysis, human legal review, human approval gate, automated deployment, and human verification. Demonstrates all three agent types. From Jessica Talisman's NTWF article.",
        "Created": "2026-01-15",
        "Modified": "2026-01-15",
        "Identifier": "WF-PROD-001",
        "WorkflowSteps": "step-risk-assessment, step-legal-review, step-release-approval, step-deployment, step-post-deployment",
        "CountOfWorkflowSteps": 5
      },
      {
        "WorkflowId": "quarterly-business-review",
        "Title": "Quarterly Business Review",
        "Description": "Cross-departmental workflow for QBR preparation. Involves Engineering and Finance. Answers CQ8: 'What datasets does the QBR consume?'",
        "Created": "2025-10-01",
        "Modified": "2025-12-15",
        "Identifier": "WF-QBR-001",
        "WorkflowSteps": "step-data-collection, step-metrics-analysis, step-financial-review, step-executive-summary",
        "CountOfWorkflowSteps": 4
      }
    ]
  },
  "WorkflowSteps": {
    "Description": "Table: WorkflowSteps. Subclass of prov:Activity per NTWF ontology.",
    "schema": [
      {"name": "WorkflowStepId", "datatype": "string", "type": "raw", "nullable": false},
      {"name": "Label", "datatype": "string", "type": "raw", "nullable": true, "Description": "Step name. Maps to rdfs:label."},
      {"name": "SequencePosition", "datatype": "integer", "type": "raw", "nullable": true, "Description": "Ordinal position. Maps to ntwf:sequencePosition."},
      {"name": "RequiresHumanApproval", "datatype": "boolean", "type": "raw", "nullable": true, "Description": "Whether human required. Maps to ntwf:requiresHumanApproval. Answers CQ3."},
      {"name": "StepDurationMinutes", "datatype": "integer", "type": "raw", "nullable": true, "Description": "Expected duration. Maps to ntwf:stepDurationMinutes."},
      {"name": "IsStepOf", "datatype": "string", "type": "relationship", "nullable": true, "RelatedTo": "Workflows", "Description": "Parent workflow. Maps to ntwf:isStepOf."},
      {"name": "AssignedRole", "datatype": "string", "type": "relationship", "nullable": true, "RelatedTo": "Roles", "Description": "Responsible role. Maps to ntwf:assignedRole. Implements role-agent separation."},
      {"name": "ApprovalGate", "datatype": "string", "type": "relationship", "nullable": true, "RelatedTo": "ApprovalGates", "Description": "Approval gate if this is a gate step. Establishes double-typing."},
      {"name": "ProducesArtifact", "datatype": "string", "type": "relationship", "nullable": true, "RelatedTo": "Artifacts", "Description": "Artifact produced. Maps to ntwf:producesArtifact / prov:generated."},
      {"name": "RequiresArtifact", "datatype": "string", "type": "relationship", "nullable": true, "RelatedTo": "Artifacts", "Description": "Artifact required as input. Maps to ntwf:requiresArtifact / prov:used."},
      {"name": "ConsumesDataset", "datatype": "string", "type": "relationship", "nullable": true, "RelatedTo": "Datasets", "Description": "Dataset consumed. Maps to ntwf:consumesDataset. Answers CQ8."},
      {"name": "IsStepOfTitle", "datatype": "string", "type": "lookup", "nullable": true, "formula": "=INDEX(Workflows!{{Title}}, MATCH(WorkflowSteps!{{IsStepOf}}, Workflows!{{WorkflowId}}, 0))"},
      {"name": "AssignedRoleLabel", "datatype": "string", "type": "lookup", "nullable": true, "formula": "=INDEX(Roles!{{Label}}, MATCH(WorkflowSteps!{{AssignedRole}}, Roles!{{RoleId}}, 0))"},
      {"name": "AssignedRoleFilledByName", "datatype": "string", "type": "lookup", "nullable": true, "formula": "=INDEX(Roles!{{FilledByName}}, MATCH(WorkflowSteps!{{AssignedRole}}, Roles!{{RoleId}}, 0))"},
      {"name": "AssignedRoleDepartment", "datatype": "string", "type": "lookup", "nullable": true, "formula": "=INDEX(Roles!{{DepartmentName}}, MATCH(WorkflowSteps!{{AssignedRole}}, Roles!{{RoleId}}, 0))"}
    ],
