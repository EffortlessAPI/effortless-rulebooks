        "WorkflowStep": "step-financial-review",
        "EscalationThresholdHours": 48,
        "WorkflowStepLabel": "Financial Review",
        "WorkflowStepAssignedRole": "Financial Analyst"
      }
    ]
  },
  "Roles": {
    "Description": "Table: Roles. Custom NTWF class. Structural center implementing role-agent separation (Heuristic 2).",
    "schema": [
      {"name": "RoleId", "datatype": "string", "type": "raw", "nullable": false},
      {"name": "Label", "datatype": "string", "type": "raw", "nullable": true, "Description": "Role name. Maps to rdfs:label."},
      {"name": "Comment", "datatype": "string", "type": "raw", "nullable": true, "Description": "Role responsibilities. Maps to rdfs:comment."},
      {"name": "Department", "datatype": "string", "type": "relationship", "nullable": true, "RelatedTo": "Departments", "Description": "Owning department. Maps to ntwf:ownedBy. Enables CQ7."},
      {"name": "FilledBy", "datatype": "string", "type": "relationship", "nullable": true, "RelatedTo": "Agents", "Description": "Current agent. Maps to ntwf:filledBy. THE change-management triple."},
      {"name": "DelegatesTo", "datatype": "string", "type": "relationship", "nullable": true, "RelatedTo": "Roles", "Description": "Escalation role. Maps to ntwf:delegatesTo. Enables CQ6."},
      {"name": "DelegatedToBy", "datatype": "string", "type": "relationship", "nullable": true, "RelatedTo": "Roles", "Description": "Inverse of DelegatesTo."},
      {"name": "WorkflowSteps", "datatype": "string", "type": "relationship", "nullable": true, "RelatedTo": "WorkflowSteps", "Description": "Steps assigned to this role."},
      {"name": "CountOfWorkflowSteps", "datatype": "integer", "type": "aggregation", "nullable": true, "formula": "=COUNTIFS(WorkflowSteps!{{AssignedRole}}, Roles!{{RoleId}})"},
      {"name": "DepartmentName", "datatype": "string", "type": "lookup", "nullable": true, "formula": "=INDEX(Departments!{{Name}}, MATCH(Roles!{{Department}}, Departments!{{DepartmentId}}, 0))"},
      {"name": "FilledByName", "datatype": "string", "type": "lookup", "nullable": true, "formula": "=INDEX(Agents!{{Name}}, MATCH(Roles!{{FilledBy}}, Agents!{{AgentId}}, 0))"},
      {"name": "FilledByMBox", "datatype": "string", "type": "lookup", "nullable": true, "formula": "=INDEX(Agents!{{Mbox}}, MATCH(Roles!{{FilledBy}}, Agents!{{AgentId}}, 0))"},
      {"name": "FilledByAgentType", "datatype": "string", "type": "lookup", "nullable": true, "formula": "=INDEX(Agents!{{TypeOfAgent}}, MATCH(Roles!{{FilledBy}}, Agents!{{AgentId}}, 0))"},
      {"name": "DelegatesToLabel", "datatype": "string", "type": "lookup", "nullable": true, "formula": "=INDEX(Roles!{{Label}}, MATCH(Roles!{{DelegatesTo}}, Roles!{{RoleId}}, 0))"}
    ],
