  "PrecedesSteps": {
    "Description": "Table: PrecedesSteps. Junction table for step ordering. Maps to ntwf:precedesStep (owl:TransitiveProperty).",
    "schema": [
      {"name": "PrecedesStepId", "datatype": "string", "type": "raw", "nullable": false},
      {"name": "FromStep", "datatype": "string", "type": "relationship", "nullable": true, "RelatedTo": "WorkflowSteps", "Description": "Step that comes BEFORE."},
      {"name": "ToStep", "datatype": "string", "type": "relationship", "nullable": true, "RelatedTo": "WorkflowSteps", "Description": "Step that comes AFTER."},
      {"name": "FromStepLabel", "datatype": "string", "type": "lookup", "nullable": true, "formula": "=INDEX(WorkflowSteps!{{Label}}, MATCH(PrecedesSteps!{{FromStep}}, WorkflowSteps!{{WorkflowStepId}}, 0))"},
      {"name": "ToStepLabel", "datatype": "string", "type": "lookup", "nullable": true, "formula": "=INDEX(WorkflowSteps!{{Label}}, MATCH(PrecedesSteps!{{ToStep}}, WorkflowSteps!{{WorkflowStepId}}, 0))"}
    ],
    "data": [
      {"PrecedesStepId": "prod-1-to-2", "FromStep": "step-risk-assessment", "ToStep": "step-legal-review", "FromStepLabel": "Risk Assessment", "ToStepLabel": "Legal Review"},
      {"PrecedesStepId": "prod-2-to-3", "FromStep": "step-legal-review", "ToStep": "step-release-approval", "FromStepLabel": "Legal Review", "ToStepLabel": "Release Approval"},
      {"PrecedesStepId": "prod-3-to-4", "FromStep": "step-release-approval", "ToStep": "step-deployment", "FromStepLabel": "Release Approval", "ToStepLabel": "Deployment Execution"},
      {"PrecedesStepId": "prod-4-to-5", "FromStep": "step-deployment", "ToStep": "step-post-deployment", "FromStepLabel": "Deployment Execution", "ToStepLabel": "Post-Deployment Verification"},
      {"PrecedesStepId": "qbr-1-to-2", "FromStep": "step-data-collection", "ToStep": "step-metrics-analysis", "FromStepLabel": "Data Collection", "ToStepLabel": "Metrics Analysis"},
      {"PrecedesStepId": "qbr-2-to-3", "FromStep": "step-metrics-analysis", "ToStep": "step-financial-review", "FromStepLabel": "Metrics Analysis", "ToStepLabel": "Financial Review"},
      {"PrecedesStepId": "qbr-3-to-4", "FromStep": "step-financial-review", "ToStep": "step-executive-summary", "FromStepLabel": "Financial Review", "ToStepLabel": "Executive Summary"}
    ]
  },
  "ApprovalGates": {
    "Description": "Table: ApprovalGates. Subclass of WorkflowStep. Decision points requiring explicit authorization.",
    "schema": [
      {"name": "ApprovalGateId", "datatype": "string", "type": "raw", "nullable": false},
      {"name": "Name", "datatype": "string", "type": "raw", "nullable": true, "Description": "Gate name. Maps to rdfs:label."},
      {"name": "Description", "datatype": "string", "type": "raw", "nullable": true},
      {"name": "WorkflowStep", "datatype": "string", "type": "relationship", "nullable": true, "RelatedTo": "WorkflowSteps", "Description": "The step this gate is attached to. Establishes double-typing."},
      {"name": "EscalationThresholdHours", "datatype": "integer", "type": "raw", "nullable": true, "Description": "Hours before delegation chain activates. Maps to ntwf:escalationThresholdHours."},
      {"name": "WorkflowStepLabel", "datatype": "string", "type": "lookup", "nullable": true, "formula": "=INDEX(WorkflowSteps!{{Label}}, MATCH(ApprovalGates!{{WorkflowStep}}, WorkflowSteps!{{WorkflowStepId}}, 0))"},
      {"name": "WorkflowStepAssignedRole", "datatype": "string", "type": "lookup", "nullable": true, "formula": "=INDEX(WorkflowSteps!{{AssignedRoleLabel}}, MATCH(ApprovalGates!{{WorkflowStep}}, WorkflowSteps!{{WorkflowStepId}}, 0))"}
    ],
    "data": [
      {
        "ApprovalGateId": "gate-release-approval",
