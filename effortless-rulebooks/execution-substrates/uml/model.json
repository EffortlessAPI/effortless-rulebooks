{
  "classes": {
    "Client": {
      "attributes": [
        {
          "name": "ClientId",
          "type": "string"
        },
        {
          "name": "Customer",
          "type": "string"
        },
        {
          "name": "EmailAddress",
          "type": "string"
        },
        {
          "name": "FirstName",
          "type": "string"
        },
        {
          "name": "LastName",
          "type": "string"
        }
      ],
      "derived": [
        {
          "name": "FullName",
          "type": "string",
          "formula": "={{FirstName}} & \" \" & {{LastName}}"
        }
      ]
    },
    "Employees": {
      "attributes": [
        {
          "name": "EmployeeId",
          "type": "string"
        },
        {
          "name": "Name",
          "type": "string"
        },
        {
          "name": "EmailAddress",
          "type": "string"
        },
        {
          "name": "PhoneNumber",
          "type": "string"
        },
        {
          "name": "Role",
          "type": "string"
        },
        {
          "name": "Projects",
          "type": "string"
        }
      ],
      "derived": [
        {
          "name": "RoleName",
          "type": "string",
          "formula": "=INDEX(Roles!{{Name}}, MATCH(Employees!{{Role}}, Roles!{{RoleId}}, 0))"
        },
        {
          "name": "RoleDescription",
          "type": "string",
          "formula": "=INDEX(Roles!{{Description}}, MATCH(Employees!{{Role}}, Roles!{{RoleId}}, 0))"
        },
        {
          "name": "RoleIsManager",
          "type": "boolean",
          "formula": "=INDEX(Roles!{{IsManager}}, MATCH(Employees!{{Role}}, Roles!{{RoleId}}, 0))"
        }
      ]
    },
    "Projects": {
      "attributes": [
        {
          "name": "ProjectId",
          "type": "string"
        },
        {
          "name": "Name",
          "type": "string"
        },
        {
          "name": "Description",
          "type": "string"
        },
        {
          "name": "ProjectType",
          "type": "string"
        },
        {
          "name": "DueDate",
          "type": "datetime"
        },
        {
          "name": "IsApproved",
          "type": "boolean"
        },
        {
          "name": "ApprovedBy",
          "type": "string"
        }
      ],
      "derived": [
        {
          "name": "ProjectTypeName",
          "type": "string",
          "formula": "=INDEX(TypesOfProject!{{Name}}, MATCH(Projects!{{ProjectType}}, TypesOfProject!{{TypesOfProjectId}}, 0))"
        },
        {
          "name": "ProjectTypeDescription",
          "type": "string",
          "formula": "=INDEX(TypesOfProject!{{Description}}, MATCH(Projects!{{ProjectType}}, TypesOfProject!{{TypesOfProjectId}}, 0))"
        },
        {
          "name": "ProjectTypeRequiresManagerApproval",
          "type": "boolean",
          "formula": "=INDEX(TypesOfProject!{{RequiresManagerApproval}}, MATCH(Projects!{{ProjectType}}, TypesOfProject!{{TypesOfProjectId}}, 0))"
        },
        {
          "name": "ApprovedByRoleIsManager",
          "type": "boolean",
          "formula": "=INDEX(Employees!{{RoleIsManager}}, MATCH(Projects!{{ApprovedBy}}, Employees!{{EmployeeId}}, 0))"
        },
        {
          "name": "ApprovedByName",
          "type": "string",
          "formula": "=INDEX(Employees!{{Name}}, MATCH(Projects!{{ApprovedBy}}, Employees!{{EmployeeId}}, 0))"
        },
        {
          "name": "ApprovedByEmailAddress",
          "type": "string",
          "formula": "=INDEX(Employees!{{EmailAddress}}, MATCH(Projects!{{ApprovedBy}}, Employees!{{EmployeeId}}, 0))"
        },
        {
          "name": "ApprovedByPhoneNumber",
          "type": "string",
          "formula": "=INDEX(Employees!{{PhoneNumber}}, MATCH(Projects!{{ApprovedBy}}, Employees!{{EmployeeId}}, 0))"
        }
      ]
    },
    "Roles": {
      "attributes": [
        {
          "name": "RoleId",
          "type": "string"
        },
        {
          "name": "Name",
          "type": "string"
        },
        {
          "name": "Description",
          "type": "string"
        },
        {
          "name": "IsManager",
          "type": "boolean"
        },
        {
          "name": "Employees",
          "type": "string"
        }
      ],
      "derived": [
        {
          "name": "CountOfEmployees",
          "type": "integer",
          "formula": "=COUNTIFS(Employees!{{Role}}, Roles!{{RoleId}})"
        }
      ]
    },
    "TypesOfProject": {
      "attributes": [
        {
          "name": "TypesOfProjectId",
          "type": "string"
        },
        {
          "name": "Name",
          "type": "string"
        },
        {
          "name": "Description",
          "type": "string"
        },
        {
          "name": "RequiresManagerApproval",
          "type": "boolean"
        },
        {
          "name": "Projects",
          "type": "string"
        }
      ],
      "derived": [
        {
          "name": "CountOfProjects",
          "type": "integer",
          "formula": "=COUNTIFS(Projects!{{ProjectType}}, TypesOfProject!{{TypesOfProjectId}})"
        }
      ]
    }
  },
