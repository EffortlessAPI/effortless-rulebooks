{
  "$schema": "https://example.com/cmcc-schema/v1",
  "Name": "Lazr Coulomb's Law",
  "Description": "Physics simulation: electrostatic force between charged particles",
  "Charges": {
    "Description": "Individual charged particles with position and mass",
    "schema": [
      {
        "name": "ChargeId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Unique identifier"
      },
      {
        "name": "Label",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Human-readable label"
      },
      {
        "name": "ChargeValue",
        "datatype": "number",
        "type": "raw",
        "nullable": false,
        "Description": "Charge in Coulombs"
      },
      {
        "name": "PositionX",
        "datatype": "number",
        "type": "raw",
        "nullable": false,
        "Description": "X coordinate"
      },
      {
        "name": "PositionY",
        "datatype": "number",
        "type": "raw",
        "nullable": false,
        "Description": "Y coordinate"
      },
      {
        "name": "PositionZ",
        "datatype": "number",
        "type": "raw",
        "nullable": false,
        "Description": "Z coordinate"
      },
      {
        "name": "Mass",
        "datatype": "number",
        "type": "raw",
        "nullable": true,
        "Description": "Mass in kg"
      }
    ],
    "data": [
      {
        "ChargeId": "charge_1",
        "Label": "Proton A",
        "ChargeValue": 1.602e-19,
        "PositionX": 0,
        "PositionY": 0,
        "PositionZ": 0,
        "Mass": 1.673e-27
      },
      {
        "ChargeId": "charge_2",
        "Label": "Electron B",
        "ChargeValue": -1.602e-19,
        "PositionX": 1e-10,
        "PositionY": 0,
        "PositionZ": 0,
        "Mass": 9.109e-31
      }
    ]
  },
  "ChargeInteractions": {
    "Description": "Pairs of charges with computed electrostatic force",
    "schema": [
      {
        "name": "InteractionId",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Interaction ID"
      },
      {
        "name": "Charge1Id",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "First charge"
      },
      {
        "name": "Charge2Id",
        "datatype": "string",
        "type": "raw",
        "nullable": false,
        "Description": "Second charge"
      },
      {
        "name": "IsRepulsive",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": false,
        "Description": "Same charge sign = repulsive",
        "formula": "=VLOOKUP({{Charge1Id}}, Charges!{{ChargeId}}, Charges!{{ChargeValue}}) * VLOOKUP({{Charge2Id}}, Charges!{{ChargeId}}, Charges!{{ChargeValue}}) > 0"
      },
      {
        "name": "IsAttractive",
        "datatype": "boolean",
        "type": "calculated",
        "nullable": false,
        "Description": "Opposite charge sign = attractive",
        "formula": "=VLOOKUP({{Charge1Id}}, Charges!{{ChargeId}}, Charges!{{ChargeValue}}) * VLOOKUP({{Charge2Id}}, Charges!{{ChargeId}}, Charges!{{ChargeValue}}) < 0"
      }
    ],
    "data": [
      {
        "InteractionId": "interaction_1_2",
        "Charge1Id": "charge_1",
        "Charge2Id": "charge_2"
      }
    ]
  }
}
