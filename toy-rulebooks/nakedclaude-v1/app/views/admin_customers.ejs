<%- include('_header', { user: user }) %>
<h1>All Customers</h1>
<table><thead><tr><th>Name</th><th>Owner</th><th>Status</th><th></th></tr></thead><tbody>
<% customers.forEach(c => { %>
  <tr>
    <td><a href="/admin/customers/<%= c.customer_id %>"><%= c.name %></a></td>
    <td><%= c.owner_email %></td>
    <td><span class="badge <%= c.is_stopped ? 'stopped':'ok' %>"><%= c.status_display_name %></span></td>
    <td><a href="/admin/customers/<%= c.customer_id %>">view</a></td>
  </tr>
<% }) %>
</tbody></table>
<%- include('_footer') %>
