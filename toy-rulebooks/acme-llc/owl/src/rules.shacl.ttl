@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix effortless-ntwf: <https://w3id.org/effortless-ntwf#> .

# === Shape with rules for Customers ===
effortless-ntwf:CustomersShape a sh:NodeShape ;
    sh:targetClass effortless-ntwf:Customers ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Customers_Name" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:name ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Customers .
    OPTIONAL { $this effortless-ntwf:emailAddress ?email_address . }
                BIND(REPLACE(?email_address, "@", "-") AS ?_result)
            }
        """ ;
    ] ;
    sh:rule [
        a sh:SPARQLRule ;
        rdfs:label "rule_Customers_FullName" ;
        sh:prefixes effortless-ntwf: ;
        sh:construct """
            PREFIX effortless-ntwf: <https://w3id.org/effortless-ntwf#>
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            CONSTRUCT {
                $this effortless-ntwf:fullName ?_result .
            }
            WHERE {
    $this a effortless-ntwf:Customers .
    OPTIONAL { $this effortless-ntwf:firstName ?first_name . }
    OPTIONAL { $this effortless-ntwf:lastName ?last_name . }
                BIND(CONCAT(IF(isIRI(?first_name), REPLACE(STR(?first_name), "^.*[#/]", ""), STR(?first_name)), " ", IF(isIRI(?last_name), REPLACE(STR(?last_name), "^.*[#/]", ""), STR(?last_name))) AS ?_result)
            }
        """ ;
    ] .
# Rule for Initials - parse error: Unknown function: LEFT

# Generated 2 SHACL rules